@inject IConfiguration Configuration
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @{
        // Sub-path support. Local dev: "/". Production behind reverse proxy: "/supplier-portal-dev/".
        // Override via env var AppBasePath or appsettings.json -> AppBasePath.
        // MUST start AND end with "/".
        var basePath = Configuration["AppBasePath"];
        if (string.IsNullOrWhiteSpace(basePath)) basePath = "/";
        if (!basePath.StartsWith('/')) basePath = "/" + basePath;
        if (!basePath.EndsWith('/')) basePath += "/";
    }
    <base href="@basePath" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&family=Material+Symbols+Outlined&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="_content/Radzen.Blazor/css/material-base.css" />
    <link rel="stylesheet" href="_content/Radzen.Blazor/css/material.css" />
    <link rel="stylesheet" href="@Assets["css/merino.css"]" />
    <link rel="stylesheet" href="@Assets["css/catalog-list.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />

    <ImportMap />
    <link rel="icon" type="image/png" href="@Assets["favicon.png"]" />
    <link rel="apple-touch-icon" href="@Assets["favicon.png"]" />
    <title>MerinoOne Supplier Portal</title>
    <HeadOutlet />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <RadzenComponents @rendermode="InteractiveServer" />
    <ReconnectModal />
    <script src="_content/Radzen.Blazor/Radzen.Blazor.js"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>
