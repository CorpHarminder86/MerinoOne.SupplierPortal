@inherits LayoutComponentBase
@implements IDisposable
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject TokenAccessor Token
@inject ApiClient Api
@inject NavigationManager Nav
@inject ShellState Shell
@inject PageRefreshService PageRefresh
@inject NotificationService Notification
@inject ProtectedLocalStorage Storage
@inject IJSRuntime JS

@if (!Token.IsAuthenticated)
{
    <div style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:var(--mer-canvas);">
        <div style="color:var(--mer-ink-500);font-size:13px;">Redirecting to sign in…</div>
    </div>
}
else if (Token.MustChangePassword && !IsOnChangePasswordRoute())
{
    <div style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:var(--mer-canvas);">
        <div class="rz-card" style="padding:24px;max-width:420px;text-align:center;">
            <span class="material-symbols-outlined" style="font-size:36px;color:var(--mer-warning);">lock_reset</span>
            <h2 style="margin:8px 0 6px;color:var(--mer-blue-darker);font-size:18px;">Password change required</h2>
            <p style="color:var(--mer-ink-500);font-size:13px;margin-bottom:14px;">Redirecting you to the password update page…</p>
        </div>
    </div>
}
else
{
    <div class="mer-shell">
        <aside class="mer-sidenav @(Shell.IsSidenavCollapsed ? "mer-sidenav--collapsed" : null)">
            <div class="mer-brand">
                <div class="mer-brand__logo"><img src="img/merino-logo.png" alt="Merino" /></div>
                <div class="mer-brand__text">
                    <div class="mer-brand__name">MERIN<span class="infinity-symbol">∞</span>NE</div>
                    <div class="mer-brand__tag">SUPPLIER PORTAL</div>
                </div>
            </div>
            <nav class="mer-nav">
                <div class="mer-nav__label">Overview</div>
                <NavLink class="mer-nav-item" href="" Match="NavLinkMatch.All" ActiveClass="active">
                    <span class="mer-nav-item__icon material-symbols-outlined">dashboard</span>
                    <span class="mer-nav-item__label">Dashboard</span>
                </NavLink>

                <div class="mer-nav__label">Suppliers</div>
                @* Match.All on "Suppliers" so it doesn't stay active when the user navigates
                   to the sub-route /suppliers/onboarding (default Prefix match lights both). *@
                <NavLink class="mer-nav-item" href="suppliers" Match="NavLinkMatch.All" ActiveClass="active">
                    <span class="mer-nav-item__icon material-symbols-outlined">groups</span>
                    <span class="mer-nav-item__label">Suppliers</span>
                </NavLink>
                @if (Token.IsAdmin)
                {
                    <NavLink class="mer-nav-item" href="suppliers/onboarding" Match="NavLinkMatch.All" ActiveClass="active">
                        <span class="mer-nav-item__icon material-symbols-outlined">how_to_reg</span>
                        <span class="mer-nav-item__label">Onboarding Queue</span>
                    </NavLink>
                }

                <div class="mer-nav__label">Procurement</div>
                <NavLink class="mer-nav-item" href="purchase-orders" ActiveClass="active">
                    <span class="mer-nav-item__icon material-symbols-outlined">description</span>
                    <span class="mer-nav-item__label">Purchase Orders</span>
                </NavLink>
                <NavLink class="mer-nav-item" href="delivery-schedules" ActiveClass="active">
                    <span class="mer-nav-item__icon material-symbols-outlined">event</span>
                    <span class="mer-nav-item__label">Delivery Schedules</span>
                </NavLink>
                <NavLink class="mer-nav-item" href="asns" ActiveClass="active">
                    <span class="mer-nav-item__icon material-symbols-outlined">local_shipping</span>
                    <span class="mer-nav-item__label">ASNs</span>
                </NavLink>
                <NavLink class="mer-nav-item" href="goods-receipts" ActiveClass="active">
                    <span class="mer-nav-item__icon material-symbols-outlined">inventory_2</span>
                    <span class="mer-nav-item__label">Goods Receipts</span>
                </NavLink>

                <div class="mer-nav__label">Finance</div>
                <NavLink class="mer-nav-item" href="invoices" ActiveClass="active">
                    <span class="mer-nav-item__icon material-symbols-outlined">receipt_long</span>
                    <span class="mer-nav-item__label">Invoices</span>
                </NavLink>
                <NavLink class="mer-nav-item" href="credit-debit-notes" ActiveClass="active">
                    <span class="mer-nav-item__icon material-symbols-outlined">request_quote</span>
                    <span class="mer-nav-item__label">Credit/Debit Notes</span>
                </NavLink>
                <NavLink class="mer-nav-item" href="payments" ActiveClass="active">
                    <span class="mer-nav-item__icon material-symbols-outlined">payments</span>
                    <span class="mer-nav-item__label">Payments</span>
                </NavLink>

                <div class="mer-nav__label">Communication</div>
                <NavLink class="mer-nav-item" href="messages" ActiveClass="active">
                    <span class="mer-nav-item__icon material-symbols-outlined">mail</span>
                    <span class="mer-nav-item__label">Messages</span>
                </NavLink>

                @if (Token.IsAdmin)
                {
                    <div class="mer-nav__label">Integrations</div>
                    <NavLink class="mer-nav-item" href="integrations/sync-log" ActiveClass="active">
                        <span class="mer-nav-item__icon material-symbols-outlined">sync</span>
                        <span class="mer-nav-item__label">Sync Log</span>
                    </NavLink>
                    <NavLink class="mer-nav-item" href="integrations/errors" ActiveClass="active">
                        <span class="mer-nav-item__icon material-symbols-outlined">error</span>
                        <span class="mer-nav-item__label">Integration Errors</span>
                    </NavLink>

                    <div class="mer-nav__label">Administration</div>
                    <NavLink class="mer-nav-item" href="admin/users" ActiveClass="active">
                        <span class="mer-nav-item__icon material-symbols-outlined">group</span>
                        <span class="mer-nav-item__label">Users</span>
                    </NavLink>
                    <NavLink class="mer-nav-item" href="admin/roles" ActiveClass="active">
                        <span class="mer-nav-item__icon material-symbols-outlined">admin_panel_settings</span>
                        <span class="mer-nav-item__label">Roles</span>
                    </NavLink>
                    <NavLink class="mer-nav-item" href="admin/supplier-invites" ActiveClass="active">
                        <span class="mer-nav-item__icon material-symbols-outlined">mail_outline</span>
                        <span class="mer-nav-item__label">Supplier Invites</span>
                    </NavLink>
                    <NavLink class="mer-nav-item" href="admin/delivery-terms" ActiveClass="active">
                        <span class="mer-nav-item__icon material-symbols-outlined">local_shipping</span>
                        <span class="mer-nav-item__label">Delivery Terms</span>
                    </NavLink>
                    <NavLink class="mer-nav-item" href="admin/payment-terms" ActiveClass="active">
                        <span class="mer-nav-item__icon material-symbols-outlined">savings</span>
                        <span class="mer-nav-item__label">Payment Terms</span>
                    </NavLink>
                    <NavLink class="mer-nav-item" href="admin/items" ActiveClass="active">
                        <span class="mer-nav-item__icon material-symbols-outlined">inventory_2</span>
                        <span class="mer-nav-item__label">Items</span>
                    </NavLink>
                    <NavLink class="mer-nav-item" href="admin/settings" ActiveClass="active">
                        <span class="mer-nav-item__icon material-symbols-outlined">tune</span>
                        <span class="mer-nav-item__label">System Settings</span>
                    </NavLink>
                    <NavLink class="mer-nav-item" href="admin/email-templates" ActiveClass="active">
                        <span class="mer-nav-item__icon material-symbols-outlined">mail</span>
                        <span class="mer-nav-item__label">Email Templates</span>
                    </NavLink>
                }
            </nav>
        </aside>

        <div class="mer-main">
            <header class="mer-topbar">
                <button class="mer-topbar__btn" @onclick="Shell.ToggleSidenav" title="@(Shell.IsSidenavCollapsed ? "Expand menu" : "Collapse menu")" aria-label="Toggle navigation"><span class="material-symbols-outlined">menu</span></button>
                <nav class="mer-globalbc">
                    <a class="mer-globalbc__item" href="">Home</a>
                </nav>
                <GlobalSearch />
                <div class="mer-topbar__spacer"></div>
                <button type="button" class="mer-topbar__btn" title="Refresh page data"
                        @onclick="RefreshPageAsync" disabled="@_refreshing">
                    <span class="material-symbols-outlined @(_refreshing ? "mer-spin" : "")">refresh</span>
                </button>
                <button class="mer-topbar__btn" title="Notifications"><span class="material-symbols-outlined">notifications</span></button>

                <div class="mer-userpill-wrap" @onclick:stopPropagation="true">
                    <button type="button" class="mer-userpill" @onclick="ToggleUserMenu">
                        <div class="mer-userpill__avatar">@Initials</div>
                        <div class="mer-userpill__meta">
                            <span class="mer-userpill__name">@DisplayName</span>
                            <span class="mer-userpill__role">@RoleLabel</span>
                        </div>
                        <span class="material-symbols-outlined mer-userpill__caret">expand_more</span>
                    </button>

                    @if (_userMenuOpen)
                    {
                        <div class="mer-usermenu">
                            <div class="mer-usermenu__header">
                                <div class="mer-usermenu__name">@DisplayName</div>
                                <div class="mer-usermenu__email">@(Token.Email ?? Token.UserCode ?? "")</div>
                            </div>
                            <button type="button" class="mer-usermenu__item" @onclick='() => UserMenuClick("profile")'>
                                <span class="material-symbols-outlined">person</span> My profile
                            </button>
                            <button type="button" class="mer-usermenu__item" @onclick='() => UserMenuClick("preferences")'>
                                <span class="material-symbols-outlined">settings</span> Preferences
                            </button>
                            <button type="button" class="mer-usermenu__item" @onclick='() => UserMenuClick("refresh")'>
                                <span class="material-symbols-outlined">refresh</span> Refresh permissions
                            </button>
                            <div class="mer-usermenu__sep"></div>
                            <button type="button" class="mer-usermenu__item mer-usermenu__item--danger" @onclick='() => UserMenuClick("logout")'>
                                <span class="material-symbols-outlined">logout</span> Sign out
                            </button>
                        </div>
                    }
                </div>
            </header>

            <main class="mer-page">
                <GlobalErrorBoundary>
                    @Body
                </GlobalErrorBoundary>
            </main>
        </div>
    </div>
}

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _refreshing;
    private bool _userMenuOpen;
    private bool _signingOut;
    private bool _hydrated;

    protected override void OnInitialized()
    {
        Shell.OnChange += OnShellChange;
        Nav.LocationChanged += OnLocationChanged;
        Token.Changed += OnTokenChanged;
        Token.SessionExpired += HandleSessionExpired;
    }

    private void OnShellChange() => InvokeAsync(StateHasChanged);
    private void OnTokenChanged() => InvokeAsync(StateHasChanged);

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        EnforceRouteGuard();
        InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await HydrateTokenAsync();
            EnforceRouteGuard();
        }

        if (Token.IsAuthenticated && Token.MustChangePassword && !IsOnChangePasswordRoute())
        {
            await Task.Yield();
            Nav.NavigateToRoute("/change-password", forceLoad: false);
        }
    }

    private async Task HydrateTokenAsync()
    {
        if (_hydrated) return;
        if (Token.IsAuthenticated) { _hydrated = true; return; }

        string? stored = null;
        try
        {
            var read = await Storage.GetAsync<string>("merinoone.token");
            if (read.Success) stored = read.Value;
        }
        catch { /* protected storage may not be ready during pre-render */ }

        if (string.IsNullOrEmpty(stored))
        {
            // No token persisted — route guard pushes to /login on the next location change.
            _hydrated = true;
            return;
        }

        // Provisionally seed the accessor so ApiClient attaches the bearer on the /me call.
        Token.SetSession(stored!, null, null, null, Array.Empty<string>(), Array.Empty<string>(), null, false);

        try
        {
            var resp = await Api.GetAsync<MerinoOne.SupplierPortal.Contracts.Auth.LoginResponse>("api/auth/me");
            if (resp?.Success == true && resp.Data is not null)
            {
                Token.SetSession(
                    resp.Data.Token,
                    resp.Data.UserCode,
                    Token.Email,
                    resp.Data.FullName,
                    resp.Data.Roles,
                    resp.Data.Permissions,
                    resp.Data.ExpiresAt,
                    resp.Data.MustChangePassword);
                try { await Storage.SetAsync("merinoone.token", resp.Data.Token); } catch { }
                // Refresh the same-origin "merino-jwt" cookie that /files/proxy/{id} reads on
                // every request. ProtectedLocalStorage rehydrates the in-memory TokenAccessor
                // on reload/new tab, but the cookie may have expired (8h Max-Age) or been
                // dropped — without this refresh, the image proxy returns 401 and the user
                // sees broken thumbnails on supplier-detail until they explicitly re-login.
                try
                {
                    await JS.InvokeVoidAsync(
                        "eval",
                        $"document.cookie = 'merino-jwt={resp.Data.Token};Path=/;Max-Age=28800;SameSite=Strict' + (location.protocol === 'https:' ? ';Secure' : '');");
                }
                catch { /* best-effort — proxy will return 401 if cookie missing */ }
                _hydrated = true;
                StateHasChanged();
                return;
            }

            // Endpoint replied but the session is no longer valid — clear and bounce.
            Token.Clear();
            try { await Storage.DeleteAsync("merinoone.token"); } catch { }
            _hydrated = true;
            Nav.NavigateToRoute("/login", forceLoad: false);
        }
        catch (ApiException)
        {
            // 401 or any API failure → clear stored token, redirect to /login.
            Token.Clear();
            try { await Storage.DeleteAsync("merinoone.token"); } catch { }
            _hydrated = true;
            Nav.NavigateToRoute("/login", forceLoad: false);
        }
        catch
        {
            // Network / unexpected failures: clear silently and bounce, same as 401.
            Token.Clear();
            try { await Storage.DeleteAsync("merinoone.token"); } catch { }
            _hydrated = true;
            Nav.NavigateToRoute("/login", forceLoad: false);
        }
    }

    private void EnforceRouteGuard()
    {
        var rel = Nav.ToBaseRelativePath(Nav.Uri).TrimEnd('/').ToLowerInvariant();
        var path = rel.Split('?')[0];
        if (path is "login" or "register" or "not-found" or "error") return;
        if (!Token.IsAuthenticated && _hydrated)
            Nav.NavigateToRoute("/login", forceLoad: false);
    }

    private bool IsOnChangePasswordRoute()
    {
        // Sub-path-safe: Uri.AbsolutePath includes the PathBase prefix (e.g. "/supplier-portal-dev/change-password")
        // when deployed behind a reverse proxy, so a literal "/change-password" comparison never matches and the
        // post-NavigateToRoute guard at the top of this file re-renders the "Redirecting..." card forever.
        // Mirror the EnforceRouteGuard() pattern above — ToBaseRelativePath strips the base + leading slash.
        var rel = Nav.ToBaseRelativePath(Nav.Uri).Split('?')[0].TrimEnd('/').ToLowerInvariant();
        return rel.Equals("change-password") || rel.StartsWith("change-password/");
    }

    public void Dispose()
    {
        Shell.OnChange -= OnShellChange;
        Nav.LocationChanged -= OnLocationChanged;
        Token.Changed -= OnTokenChanged;
        Token.SessionExpired -= HandleSessionExpired;
    }

    private async Task RefreshPageAsync()
    {
        if (_refreshing) return;
        _refreshing = true;
        StateHasChanged();
        try
        {
            // Pages inheriting AuthenticatedPageBase auto-subscribe to this event.
            await PageRefresh.RequestRefreshAsync();

            // Fallback for pages that load in OnInitializedAsync without inheriting the base.
            // Use forceReload:true — interactive Server mode treats same-URL Refresh(false) as
            // a no-op when the route component instance is reused, so OnInitializedAsync never
            // re-runs. forceLoad does a real HTTP GET → MainLayout.HydrateTokenAsync re-fetches
            // /api/auth/me to restore the session. Skip on /login.
            var rel = Nav.ToBaseRelativePath(Nav.Uri).Split('?')[0].TrimEnd('/').ToLowerInvariant();
            if (rel != "login")
            {
                Nav.NavigateTo(Nav.Uri, forceLoad: true);
            }
        }
        finally { _refreshing = false; StateHasChanged(); }
    }

    private void ToggleUserMenu() => _userMenuOpen = !_userMenuOpen;

    private string DisplayName =>
        !string.IsNullOrWhiteSpace(Token.FullName) ? Token.FullName! :
        !string.IsNullOrWhiteSpace(Token.Email)    ? Token.Email!    :
        !string.IsNullOrWhiteSpace(Token.UserCode) ? Token.UserCode! : "Guest";

    private string Initials
    {
        get
        {
            var name = DisplayName;
            if (string.IsNullOrWhiteSpace(name) || name == "Guest") return "??";
            var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
            if (parts.Length == 1) return parts[0][..Math.Min(2, parts[0].Length)].ToUpperInvariant();
            return $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant();
        }
    }

    private string RoleLabel => Token.Roles.FirstOrDefault() ?? "User";

    private async Task UserMenuClick(string value)
    {
        _userMenuOpen = false;
        switch (value)
        {
            case "profile":     Stub("My profile");        break;
            case "preferences": Stub("Preferences");       break;
            case "refresh":     await RefreshUserAsync();  break;
            case "logout":      await LogoutAsync();       break;
        }
    }

    private async Task RefreshUserAsync()
    {
        try
        {
            var resp = await Api.GetAsync<MerinoOne.SupplierPortal.Contracts.Auth.LoginResponse>("api/auth/me");
            if (resp?.Success == true && resp.Data is not null)
            {
                Token.SetSession(
                    resp.Data.Token,
                    resp.Data.UserCode,
                    Token.Email,
                    resp.Data.FullName,
                    resp.Data.Roles,
                    resp.Data.Permissions,
                    resp.Data.ExpiresAt,
                    resp.Data.MustChangePassword);
                try { await Storage.SetAsync("merinoone.token", resp.Data.Token); } catch { }
                Notification.Notify(NotificationSeverity.Success, "Permissions refreshed.");
                return;
            }

            Notification.Notify(NotificationSeverity.Warning, "Session expired. Please sign in again.");
            await LogoutAsync();
        }
        catch (ApiException ex) when (ex.StatusCode == 401)
        {
            await LogoutAsync();
        }
        catch (Exception)
        {
            Notification.Notify(NotificationSeverity.Error, "Failed to refresh permissions.");
        }
    }

    private void Stub(string label) => Notification.Notify(NotificationSeverity.Info, $"{label} — coming soon");

    private void HandleSessionExpired() => _ = InvokeAsync(SignOutDueToExpiryAsync);

    private async Task SignOutDueToExpiryAsync()
    {
        if (_signingOut || !Token.IsAuthenticated) return;
        _signingOut = true;
        try
        {
            Notification.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Info,
                Summary  = "Session expired",
                Detail   = "Please sign in again.",
                Duration = 5000
            });
            await LogoutAsync();
        }
        finally { _signingOut = false; }
    }

    private async Task LogoutAsync()
    {
        try { await Api.LogoutAsync(); } catch { }
        Token.Clear();
        try { await Storage.DeleteAsync("merinoone.token"); } catch { }
        try { await JS.InvokeVoidAsync("sessionStorage.removeItem", "merinoone.tabs"); } catch { }
        // Drop the proxy-auth cookie too so a stolen cookie can't outlive the session.
        try { await JS.InvokeVoidAsync("eval", "document.cookie = 'merino-jwt=;Path=/;Max-Age=0';"); } catch { }
        Nav.NavigateToRoute("/login", forceLoad: false);
    }
}
