@inherits LayoutComponentBase
@inject TokenAccessor Token
@inject NavigationManager Nav

@if (!Token.IsAuthenticated)
{
    <Login OnLoggedIn="@(() => InvokeAsync(StateHasChanged))" />
}
else
{
    <div class="mer-shell">
        <aside class="mer-sidenav">
            <div class="mer-brand">
                <div class="mer-brand__logo"><span class="material-symbols-outlined" style="color:var(--mer-blue-darker)">factory</span></div>
                <div class="mer-brand__text">
                    <div class="mer-brand__name">MERIN<span class="infinity-symbol">∞</span>NE</div>
                    <div class="mer-brand__tag">SUPPLIER PORTAL</div>
                </div>
            </div>
            <nav class="mer-nav">
                <div class="mer-nav__label">Overview</div>
                <NavLink class="mer-nav-item" href="/" Match="NavLinkMatch.All" ActiveClass="active">
                    <span class="mer-nav-item__icon material-symbols-outlined">dashboard</span>
                    <span class="mer-nav-item__label">Dashboard</span>
                </NavLink>

                <div class="mer-nav__label">Suppliers</div>
                <NavLink class="mer-nav-item" href="/suppliers" ActiveClass="active">
                    <span class="mer-nav-item__icon material-symbols-outlined">groups</span>
                    <span class="mer-nav-item__label">Suppliers</span>
                </NavLink>
                @if (Token.IsAdmin)
                {
                    <NavLink class="mer-nav-item" href="/suppliers/onboarding" ActiveClass="active">
                        <span class="mer-nav-item__icon material-symbols-outlined">how_to_reg</span>
                        <span class="mer-nav-item__label">Onboarding Queue</span>
                    </NavLink>
                }

                <div class="mer-nav__label">Communication</div>
                <NavLink class="mer-nav-item" href="/messages" ActiveClass="active">
                    <span class="mer-nav-item__icon material-symbols-outlined">mail</span>
                    <span class="mer-nav-item__label">Messages</span>
                </NavLink>
            </nav>
        </aside>

        <div class="mer-main">
            <header class="mer-topbar">
                <button class="mer-topbar__btn"><span class="material-symbols-outlined">menu</span></button>
                <nav class="mer-globalbc">
                    <a class="mer-globalbc__item" href="/">Home</a>
                </nav>
                <div class="mer-topbar__spacer"></div>
                <button class="mer-topbar__btn"><span class="material-symbols-outlined">notifications</span></button>
                <button class="mer-userpill" @onclick="Logout">
                    <div class="mer-userpill__avatar">@Initials</div>
                    <div class="mer-userpill__meta">
                        <span class="mer-userpill__name">@Token.FullName</span>
                        <span class="mer-userpill__role">@(string.Join(", ", Token.Roles))</span>
                    </div>
                    <span class="material-symbols-outlined" style="font-size:18px;color:var(--mer-ink-500)">logout</span>
                </button>
            </header>

            <main class="mer-page">
                @Body
            </main>
        </div>
    </div>
}

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private string Initials
    {
        get
        {
            if (string.IsNullOrEmpty(Token.FullName)) return "?";
            var parts = Token.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
            var initials = string.Concat(parts.Select(p => p[0])).ToUpper();
            return initials.Length > 2 ? initials[..2] : initials;
        }
    }

    private void Logout()
    {
        Token.Clear();
        Nav.NavigateTo("/", forceLoad: true);
    }
}
