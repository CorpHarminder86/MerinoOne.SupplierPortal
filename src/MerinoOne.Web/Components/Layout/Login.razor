@inject ApiClient Api
@inject TokenAccessor Token

<div class="mer-auth-shell">
    <aside class="mer-auth-aside">
        <div class="mer-auth-brand">
            <div style="width:44px;height:44px;border-radius:10px;background:#fff;display:flex;align-items:center;justify-content:center;">
                <span class="material-symbols-outlined" style="color:var(--mer-blue-darker);font-size:28px">factory</span>
            </div>
            <div>
                <div class="mer-auth-brand__name">MERIN<span class="infinity-symbol">∞</span>NE</div>
                <div class="mer-auth-brand__tag">SUPPLIER PORTAL</div>
            </div>
        </div>
        <div class="mer-auth-blurb">
            <h1>Supplier collaboration, simplified.</h1>
            <p>POs, ASNs, invoices and payments — one secure portal between MCSL and its suppliers.</p>
        </div>
        <div class="mer-auth-foot">© 2026 Merino Composites Ltd</div>
    </aside>
    <main class="mer-auth-main">
        <div class="mer-auth-card">
            <h2>Welcome back</h2>
            <p class="mer-auth-sub">Sign in with your portal credentials.</p>
            <div style="margin-bottom:12px;">
                <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">User code</label>
                <input class="rz-textbox" style="width:100%;height:38px;padding:6px 10px;" @bind="userCode" />
            </div>
            <div style="margin-bottom:12px;">
                <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Password</label>
                <input type="password" class="rz-textbox" style="width:100%;height:38px;padding:6px 10px;" @bind="password" @bind:event="oninput" @onkeydown="OnKeyDown" />
            </div>
            @if (!string.IsNullOrEmpty(error))
            {
                <div style="background:var(--mer-red-50);color:var(--mer-red);padding:8px 12px;border-radius:6px;font-size:12px;margin-bottom:12px;">@error</div>
            }
            <button class="rz-button rz-primary" style="width:100%;height:42px;font-size:14px;font-weight:600;border:0;border-radius:6px;" disabled="@busy" @onclick="DoLogin">
                @(busy ? "Signing in…" : "Sign in")
            </button>
            <p class="mer-auth-foot-text">Try: admin1 / Merino@@123 · sup1 / Merino@@123</p>
        </div>
    </main>
</div>

<style>
    .mer-auth-shell { display: flex; min-height: 100vh; background: var(--mer-canvas); }
    .mer-auth-aside { flex: 0 0 42%; background: var(--mer-blue-darker); color: #fff; padding: 48px 56px; display: flex; flex-direction: column; justify-content: space-between; position: relative; overflow: hidden; }
    .mer-auth-aside::after { content: ''; position: absolute; top: -120px; right: -120px; width: 360px; height: 360px; border-radius: 50%; background: radial-gradient(circle, var(--mer-green) 0%, transparent 70%); opacity: .25; pointer-events: none; }
    .mer-auth-brand { display: flex; align-items: center; gap: 14px; position: relative; z-index: 1; }
    .mer-auth-brand__name { font-size: 18px; font-weight: 800; letter-spacing: .14em; }
    .mer-auth-brand__tag { font-size: 11px; color: var(--mer-green); letter-spacing: .18em; text-transform: uppercase; margin-top: 2px; }
    .mer-auth-blurb { position: relative; z-index: 1; max-width: 420px; }
    .mer-auth-blurb h1 { color: #fff; font-size: 28px; line-height: 1.2; margin-bottom: 12px; }
    .mer-auth-blurb p { color: rgba(255,255,255,.75); font-size: 14px; line-height: 1.6; }
    .mer-auth-foot { position: relative; z-index: 1; font-size: 11px; color: rgba(255,255,255,.5); }
    .mer-auth-main { flex: 1; display: flex; align-items: center; justify-content: center; padding: 48px 32px; }
    .mer-auth-card { width: 100%; max-width: 400px; }
    .mer-auth-card h2 { font-size: 22px; font-weight: 700; color: var(--mer-blue-darker); margin-bottom: 6px; }
    .mer-auth-card p.mer-auth-sub { font-size: 13px; color: var(--mer-ink-500); margin-bottom: 24px; }
    .mer-auth-foot-text { margin-top: 20px; font-size: 11px; color: var(--mer-ink-400); text-align: center; }
    @@media (max-width: 800px) { .mer-auth-aside { display: none; } }
</style>

@code {
    [Parameter] public EventCallback OnLoggedIn { get; set; }
    private string userCode = string.Empty;
    private string password = string.Empty;
    private string error = string.Empty;
    private bool busy = false;

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !busy) await DoLogin();
    }

    private async Task DoLogin()
    {
        error = string.Empty; busy = true;
        try
        {
            var resp = await Api.LoginAsync(new LoginRequest(userCode.Trim(), password));
            if (resp?.Success == true)
                await OnLoggedIn.InvokeAsync();
            else
                error = resp?.Errors?.FirstOrDefault() ?? "Login failed.";
        }
        catch (Exception ex) { error = ex.Message; }
        finally { busy = false; }
    }
}
