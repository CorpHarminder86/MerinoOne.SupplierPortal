@page "/integrations/outbound-endpoints"
@implements IDisposable
@inject ApiClient Api
@inject TokenAccessor Token
@inject NotificationService Notif

@* R8 (2026-07-04) — TSD R8 §7. Integration › Outbound (IDM) endpoints. CRUD grid + per-row Validate + a mapping
   test bench (document picker → build envelope → optional dry-run POST). View gate = Integration.Read; all
   mutating/validate/test affordances gate on Integration.Manage (the server enforces regardless). Separate page
   from the inbound Integration/EndpointsList.razor — matches its style, does NOT extend it. *@

<PageTitle>Outbound endpoints</PageTitle>

@if (!Token.HasPermission("Integration.Read"))
{
    <div class="tl-empty">
        <span class="material-symbols-outlined" style="font-size:32px;">lock</span>
        <div>Access denied — Integration access required.</div>
    </div>
}
else
{
    <div class="tl-page">
        <header class="tl-header">
            <div>
                <div class="tl-title-row">
                    <h1 class="tl-title">Outbound endpoints</h1>
                    <span class="tl-count-chip">@(rows?.Count ?? 0)</span>
                </div>
                <p class="tl-sub">Infor IDM transport endpoints — auth + base URL resolve from the Infor connection</p>
            </div>
            @if (CanManage)
            {
                <div class="tl-header__actions">
                    <button class="mbtn mbtn--outline" @onclick="OpenTestBench" disabled="@busy" title="Render an IDM envelope for a sample document">
                        <span class="material-symbols-outlined">science</span> Test bench
                    </button>
                    <button class="mbtn mbtn--primary" @onclick="OpenNew" disabled="@busy">
                        <span class="material-symbols-outlined">add</span> New endpoint
                    </button>
                </div>
            }
        </header>

        @if (loading)
        {
            <div class="tl-empty">Loading…</div>
        }
        else if (rows == null || rows.Count == 0)
        {
            <div class="tl-empty">
                <span class="material-symbols-outlined" style="font-size:32px;">cable</span>
                <div>No outbound endpoints configured.</div>
            </div>
        }
        else
        {
            <div class="tl-grid-wrapper" style="--tl-cols: 160px 90px 1fr 1fr 140px 120px 80px 200px; --tl-min-width: 1400px;">
                <div class="tlg-header">
                    <div class="tlg-col">Endpoint key</div>
                    <div class="tlg-col">Method</div>
                    <div class="tlg-col">Relative path</div>
                    <div class="tlg-col">Static headers</div>
                    <div class="tlg-col">Ack parser</div>
                    <div class="tlg-col">Default ACL</div>
                    <div class="tlg-col">Enabled</div>
                    <div class="tlg-col tlg-col--actions">Actions</div>
                </div>
                @foreach (var e in rows)
                {
                    var ep = e;
                    <div class="tlg-row">
                        <div class="tlg-col tlg-name">@ep.EndpointKey</div>
                        <div class="tlg-col tlg-code">@ep.HttpMethod</div>
                        <div class="tlg-col tlg-desc" title="@ep.RelativePath">@ep.RelativePath</div>
                        <div class="tlg-col tlg-desc tlg-code" title="@ep.StaticHeadersJson">@(string.IsNullOrEmpty(ep.StaticHeadersJson) ? "—" : ep.StaticHeadersJson)</div>
                        <div class="tlg-col tlg-code">@(string.IsNullOrEmpty(ep.AckParserKey) ? "—" : ep.AckParserKey)</div>
                        <div class="tlg-col tlg-code">@(string.IsNullOrEmpty(ep.DefaultAcl) ? "—" : ep.DefaultAcl)</div>
                        <div class="tlg-col"><span class="tlg-status @(ep.IsEnabled ? "tlg-status--active" : "tlg-status--danger")">@(ep.IsEnabled ? "On" : "Off")</span></div>
                        <div class="tlg-col tlg-col--actions" style="display:flex;gap:6px;">
                            @if (CanManage)
                            {
                                <button class="mbtn mbtn--row mbtn--accent" @onclick="() => OpenEdit(ep)" disabled="@busy" title="Edit endpoint">
                                    <span class="material-symbols-outlined">edit</span> Edit
                                </button>
                                <button class="mbtn mbtn--row mbtn--success" @onclick="() => Validate(ep)" disabled="@busy" title="Validate token + reachability">
                                    <span class="material-symbols-outlined">wifi_tethering</span> Validate
                                </button>
                                <button class="mbtn mbtn--row mbtn--danger" @onclick="() => ConfirmDelete(ep)" disabled="@busy" title="Delete endpoint">
                                    <span class="material-symbols-outlined">delete</span> Delete
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
        }

        @* Validate result banner — self-styled from global tokens (no dependency on scoped settings CSS). *@
        @if (validateResult is not null)
        {
            <div style="margin-top:16px;display:flex;align-items:center;gap:10px;padding:10px 14px;border-radius:var(--mer-radius);font-size:13px;@(validateResult.Success
                ? "background:var(--mer-green-50);color:var(--mer-green-700);border:1px solid var(--mer-green);"
                : "background:var(--mer-red-50);color:var(--mer-red);border:1px solid var(--mer-danger);")">
                <span class="material-symbols-outlined" style="font-size:18px;">@(validateResult.Success ? "check_circle" : "error")</span>
                <span style="flex:1;">@ValidateBanner(validateResult)</span>
                <button type="button" style="background:transparent;border:0;color:inherit;opacity:.7;cursor:pointer;font-size:18px;line-height:1;padding:0 4px;" @onclick="() => validateResult = null">×</button>
            </div>
        }
    </div>

    @* ---------------- Create / edit dialog ---------------- *@
    @if (editing is not null)
    {
        <div style="position:fixed;inset:0;background:var(--mer-modal-backdrop);display:flex;align-items:center;justify-content:center;z-index:1000;">
            <div class="merino-dialog" data-variant="info" data-size="md" style="width:640px;max-width:92vw;">
                <div class="merino-dialog__accent"></div>
                <header class="merino-dialog__header">
                    <div class="merino-dialog__icon merino-dialog__icon--info"><span class="material-symbols-outlined">cable</span></div>
                    <div class="merino-dialog__head-text">
                        <div class="merino-dialog__eyebrow">Outbound endpoint</div>
                        <h2 class="merino-dialog__title">@(editingId.HasValue ? "Edit endpoint" : "New endpoint")</h2>
                    </div>
                    <button class="merino-dialog__close" @onclick="() => editing = null"><span class="material-symbols-outlined">close</span></button>
                </header>
                <div class="merino-dialog__body">
                    <div style="display:flex;flex-direction:column;gap:12px;">
                        <div>
                            <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Endpoint key *</label>
                            <input class="rz-textbox" style="width:100%;padding:8px 10px;font-family:Inter,monospace;" @bind="formKey" placeholder="e.g. IdmCreate" />
                        </div>
                        <div style="display:flex;gap:12px;">
                            <div style="width:140px;">
                                <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">HTTP method *</label>
                                <select class="rz-dropdown" style="width:100%;padding:8px 10px;" @bind="formMethod">
                                    <option value="POST">POST</option>
                                    <option value="PUT">PUT</option>
                                    <option value="DELETE">DELETE</option>
                                    <option value="GET">GET</option>
                                </select>
                            </div>
                            <div style="flex:1;">
                                <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Relative path *</label>
                                <input class="rz-textbox" style="width:100%;padding:8px 10px;font-family:Inter,monospace;" @bind="formPath" placeholder="e.g. /items" />
                            </div>
                        </div>
                        <div>
                            <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Static headers (JSON)</label>
                            <textarea class="rz-textbox" style="width:100%;min-height:70px;padding:8px 10px;font-family:Inter,monospace;font-size:12.5px;" @bind="formHeaders" placeholder='{ "Content-Type": "application/xml" }'></textarea>
                        </div>
                        <div style="display:flex;gap:12px;">
                            <div style="flex:1;">
                                <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Ack parser key</label>
                                <input class="rz-textbox" style="width:100%;padding:8px 10px;" @bind="formAckParser" placeholder="e.g. IdmPid" />
                            </div>
                            <div style="flex:1;">
                                <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Default ACL</label>
                                <input class="rz-textbox" style="width:100%;padding:8px 10px;" @bind="formAcl" placeholder="e.g. Everyone" />
                            </div>
                        </div>
                        <label style="display:flex;align-items:center;gap:8px;font-size:13px;cursor:pointer;">
                            <input type="checkbox" @bind="formEnabled" /> Enabled
                        </label>
                    </div>
                    @if (!string.IsNullOrEmpty(formError))
                    {
                        <div style="background:var(--mer-red-50);color:var(--mer-red);padding:8px 12px;border-radius:6px;font-size:12px;margin-top:8px;">@formError</div>
                    }
                </div>
                <footer class="merino-dialog__footer">
                    <div class="merino-dialog__actions">
                        <button class="merino-dialog__btn" data-intent="ghost" @onclick="() => editing = null">Cancel</button>
                        <button class="merino-dialog__btn" data-intent="primary" @onclick="Save" disabled="@busy">@(busy ? "Saving…" : "Save")</button>
                    </div>
                </footer>
            </div>
        </div>
    }

    @* ---------------- Delete confirm ---------------- *@
    @if (deleteRow is not null)
    {
        <div style="position:fixed;inset:0;background:var(--mer-modal-backdrop);display:flex;align-items:center;justify-content:center;z-index:1001;">
            <div class="merino-dialog" data-variant="danger" data-size="sm" style="width:480px;">
                <div class="merino-dialog__accent"></div>
                <header class="merino-dialog__header">
                    <div class="merino-dialog__icon merino-dialog__icon--danger"><span class="material-symbols-outlined">delete</span></div>
                    <div class="merino-dialog__head-text">
                        <div class="merino-dialog__eyebrow">Outbound endpoint</div>
                        <h2 class="merino-dialog__title">Delete endpoint?</h2>
                    </div>
                    <button class="merino-dialog__close" @onclick="() => deleteRow = null"><span class="material-symbols-outlined">close</span></button>
                </header>
                <div class="merino-dialog__body">
                    <p style="font-size:13px;color:var(--mer-ink-700);margin:0;">Delete endpoint <strong>@deleteRow.EndpointKey</strong>? This soft-deletes the config row.</p>
                </div>
                <footer class="merino-dialog__footer">
                    <div class="merino-dialog__actions">
                        <button class="merino-dialog__btn" data-intent="ghost" @onclick="() => deleteRow = null">Cancel</button>
                        <button class="merino-dialog__btn" data-intent="primary" @onclick="Delete" disabled="@busy">@(busy ? "Deleting…" : "Delete")</button>
                    </div>
                </footer>
            </div>
        </div>
    }

    @* ---------------- Test bench dialog ---------------- *@
    @if (showTestBench)
    {
        <div style="position:fixed;inset:0;background:var(--mer-modal-backdrop);display:flex;align-items:center;justify-content:center;z-index:1000;">
            <div class="merino-dialog" data-variant="info" data-size="xl" style="width:1100px;max-width:94vw;">
                <div class="merino-dialog__accent"></div>
                <header class="merino-dialog__header">
                    <div class="merino-dialog__icon merino-dialog__icon--info"><span class="material-symbols-outlined">science</span></div>
                    <div class="merino-dialog__head-text">
                        <div class="merino-dialog__eyebrow">Integration</div>
                        <h2 class="merino-dialog__title">IDM envelope test bench</h2>
                        <p class="merino-dialog__subtitle">Pick a document, build the exact Create envelope, and optionally dry-run POST it</p>
                    </div>
                    <button class="merino-dialog__close" @onclick="CloseTestBench"><span class="material-symbols-outlined">close</span></button>
                </header>
                <div class="merino-dialog__body">
                    <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-bottom:12px;">
                        <input class="rz-textbox" style="flex:1;min-width:220px;padding:8px 10px;" placeholder="Search documents by file name / type" @bind="docSearch" @bind:after="SearchDocs" />
                        <label style="display:flex;align-items:center;gap:6px;font-size:13px;cursor:pointer;">
                            <input type="checkbox" @bind="dryRun" /> Dry-run POST
                        </label>
                        <button class="mbtn mbtn--primary" @onclick="BuildEnvelope" disabled="@(busy || selectedDoc is null)" title="Render the envelope">
                            <span class="material-symbols-outlined">build</span> @(dryRun ? "Dry-run POST" : "Build envelope")
                        </button>
                    </div>

                    <div style="display:grid;grid-template-columns:340px 1fr;gap:14px;">
                        @* Document picker *@
                        <div style="border:1px solid var(--mer-line);border-radius:8px;overflow:hidden;">
                            <div style="padding:8px 10px;font-size:12px;font-weight:700;color:var(--mer-ink-700);background:var(--mer-canvas);border-bottom:1px solid var(--mer-line);">Documents</div>
                            <div style="max-height:52vh;overflow:auto;">
                                @if (docsLoading)
                                {
                                    <div style="padding:12px;color:var(--mer-ink-500);font-size:13px;">Searching…</div>
                                }
                                else if (docs.Count == 0)
                                {
                                    <div style="padding:12px;color:var(--mer-ink-500);font-size:13px;">No documents found.</div>
                                }
                                else
                                {
                                    @foreach (var d in docs)
                                    {
                                        var doc = d;
                                        <button type="button" @onclick="() => SelectDoc(doc)"
                                                style="display:block;width:100%;text-align:left;padding:9px 10px;border:0;border-bottom:1px solid var(--mer-line-soft);cursor:pointer;background:@(selectedDoc?.DocumentUploadId == doc.DocumentUploadId ? "var(--mer-blue-50)" : "transparent");">
                                            <div style="font-size:12.5px;font-weight:600;color:var(--mer-ink-900);">@doc.FileName</div>
                                            <div style="font-size:11px;color:var(--mer-ink-500);">@doc.DocumentType · @doc.OwnerEntityType@(string.IsNullOrEmpty(doc.IdmEntityType) ? "" : $" → {doc.IdmEntityType}") @(doc.HasPid ? "· has PID" : "")</div>
                                        </button>
                                    }
                                }
                            </div>
                        </div>

                        @* Envelope output *@
                        <div>
                            @if (testResult is null)
                            {
                                <div style="padding:12px;color:var(--mer-ink-500);font-size:13px;">Select a document and build the envelope.</div>
                            }
                            else
                            {
                                <div style="margin-bottom:10px;">
                                    @if (testResult.GateSatisfied)
                                    {
                                        <span class="tlg-status tlg-status--active">Gate satisfied</span>
                                    }
                                    else
                                    {
                                        <span class="tlg-status tlg-status--danger">Gate failed</span>
                                        <ul style="margin:6px 0 0;padding-left:18px;font-size:12px;color:var(--mer-danger);">
                                            @foreach (var f in testResult.GateFailures)
                                            {
                                                <li>@f</li>
                                            }
                                        </ul>
                                    }
                                </div>
                                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                                    <div>
                                        <div style="font-size:12px;font-weight:700;color:var(--mer-ink-700);margin-bottom:4px;">Headers</div>
                                        <pre style="margin:0;max-height:40vh;overflow:auto;background:var(--mer-canvas);border:1px solid var(--mer-line);border-radius:8px;padding:10px 12px;font-family:Inter,monospace;font-size:12px;line-height:1.5;white-space:pre;">@FormatJson(testResult.HeadersJson)</pre>
                                    </div>
                                    <div>
                                        <div style="font-size:12px;font-weight:700;color:var(--mer-ink-700);margin-bottom:4px;">Body</div>
                                        <pre style="margin:0;max-height:40vh;overflow:auto;background:var(--mer-canvas);border:1px solid var(--mer-line);border-radius:8px;padding:10px 12px;font-family:Inter,monospace;font-size:12px;line-height:1.5;white-space:pre;">@FormatJson(testResult.BodyJson)</pre>
                                    </div>
                                </div>
                                @if (testResult.DryRunStatus.HasValue)
                                {
                                    <div style="margin-top:12px;">
                                        <div style="font-size:12px;font-weight:700;color:var(--mer-ink-700);margin-bottom:4px;">
                                            Dry-run response
                                            <span class="tlg-status @(testResult.DryRunStatus is >= 200 and < 300 ? "tlg-status--active" : "tlg-status--danger")" style="margin-left:6px;">HTTP @testResult.DryRunStatus</span>
                                        </div>
                                        <pre style="margin:0;max-height:30vh;overflow:auto;background:var(--mer-canvas);border:1px solid var(--mer-line);border-radius:8px;padding:10px 12px;font-family:Inter,monospace;font-size:12px;line-height:1.5;white-space:pre-wrap;word-break:break-word;">@testResult.DryRunResponse</pre>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(testError))
                    {
                        <div style="background:var(--mer-red-50);color:var(--mer-red);padding:8px 12px;border-radius:6px;font-size:12px;margin-top:10px;">@testError</div>
                    }
                </div>
                <footer class="merino-dialog__footer">
                    <div class="merino-dialog__actions">
                        <button class="merino-dialog__btn" data-intent="primary" @onclick="CloseTestBench">Close</button>
                    </div>
                </footer>
            </div>
        </div>
    }
}

@code {
    private bool CanManage => Token.HasPermission("Integration.Manage");

    private List<OutboundEndpointConfigDto>? rows;
    private bool loading = true;
    private bool busy;

    protected override async Task OnInitializedAsync()
    {
        Token.Changed += OnTokenChanged;
        await Load();
    }

    private void OnTokenChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => Token.Changed -= OnTokenChanged;

    private async Task Load()
    {
        loading = true;
        var resp = await Api.GetAsync<List<OutboundEndpointConfigDto>>("api/integration/idm/endpoints");
        rows = resp?.Data ?? new();
        loading = false;
    }

    // ===== Create / edit =====
    private OutboundEndpointConfigDto? editing;
    private Guid? editingId;
    private string formKey = string.Empty;
    private string formMethod = "POST";
    private string formPath = string.Empty;
    private string formHeaders = string.Empty;
    private string formAckParser = string.Empty;
    private string formAcl = string.Empty;
    private bool formEnabled = true;
    private string formError = string.Empty;

    private void OpenNew()
    {
        editing = new OutboundEndpointConfigDto(Guid.Empty, "", "POST", "", null, null, null, true);
        editingId = null;
        formKey = ""; formMethod = "POST"; formPath = ""; formHeaders = ""; formAckParser = ""; formAcl = ""; formEnabled = true;
        formError = string.Empty;
    }

    private void OpenEdit(OutboundEndpointConfigDto e)
    {
        editing = e;
        editingId = e.Id;
        formKey = e.EndpointKey;
        formMethod = e.HttpMethod;
        formPath = e.RelativePath;
        formHeaders = e.StaticHeadersJson ?? "";
        formAckParser = e.AckParserKey ?? "";
        formAcl = e.DefaultAcl ?? "";
        formEnabled = e.IsEnabled;
        formError = string.Empty;
    }

    private async Task Save()
    {
        formError = string.Empty;
        if (string.IsNullOrWhiteSpace(formKey)) { formError = "Endpoint key is required."; return; }
        if (string.IsNullOrWhiteSpace(formPath)) { formError = "Relative path is required."; return; }
        busy = true;
        var req = new SaveOutboundEndpointConfigRequest(
            editingId,
            formKey.Trim(),
            formMethod,
            formPath.Trim(),
            string.IsNullOrWhiteSpace(formHeaders) ? null : formHeaders.Trim(),
            string.IsNullOrWhiteSpace(formAckParser) ? null : formAckParser.Trim(),
            string.IsNullOrWhiteSpace(formAcl) ? null : formAcl.Trim(),
            formEnabled);
        var resp = await Api.PostAsync<Guid, SaveOutboundEndpointConfigRequest>("api/integration/idm/endpoints", req);
        if (resp?.Success == true)
        {
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Saved" });
            editing = null;
            await Load();
        }
        else { formError = resp?.Errors?.FirstOrDefault() ?? "Failed to save."; }
        busy = false;
    }

    // ===== Delete =====
    private OutboundEndpointConfigDto? deleteRow;
    private void ConfirmDelete(OutboundEndpointConfigDto e) => deleteRow = e;

    private async Task Delete()
    {
        if (deleteRow is null) return;
        busy = true;
        var resp = await Api.DeleteAsync($"api/integration/idm/endpoints/{deleteRow.Id}");
        if (resp?.Success == true)
        {
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Deleted" });
            deleteRow = null;
            await Load();
        }
        else { Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Delete failed", Detail = resp?.Errors?.FirstOrDefault() ?? string.Empty }); }
        busy = false;
    }

    // ===== Validate =====
    private ValidateOutboundEndpointResultDto? validateResult;

    private async Task Validate(OutboundEndpointConfigDto e)
    {
        busy = true;
        validateResult = null;
        var resp = await Api.PostAsync<ValidateOutboundEndpointResultDto, object>($"api/integration/idm/endpoints/{e.Id}/validate", new { });
        if (resp?.Success == true && resp.Data is not null)
        {
            validateResult = resp.Data;
        }
        else
        {
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Validate failed", Detail = resp?.Errors?.FirstOrDefault() ?? string.Empty });
        }
        busy = false;
    }

    private static string ValidateBanner(ValidateOutboundEndpointResultDto r)
    {
        var flags = $"token {(r.TokenOk ? "OK" : "FAIL")} · reachability {(r.ReachabilityOk ? "OK" : "FAIL")} · HTTP {r.HttpStatus}";
        return string.IsNullOrWhiteSpace(r.Message) ? flags : $"{r.Message} ({flags})";
    }

    // ===== Test bench =====
    private bool showTestBench;
    private string docSearch = string.Empty;
    private bool docsLoading;
    private List<IdmDocumentPickDto> docs = new();
    private IdmDocumentPickDto? selectedDoc;
    private bool dryRun;
    private IdmTestBenchResultDto? testResult;
    private string testError = string.Empty;

    private async Task OpenTestBench()
    {
        showTestBench = true;
        docSearch = ""; selectedDoc = null; dryRun = false; testResult = null; testError = string.Empty;
        await SearchDocs();
    }

    private void CloseTestBench()
    {
        showTestBench = false;
        docs = new(); selectedDoc = null; testResult = null;
    }

    private async Task SearchDocs()
    {
        docsLoading = true;
        var url = "api/integration/idm/test-bench/documents";
        if (!string.IsNullOrWhiteSpace(docSearch)) url += $"?search={Uri.EscapeDataString(docSearch.Trim())}";
        var resp = await Api.GetAsync<List<IdmDocumentPickDto>>(url);
        docs = resp?.Data ?? new();
        docsLoading = false;
    }

    private void SelectDoc(IdmDocumentPickDto d) { selectedDoc = d; testResult = null; testError = string.Empty; }

    private async Task BuildEnvelope()
    {
        if (selectedDoc is null) return;
        busy = true;
        testError = string.Empty;
        testResult = null;
        var req = new IdmTestBenchRequest(selectedDoc.DocumentUploadId, dryRun);
        var resp = await Api.PostAsync<IdmTestBenchResultDto, IdmTestBenchRequest>("api/integration/idm/test-bench", req);
        if (resp?.Success == true && resp.Data is not null)
        {
            testResult = resp.Data;
        }
        else
        {
            testError = resp?.Errors?.FirstOrDefault() ?? "Failed to build envelope.";
        }
        busy = false;
    }

    private static string? FormatJson(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return raw;
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(raw);
            return System.Text.Json.JsonSerializer.Serialize(doc.RootElement,
                new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        }
        catch { return raw; }
    }
}
