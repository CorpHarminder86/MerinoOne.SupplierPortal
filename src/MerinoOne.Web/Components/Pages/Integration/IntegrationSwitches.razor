@page "/integrations/switches"
@inject NavigationManager Nav

@* R9 — the kill switches moved under Admin → System settings → Kill Switches (they are admin controls,
   not a standalone monitor). This route is kept as a redirect so existing bookmarks still land. *@

@code {
    protected override void OnInitialized()
        => Nav.NavigateTo("/admin/settings?category=KillSwitches", replace: true);
}
