@page "/purchase-orders"
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>Purchase Orders</PageTitle>

<div class="tl-page">
    <header class="tl-header">
        <div>
            <div class="tl-title-row">
                <h1 class="tl-title">Purchase Orders</h1>
                <span class="tl-count-chip">@(paged?.TotalCount ?? 0)</span>
            </div>
            <p class="tl-sub">Released and in-progress purchase orders</p>
        </div>
        <div class="tl-header__actions">
            @* R4 #6 — pick eligible POs from one supplier, then create an ASN covering them. *@
            @if (asnSel.Count > 0)
            {
                <button class="rz-button rz-primary" style="padding:8px 14px;border-radius:6px;border:0;color:#fff;cursor:pointer;" @onclick="CreateAsnFromSelected">
                    <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">local_shipping</span> Create ASN (@asnSel.Count)
                </button>
            }
        </div>
    </header>

    <div class="tl-filter-bar" style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
        <input class="rz-textbox" placeholder="Search PO # / supplier…" style="width:280px;padding:8px 12px;" @bind="search" @bind:event="oninput" @onkeyup="OnSearchKeyup" />
        <select class="rz-dropdown" style="padding:8px 12px;border:1px solid var(--mer-ink-300);border-radius:6px;background:var(--mer-surface);" @bind="statusFilter" @bind:after="Reload">
            <option value="">All statuses</option>
            <option value="Released">Released</option>
            <option value="Acknowledged">Acknowledged</option>
            <option value="Accepted">Accepted</option>
            <option value="Negotiation">Negotiation</option>
            <option value="Approved">Approved</option>
            <option value="PartiallyDelivered">Partially Delivered</option>
            <option value="Delivered">Delivered</option>
            <option value="Rejected">Rejected</option>
            <option value="Closed">Closed</option>
        </select>
        <select class="rz-dropdown" style="padding:8px 12px;border:1px solid var(--mer-ink-300);border-radius:6px;background:var(--mer-surface);" @bind="typeFilter" @bind:after="Reload">
            <option value="">All types</option>
            <option value="Material">Material</option>
            <option value="Service">Service</option>
        </select>
        @* Supplier filter — only when the signed-in user can act for more than one supplier (multi-mapped
           supplier login). Single-supplier users don't need it; the list is already seccode-scoped. *@
        @if (suppliers.Count > 1)
        {
            <select class="rz-dropdown" style="padding:8px 12px;border:1px solid var(--mer-ink-300);border-radius:6px;background:var(--mer-surface);min-width:220px;" @bind="supplierFilter" @bind:after="OnSupplierChanged">
                <option value="">All suppliers</option>
                @foreach (var s in suppliers)
                {
                    <option value="@s.Id">@s.LegalName (@s.SupplierCode)</option>
                }
            </select>
        }
    </div>

    @if (loading)
    {
        <div class="tl-empty">Loading…</div>
    }
    else if (paged == null || paged.Items.Count == 0)
    {
        <div class="tl-empty">
            <span class="material-symbols-outlined" style="font-size:32px;">description</span>
            <div>No purchase orders match.</div>
        </div>
    }
    else
    {
        <div class="tl-grid-wrapper" style="--tl-cols: 40px 140px 1.3fr 90px 130px 120px 120px 105px 115px 110px 70px 90px; --tl-min-width: 1500px;">
            <div class="tlg-header">
                <div class="tlg-col" title="Select for ASN"></div>
                <div class="tlg-col">PO #</div>
                <div class="tlg-col">Supplier</div>
                <div class="tlg-col">Type</div>
                <div class="tlg-col tlg-col--num">Amount</div>
                <div class="tlg-col">Payment terms</div>
                <div class="tlg-col">Delivery terms</div>
                <div class="tlg-col">PO Date</div>
                <div class="tlg-col">Status</div>
                <div class="tlg-col">Response</div>
                <div class="tlg-col tlg-col--num">Version</div>
                <div class="tlg-col tlg-col--actions"></div>
            </div>
            @foreach (var po in paged.Items)
            {
                var item = po;
                // R4 (2026-06-26) — D1: the list DTO's PoResponseMode now carries the PoConfirmationMode value
                // (AutoAccept / AcknowledgeToShip / AcceptToShip). AutoAccept = no manual step (auto-accepted at
                // release); the other two require a manual Ack/Accept/Reject.
                var isAuto = string.Equals(item.PoResponseMode, "AutoAccept", StringComparison.OrdinalIgnoreCase);
                // Non-AutoAccept + actionable status → surface a quick "Respond" deep-link to the detail page where the
                // permission-gated Acknowledge / Accept / Reject dialogs live. AutoAccept rows are accepted
                // automatically at release, so they only carry the mode badge.
                var canRespond = !isAuto && (item.PoStatus == "Released" || item.PoStatus == "Acknowledged");
                var asnEligible = item.PoStatus is "Released" or "Acknowledged" or "Accepted" or "PartiallyDelivered";
                var asnLocked = asnSelSupplier.HasValue && asnSelSupplier != item.SupplierId;
                <div class="tlg-row" @onclick="() => OpenDetail(item.Id)" style="cursor:pointer">
                    <div class="tlg-col" @onclick:stopPropagation="true">
                        @if (asnEligible)
                        {
                            <input type="checkbox" checked="@asnSel.Contains(item.Id)" disabled="@asnLocked"
                                   title="@(asnLocked ? "An ASN covers one supplier — clear the selection to switch" : "Select for ASN")"
                                   @onchange="@(e => ToggleAsnSel(item, (bool)e.Value!))" />
                        }
                    </div>
                    <div class="tlg-col tlg-code">@item.PoNumber</div>
                    <div class="tlg-col tlg-name">@item.SupplierName</div>
                    <div class="tlg-col">@item.PoType</div>
                    <div class="tlg-col tlg-col--num tlg-code">@(string.IsNullOrEmpty(item.CurrencyCode) ? "" : item.CurrencyCode + " ")@item.TotalAmount.ToString("N2")</div>
                    <div class="tlg-col">@(string.IsNullOrEmpty(item.PaymentTerms) ? "—" : item.PaymentTerms)</div>
                    <div class="tlg-col">@(string.IsNullOrEmpty(item.DeliveryTerms) ? "—" : item.DeliveryTerms)</div>
                    <div class="tlg-col tlg-code">@item.PoDate.ToString("yyyy-MM-dd")</div>
                    <div class="tlg-col"><span class="tlg-status @StatusClass(item.PoStatus)">@item.PoStatus</span></div>
                    <div class="tlg-col">
                        @if (isAuto)
                        {
                            <span class="tlg-status tlg-status--info" title="Ship at release — POs are accepted automatically">
                                <span class="material-symbols-outlined" style="font-size:13px;vertical-align:middle;">bolt</span> Auto-accept
                            </span>
                        }
                        else
                        {
                            <span class="tlg-status tlg-status--active" title="@PoModeTitle(item.PoResponseMode)">@PoModeShort(item.PoResponseMode)</span>
                        }
                    </div>
                    <div class="tlg-col tlg-col--num">@item.Version</div>
                    <div class="tlg-col tlg-col--actions" @onclick:stopPropagation="true">
                        @if (canRespond)
                        {
                            <button @onclick="() => OpenDetail(item.Id)" title="Respond to this PO"
                                    style="display:inline-flex;align-items:center;gap:5px;background:transparent;border:1px solid var(--mer-ink-300);border-radius:6px;padding:4px 10px;color:var(--mer-blue);cursor:pointer;font-size:11.5px;">
                                <span class="material-symbols-outlined" style="font-size:15px;">reply</span> Respond
                            </button>
                        }
                    </div>
                </div>
            }
        </div>

        <Pager Page="page" PageSize="PageSize" TotalCount="paged.TotalCount" PageChanged="OnPageChanged" />
    }
</div>

@code {
    private PagedResult<PurchaseOrderListItemDto>? paged;
    private List<SupplierListItemDto> suppliers = new();
    private bool loading = true;
    private string search = string.Empty;
    private string statusFilter = string.Empty;
    private string typeFilter = string.Empty;
    private string supplierFilter = string.Empty;
    private int page = 1;
    private const int PageSize = 50;

    // R4 #6 — "Create ASN from selected POs". An ASN ships from one supplier, so selection locks to it.
    private readonly HashSet<Guid> asnSel = new();
    private Guid? asnSelSupplier;

    protected override async Task OnInitializedAsync()
    {
        // Seccode-scoped: a supplier login mapped to several suppliers gets them all here; an
        // internal user gets the visible set. Drives the optional supplier filter (rendered only when >1).
        var sup = await Api.GetAsync<List<SupplierListItemDto>>("api/suppliers");
        suppliers = sup?.Data ?? new();
        await Reload();
    }

    private async Task OnSupplierChanged() { page = 1; await Reload(); }

    private async Task Reload()
    {
        loading = true;
        var url = $"api/purchase-orders?page={page}&pageSize={PageSize}";
        if (!string.IsNullOrWhiteSpace(statusFilter)) url += $"&status={Uri.EscapeDataString(statusFilter)}";
        if (!string.IsNullOrWhiteSpace(typeFilter)) url += $"&type={Uri.EscapeDataString(typeFilter)}";
        if (!string.IsNullOrWhiteSpace(supplierFilter)) url += $"&supplierId={Uri.EscapeDataString(supplierFilter)}";
        if (!string.IsNullOrWhiteSpace(search)) url += $"&search={Uri.EscapeDataString(search.Trim())}";
        var resp = await Api.GetAsync<PagedResult<PurchaseOrderListItemDto>>(url);
        paged = resp?.Data;
        loading = false;
    }

    private async Task OnSearchKeyup(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") { page = 1; await Reload(); }
    }

    private async Task OnPageChanged(int newPage) { page = newPage; await Reload(); }

    private void OpenDetail(Guid id) => Nav.NavigateToRoute($"/purchase-orders/{id}");

    private void ToggleAsnSel(PurchaseOrderListItemDto po, bool on)
    {
        if (on)
        {
            if (asnSel.Count == 0) asnSelSupplier = po.SupplierId;
            if (asnSelSupplier != po.SupplierId) return; // one supplier per ASN
            asnSel.Add(po.Id);
        }
        else
        {
            asnSel.Remove(po.Id);
            if (asnSel.Count == 0) asnSelSupplier = null;
        }
    }

    private void CreateAsnFromSelected()
    {
        if (asnSel.Count == 0) return;
        Nav.NavigateToRoute($"/asns/new?pos={string.Join(",", asnSel)}");
    }

    // R4 (2026-06-26) — D1: short label + tooltip for the non-AutoAccept confirmation modes.
    private static string PoModeShort(string mode) => mode switch
    {
        "AcknowledgeToShip" => "Acknowledge",
        "AcceptToShip" => "Accept",
        _ => "Accept"
    };

    private static string PoModeTitle(string mode) => mode switch
    {
        "AcknowledgeToShip" => "Acknowledge before ship — acknowledging unblocks shipping",
        "AcceptToShip" => "Accept before ship — the PO must be accepted before any ASN",
        _ => "The PO must be confirmed before shipping"
    };

    private string StatusClass(string status) => status switch
    {
        "Accepted" or "Delivered" or "Closed" or "Approved" => "tlg-status--active",
        "Released" or "Acknowledged" or "DateProposed" or "PartiallyDelivered" or "Negotiation" => "tlg-status--pending",
        "Rejected" or "Cancelled" => "tlg-status--danger",
        _ => "tlg-status--info"
    };
}
