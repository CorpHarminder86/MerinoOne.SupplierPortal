@page "/purchase-orders/{Id:guid}"
@inject ApiClient Api
@inject TokenAccessor Token
@inject NavigationManager Nav
@inject NotificationService Notif

<PageTitle>@detail?.PoNumber</PageTitle>

@if (loading)
{
    <div class="tl-empty">Loading…</div>
}
else if (detail == null)
{
    <div class="tl-empty">Purchase order not found.</div>
}
else
{
    <div class="tl-page">
        <a href="purchase-orders" class="mer-back-link">
            <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">arrow_back</span>
            Back to list
        </a>
        <header class="tl-header">
            <div>
                <div class="tl-title-row">
                    <h1 class="tl-title">@detail.PoNumber</h1>
                    <span class="tlg-status @StatusClass(detail.PoStatus)">@detail.PoStatus</span>
                    <span class="tl-count-chip">v@detail.Version</span>
                </div>
                <p class="tl-sub">@detail.SupplierName · @detail.PoType · @detail.PoDate.ToString("yyyy-MM-dd")</p>
            </div>
            <div class="tl-header__actions">
                @* PO response actions are shown only when the supplier is in MANUAL response mode.
                   In AUTO mode the PO is acknowledged + accepted automatically at release, so the
                   manual Ack/Accept/Reject affordances are hidden (req 3 / §0 Q8). *@
                @if (ManualResponse && Token.HasPermission("PurchaseOrder.Acknowledge") && detail.PoStatus == "Released")
                {
                    <button class="rz-button" style="padding:8px 14px;border-radius:6px;border:1px solid var(--mer-ink-300);background:var(--mer-surface);cursor:pointer;color:var(--mer-ink-700);" @onclick="OpenAcknowledge" disabled="@busy">
                        <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">check_circle</span> Acknowledge
                    </button>
                }
                @if (ManualResponse && Token.HasPermission("PurchaseOrder.Accept") && (detail.PoStatus == "Released" || detail.PoStatus == "Acknowledged"))
                {
                    <button class="rz-button rz-secondary" style="padding:8px 14px;border-radius:6px;border:0;color:#fff;cursor:pointer;" @onclick="OpenAccept" disabled="@busy">
                        <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">task_alt</span> Accept
                    </button>
                    <button class="rz-button" style="padding:8px 14px;border-radius:6px;border:1px solid var(--mer-red);background:var(--mer-surface);color:var(--mer-red);cursor:pointer;" @onclick="OpenReject" disabled="@busy">
                        <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">cancel</span> Reject
                    </button>
                }
                @* PO Negotiation (req 1) — supplier proposes revised qty / delivery dates. Peer of Accept/Reject,
                   gated on the negotiate permission + an eligible status. Hidden once a negotiation is open
                   (PoStatus == "Negotiation") so only "Cancel Negotiation" shows. *@
                @if (Token.HasPermission("PurchaseOrder.Negotiate") && (detail.PoStatus == "Released" || detail.PoStatus == "Acknowledged"))
                {
                    <button class="rz-button" style="padding:8px 14px;border-radius:6px;border:1px solid var(--mer-blue);background:var(--mer-surface);color:var(--mer-blue);cursor:pointer;" @onclick="EnterNegotiation" disabled="@busy">
                        <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">handshake</span> Negotiation
                    </button>
                }
                @* While a negotiation is open the PO is locked in "Negotiation" — Ack/Accept/Reject/Negotiation
                   are all hidden (their status guards above already exclude "Negotiation"); the supplier may
                   only withdraw it (req 3 / state machine §2). *@
                @if (Token.HasPermission("PurchaseOrder.Negotiate") && detail.PoStatus == "Negotiation")
                {
                    <button class="rz-button" style="padding:8px 14px;border-radius:6px;border:1px solid var(--mer-red);background:var(--mer-surface);color:var(--mer-red);cursor:pointer;" @onclick="CancelNegotiation" disabled="@busy">
                        <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">undo</span> Cancel Negotiation
                    </button>
                }
                @if (!ManualResponse && (detail.PoStatus == "Released" || detail.PoStatus == "Acknowledged"))
                {
                    <span class="tlg-status tlg-status--info" title="Supplier is in Auto PO-response mode" style="align-self:center;">
                        <span class="material-symbols-outlined" style="font-size:14px;vertical-align:middle;">bolt</span> Auto response
                    </span>
                }
                @if (Token.HasPermission("PurchaseOrder.ApproveProposal") && detail.PoStatus == "DateProposed")
                {
                    <button class="rz-button rz-primary" style="padding:8px 14px;border-radius:6px;border:0;color:#fff;cursor:pointer;" @onclick="OpenApproveProposal" disabled="@busy">
                        <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">event_available</span> Approve Proposal
                    </button>
                }
            </div>
        </header>

        <div class="mer-tabs" style="display:flex;gap:0;border-bottom:1px solid var(--mer-line);margin-bottom:16px;">
            <button class="mer-tab @(tab=="overview"?"mer-tab--active":"")" @onclick="TabOverview" style="padding:10px 16px;background:transparent;border:0;border-bottom:2px solid @(tab=="overview"?"var(--mer-blue)":"transparent");cursor:pointer;font:600 13px/1 'Plus Jakarta Sans',sans-serif;color:@(tab=="overview"?"var(--mer-blue)":"var(--mer-ink-700)");">Overview</button>
            <button class="mer-tab @(tab=="history"?"mer-tab--active":"")" @onclick="TabHistory" style="padding:10px 16px;background:transparent;border:0;border-bottom:2px solid @(tab=="history"?"var(--mer-blue)":"transparent");cursor:pointer;font:600 13px/1 'Plus Jakarta Sans',sans-serif;color:@(tab=="history"?"var(--mer-blue)":"var(--mer-ink-700)");">History</button>
        </div>

        @if (tab == "history")
        {
            @* PO-scoped history endpoint (PurchaseOrder.Read) so the supplier sees their own PO's history —
               incl. negotiation qty/delivery changes — not just admins (the generic audit API needs Settings.Read). *@
            <AuditHistoryTab EntityName="PurchaseOrder" EntityId="@Id" ApiPath="@($"api/purchase-orders/{Id}/history")" />
        }
        else
        {
        <div style="display:grid;grid-template-columns:1.5fr 1fr;gap:16px;">
            <div class="rz-card" style="padding:20px;">
                <h3 style="font-size:14px;font-weight:700;margin-bottom:12px;color:var(--mer-blue-darker);">Order details</h3>
                <dl style="display:grid;grid-template-columns:160px 1fr;gap:6px 16px;font-size:13px;">
                    <dt style="color:var(--mer-ink-500);">Supplier</dt><dd>@detail.SupplierName (@detail.SupplierCode)</dd>
                    <dt style="color:var(--mer-ink-500);">Buyer</dt><dd>@(detail.BuyerName ?? "—")</dd>
                    <dt style="color:var(--mer-ink-500);">PO Date</dt><dd style="font-family:Inter,monospace;">@detail.PoDate.ToString("yyyy-MM-dd")</dd>
                    <dt style="color:var(--mer-ink-500);">Currency</dt><dd>@(string.IsNullOrEmpty(detail.CurrencyCode) ? "—" : detail.CurrencyCode)</dd>
                    <dt style="color:var(--mer-ink-500);">Payment terms</dt><dd>@(detail.PaymentTerms ?? "—")</dd>
                    <dt style="color:var(--mer-ink-500);">Delivery terms</dt><dd>@(detail.DeliveryTerms ?? "—")</dd>
                    <dt style="color:var(--mer-ink-500);">Total amount</dt><dd style="font-family:Inter,monospace;font-weight:700;color:var(--mer-blue-darker);">@(string.IsNullOrEmpty(detail.CurrencyCode) ? "" : detail.CurrencyCode + " ")@detail.TotalAmount.ToString("0.00")</dd>
                    @if (detail.AcknowledgmentAt.HasValue)
                    {
                        <dt style="color:var(--mer-ink-500);">Acknowledged</dt><dd style="font-family:Inter,monospace;">@detail.AcknowledgmentAt.Value.ToString("yyyy-MM-dd HH:mm")</dd>
                    }
                    @if (detail.AcceptedAt.HasValue)
                    {
                        <dt style="color:var(--mer-ink-500);">Accepted</dt><dd style="font-family:Inter,monospace;">@detail.AcceptedAt.Value.ToString("yyyy-MM-dd HH:mm")</dd>
                    }
                    @if (detail.ProposedDeliveryDate.HasValue)
                    {
                        <dt style="color:var(--mer-ink-500);">Proposed delivery</dt><dd style="font-family:Inter,monospace;color:var(--mer-amber-800);">@detail.ProposedDeliveryDate.Value.ToString("yyyy-MM-dd")</dd>
                    }
                    @if (!string.IsNullOrEmpty(detail.RejectionReason))
                    {
                        <dt style="color:var(--mer-ink-500);">Rejection reason</dt><dd style="background:var(--mer-red-50);color:var(--mer-red);padding:6px 10px;border-radius:4px;">@detail.RejectionReason</dd>
                    }
                </dl>
            </div>

            <div class="rz-card" style="padding:20px;">
                <h3 style="font-size:14px;font-weight:700;margin-bottom:12px;color:var(--mer-blue-darker);">Notes</h3>
                <p style="font-size:13px;color:var(--mer-ink-700);white-space:pre-wrap;">@(string.IsNullOrEmpty(detail.Notes) ? "No notes." : detail.Notes)</p>
            </div>
        </div>

        @* ---------------- Negotiation edit bar (req 3) ---------------- *@
        @if (negotiating)
        {
            <div class="rz-card" style="padding:16px 20px;margin-top:16px;border:1px solid var(--mer-blue);background:var(--mer-blue-50);">
                <div style="display:flex;align-items:flex-start;gap:10px;">
                    <span class="material-symbols-outlined" style="font-size:20px;color:var(--mer-blue);">handshake</span>
                    <div style="flex:1;">
                        <div style="font-size:13px;font-weight:700;color:var(--mer-blue-darker);">Negotiation mode</div>
                        <p style="font-size:12px;color:var(--mer-ink-700);margin:2px 0 10px;">Edit the <b>Qty</b> and <b>Delivery Date</b> on the lines you want to renegotiate. Only changed lines are submitted.</p>
                        <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);display:block;margin-bottom:4px;">Notes for the buyer (optional)</label>
                        <textarea class="rz-textbox" rows="2" style="width:100%;max-width:560px;padding:8px 10px;font-family:inherit;" @bind="negotiationNotes"></textarea>
                        @if (!string.IsNullOrEmpty(negotiationError))
                        {
                            <div style="background:var(--mer-red-50);color:var(--mer-red);padding:8px 12px;border-radius:6px;font-size:12px;margin-top:8px;max-width:560px;">@negotiationError</div>
                        }
                    </div>
                    <div style="display:flex;gap:8px;flex-shrink:0;">
                        <button class="rz-button" style="padding:8px 14px;border-radius:6px;border:1px solid var(--mer-ink-300);background:var(--mer-surface);color:var(--mer-ink-700);cursor:pointer;" @onclick="CancelEdit" disabled="@busy">Cancel</button>
                        <button class="rz-button rz-primary" style="padding:8px 14px;border-radius:6px;border:0;color:#fff;cursor:pointer;" @onclick="SubmitNegotiation" disabled="@busy">
                            <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">send</span> @(busy ? "Submitting…" : "Submit Negotiation")
                        </button>
                    </div>
                </div>
            </div>
        }

        <div class="rz-card" style="padding:20px;margin-top:16px;">
            <h3 style="font-size:14px;font-weight:700;margin-bottom:12px;color:var(--mer-blue-darker);">Lines (@detail.Lines.Count)</h3>
            @if (detail.Lines.Count == 0)
            {
                <p style="font-size:13px;color:var(--mer-ink-500);">No lines on this PO.</p>
            }
            else
            {
                <table style="width:100%;font-size:12.5px;border-collapse:collapse;">
                    <thead>
                        <tr style="border-bottom:1px solid var(--mer-line);">
                            <th style="text-align:left;padding:6px 4px;color:var(--mer-ink-700);">Pos</th>
                            <th style="text-align:left;padding:6px 4px;color:var(--mer-ink-700);">Seq</th>
                            <th style="text-align:left;padding:6px 4px;color:var(--mer-ink-700);">Item</th>
                            <th style="text-align:left;padding:6px 4px;color:var(--mer-ink-700);">Description</th>
                            <th style="text-align:right;padding:6px 4px;color:var(--mer-ink-700);">Qty</th>
                            <th style="text-align:left;padding:6px 4px;color:var(--mer-ink-700);">Unit</th>
                            <th style="text-align:right;padding:6px 4px;color:var(--mer-ink-700);">Price Unit</th>
                            <th style="text-align:right;padding:6px 4px;color:var(--mer-ink-700);">Net Amount</th>
                            <th style="text-align:right;padding:6px 4px;color:var(--mer-ink-700);">Disc %</th>
                            <th style="text-align:right;padding:6px 4px;color:var(--mer-ink-700);">Disc Amt</th>
                            <th style="text-align:left;padding:6px 4px;color:var(--mer-ink-700);">Tax</th>
                            <th style="text-align:left;padding:6px 4px;color:var(--mer-ink-700);">Delivery</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var ln in detail.Lines.OrderBy(l => l.PositionNo).ThenBy(l => l.SequenceNo))
                    {
                        var line = ln;
                        <tr style="border-bottom:1px solid var(--mer-line-soft);">
                            <td style="padding:6px 4px;font-family:Inter,monospace;">@line.PositionNo</td>
                            <td style="padding:6px 4px;font-family:Inter,monospace;">@line.SequenceNo</td>
                            <td style="padding:6px 4px;font-family:Inter,monospace;">@line.ItemCode</td>
                            <td style="padding:6px 4px;">@line.ItemDescription</td>
                            @if (negotiating && edits.TryGetValue(line.Id, out var edit))
                            {
                                @* Editable Qty + Price Unit (req 3 + price addendum) — all other columns stay read-only. *@
                                <td style="padding:6px 4px;text-align:right;">
                                    <input type="number" step="0.001" min="0" class="rz-textbox" style="width:90px;padding:4px 6px;text-align:right;font-family:Inter,monospace;" @bind="edit.Qty" />
                                </td>
                                <td style="padding:6px 4px;">@line.OrderUnit</td>
                                <td style="padding:6px 4px;text-align:right;">
                                    <input type="number" step="0.01" min="0" class="rz-textbox" style="width:100px;padding:4px 6px;text-align:right;font-family:Inter,monospace;" @bind="edit.Price" />
                                </td>
                                <td style="padding:6px 4px;text-align:right;font-family:Inter,monospace;">@line.NetAmount.ToString("0.00")</td>
                                <td style="padding:6px 4px;text-align:right;font-family:Inter,monospace;">@(line.DiscountPct == 0 ? "—" : line.DiscountPct.ToString("0.##"))</td>
                                <td style="padding:6px 4px;text-align:right;font-family:Inter,monospace;">@(line.DiscountAmount == 0 ? "—" : line.DiscountAmount.ToString("0.00"))</td>
                                <td style="padding:6px 4px;" title="@line.TaxDescription">@(string.IsNullOrEmpty(line.TaxCode) ? "—" : line.TaxCode)</td>
                                @* Editable Delivery Date (req 3). *@
                                <td style="padding:6px 4px;">
                                    <input type="date" class="rz-textbox" style="padding:4px 6px;font-family:Inter,monospace;" @bind="edit.DeliveryDate" />
                                </td>
                            }
                            else
                            {
                                <td style="padding:6px 4px;text-align:right;font-family:Inter,monospace;">@line.OrderQty.ToString("0.###")</td>
                                <td style="padding:6px 4px;">@line.OrderUnit</td>
                                <td style="padding:6px 4px;text-align:right;font-family:Inter,monospace;">@line.PriceUnit.ToString("0.00")</td>
                                <td style="padding:6px 4px;text-align:right;font-family:Inter,monospace;">@line.NetAmount.ToString("0.00")</td>
                                <td style="padding:6px 4px;text-align:right;font-family:Inter,monospace;">@(line.DiscountPct == 0 ? "—" : line.DiscountPct.ToString("0.##"))</td>
                                <td style="padding:6px 4px;text-align:right;font-family:Inter,monospace;">@(line.DiscountAmount == 0 ? "—" : line.DiscountAmount.ToString("0.00"))</td>
                                <td style="padding:6px 4px;" title="@line.TaxDescription">@(string.IsNullOrEmpty(line.TaxCode) ? "—" : line.TaxCode)</td>
                                <td style="padding:6px 4px;font-family:Inter,monospace;">@(line.DeliveryDate?.ToString("yyyy-MM-dd") ?? "—")</td>
                            }
                        </tr>
                    }
                    </tbody>
                    <tfoot>
                        <tr style="border-top:2px solid var(--mer-line);font-weight:700;">
                            <td colspan="7" style="padding:8px 4px;text-align:right;color:var(--mer-ink-700);">Total@(string.IsNullOrEmpty(detail.CurrencyCode) ? "" : " (" + detail.CurrencyCode + ")")</td>
                            <td style="padding:8px 4px;text-align:right;font-family:Inter,monospace;color:var(--mer-blue-darker);">@detail.TotalAmount.ToString("0.00")</td>
                            <td colspan="4"></td>
                        </tr>
                    </tfoot>
                </table>
            }
        </div>
        }
    </div>

    @if (showAcknowledge)
    {
        <div style="position:fixed;inset:0;background:var(--mer-modal-backdrop);display:flex;align-items:center;justify-content:center;z-index:1000;">
            <div class="merino-dialog" data-variant="info" style="width:540px;">
                <div class="merino-dialog__accent"></div>
                <header class="merino-dialog__header">
                    <div class="merino-dialog__icon merino-dialog__icon--info"><span class="material-symbols-outlined">check_circle</span></div>
                    <div class="merino-dialog__head-text">
                        <div class="merino-dialog__eyebrow">Purchase Order</div>
                        <h2 class="merino-dialog__title">Acknowledge @detail.PoNumber?</h2>
                        <p class="merino-dialog__subtitle">Confirms you've seen the PO. Add any notes for the buyer.</p>
                    </div>
                    <button class="merino-dialog__close" @onclick="() => showAcknowledge = false"><span class="material-symbols-outlined">close</span></button>
                </header>
                <div class="merino-dialog__body">
                    <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Notes (optional)</label>
                    <textarea class="rz-textbox" rows="3" style="width:100%;padding:8px 10px;font-family:inherit;" @bind="dialogNotes"></textarea>
                    @if (!string.IsNullOrEmpty(dialogError)) { <div style="background:var(--mer-red-50);color:var(--mer-red);padding:8px 12px;border-radius:6px;font-size:12px;margin-top:8px;">@dialogError</div> }
                </div>
                <footer class="merino-dialog__footer">
                    <div class="merino-dialog__actions">
                        <button class="merino-dialog__btn" data-intent="ghost" @onclick="() => showAcknowledge = false">Cancel</button>
                        <button class="merino-dialog__btn" data-intent="primary" @onclick="DoAcknowledge" disabled="@busy">@(busy ? "Working…" : "Acknowledge")</button>
                    </div>
                </footer>
            </div>
        </div>
    }

    @if (showAccept)
    {
        <div style="position:fixed;inset:0;background:var(--mer-modal-backdrop);display:flex;align-items:center;justify-content:center;z-index:1000;">
            <div class="merino-dialog" data-variant="success" style="width:540px;">
                <div class="merino-dialog__accent"></div>
                <header class="merino-dialog__header">
                    <div class="merino-dialog__icon merino-dialog__icon--success"><span class="material-symbols-outlined">task_alt</span></div>
                    <div class="merino-dialog__head-text">
                        <div class="merino-dialog__eyebrow">Purchase Order</div>
                        <h2 class="merino-dialog__title">Accept @detail.PoNumber</h2>
                        <p class="merino-dialog__subtitle">Optionally propose an alternate delivery date.</p>
                    </div>
                    <button class="merino-dialog__close" @onclick="() => showAccept = false"><span class="material-symbols-outlined">close</span></button>
                </header>
                <div class="merino-dialog__body">
                    <div style="margin-bottom:10px;">
                        <label style="display:block;font-size:12px;font-weight:600;color:var(--mer-ink-700);margin-bottom:4px;">
                            <input type="radio" name="del" checked="@(!proposeAlt)" @onchange="() => proposeAlt = false" /> Accept as-is
                        </label>
                        <label style="display:block;font-size:12px;font-weight:600;color:var(--mer-ink-700);">
                            <input type="radio" name="del" checked="@proposeAlt" @onchange="() => proposeAlt = true" /> Propose alternate date
                        </label>
                    </div>
                    @if (proposeAlt)
                    {
                        <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Proposed date</label>
                        <input type="date" class="rz-textbox" style="width:100%;padding:8px 10px;" @bind="proposedDate" />
                    }
                    <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);margin-top:8px;display:block;">Notes (optional)</label>
                    <textarea class="rz-textbox" rows="3" style="width:100%;padding:8px 10px;font-family:inherit;" @bind="dialogNotes"></textarea>
                    @* Confirmation step (req 2) — the supplier must explicitly confirm before the Accept POSTs.
                       This commits to the PO terms (or the proposed alternate date) and cannot be undone. *@
                    <label style="display:flex;align-items:flex-start;gap:8px;font-size:12.5px;color:var(--mer-ink-700);margin-top:12px;background:var(--mer-amber-50, var(--mer-blue-50));padding:10px 12px;border-radius:6px;">
                        <input type="checkbox" checked="@acceptConfirmed" @onchange="e => acceptConfirmed = (bool)(e.Value ?? false)" style="margin-top:2px;" />
                        <span>I confirm I am accepting <b>@detail.PoNumber</b>@(proposeAlt ? " with the proposed delivery date above" : " as ordered"). This commits the order and cannot be undone.</span>
                    </label>
                    @if (!string.IsNullOrEmpty(dialogError)) { <div style="background:var(--mer-red-50);color:var(--mer-red);padding:8px 12px;border-radius:6px;font-size:12px;margin-top:8px;">@dialogError</div> }
                </div>
                <footer class="merino-dialog__footer">
                    <div class="merino-dialog__actions">
                        <button class="merino-dialog__btn" data-intent="ghost" @onclick="() => showAccept = false">Cancel</button>
                        <button class="merino-dialog__btn" data-intent="primary" @onclick="DoAccept" disabled="@(busy || !acceptConfirmed)">@(busy ? "Working…" : "Confirm Accept")</button>
                    </div>
                </footer>
            </div>
        </div>
    }

    @if (showReject)
    {
        <div style="position:fixed;inset:0;background:var(--mer-modal-backdrop);display:flex;align-items:center;justify-content:center;z-index:1000;">
            <div class="merino-dialog" data-variant="danger" style="width:540px;">
                <div class="merino-dialog__accent"></div>
                <header class="merino-dialog__header">
                    <div class="merino-dialog__icon merino-dialog__icon--danger"><span class="material-symbols-outlined">cancel</span></div>
                    <div class="merino-dialog__head-text">
                        <div class="merino-dialog__eyebrow">Purchase Order</div>
                        <h2 class="merino-dialog__title">Reject @detail.PoNumber</h2>
                        <p class="merino-dialog__subtitle">Provide a reason for rejection.</p>
                    </div>
                    <button class="merino-dialog__close" @onclick="() => showReject = false"><span class="material-symbols-outlined">close</span></button>
                </header>
                <div class="merino-dialog__body">
                    <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Reason (required)</label>
                    <textarea class="rz-textbox" rows="4" style="width:100%;padding:8px 10px;font-family:inherit;" @bind="rejectionReason"></textarea>
                    @if (!string.IsNullOrEmpty(dialogError)) { <div style="background:var(--mer-red-50);color:var(--mer-red);padding:8px 12px;border-radius:6px;font-size:12px;margin-top:8px;">@dialogError</div> }
                </div>
                <footer class="merino-dialog__footer">
                    <div class="merino-dialog__actions">
                        <button class="merino-dialog__btn" data-intent="ghost" @onclick="() => showReject = false">Cancel</button>
                        <button class="merino-dialog__btn" data-intent="danger" @onclick="DoReject" disabled="@busy">@(busy ? "Working…" : "Reject")</button>
                    </div>
                </footer>
            </div>
        </div>
    }

    @if (showApproveProposal)
    {
        <div style="position:fixed;inset:0;background:var(--mer-modal-backdrop);display:flex;align-items:center;justify-content:center;z-index:1000;">
            <div class="merino-dialog" data-variant="info" style="width:540px;">
                <div class="merino-dialog__accent"></div>
                <header class="merino-dialog__header">
                    <div class="merino-dialog__icon merino-dialog__icon--info"><span class="material-symbols-outlined">event_available</span></div>
                    <div class="merino-dialog__head-text">
                        <div class="merino-dialog__eyebrow">Buyer action</div>
                        <h2 class="merino-dialog__title">Approve proposed date</h2>
                        <p class="merino-dialog__subtitle">Proposed: <b>@(detail.ProposedDeliveryDate?.ToString("yyyy-MM-dd"))</b></p>
                    </div>
                    <button class="merino-dialog__close" @onclick="() => showApproveProposal = false"><span class="material-symbols-outlined">close</span></button>
                </header>
                <div class="merino-dialog__body">
                    <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Comment (optional)</label>
                    <textarea class="rz-textbox" rows="3" style="width:100%;padding:8px 10px;font-family:inherit;" @bind="dialogNotes"></textarea>
                    @if (!string.IsNullOrEmpty(dialogError)) { <div style="background:var(--mer-red-50);color:var(--mer-red);padding:8px 12px;border-radius:6px;font-size:12px;margin-top:8px;">@dialogError</div> }
                </div>
                <footer class="merino-dialog__footer">
                    <div class="merino-dialog__actions">
                        <button class="merino-dialog__btn" data-intent="ghost" @onclick="() => showApproveProposal = false">Cancel</button>
                        <button class="merino-dialog__btn" data-intent="primary" @onclick="DoApproveProposal" disabled="@busy">@(busy ? "Working…" : "Approve")</button>
                    </div>
                </footer>
            </div>
        </div>
    }
}

@code {
    [Parameter] public Guid Id { get; set; }
    private PurchaseOrderDetailDto? detail;
    private bool loading = true;
    private bool busy = false;
    private string tab = "overview";

    // Supplier's PO-response mode now travels on PurchaseOrderDetailDto.PoResponseMode (joined from
    // Supplier.PoResponseMode by the API) — no second GET /api/suppliers/{id} needed. Defaults to Manual
    // (the DTO's own default) so a missing/empty value never hides the manual actions.
    private bool ManualResponse => !string.Equals(detail?.PoResponseMode, "Auto", StringComparison.OrdinalIgnoreCase);

    private void TabOverview() => tab = "overview";
    private void TabHistory() => tab = "history";

    private bool showAcknowledge = false;
    private bool showAccept = false;
    private bool showReject = false;
    private bool showApproveProposal = false;
    private bool proposeAlt = false;
    private bool acceptConfirmed = false;   // req 2 — explicit confirm gate on the Accept dialog
    private DateTime? proposedDate;
    private string dialogNotes = string.Empty;
    private string rejectionReason = string.Empty;
    private string dialogError = string.Empty;

    // ---------------- Negotiation (req 1 + 3 + 4) ----------------
    // Inline editable line grid state. `edits` is keyed by PurchaseOrderLineId and seeded from the live PO
    // line (OrderQty / DeliveryDate); on submit we POST only the lines whose Qty OR DeliveryDate changed.
    private sealed class LineEdit
    {
        public decimal OriginalQty;
        public DateTime? OriginalDate;
        public decimal OriginalPrice;
        public decimal Qty;
        public DateTime? DeliveryDate;
        public decimal Price;
        public bool Changed => Qty != OriginalQty || DeliveryDate != OriginalDate || Price != OriginalPrice;
    }
    private bool negotiating = false;
    private string negotiationNotes = string.Empty;
    private string negotiationError = string.Empty;
    private Dictionary<Guid, LineEdit> edits = new();

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        loading = true;
        var resp = await Api.GetAsync<PurchaseOrderDetailDto>($"api/purchase-orders/{Id}");
        detail = resp?.Data;
        loading = false;
        // PoResponseMode is read straight off `detail` (see ManualResponse) — no supplier round-trip.
    }

    private void OpenAcknowledge() { dialogNotes = string.Empty; dialogError = string.Empty; showAcknowledge = true; }
    private void OpenAccept() { dialogNotes = string.Empty; dialogError = string.Empty; proposeAlt = false; proposedDate = null; acceptConfirmed = false; showAccept = true; }
    private void OpenReject() { rejectionReason = string.Empty; dialogError = string.Empty; showReject = true; }
    private void OpenApproveProposal() { dialogNotes = string.Empty; dialogError = string.Empty; showApproveProposal = true; }

    // ---------------- Negotiation handlers ----------------
    // Enter inline edit mode (req 3): snapshot each line's qty/date so we can diff on submit and discard on cancel.
    private void EnterNegotiation()
    {
        if (detail is null) return;
        negotiationError = string.Empty;
        negotiationNotes = string.Empty;
        edits = detail.Lines.ToDictionary(
            l => l.Id,
            l => new LineEdit { OriginalQty = l.OrderQty, OriginalDate = l.DeliveryDate, OriginalPrice = l.PriceUnit, Qty = l.OrderQty, DeliveryDate = l.DeliveryDate, Price = l.PriceUnit });
        negotiating = true;
    }

    // Discard local edits, no API call (req 3).
    private void CancelEdit()
    {
        negotiating = false;
        edits = new();
        negotiationNotes = string.Empty;
        negotiationError = string.Empty;
    }

    private async Task SubmitNegotiation()
    {
        if (detail is null) return;
        var changed = edits
            .Where(kv => kv.Value.Changed)
            .Select(kv => new PoNegotiationLineInput(kv.Key, kv.Value.Qty, kv.Value.DeliveryDate, kv.Value.Price))
            .ToList();

        if (changed.Count == 0) { negotiationError = "Change at least one line's quantity, delivery date or price before submitting."; return; }
        if (changed.Any(l => l.NegotiatedQty <= 0)) { negotiationError = "Negotiated quantity must be greater than zero."; return; }
        if (changed.Any(l => l.NegotiatedPrice < 0)) { negotiationError = "Negotiated price cannot be negative."; return; }

        busy = true; negotiationError = string.Empty;
        var req = new CreatePoNegotiationRequest(detail.Id, string.IsNullOrWhiteSpace(negotiationNotes) ? null : negotiationNotes.Trim(), changed);
        var resp = await Api.PostAsync<PoNegotiationDto, CreatePoNegotiationRequest>("api/purchase-orders/negotiations", req);
        if (resp?.Success == true)
        {
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Negotiation submitted", Detail = "The buyer will review your proposed changes." });
            CancelEdit();
            await Load();   // PO now shows "Negotiation"
        }
        else
        {
            negotiationError = resp?.Errors?.FirstOrDefault() ?? "Failed to submit negotiation.";
        }
        busy = false;
    }

    // Withdraw the open negotiation (req 3 / state machine). Needs the open negotiation's id, which we look up
    // from the supplier's own Submitted list filtered to this PO, then POST .../{id}/cancel.
    private async Task CancelNegotiation()
    {
        if (detail is null) return;
        busy = true;
        var list = await Api.GetAsync<List<PoNegotiationListItemDto>>("api/purchase-orders/negotiations?status=Submitted");
        var open = list?.Data?.FirstOrDefault(n => string.Equals(n.PoNumber, detail.PoNumber, StringComparison.OrdinalIgnoreCase));
        if (open is null)
        {
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Could not cancel", Detail = "No open negotiation found for this PO.", Duration = 6000 });
            await Load();
            busy = false;
            return;
        }
        var resp = await Api.PostAsync<object?>($"api/purchase-orders/negotiations/{open.Id}/cancel", new { });
        if (resp?.Success == true)
        {
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Warning, Summary = "Negotiation cancelled", Detail = "The PO reverted to its previous status." });
        }
        else
        {
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Could not cancel", Detail = resp?.Errors?.FirstOrDefault() ?? "Cancel failed.", Duration = 6000 });
        }
        await Load();
        busy = false;
    }

    private async Task DoAcknowledge()
    {
        busy = true; dialogError = string.Empty;
        var resp = await Api.PostAsync<PurchaseOrderDetailDto, AcknowledgePoRequest>($"api/purchase-orders/{Id}/acknowledge", new AcknowledgePoRequest(string.IsNullOrWhiteSpace(dialogNotes) ? null : dialogNotes));
        if (resp?.Success == true) { Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Acknowledged" }); showAcknowledge = false; await Load(); }
        else { dialogError = resp?.Errors?.FirstOrDefault() ?? "Failed."; }
        busy = false;
    }

    private async Task DoAccept()
    {
        busy = true; dialogError = string.Empty;
        var req = new AcceptPoRequest(proposeAlt ? proposedDate : null, string.IsNullOrWhiteSpace(dialogNotes) ? null : dialogNotes);
        // NOTE: AcceptPoRequest.ProposedDate maps to PO.ProposedDeliveryDate server-side per backend DTOs.
        var resp = await Api.PostAsync<PurchaseOrderDetailDto, AcceptPoRequest>($"api/purchase-orders/{Id}/accept", req);
        if (resp?.Success == true) { Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Accepted" }); showAccept = false; await Load(); }
        else { dialogError = resp?.Errors?.FirstOrDefault() ?? "Failed."; }
        busy = false;
    }

    private async Task DoReject()
    {
        if (string.IsNullOrWhiteSpace(rejectionReason)) { dialogError = "Reason is required."; return; }
        busy = true; dialogError = string.Empty;
        var resp = await Api.PostAsync<PurchaseOrderDetailDto, RejectPoRequest>($"api/purchase-orders/{Id}/reject", new RejectPoRequest(rejectionReason));
        if (resp?.Success == true) { Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Warning, Summary = "Rejected" }); showReject = false; await Load(); }
        else { dialogError = resp?.Errors?.FirstOrDefault() ?? "Failed."; }
        busy = false;
    }

    private async Task DoApproveProposal()
    {
        busy = true; dialogError = string.Empty;
        var resp = await Api.PostAsync<PurchaseOrderDetailDto, ApproveProposalRequest>($"api/purchase-orders/{Id}/approve-proposal", new ApproveProposalRequest(string.IsNullOrWhiteSpace(dialogNotes) ? null : dialogNotes));
        if (resp?.Success == true) { Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Approved" }); showApproveProposal = false; await Load(); }
        else { dialogError = resp?.Errors?.FirstOrDefault() ?? "Failed."; }
        busy = false;
    }

    private string StatusClass(string status) => status switch
    {
        "Accepted" or "Delivered" or "Closed" or "Approved" => "tlg-status--active",
        "Released" or "Acknowledged" or "DateProposed" or "PartiallyDelivered" or "Negotiation" => "tlg-status--pending",
        "Rejected" or "Cancelled" => "tlg-status--danger",
        _ => "tlg-status--info"
    };
}
