@page "/register/{Token}"
@layout EmptyLayout
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@implements IDisposable
@using System.Net.Http
@using System.Net.Http.Json
@using System.Text.RegularExpressions
@using Microsoft.AspNetCore.Components.Forms
@using MerinoOne.SupplierPortal.Contracts.Common
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>Supplier registration</PageTitle>

@if (loading)
{
    <div class="tl-empty" style="background:var(--mer-surface);border:1px solid var(--mer-line);border-radius:var(--mer-radius-lg);padding:32px;">
        Loading invite…
    </div>
}
else if (invite == null)
{
    <div class="rz-card" style="padding:32px;text-align:center;">
        <span class="material-symbols-outlined" style="font-size:48px;color:var(--mer-red);">error</span>
        <h2 style="margin:12px 0 6px;color:var(--mer-blue-darker);">Invalid or expired invite</h2>
        <p style="color:var(--mer-ink-500);font-size:13px;">This registration link is no longer valid. Please contact your Merino representative for a fresh invite.</p>
    </div>
}
else if (registered)
{
    <div class="rz-card" style="padding:32px;text-align:center;">
        <span class="material-symbols-outlined" style="font-size:48px;color:var(--mer-green-dark);">task_alt</span>
        <h2 style="margin:12px 0 6px;color:var(--mer-blue-darker);">Registration submitted</h2>
        <p style="color:var(--mer-ink-700);font-size:13px;max-width:520px;margin:0 auto;">
            Thank you. Our team will review your details and contact you on <b>@invite.Email</b>. You will receive
            a portal login once your supplier registration is approved.
        </p>
    </div>
}
else if (!_otpVerified)
{
    <div class="rz-card" style="padding:32px;max-width:480px;margin:0 auto;">
        <header style="margin-bottom:20px;text-align:center;">
            <div style="font-size:11px;font-weight:700;letter-spacing:0.12em;color:var(--mer-ink-500);text-transform:uppercase;">Verify</div>
            <h1 style="margin:6px 0 6px;font-size:20px;color:var(--mer-blue-darker);">Enter the code we sent to @invite.Email</h1>
            <p style="color:var(--mer-ink-500);font-size:12.5px;">Check your inbox for a 6-digit verification code. It expires in 10 minutes.</p>
        </header>

        <div style="margin-bottom:14px;">
            <input class="rz-textbox"
                   style="width:100%;padding:14px 12px;font-family:Inter,monospace;font-size:22px;letter-spacing:0.4em;text-align:center;"
                   maxlength="6"
                   placeholder="000000"
                   @bind="_otpCode"
                   @bind:event="oninput"
                   disabled="@_otpBusy" />
        </div>

        @if (!string.IsNullOrEmpty(_otpError))
        {
            <div style="background:var(--mer-red-50);color:var(--mer-red);padding:8px 12px;border-radius:6px;font-size:12.5px;margin-bottom:12px;">@_otpError</div>
        }

        <div style="display:flex;justify-content:space-between;align-items:center;gap:12px;">
            <button class="rz-button rz-primary"
                    style="padding:10px 18px;border-radius:6px;border:0;color:#fff;cursor:pointer;font-weight:600;flex:1;"
                    @onclick="VerifyOtp"
                    disabled="@(_otpBusy || string.IsNullOrWhiteSpace(_otpCode) || _otpCode.Trim().Length != 6)">
                @(_otpBusy ? "Verifying…" : "Verify")
            </button>
            <button style="background:transparent;border:0;color:var(--mer-blue);cursor:@(_resendInSeconds > 0 || _otpBusy ? "default" : "pointer");font-size:12.5px;font-weight:600;@(_resendInSeconds > 0 || _otpBusy ? "opacity:0.5;" : "")"
                    @onclick="ResendOtp"
                    disabled="@(_resendInSeconds > 0 || _otpBusy)">
                @(_resendInSeconds > 0 ? $"Resend in {_resendInSeconds}s" : "Resend code")
            </button>
        </div>
    </div>
}
else
{
    <div class="rz-card" style="padding:24px;">
        <header style="margin-bottom:20px;">
            <div style="font-size:11px;font-weight:700;letter-spacing:0.12em;color:var(--mer-ink-500);text-transform:uppercase;">Supplier onboarding</div>
            <h1 style="margin:4px 0 4px;font-size:22px;color:var(--mer-blue-darker);">Register as a Merino supplier</h1>
            <p style="color:var(--mer-ink-500);font-size:13px;">Invited as <b>@invite.LegalName</b> · expires @invite.ExpiresAt.ToString("yyyy-MM-dd HH:mm")</p>
        </header>

        <div style="display:flex;gap:0;margin-bottom:24px;border-bottom:1px solid var(--mer-line);overflow-x:auto;">
            @for (int i = 1; i <= 6; i++)
            {
                var step = i;
                var active = currentStep == step;
                var done = currentStep > step;
                <div style="padding:10px 16px;font-size:13px;font-weight:600;border-bottom:3px solid @(active ? "var(--mer-blue)" : done ? "var(--mer-green)" : "transparent");color:@(active ? "var(--mer-blue)" : done ? "var(--mer-green)" : "var(--mer-ink-500)");cursor:pointer;white-space:nowrap;" @onclick="@(() => GoStep(step))">
                    @step. @StepLabel(step)
                </div>
            }
        </div>

        @if (currentStep == 1)
        {
            <h3 style="font-size:14px;font-weight:700;margin-bottom:12px;color:var(--mer-blue-darker);">Company details</h3>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                <div>
                    <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Legal name *</label>
                    <input class="rz-textbox @(Err("legalName") != null ? "reg-invalid" : "")" style="width:100%;padding:8px 10px;" @bind="legalName" @bind:after='@(() => Clear("legalName"))' />
                    @ErrChip("legalName")
                </div>
                <div>
                    <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Trade name</label>
                    <input class="rz-textbox" style="width:100%;padding:8px 10px;" @bind="tradeName" />
                </div>
                <div style="grid-column:1 / span 2;">
                    <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Supplier type *</label>
                    <div style="display:flex;gap:16px;margin-top:4px;">
                        @foreach (var t in new[] { "Material", "Service", "Both" })
                        {
                            <label style="display:flex;align-items:center;gap:6px;font-size:13px;cursor:pointer;">
                                <input type="radio" name="supplierType" value="@t" checked="@(supplierType == t)" @onchange='@(() => { supplierType = t; Clear("supplierType"); })' />
                                @t
                            </label>
                        }
                    </div>
                    @ErrChip("supplierType")
                </div>
                <div style="grid-column:1 / span 2;">
                    <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Website</label>
                    <input class="rz-textbox @(Err("website") != null ? "reg-invalid" : "")" style="width:100%;padding:8px 10px;" @bind="website" @bind:after='@(() => Clear("website"))' placeholder="https://example.com" />
                    @ErrChip("website")
                </div>
            </div>
        }
        else if (currentStep == 2)
        {
            <h3 style="font-size:14px;font-weight:700;margin-bottom:12px;color:var(--mer-blue-darker);">Statutory identifiers</h3>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                <div>
                    <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">GST number</label>
                    <input class="rz-textbox @(Err("gstNumber") != null ? "reg-invalid" : "")" style="width:100%;padding:8px 10px;font-family:Inter,monospace;text-transform:uppercase;" @bind="gstNumber" @bind:after='@(() => Clear("gstNumber"))' placeholder="15 chars, e.g. 27ABCDE1234F1Z5" />
                    @ErrChip("gstNumber")
                </div>
                <div>
                    <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">PAN number</label>
                    <input class="rz-textbox @(Err("panNumber") != null ? "reg-invalid" : "")" style="width:100%;padding:8px 10px;font-family:Inter,monospace;text-transform:uppercase;" @bind="panNumber" @bind:after='@(() => Clear("panNumber"))' placeholder="e.g. ABCDE1234F" />
                    @ErrChip("panNumber")
                </div>
                <div style="grid-column:1 / span 2;">
                    <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">MSME registration number</label>
                    <input class="rz-textbox @(Err("msmeNumber") != null ? "reg-invalid" : "")" style="width:100%;padding:8px 10px;font-family:Inter,monospace;" @bind="msmeNumber" @bind:after='@(() => Clear("msmeNumber"))' />
                    @ErrChip("msmeNumber")
                </div>
            </div>
        }
        else if (currentStep == 3)
        {
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
                <h3 style="font-size:14px;font-weight:700;color:var(--mer-blue-darker);">Addresses (@addresses.Count)</h3>
                <button class="rz-button" style="padding:6px 12px;border-radius:6px;border:1px solid var(--mer-ink-300);background:var(--mer-surface);cursor:pointer;font-size:12px;" @onclick="AddAddress">
                    <span class="material-symbols-outlined" style="font-size:14px;vertical-align:middle;">add</span> Add address
                </button>
            </div>
            @for (int i = 0; i < addresses.Count; i++)
            {
                var idx = i;
                var a = addresses[idx];
                // Pre-compute keys as locals so attribute values don't need nested $"..." inside double quotes.
                var kPostal  = AddrKey(idx, "postal");
                var kLine1   = AddrKey(idx, "line1");
                var kCity    = AddrKey(idx, "city");
                var kState   = AddrKey(idx, "state");
                var kCountry = AddrKey(idx, "country");
                <div style="border:1px solid var(--mer-line);border-radius:8px;padding:16px;margin-bottom:12px;background:var(--mer-ink-50);">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
                        <span style="font-size:12px;font-weight:700;color:var(--mer-blue-darker);">Address #@(idx + 1)</span>
                        @if (addresses.Count > 1)
                        {
                            <button @onclick="() => addresses.RemoveAt(idx)" style="background:transparent;border:0;color:var(--mer-red);cursor:pointer;">
                                <span class="material-symbols-outlined" style="font-size:18px;">delete</span>
                            </button>
                        }
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
                        <select class="rz-dropdown" style="padding:6px 10px;border:1px solid var(--mer-ink-300);border-radius:6px;background:var(--mer-surface);font-size:12px;" @bind="a.AddressType">
                            <option value="Registered">Registered</option>
                            <option value="Billing">Billing</option>
                            <option value="Shipping">Shipping</option>
                            <option value="Other">Other</option>
                        </select>
                        <div>
                            <input class="rz-textbox @(InvalidClass(kPostal))" style="padding:6px 10px;font-size:12px;width:100%;" placeholder="Postal code *" @bind="a.PostalCode" @bind:after="() => Clear(kPostal)" />
                            @ErrChip(kPostal)
                        </div>
                        <div style="grid-column:1 / span 2;">
                            <input class="rz-textbox @(InvalidClass(kLine1))" style="padding:6px 10px;font-size:12px;width:100%;" placeholder="Line 1 *" @bind="a.Line1" @bind:after="() => Clear(kLine1)" />
                            @ErrChip(kLine1)
                        </div>
                        <input class="rz-textbox" style="padding:6px 10px;font-size:12px;grid-column:1 / span 2;" placeholder="Line 2" @bind="a.Line2" />
                        <div>
                            <input class="rz-textbox @(InvalidClass(kCity))" style="padding:6px 10px;font-size:12px;width:100%;" placeholder="City *" @bind="a.City" @bind:after="() => Clear(kCity)" />
                            @ErrChip(kCity)
                        </div>
                        <div>
                            <input class="rz-textbox @(InvalidClass(kState))" style="padding:6px 10px;font-size:12px;width:100%;" placeholder="State *" @bind="a.State" @bind:after="() => Clear(kState)" />
                            @ErrChip(kState)
                        </div>
                        <div style="grid-column:1 / span 2;">
                            <input class="rz-textbox @(InvalidClass(kCountry))" style="padding:6px 10px;font-size:12px;width:100%;" placeholder="Country *" @bind="a.Country" @bind:after="() => Clear(kCountry)" />
                            @ErrChip(kCountry)
                        </div>
                    </div>
                </div>
            }
        }
        else if (currentStep == 4)
        {
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
                <h3 style="font-size:14px;font-weight:700;color:var(--mer-blue-darker);">Contacts (@contacts.Count)</h3>
                <button class="rz-button" style="padding:6px 12px;border-radius:6px;border:1px solid var(--mer-ink-300);background:var(--mer-surface);cursor:pointer;font-size:12px;" @onclick="AddContact">
                    <span class="material-symbols-outlined" style="font-size:14px;vertical-align:middle;">add</span> Add contact
                </button>
            </div>
            @for (int i = 0; i < contacts.Count; i++)
            {
                var idx = i;
                var c = contacts[idx];
                var kName  = ConKey(idx, "name");
                var kEmail = ConKey(idx, "email");
                var kPhone = ConKey(idx, "phone");
                <div style="border:1px solid var(--mer-line);border-radius:8px;padding:16px;margin-bottom:12px;background:var(--mer-ink-50);">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
                        <span style="font-size:12px;font-weight:700;color:var(--mer-blue-darker);">Contact #@(idx + 1)</span>
                        @if (contacts.Count > 1)
                        {
                            <button @onclick="() => contacts.RemoveAt(idx)" style="background:transparent;border:0;color:var(--mer-red);cursor:pointer;">
                                <span class="material-symbols-outlined" style="font-size:18px;">delete</span>
                            </button>
                        }
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
                        <div>
                            <input class="rz-textbox @(InvalidClass(kName))" style="padding:6px 10px;font-size:12px;width:100%;" placeholder="Name *" @bind="c.Name" @bind:after="() => Clear(kName)" />
                            @ErrChip(kName)
                        </div>
                        <input class="rz-textbox" style="padding:6px 10px;font-size:12px;" placeholder="Designation" @bind="c.Designation" />
                        <div>
                            <input class="rz-textbox @(InvalidClass(kEmail))" style="padding:6px 10px;font-size:12px;width:100%;" placeholder="Email *" @bind="c.Email" @bind:after="() => Clear(kEmail)" />
                            @ErrChip(kEmail)
                        </div>
                        <div>
                            <input class="rz-textbox @(InvalidClass(kPhone))" style="padding:6px 10px;font-size:12px;width:100%;" placeholder="Phone" @bind="c.Phone" @bind:after="() => Clear(kPhone)" />
                            @ErrChip(kPhone)
                        </div>
                        <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer;">
                            <input type="checkbox" checked="@c.IsPrimary" @onchange='@((ChangeEventArgs e) => { SetPrimary(idx, (bool)(e.Value ?? false)); Clear("con.primary"); })' />
                            Primary contact
                        </label>
                    </div>
                </div>
            }
            @ErrChip("con.primary")
        }
        else if (currentStep == 5)
        {
            <h3 style="font-size:14px;font-weight:700;margin-bottom:6px;color:var(--mer-blue-darker);">Onboarding documents</h3>
            <p style="color:var(--mer-ink-500);font-size:12.5px;margin-bottom:14px;">Upload the documents required to complete your onboarding. PAN card and cancelled cheque are always required. GST and MSME certificates are required when you have provided those numbers.</p>
            <DocumentUploader Token="@Token" Slots="@DocSlots" OnUploaded="OnDocUploaded" />
            @ErrChip("docs")
        }
        else if (currentStep == 6)
        {
            <h3 style="font-size:14px;font-weight:700;margin-bottom:12px;color:var(--mer-blue-darker);">Review and submit</h3>
            <dl style="display:grid;grid-template-columns:180px 1fr;gap:6px 16px;font-size:13px;">
                <dt style="color:var(--mer-ink-500);">Legal name</dt><dd>@legalName</dd>
                <dt style="color:var(--mer-ink-500);">Trade name</dt><dd>@tradeName</dd>
                <dt style="color:var(--mer-ink-500);">Supplier type</dt><dd>@supplierType</dd>
                <dt style="color:var(--mer-ink-500);">Website</dt><dd>@website</dd>
                <dt style="color:var(--mer-ink-500);">GST / PAN / MSME</dt><dd style="font-family:Inter,monospace;">@gstNumber · @panNumber · @msmeNumber</dd>
                <dt style="color:var(--mer-ink-500);">Addresses</dt><dd>@addresses.Count</dd>
                <dt style="color:var(--mer-ink-500);">Contacts</dt><dd>@contacts.Count (@(contacts.Count(c => c.IsPrimary)) primary)</dd>
                <dt style="color:var(--mer-ink-500);">Documents</dt>
                <dd>
                    @{
                        var uploaded = DocSlots.Count(s => s.File != null);
                        var total = DocSlots.Count;
                    }
                    @uploaded of @total uploaded
                </dd>
            </dl>
            @if (!string.IsNullOrEmpty(submitError))
            {
                <div style="background:var(--mer-red-50);color:var(--mer-red);padding:8px 12px;border-radius:6px;font-size:12px;margin-top:12px;">@submitError</div>
            }
        }

        <div style="display:flex;justify-content:space-between;margin-top:24px;padding-top:16px;border-top:1px solid var(--mer-line);">
            <button class="rz-button" style="padding:8px 14px;border-radius:6px;border:1px solid var(--mer-ink-300);background:var(--mer-surface);cursor:pointer;" @onclick="Prev" disabled="@(currentStep == 1)">Back</button>
            @if (currentStep < 6)
            {
                <button class="rz-button rz-primary" style="padding:8px 14px;border-radius:6px;border:0;color:#fff;cursor:pointer;" @onclick="Next">Next</button>
            }
            else
            {
                <button class="rz-button rz-secondary" style="padding:8px 14px;border-radius:6px;border:0;color:#fff;cursor:pointer;" @onclick="Submit" disabled="@busy">@(busy ? "Submitting…" : "Submit registration")</button>
            }
        </div>
    </div>
}

<style>
    .reg-invalid { border:1px solid var(--mer-red) !important; outline:0; }
    .reg-err { color:var(--mer-red); font-size:11px; margin-top:4px; line-height:1.3; }
</style>

@code {
    [Parameter] public string Token { get; set; } = string.Empty;
    private SupplierInviteDetailDto? invite;
    private bool loading = true;
    private bool busy = false;
    private bool registered = false;
    private int currentStep = 1;
    private string submitError = string.Empty;

    // Invite-OTP gate (in-memory only; page reload forces a fresh code entry by design).
    private bool _otpVerified;
    private bool _otpBusy;
    private string _otpCode = string.Empty;
    private string _otpError = string.Empty;
    private int _resendInSeconds;
    private System.Threading.Timer? _resendTimer;

    private string legalName = string.Empty;
    private string tradeName = string.Empty;
    private string supplierType = "Material";
    private string website = string.Empty;
    private string gstNumber = string.Empty;
    private string panNumber = string.Empty;
    private string msmeNumber = string.Empty;

    private List<AddressRow> addresses = new();
    private List<ContactRow> contacts = new();
    // DocSlot type lives in the shared DocumentUploader component; we reuse it via the type alias below.
    private List<DocumentUploader.DocSlot> DocSlots = new();

    private const long MaxFileBytes = 5 * 1024 * 1024; // 5 MB

    // ─── Per-step validation ────────────────────────────────────────────────
    //
    // Mirrors backend FluentValidation rules (CreateSupplierInviteCommandValidator +
    // RegisterSupplierCommandValidator) so the user sees errors at the offending step
    // instead of one big "submission failed" at the end. Map key conventions:
    //   legalName / supplierType / website / gstNumber / panNumber / msmeNumber
    //   addr.{idx}.{line1|city|state|country|postal}
    //   con.{idx}.{name|email|phone}
    //   con.primary  ← cross-row check
    //   docs         ← cross-slot check on step 5

    private readonly Dictionary<string, string> _err = new();

    // GST: 15 alphanumeric. Backend uses ^[0-9A-Z]{15}$.
    private static readonly Regex GstRegex = new("^[0-9A-Z]{15}$", RegexOptions.Compiled);
    // PAN: 5 letters + 4 digits + 1 letter.
    private static readonly Regex PanRegex = new("^[A-Z]{5}[0-9]{4}[A-Z]{1}$", RegexOptions.Compiled);
    // E.164-ish loose: optional + then 8-15 digits.
    private static readonly Regex PhoneRegex = new("^\\+?\\d{8,15}$", RegexOptions.Compiled);
    // Minimal sanity check for email; backend re-validates with proper EmailAddress rule.
    private static readonly Regex EmailRegex = new("^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$", RegexOptions.Compiled);
    // Postal code: digits, optional dash/space, 3-12 chars (loose — supports IN/UK/CA).
    private static readonly Regex PostalRegex = new("^[A-Za-z0-9][A-Za-z0-9 \\-]{2,11}$", RegexOptions.Compiled);

    private string? Err(string key) => _err.TryGetValue(key, out var v) ? v : null;
    private void Clear(string key) { _err.Remove(key); }
    private string InvalidClass(string key) => _err.ContainsKey(key) ? "reg-invalid" : string.Empty;
    private static string AddrKey(int idx, string field) => "addr." + idx + "." + field;
    private static string ConKey(int idx, string field) => "con." + idx + "." + field;
    private RenderFragment ErrChip(string key) => __builder =>
    {
        if (_err.TryGetValue(key, out var msg))
        {
            __builder.OpenElement(0, "div");
            __builder.AddAttribute(1, "class", "reg-err");
            __builder.AddContent(2, msg);
            __builder.CloseElement();
        }
    };

    private bool ValidateStep(int step)
    {
        switch (step)
        {
            case 1:
                if (string.IsNullOrWhiteSpace(legalName)) _err["legalName"] = "Legal name is required.";
                if (string.IsNullOrWhiteSpace(supplierType)) _err["supplierType"] = "Pick a supplier type.";
                if (!string.IsNullOrWhiteSpace(website) && !(website.StartsWith("http://") || website.StartsWith("https://")))
                    _err["website"] = "Website must start with http:// or https://.";
                break;

            case 2:
                if (!string.IsNullOrWhiteSpace(gstNumber) && !GstRegex.IsMatch(gstNumber.Trim().ToUpperInvariant()))
                    _err["gstNumber"] = "GST must be 15 alphanumeric characters (e.g. 27ABCDE1234F1Z5).";
                if (!string.IsNullOrWhiteSpace(panNumber) && !PanRegex.IsMatch(panNumber.Trim().ToUpperInvariant()))
                    _err["panNumber"] = "PAN must be 5 letters + 4 digits + 1 letter (e.g. ABCDE1234F).";
                if (!string.IsNullOrWhiteSpace(msmeNumber) && msmeNumber.Trim().Length > 50)
                    _err["msmeNumber"] = "MSME number too long (max 50 chars).";
                break;

            case 3:
                if (addresses.Count == 0)
                {
                    _err["addr.0.line1"] = "Add at least one address.";
                    break;
                }
                for (int i = 0; i < addresses.Count; i++)
                {
                    var a = addresses[i];
                    if (string.IsNullOrWhiteSpace(a.Line1)) _err[$"addr.{i}.line1"] = "Address line 1 required.";
                    if (string.IsNullOrWhiteSpace(a.City)) _err[$"addr.{i}.city"] = "City required.";
                    if (string.IsNullOrWhiteSpace(a.State)) _err[$"addr.{i}.state"] = "State required.";
                    if (string.IsNullOrWhiteSpace(a.Country)) _err[$"addr.{i}.country"] = "Country required.";
                    if (string.IsNullOrWhiteSpace(a.PostalCode)) _err[$"addr.{i}.postal"] = "Postal code required.";
                    else if (!PostalRegex.IsMatch(a.PostalCode.Trim())) _err[$"addr.{i}.postal"] = "Postal code looks invalid.";
                }
                break;

            case 4:
                if (contacts.Count == 0)
                {
                    _err["con.0.name"] = "Add at least one contact.";
                    break;
                }
                for (int i = 0; i < contacts.Count; i++)
                {
                    var c = contacts[i];
                    if (string.IsNullOrWhiteSpace(c.Name)) _err[$"con.{i}.name"] = "Contact name required.";
                    if (string.IsNullOrWhiteSpace(c.Email)) _err[$"con.{i}.email"] = "Email required.";
                    else if (!EmailRegex.IsMatch(c.Email.Trim())) _err[$"con.{i}.email"] = "Email format looks invalid.";
                    if (!string.IsNullOrWhiteSpace(c.Phone) && !PhoneRegex.IsMatch(c.Phone.Trim()))
                        _err[$"con.{i}.phone"] = "Phone must be 8–15 digits (optional leading +).";
                }
                if (!contacts.Any(c => c.IsPrimary)) _err["con.primary"] = "Mark exactly one contact as primary.";
                break;

            case 5:
                var missing = DocSlots.Where(s => s.Required && s.File == null).Select(s => s.Label).ToList();
                if (missing.Count > 0) _err["docs"] = "Upload required documents: " + string.Join(", ", missing) + ".";
                break;
        }
        return _err.Count == 0;
    }

    private void OnDocUploaded(MerinoOne.SupplierPortal.Contracts.SupplierRegistration.UploadedDocumentDto _) => Clear("docs");

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var resp = await Api.GetAsync<SupplierInviteDetailDto>($"api/supplier-registration/invites/by-token/{Token}");
            if (resp?.Success == true && resp.Data != null && resp.Data.Status == "Pending")
            {
                invite = resp.Data;
                legalName = invite.LegalName;
                addresses.Add(new AddressRow());
                contacts.Add(new ContactRow { Email = invite.Email, IsPrimary = true });
            }
        }
        catch
        {
            // invite stays null -> empty state
        }
        loading = false;
    }

    private async Task VerifyOtp()
    {
        _otpError = string.Empty;
        if (string.IsNullOrWhiteSpace(_otpCode) || _otpCode.Trim().Length != 6)
        {
            _otpError = "Enter the 6-digit code from your email.";
            return;
        }
        _otpBusy = true;
        try
        {
            var resp = await Api.PostAsync<VerifyInviteOtpResponse, VerifyInviteOtpRequest>(
                $"api/supplier-registration/invites/{Token}/verify-otp",
                new VerifyInviteOtpRequest(_otpCode.Trim()));

            if (resp?.Success == true && resp.Data?.Verified == true)
            {
                _otpVerified = true;
                _otpError = string.Empty;
            }
            else
            {
                var msg = resp?.Data?.Message ?? resp?.Errors?.FirstOrDefault();
                if (resp?.Data is { } d && string.IsNullOrEmpty(msg))
                {
                    msg = d.RemainingAttempts > 0
                        ? $"Invalid OTP — {d.RemainingAttempts} attempts left."
                        : "OTP not found, please resend.";
                }
                _otpError = msg ?? "Verification failed. Please try again.";
            }
        }
        catch (Exception ex)
        {
            _otpError = $"Verification failed: {ex.Message}";
        }
        finally
        {
            _otpBusy = false;
        }
    }

    private async Task ResendOtp()
    {
        if (_resendInSeconds > 0 || _otpBusy) return;
        _otpBusy = true;
        _otpError = string.Empty;
        try
        {
            var resp = await Api.PostAsync<ResendInviteOtpResponse, object>(
                $"api/supplier-registration/invites/{Token}/resend-otp",
                new { });

            if (resp?.Success == true && resp.Data?.Sent == true)
            {
                StartResendCountdown(resp.Data.RetryAfterSeconds > 0 ? resp.Data.RetryAfterSeconds : 60);
            }
            else
            {
                // Throttled or transient failure — parse cooldown from response/message and arm the timer anyway.
                var seconds = resp?.Data?.RetryAfterSeconds ?? 0;
                if (seconds <= 0)
                {
                    var msg = resp?.Data?.Message ?? resp?.Errors?.FirstOrDefault();
                    if (!string.IsNullOrEmpty(msg))
                    {
                        var m = Regex.Match(msg, "(\\d+)\\s*s");
                        if (m.Success && int.TryParse(m.Groups[1].Value, out var parsed)) seconds = parsed;
                    }
                }
                StartResendCountdown(seconds > 0 ? seconds : 60);
                _otpError = resp?.Data?.Message ?? resp?.Errors?.FirstOrDefault() ?? "Could not resend code. Please wait and try again.";
            }
        }
        catch (Exception ex)
        {
            _otpError = $"Could not resend code: {ex.Message}";
            StartResendCountdown(60);
        }
        finally
        {
            _otpBusy = false;
        }
    }

    private void StartResendCountdown(int seconds)
    {
        _resendTimer?.Dispose();
        _resendInSeconds = seconds;
        _resendTimer = new System.Threading.Timer(async _ =>
        {
            _resendInSeconds--;
            if (_resendInSeconds <= 0)
            {
                _resendInSeconds = 0;
                _resendTimer?.Dispose();
                _resendTimer = null;
            }
            await InvokeAsync(StateHasChanged);
        }, null, 1000, 1000);
    }

    public void Dispose()
    {
        _resendTimer?.Dispose();
        _resendTimer = null;
    }

    private void GoStep(int s) { if (s <= currentStep) currentStep = s; }
    private void Prev() { if (currentStep > 1) currentStep--; }

    private void Next()
    {
        if (currentStep >= 6) return;
        _err.Clear();
        if (!ValidateStep(currentStep)) return; // errors now in _err — render will show chips
        // Build the document slot list when entering step 5.
        if (currentStep == 4)
        {
            RebuildDocSlots();
        }
        currentStep++;
    }

    private void RebuildDocSlots()
    {
        // Preserve already-uploaded files for slots that survive a step transition.
        var existing = DocSlots.ToDictionary(s => s.DocumentType, s => s);
        DocSlots = new List<DocumentUploader.DocSlot>
        {
            BuildSlot(existing, "OnboardingPan",    "PAN card",          "id_card",     true,                                "PDF / JPG / PNG — up to 5 MB"),
            BuildSlot(existing, "OnboardingCheque", "Cancelled cheque",  "account_balance", true,                            "PDF / JPG / PNG — up to 5 MB"),
        };
        if (!string.IsNullOrWhiteSpace(gstNumber))
        {
            DocSlots.Add(BuildSlot(existing, "OnboardingGst", "GST certificate", "verified", true, "Required because you entered a GST number"));
        }
        if (!string.IsNullOrWhiteSpace(msmeNumber))
        {
            DocSlots.Add(BuildSlot(existing, "OnboardingMsme", "MSME certificate", "workspace_premium", true, "Required because you entered an MSME number"));
        }
    }

    private static DocumentUploader.DocSlot BuildSlot(Dictionary<string, DocumentUploader.DocSlot> existing, string type, string label, string icon, bool required, string hint)
    {
        if (existing.TryGetValue(type, out var prior)) return prior;
        return new DocumentUploader.DocSlot { DocumentType = type, Label = label, Icon = icon, Required = required, Hint = hint };
    }

    private string StepLabel(int s) => s switch
    {
        1 => "Company",
        2 => "Statutory",
        3 => "Addresses",
        4 => "Contacts",
        5 => "Documents",
        6 => "Review",
        _ => ""
    };

    private void AddAddress() => addresses.Add(new AddressRow { AddressType = "Billing" });
    private void AddContact() => contacts.Add(new ContactRow());

    private void SetPrimary(int idx, bool on)
    {
        if (on)
        {
            for (int i = 0; i < contacts.Count; i++) contacts[i].IsPrimary = (i == idx);
        }
        else
        {
            contacts[idx].IsPrimary = false;
        }
    }

    private async Task Submit()
    {
        busy = true;
        submitError = string.Empty;

        // Construct a hybrid payload: positional record fields + documents[] added as anonymous extension.
        // Posting as anonymous object so we can include `documents` alongside the existing contract.
        var payload = new
        {
            token = Token,
            legalName = legalName.Trim(),
            tradeName = string.IsNullOrWhiteSpace(tradeName) ? null : tradeName.Trim(),
            supplierType = supplierType,
            gstNumber = string.IsNullOrWhiteSpace(gstNumber) ? null : gstNumber.Trim(),
            panNumber = string.IsNullOrWhiteSpace(panNumber) ? null : panNumber.Trim(),
            msmeRegNumber = string.IsNullOrWhiteSpace(msmeNumber) ? null : msmeNumber.Trim(),
            website = string.IsNullOrWhiteSpace(website) ? null : website.Trim(),
            addresses = addresses.Select(a => new
            {
                addressType = a.AddressType,
                line1 = a.Line1.Trim(),
                line2 = string.IsNullOrWhiteSpace(a.Line2) ? null : a.Line2.Trim(),
                city = a.City.Trim(),
                state = a.State.Trim(),
                postalCode = a.PostalCode.Trim(),
                country = a.Country.Trim()
            }).ToList(),
            contacts = contacts.Select(c => new
            {
                name = c.Name.Trim(),
                designation = string.IsNullOrWhiteSpace(c.Designation) ? null : c.Designation.Trim(),
                email = c.Email.Trim(),
                phone = string.IsNullOrWhiteSpace(c.Phone) ? null : c.Phone.Trim(),
                isPrimary = c.IsPrimary
            }).ToList(),
            documents = DocSlots.Where(s => s.File != null).Select(s => new
            {
                id = s.File!.Id,
                documentType = s.DocumentType,
                fileName = s.File.FileName,
                fileUrl = s.File.FileUrl,
                fileSizeKb = s.File.FileSizeKb,
                mimeType = s.File.MimeType
            }).ToList()
        };

        try
        {
            var resp = await Api.PostAsync<SupplierRegistrationResponse, object>("api/supplier-registration/register", payload);
            if (resp?.Success == true)
            {
                registered = true;
            }
            else
            {
                submitError = resp?.Errors?.FirstOrDefault() ?? "Registration failed. Please try again.";
            }
        }
        catch (Exception ex)
        {
            submitError = $"Network error: {ex.Message}";
        }
        busy = false;
    }

    private class AddressRow
    {
        public string AddressType { get; set; } = "Registered";
        public string Line1 { get; set; } = string.Empty;
        public string? Line2 { get; set; }
        public string City { get; set; } = string.Empty;
        public string State { get; set; } = string.Empty;
        public string PostalCode { get; set; } = string.Empty;
        public string Country { get; set; } = "India";
    }

    private class ContactRow
    {
        public string Name { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string? Phone { get; set; }
        public string? Designation { get; set; }
        public bool IsPrimary { get; set; }
    }

