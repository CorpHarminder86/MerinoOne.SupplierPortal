@page "/delivery-schedules"
@inject ApiClient Api
@inject TokenAccessor Token
@inject NotificationService Notif

<PageTitle>Delivery Schedules</PageTitle>

<div class="tl-page">
    <header class="tl-header">
        <div>
            <div class="tl-title-row">
                <h1 class="tl-title">Delivery Schedules</h1>
                <span class="tl-count-chip">@(paged?.TotalCount ?? 0)</span>
            </div>
            <p class="tl-sub">Supplier-proposed delivery windows</p>
        </div>
    </header>

    <div class="tl-filter-bar" style="display:flex;gap:8px;align-items:center;">
        <select class="rz-dropdown" style="padding:8px 12px;border:1px solid var(--mer-ink-300);border-radius:6px;background:var(--mer-surface);" @bind="statusFilter" @bind:after="Reload">
            <option value="">All statuses</option>
            <option value="Proposed">Proposed</option>
            <option value="Approved">Approved</option>
            <option value="Rejected">Rejected</option>
            <option value="Cancelled">Cancelled</option>
        </select>
    </div>

    @if (loading)
    {
        <div class="tl-empty">Loading…</div>
    }
    else if (paged == null || paged.Items.Count == 0)
    {
        <div class="tl-empty">
            <span class="material-symbols-outlined" style="font-size:32px;">event</span>
            <div>No delivery schedules.</div>
        </div>
    }
    else
    {
        <div class="tl-grid-wrapper" style="--tl-cols: 140px 1.5fr 140px 140px 130px 140px; --tl-min-width: 1000px;">
            <div class="tlg-header">
                <div class="tlg-col">PO #</div>
                <div class="tlg-col">Supplier</div>
                <div class="tlg-col">Proposed</div>
                <div class="tlg-col">Window</div>
                <div class="tlg-col">Status</div>
                <div class="tlg-col">Actions</div>
            </div>
            @foreach (var s in paged.Items)
            {
                <div class="tlg-row">
                    <div class="tlg-col tlg-code">@s.PoNumber</div>
                    <div class="tlg-col tlg-name">@s.SupplierName</div>
                    <div class="tlg-col tlg-code">@s.ProposedDate.ToString("yyyy-MM-dd")</div>
                    <div class="tlg-col">@s.TimeWindow</div>
                    <div class="tlg-col"><span class="tlg-status @StatusClass(s.ScheduleStatus)">@s.ScheduleStatus</span></div>
                    <div class="tlg-col">
                        @if (Token.HasPermission("DeliverySchedule.Approve") && s.ScheduleStatus == "Proposed")
                        {
                            <button class="rz-button rz-secondary" style="padding:4px 8px;border-radius:4px;border:0;color:#fff;cursor:pointer;font-size:11px;margin-right:4px;" @onclick="() => OpenApprove(s.Id)">Approve</button>
                            <button class="rz-button" style="padding:4px 8px;border-radius:4px;border:1px solid var(--mer-red);background:var(--mer-surface);color:var(--mer-red);cursor:pointer;font-size:11px;" @onclick="() => OpenReject(s.Id)">Reject</button>
                        }
                    </div>
                </div>
            }
        </div>

        <Pager Page="page" PageSize="PageSize" TotalCount="paged.TotalCount" PageChanged="OnPageChanged" />
    }
</div>

@if (showApprove && activeId.HasValue)
{
    <div style="position:fixed;inset:0;background:var(--mer-modal-backdrop);display:flex;align-items:center;justify-content:center;z-index:1000;">
        <div class="merino-dialog" data-variant="success" style="width:500px;">
            <div class="merino-dialog__accent"></div>
            <header class="merino-dialog__header">
                <div class="merino-dialog__icon merino-dialog__icon--success"><span class="material-symbols-outlined">event_available</span></div>
                <div class="merino-dialog__head-text">
                    <div class="merino-dialog__eyebrow">Delivery schedule</div>
                    <h2 class="merino-dialog__title">Approve schedule?</h2>
                </div>
                <button class="merino-dialog__close" @onclick="() => showApprove = false"><span class="material-symbols-outlined">close</span></button>
            </header>
            <div class="merino-dialog__body">
                <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Comment (optional)</label>
                <textarea class="rz-textbox" rows="3" style="width:100%;padding:8px 10px;font-family:inherit;" @bind="dialogText"></textarea>
                @if (!string.IsNullOrEmpty(dialogError)) { <div style="background:var(--mer-red-50);color:var(--mer-red);padding:8px 12px;border-radius:6px;font-size:12px;margin-top:8px;">@dialogError</div> }
            </div>
            <footer class="merino-dialog__footer">
                <div class="merino-dialog__actions">
                    <button class="merino-dialog__btn" data-intent="ghost" @onclick="() => showApprove = false">Cancel</button>
                    <button class="merino-dialog__btn" data-intent="primary" @onclick="DoApprove" disabled="@busy">@(busy ? "Working…" : "Approve")</button>
                </div>
            </footer>
        </div>
    </div>
}

@if (showReject && activeId.HasValue)
{
    <div style="position:fixed;inset:0;background:var(--mer-modal-backdrop);display:flex;align-items:center;justify-content:center;z-index:1000;">
        <div class="merino-dialog" data-variant="danger" style="width:500px;">
            <div class="merino-dialog__accent"></div>
            <header class="merino-dialog__header">
                <div class="merino-dialog__icon merino-dialog__icon--danger"><span class="material-symbols-outlined">cancel</span></div>
                <div class="merino-dialog__head-text">
                    <div class="merino-dialog__eyebrow">Delivery schedule</div>
                    <h2 class="merino-dialog__title">Reject schedule</h2>
                </div>
                <button class="merino-dialog__close" @onclick="() => showReject = false"><span class="material-symbols-outlined">close</span></button>
            </header>
            <div class="merino-dialog__body">
                <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Reason (required)</label>
                <textarea class="rz-textbox" rows="4" style="width:100%;padding:8px 10px;font-family:inherit;" @bind="dialogText"></textarea>
                @if (!string.IsNullOrEmpty(dialogError)) { <div style="background:var(--mer-red-50);color:var(--mer-red);padding:8px 12px;border-radius:6px;font-size:12px;margin-top:8px;">@dialogError</div> }
            </div>
            <footer class="merino-dialog__footer">
                <div class="merino-dialog__actions">
                    <button class="merino-dialog__btn" data-intent="ghost" @onclick="() => showReject = false">Cancel</button>
                    <button class="merino-dialog__btn" data-intent="danger" @onclick="DoReject" disabled="@busy">@(busy ? "Working…" : "Reject")</button>
                </div>
            </footer>
        </div>
    </div>
}

@code {
    private PagedResult<DeliveryScheduleListItemDto>? paged;
    private bool loading = true;
    private bool busy = false;
    private bool showApprove = false;
    private bool showReject = false;
    private Guid? activeId;
    private string dialogText = string.Empty;
    private string dialogError = string.Empty;
    private string statusFilter = string.Empty;
    private int page = 1;
    private const int PageSize = 50;

    protected override async Task OnInitializedAsync() => await Reload();

    private async Task Reload()
    {
        loading = true;
        var url = $"api/delivery-schedules?page={page}&pageSize={PageSize}";
        if (!string.IsNullOrWhiteSpace(statusFilter)) url += $"&status={Uri.EscapeDataString(statusFilter)}";
        var resp = await Api.GetAsync<PagedResult<DeliveryScheduleListItemDto>>(url);
        paged = resp?.Data;
        loading = false;
    }

    private async Task OnPageChanged(int newPage) { page = newPage; await Reload(); }

    private void OpenApprove(Guid id) { activeId = id; dialogText = string.Empty; dialogError = string.Empty; showApprove = true; }
    private void OpenReject(Guid id) { activeId = id; dialogText = string.Empty; dialogError = string.Empty; showReject = true; }

    private async Task DoApprove()
    {
        if (!activeId.HasValue) return;
        busy = true; dialogError = string.Empty;
        var resp = await Api.PostAsync<DeliveryScheduleListItemDto, ApproveScheduleRequest>($"api/delivery-schedules/{activeId}/approve", new ApproveScheduleRequest(string.IsNullOrWhiteSpace(dialogText) ? null : dialogText));
        if (resp?.Success == true) { Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Approved" }); showApprove = false; await Reload(); }
        else { dialogError = resp?.Errors?.FirstOrDefault() ?? "Failed."; }
        busy = false;
    }

    private async Task DoReject()
    {
        if (!activeId.HasValue) return;
        if (string.IsNullOrWhiteSpace(dialogText)) { dialogError = "Reason is required."; return; }
        busy = true; dialogError = string.Empty;
        var resp = await Api.PostAsync<DeliveryScheduleListItemDto, RejectScheduleRequest>($"api/delivery-schedules/{activeId}/reject", new RejectScheduleRequest(dialogText));
        if (resp?.Success == true) { Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Warning, Summary = "Rejected" }); showReject = false; await Reload(); }
        else { dialogError = resp?.Errors?.FirstOrDefault() ?? "Failed."; }
        busy = false;
    }

    private string StatusClass(string status) => status switch
    {
        "Approved" => "tlg-status--active",
        "Proposed" => "tlg-status--pending",
        "Rejected" or "Cancelled" => "tlg-status--danger",
        _ => "tlg-status--info"
    };
}
