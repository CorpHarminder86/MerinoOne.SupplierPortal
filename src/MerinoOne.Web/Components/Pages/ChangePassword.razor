@page "/change-password"
@inject ApiClient Api
@inject TokenAccessor Token
@inject NavigationManager Nav

<PageTitle>Change password</PageTitle>

<div class="mer-page" style="max-width:480px;margin:0 auto;padding-top:40px;">
    <div class="rz-card" style="padding:24px;">
        <h2 style="color:var(--mer-blue-darker);font-size:20px;margin-bottom:6px;">Change your password</h2>
        @if (Token.MustChangePassword)
        {
            <p style="color:var(--mer-amber-800);background:var(--mer-amber-50);padding:8px 12px;border-radius:6px;font-size:12.5px;margin-bottom:16px;">
                <span class="material-symbols-outlined" style="font-size:14px;vertical-align:middle;">warning</span>
                You must change your initial password before continuing.
            </p>
        }
        else
        {
            <p style="color:var(--mer-ink-500);font-size:13px;margin-bottom:16px;">Update the password on your account.</p>
        }

        <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Current password</label>
        <input type="password" class="rz-textbox" style="width:100%;height:38px;padding:6px 10px;margin-bottom:12px;" @bind="currentPw" />

        <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">New password</label>
        <input type="password" class="rz-textbox" style="width:100%;height:38px;padding:6px 10px;margin-bottom:12px;" @bind="newPw" />

        <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Confirm new password</label>
        <input type="password" class="rz-textbox" style="width:100%;height:38px;padding:6px 10px;margin-bottom:12px;" @bind="confirmPw" />

        @if (!string.IsNullOrEmpty(error))
        {
            <div style="background:var(--mer-red-50);color:var(--mer-red);padding:8px 12px;border-radius:6px;font-size:12px;margin-bottom:12px;">@error</div>
        }
        @if (!string.IsNullOrEmpty(success))
        {
            <div style="background:var(--mer-green-50);color:var(--mer-green-700);padding:8px 12px;border-radius:6px;font-size:12px;margin-bottom:12px;">@success</div>
        }

        <div style="display:flex;justify-content:flex-end;gap:8px;">
            @if (!Token.MustChangePassword)
            {
                <button class="rz-button" @onclick="Cancel">Cancel</button>
            }
            <button class="rz-button rz-primary" disabled="@busy" @onclick="Submit">@(busy ? "Saving…" : "Update password")</button>
        </div>
    </div>
</div>

@code {
    private string currentPw = string.Empty, newPw = string.Empty, confirmPw = string.Empty;
    private string error = string.Empty, success = string.Empty;
    private bool busy = false;

    private async Task Submit()
    {
        error = success = string.Empty; busy = true;
        if (string.IsNullOrEmpty(currentPw) || newPw.Length < 8) { error = "New password must be at least 8 characters."; busy = false; return; }
        if (newPw != confirmPw) { error = "New passwords don't match."; busy = false; return; }
        if (newPw == currentPw) { error = "New password must differ from current."; busy = false; return; }
        var resp = await Api.PostAsync("api/users/me/change-password", new { currentPassword = currentPw, newPassword = newPw });
        if (resp?.Success == true)
        {
            Token.MustChangePassword = false;
            success = "Password updated. Redirecting…";
            await Task.Delay(900);
            Nav.NavigateTo("/", forceLoad: false);
        }
        else { error = resp?.Errors?.FirstOrDefault() ?? "Update failed."; }
        busy = false;
    }

    private void Cancel() => Nav.NavigateTo("/");
}
