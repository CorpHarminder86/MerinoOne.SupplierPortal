@page "/admin/units"
@inject ApiClient Api
@inject TokenAccessor Token
@inject NotificationService Notif
@inject DialogService Dialog

<PageTitle>Units</PageTitle>

<div class="tl-page">
    <header class="tl-header">
        <div>
            <div class="tl-title-row"><h1 class="tl-title">Units</h1><span class="tl-count-chip">@(rows?.Count ?? 0)</span></div>
            <p class="tl-sub">Unit of measure master (Infor LN)</p>
        </div>
        <div class="tl-header__actions">
            @if (Token.HasPermission("Settings.Write"))
            {
                <button class="rz-button rz-primary" style="padding:8px 14px;border-radius:6px;border:0;color:#fff;cursor:pointer;" @onclick="OpenNew"><span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">add</span> Add</button>
            }
        </div>
    </header>

    @if (loading) { <div class="tl-empty">Loading…</div> }
    else if (rows == null || rows.Count == 0)
    {
        <div class="tl-empty"><span class="material-symbols-outlined" style="font-size:32px;">straighten</span><div>No units defined.</div></div>
    }
    else
    {
        <div class="tl-grid-wrapper" style="--tl-cols: 100px 1.3fr 100px 80px 110px 90px 110px; --tl-min-width: 900px;">
            <div class="tlg-header">
                <div class="tlg-col">Code</div><div class="tlg-col">Description</div><div class="tlg-col">Type</div><div class="tlg-col">ISO</div><div class="tlg-col tlg-col--num">Conv→base</div><div class="tlg-col">Active</div><div class="tlg-col tlg-col--actions">Actions</div>
            </div>
            @foreach (var r in rows)
            {
                <div class="tlg-row">
                    <div class="tlg-col tlg-code">@r.Code</div>
                    <div class="tlg-col tlg-desc">@r.Description</div>
                    <div class="tlg-col">@r.UnitType</div>
                    <div class="tlg-col tlg-code">@r.IsoCode</div>
                    <div class="tlg-col tlg-col--num">@r.ConversionFactor @(r.BaseUnitCode is null ? "(base)" : $"→ {r.BaseUnitCode}")</div>
                    <div class="tlg-col"><span class="tlg-status @(r.IsActive ? "tlg-status--active" : "tlg-status--danger")">@(r.IsActive ? "Yes" : "No")</span></div>
                    <div class="tlg-col tlg-col--actions">
                        @if (Token.HasPermission("Settings.Write"))
                        {
                            <button @onclick="() => OpenEdit(r)" style="background:transparent;border:0;color:var(--mer-blue);cursor:pointer;" title="Edit"><span class="material-symbols-outlined" style="font-size:18px;">edit</span></button>
                            @if (r.IsActive) { <button @onclick="() => Deactivate(r.Id, r.Code)" style="background:transparent;border:0;color:var(--mer-red);cursor:pointer;" title="Deactivate"><span class="material-symbols-outlined" style="font-size:18px;">block</span></button> }
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (showDialog)
{
    <div style="position:fixed;inset:0;background:var(--mer-modal-backdrop);display:flex;align-items:center;justify-content:center;z-index:1000;">
        <div class="merino-dialog" data-variant="info" style="width:560px;">
            <div class="merino-dialog__accent"></div>
            <header class="merino-dialog__header">
                <div class="merino-dialog__icon merino-dialog__icon--info"><span class="material-symbols-outlined">straighten</span></div>
                <div class="merino-dialog__head-text"><div class="merino-dialog__eyebrow">Master</div><h2 class="merino-dialog__title">@(editingId.HasValue ? "Edit unit" : "New unit")</h2></div>
                <button class="merino-dialog__close" @onclick="() => showDialog = false"><span class="material-symbols-outlined">close</span></button>
            </header>
            <div class="merino-dialog__body">
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                    <div><label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Code @(editingId.HasValue ? "(immutable)" : "*")</label><input class="rz-textbox" style="width:100%;padding:8px 10px;font-family:Inter,monospace;" @bind="formCode" disabled="@editingId.HasValue" /></div>
                    <div><label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">ISO code</label><input class="rz-textbox" style="width:100%;padding:8px 10px;font-family:Inter,monospace;" @bind="formIso" placeholder="KGM / MTR" /></div>
                    <div style="grid-column:1 / span 2;"><label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Description *</label><input class="rz-textbox" style="width:100%;padding:8px 10px;" @bind="formDescription" /></div>
                    <div><label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Type</label>
                        <select class="rz-dropdown" style="width:100%;padding:8px 10px;" @bind="formUnitType">
                            @foreach (var t in UnitTypes) { <option value="@t">@t</option> }
                        </select>
                    </div>
                    <div><label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Decimal places</label><input type="number" class="rz-textbox" style="width:100%;padding:8px 10px;" @bind="formDecimals" /></div>
                    <div><label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Conversion factor</label><input type="number" step="any" class="rz-textbox" style="width:100%;padding:8px 10px;" @bind="formFactor" /></div>
                    <div><label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Base unit</label>
                        <select class="rz-dropdown" style="width:100%;padding:8px 10px;" @bind="formBaseUnitId">
                            <option value="">— is a base unit —</option>
                            @foreach (var u in rows ?? new()) { @if (!editingId.HasValue || u.Id != editingId) { <option value="@u.Id">@u.Code — @u.Description</option> } }
                        </select>
                    </div>
                    <label style="display:flex;align-items:center;gap:8px;font-size:13px;cursor:pointer;grid-column:1 / span 2;"><input type="checkbox" @bind="formIsActive" /> Active</label>
                </div>
                @if (!string.IsNullOrEmpty(formError)) { <div style="background:var(--mer-red-50);color:var(--mer-red);padding:8px 12px;border-radius:6px;font-size:12px;margin-top:8px;">@formError</div> }
            </div>
            <footer class="merino-dialog__footer">
                <div class="merino-dialog__actions">
                    <button class="merino-dialog__btn" data-intent="ghost" @onclick="() => showDialog = false">Cancel</button>
                    <button class="merino-dialog__btn" data-intent="primary" @onclick="Save" disabled="@busy">@(busy ? "Saving…" : "Save")</button>
                </div>
            </footer>
        </div>
    </div>
}

@code {
    private static readonly string[] UnitTypes = { "Quantity", "Length", "Area", "Volume", "Mass", "Time", "Other" };
    private List<UnitDto>? rows;
    private bool loading = true, busy, showDialog, formIsActive = true;
    private Guid? editingId;
    private string formCode = string.Empty, formDescription = string.Empty, formError = string.Empty, formUnitType = "Quantity", formBaseUnitId = string.Empty;
    private string? formIso;
    private int formDecimals = 2;
    private decimal formFactor = 1m;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load() { loading = true; var resp = await Api.GetAsync<List<UnitDto>>("api/masters/units"); rows = resp?.Data ?? new(); loading = false; }

    private void OpenNew() { editingId = null; formCode = ""; formDescription = ""; formIso = null; formUnitType = "Quantity"; formDecimals = 2; formFactor = 1m; formBaseUnitId = ""; formIsActive = true; formError = ""; showDialog = true; }
    private void OpenEdit(UnitDto r) { editingId = r.Id; formCode = r.Code; formDescription = r.Description; formIso = r.IsoCode; formUnitType = r.UnitType; formDecimals = r.DecimalPlaces; formFactor = r.ConversionFactor; formBaseUnitId = r.BaseUnitId?.ToString() ?? ""; formIsActive = r.IsActive; formError = ""; showDialog = true; }

    private async Task Save()
    {
        if (!editingId.HasValue && string.IsNullOrWhiteSpace(formCode)) { formError = "Code required."; return; }
        if (string.IsNullOrWhiteSpace(formDescription)) { formError = "Description required."; return; }
        if (formFactor <= 0) { formError = "Conversion factor must be > 0."; return; }
        busy = true;
        var iso = string.IsNullOrWhiteSpace(formIso) ? null : formIso!.Trim();
        Guid? baseId = Guid.TryParse(formBaseUnitId, out var b) ? b : null;
        ApiResult<UnitDto>? resp;
        if (editingId.HasValue)
            resp = await Api.PutAsync<UnitDto, UpdateUnitRequest>($"api/masters/units/{editingId}", new UpdateUnitRequest(formDescription.Trim(), formUnitType, iso, formDecimals, formFactor, baseId, formIsActive));
        else
            resp = await Api.PostAsync<UnitDto, CreateUnitRequest>("api/masters/units", new CreateUnitRequest(formCode.Trim(), formDescription.Trim(), formUnitType, iso, formDecimals, formFactor, baseId, formIsActive));
        if (resp?.Success == true) { Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Saved" }); showDialog = false; await Load(); }
        else { formError = resp?.Errors?.FirstOrDefault() ?? "Failed."; }
        busy = false;
    }

    private async Task Deactivate(Guid id, string label)
    {
        if (!await Dialog.ConfirmDeactivateAsync(label, "UNIT")) return;
        busy = true;
        var resp = await Api.PostAsync<object>($"api/masters/units/{id}/deactivate", new { });
        if (resp?.Success == true) { Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Deactivated" }); await Load(); }
        else { Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Failed", Detail = resp?.Errors?.FirstOrDefault() ?? "" }); }
        busy = false;
    }
}
