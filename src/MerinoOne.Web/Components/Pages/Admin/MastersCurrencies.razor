@page "/admin/currencies"
@inject ApiClient Api
@inject TokenAccessor Token
@inject NotificationService Notif
@inject DialogService Dialog

<PageTitle>Currencies</PageTitle>

<div class="tl-page">
    <header class="tl-header">
        <div>
            <div class="tl-title-row"><h1 class="tl-title">Currencies</h1><span class="tl-count-chip">@(rows?.Count ?? 0)</span></div>
            <p class="tl-sub">Currency master (Infor LN)</p>
        </div>
        <div class="tl-header__actions">
            @if (Token.HasPermission("Settings.Write"))
            {
                <button class="mbtn mbtn--primary" @onclick="OpenNew"><span class="material-symbols-outlined">add</span> Add</button>
            }
        </div>
    </header>

    @if (loading) { <div class="tl-empty">Loading…</div> }
    else if (rows == null || rows.Count == 0)
    {
        <div class="tl-empty"><span class="material-symbols-outlined" style="font-size:32px;">payments</span><div>No currencies defined.</div></div>
    }
    else
    {
        <div class="tl-grid-wrapper" style="--tl-cols: 110px 1.4fr 90px 70px 90px 150px; --tl-min-width: 840px;">
            <div class="tlg-header">
                <div class="tlg-col">Code</div><div class="tlg-col">Description</div><div class="tlg-col">ISO</div><div class="tlg-col">Symbol</div><div class="tlg-col">Active</div><div class="tlg-col tlg-col--actions">Actions</div>
            </div>
            @foreach (var r in rows)
            {
                <div class="tlg-row">
                    <div class="tlg-col tlg-code">@r.Code</div>
                    <div class="tlg-col tlg-desc">@r.Description</div>
                    <div class="tlg-col tlg-code">@r.IsoCode</div>
                    <div class="tlg-col">@r.Symbol</div>
                    <div class="tlg-col"><span class="tlg-status @(r.IsActive ? "tlg-status--active" : "tlg-status--danger")">@(r.IsActive ? "Yes" : "No")</span></div>
                    <div class="tlg-col tlg-col--actions">
                        @if (Token.HasPermission("Settings.Write"))
                        {
                            <button class="mbtn mbtn--row mbtn--accent" @onclick="() => OpenEdit(r)" title="Edit"><span class="material-symbols-outlined">edit</span> Edit</button>
                            @if (r.IsActive) { <button class="mbtn mbtn--row mbtn--danger" @onclick="() => Deactivate(r.Id, r.Code)" title="Deactivate"><span class="material-symbols-outlined">block</span> Off</button> }
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (showDialog)
{
    <div style="position:fixed;inset:0;background:var(--mer-modal-backdrop);display:flex;align-items:center;justify-content:center;z-index:1000;">
        <div class="merino-dialog" data-variant="info" style="width:500px;">
            <div class="merino-dialog__accent"></div>
            <header class="merino-dialog__header">
                <div class="merino-dialog__icon merino-dialog__icon--info"><span class="material-symbols-outlined">payments</span></div>
                <div class="merino-dialog__head-text"><div class="merino-dialog__eyebrow">Master</div><h2 class="merino-dialog__title">@(editingId.HasValue ? "Edit currency" : "New currency")</h2></div>
                <button class="merino-dialog__close" @onclick="() => showDialog = false"><span class="material-symbols-outlined">close</span></button>
            </header>
            <div class="merino-dialog__body">
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                    <div style="grid-column:1 / span 2;"><label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Code @(editingId.HasValue ? "(immutable)" : "*")</label><input class="rz-textbox" style="width:100%;padding:8px 10px;font-family:Inter,monospace;" @bind="formCode" disabled="@editingId.HasValue" /></div>
                    <div style="grid-column:1 / span 2;"><label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Description *</label><input class="rz-textbox" style="width:100%;padding:8px 10px;" @bind="formDescription" /></div>
                    <div><label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">ISO code</label><input class="rz-textbox" style="width:100%;padding:8px 10px;font-family:Inter,monospace;" @bind="formIso" maxlength="3" /></div>
                    <div><label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Symbol</label><input class="rz-textbox" style="width:100%;padding:8px 10px;" @bind="formSymbol" /></div>
                    <div><label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Decimal places</label><input type="number" class="rz-textbox" style="width:100%;padding:8px 10px;" @bind="formDecimals" /></div>
                    <label style="display:flex;align-items:center;gap:8px;font-size:13px;cursor:pointer;"><input type="checkbox" @bind="formIsActive" /> Active</label>
                </div>
                @if (!string.IsNullOrEmpty(formError)) { <div style="background:var(--mer-red-50);color:var(--mer-red);padding:8px 12px;border-radius:6px;font-size:12px;margin-top:8px;">@formError</div> }
            </div>
            <footer class="merino-dialog__footer">
                <div class="merino-dialog__actions">
                    <button class="merino-dialog__btn" data-intent="ghost" @onclick="() => showDialog = false">Cancel</button>
                    <button class="merino-dialog__btn" data-intent="primary" @onclick="Save" disabled="@busy">@(busy ? "Saving…" : "Save")</button>
                </div>
            </footer>
        </div>
    </div>
}

@code {
    private List<CurrencyDto>? rows;
    private bool loading = true, busy, showDialog, formIsActive = true;
    private Guid? editingId;
    private string formCode = string.Empty, formDescription = string.Empty, formError = string.Empty;
    private string? formIso, formSymbol;
    private int formDecimals = 2;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load() { loading = true; var resp = await Api.GetAsync<List<CurrencyDto>>("api/masters/currencies"); rows = resp?.Data ?? new(); loading = false; }

    private void OpenNew() { editingId = null; formCode = ""; formDescription = ""; formIso = null; formSymbol = null; formDecimals = 2; formIsActive = true; formError = ""; showDialog = true; }
    private void OpenEdit(CurrencyDto r) { editingId = r.Id; formCode = r.Code; formDescription = r.Description; formIso = r.IsoCode; formSymbol = r.Symbol; formDecimals = r.DecimalPlaces; formIsActive = r.IsActive; formError = ""; showDialog = true; }

    private async Task Save()
    {
        if (!editingId.HasValue && string.IsNullOrWhiteSpace(formCode)) { formError = "Code required."; return; }
        if (string.IsNullOrWhiteSpace(formDescription)) { formError = "Description required."; return; }
        busy = true;
        var iso = string.IsNullOrWhiteSpace(formIso) ? null : formIso!.Trim();
        var sym = string.IsNullOrWhiteSpace(formSymbol) ? null : formSymbol!.Trim();
        ApiResult<CurrencyDto>? resp;
        if (editingId.HasValue)
            resp = await Api.PutAsync<CurrencyDto, UpdateCurrencyRequest>($"api/masters/currencies/{editingId}", new UpdateCurrencyRequest(formDescription.Trim(), iso, sym, formDecimals, formIsActive));
        else
            resp = await Api.PostAsync<CurrencyDto, CreateCurrencyRequest>("api/masters/currencies", new CreateCurrencyRequest(formCode.Trim(), formDescription.Trim(), iso, sym, formDecimals, formIsActive));
        if (resp?.Success == true) { Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Saved" }); showDialog = false; await Load(); }
        else { formError = resp?.Errors?.FirstOrDefault() ?? "Failed."; }
        busy = false;
    }

    private async Task Deactivate(Guid id, string label)
    {
        if (!await Dialog.ConfirmDeactivateAsync(label, "CURRENCY")) return;
        busy = true;
        var resp = await Api.PostAsync<object>($"api/masters/currencies/{id}/deactivate", new { });
        if (resp?.Success == true) { Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Deactivated" }); await Load(); }
        else { Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Failed", Detail = resp?.Errors?.FirstOrDefault() ?? "" }); }
        busy = false;
    }
}
