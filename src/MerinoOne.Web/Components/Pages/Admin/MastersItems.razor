@page "/admin/items"
@inject ApiClient Api
@inject TokenAccessor Token
@inject NotificationService Notif
@inject DialogService Dialog

<PageTitle>Items</PageTitle>

<div class="tl-page">
    <header class="tl-header">
        <div>
            <div class="tl-title-row">
                <h1 class="tl-title">Items</h1>
                <span class="tl-count-chip">@(rows?.Count ?? 0)</span>
            </div>
            <p class="tl-sub">Item / material master</p>
        </div>
        <div class="tl-header__actions">
            @if (Token.HasPermission("Settings.Write"))
            {
                <button class="mbtn mbtn--primary" @onclick="OpenNew">
                    <span class="material-symbols-outlined">add</span> Add
                </button>
            }
        </div>
    </header>

    <div class="tl-filter-bar">
        <input class="rz-textbox" placeholder="Search code / description…" style="width:280px;padding:8px 12px;" @bind="search" @bind:event="oninput" @onkeyup="ApplyFilters" />
    </div>

    @if (loading)
    {
        <div class="tl-empty">Loading…</div>
    }
    else if (rows == null || rows.Count == 0)
    {
        <div class="tl-empty">
            <span class="material-symbols-outlined" style="font-size:32px;">inventory_2</span>
            <div>No items match.</div>
        </div>
    }
    else
    {
        <div class="tl-grid-wrapper" style="--tl-cols: 150px 1.4fr 110px 110px 80px 80px 110px 80px 150px; --tl-min-width: 1150px;">
            <div class="tlg-header">
                <div class="tlg-col">Code</div>
                <div class="tlg-col">Description</div>
                <div class="tlg-col">Unit</div>
                <div class="tlg-col">Group</div>
                <div class="tlg-col">Serial</div>
                <div class="tlg-col">Lot</div>
                <div class="tlg-col">Over-ship %</div>
                <div class="tlg-col">Active</div>
                <div class="tlg-col tlg-col--actions">Actions</div>
            </div>
            @foreach (var r in rows)
            {
                <div class="tlg-row">
                    <div class="tlg-col tlg-code">@r.Code</div>
                    <div class="tlg-col tlg-desc">@r.Description</div>
                    <div class="tlg-col tlg-code">@r.UnitCode</div>
                    <div class="tlg-col tlg-code">@r.ItemGroupCode</div>
                    <div class="tlg-col"><span class="tlg-status @(r.IsSerialized ? "tlg-status--active" : "tlg-status--info")">@(r.IsSerialized ? "Yes" : "No")</span></div>
                    <div class="tlg-col"><span class="tlg-status @(r.IsLotControlled ? "tlg-status--active" : "tlg-status--info")">@(r.IsLotControlled ? "Yes" : "No")</span></div>
                    <div class="tlg-col tlg-code">@r.OverShipTolerancePct.ToString("0.##")%</div>
                    <div class="tlg-col"><span class="tlg-status @(r.IsActive ? "tlg-status--active" : "tlg-status--danger")">@(r.IsActive ? "Yes" : "No")</span></div>
                    <div class="tlg-col tlg-col--actions">
                        @if (Token.HasPermission("Settings.Write"))
                        {
                            <button class="mbtn mbtn--row mbtn--accent" @onclick="() => OpenEdit(r)" title="Edit">
                                <span class="material-symbols-outlined">edit</span> Edit
                            </button>
                            @if (r.IsActive)
                            {
                                <button class="mbtn mbtn--row mbtn--danger" @onclick="() => Deactivate(r.Id, r.Code)" title="Deactivate">
                                    <span class="material-symbols-outlined">block</span> Off
                                </button>
                            }
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (showDialog)
{
    <div style="position:fixed;inset:0;background:var(--mer-modal-backdrop);display:flex;align-items:center;justify-content:center;z-index:1000;">
        <div class="merino-dialog" data-variant="info" style="width:540px;">
            <div class="merino-dialog__accent"></div>
            <header class="merino-dialog__header">
                <div class="merino-dialog__icon merino-dialog__icon--info"><span class="material-symbols-outlined">inventory_2</span></div>
                <div class="merino-dialog__head-text">
                    <div class="merino-dialog__eyebrow">Master</div>
                    <h2 class="merino-dialog__title">@(editingId.HasValue ? "Edit item" : "New item")</h2>
                </div>
                <button class="merino-dialog__close" @onclick="() => showDialog = false"><span class="material-symbols-outlined">close</span></button>
            </header>
            <div class="merino-dialog__body">
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                    <div style="grid-column:1 / span 2;">
                        <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Code @(editingId.HasValue ? "(immutable)" : "*")</label>
                        <input class="rz-textbox" style="width:100%;padding:8px 10px;font-family:Inter,monospace;" @bind="formCode" disabled="@editingId.HasValue" />
                    </div>
                    <div style="grid-column:1 / span 2;">
                        <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Description *</label>
                        <input class="rz-textbox" style="width:100%;padding:8px 10px;" @bind="formDescription" />
                    </div>
                    <div>
                        <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">HSN code</label>
                        <input class="rz-textbox" style="width:100%;padding:8px 10px;font-family:Inter,monospace;" @bind="formHsnCode" />
                    </div>
                    <div>
                        <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Unit</label>
                        <select class="rz-dropdown" style="width:100%;padding:8px 10px;" @bind="formUnitId">
                            <option value="">— none —</option>
                            @foreach (var u in units)
                            {
                                <option value="@u.Id">@u.Code — @u.Description</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Item group</label>
                        <select class="rz-dropdown" style="width:100%;padding:8px 10px;" @bind="formItemGroupId">
                            <option value="">— none —</option>
                            @foreach (var g in groups)
                            {
                                <option value="@g.Id">@g.Code — @g.Description</option>
                            }
                        </select>
                    </div>
                    @* R4 (2026-06-26) — §7.4: item-master over-ship tolerance floor. Nullable decimal(5,2), 0–999.99.
                       Blank → server keeps the entity default (0 / strict on create; unchanged on edit). *@
                    <div>
                        <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Over-ship tolerance %</label>
                        <input type="number" step="0.01" min="0" max="999.99" class="rz-textbox" style="width:100%;padding:8px 10px;font-family:Inter,monospace;" placeholder="0" @bind="formOverShipTolerancePct" />
                        <div style="font-size:10.5px;color:var(--mer-ink-500);margin-top:2px;">Permitted over-shipment ceiling for this item (0 = strict). Supplier overrides win.</div>
                    </div>
                    <div style="grid-column:1 / span 2;display:flex;gap:20px;padding:8px 10px;background:var(--mer-surface-2,#f6f7f9);border-radius:6px;">
                        <label style="display:flex;align-items:center;gap:8px;font-size:13px;color:var(--mer-ink-600);">
                            <input type="checkbox" checked="@formIsSerialized" disabled />
                            Serialized
                        </label>
                        <label style="display:flex;align-items:center;gap:8px;font-size:13px;color:var(--mer-ink-600);">
                            <input type="checkbox" checked="@formIsLotControlled" disabled />
                            Lot controlled
                        </label>
                        <span style="font-size:11px;color:var(--mer-ink-400);align-self:center;">ERP-fed (read-only)</span>
                    </div>
                    <label style="display:flex;align-items:center;gap:8px;font-size:13px;cursor:pointer;grid-column:1 / span 2;">
                        <input type="checkbox" @bind="formIsActive" />
                        Active
                    </label>
                </div>
                @if (!string.IsNullOrEmpty(formError))
                {
                    <div style="background:var(--mer-red-50);color:var(--mer-red);padding:8px 12px;border-radius:6px;font-size:12px;margin-top:8px;">@formError</div>
                }
            </div>
            <footer class="merino-dialog__footer">
                <div class="merino-dialog__actions">
                    <button class="merino-dialog__btn" data-intent="ghost" @onclick="() => showDialog = false">Cancel</button>
                    <button class="merino-dialog__btn" data-intent="primary" @onclick="Save" disabled="@busy">@(busy ? "Saving…" : "Save")</button>
                </div>
            </footer>
        </div>
    </div>
}

@code {
    private List<ItemDto>? all;
    private List<ItemDto>? rows;
    private List<UnitDto> units = new();
    private List<ItemGroupDto> groups = new();
    private bool loading = true;
    private bool busy;
    private bool showDialog;
    private Guid? editingId;
    private string formCode = string.Empty;
    private string formDescription = string.Empty;
    private string? formHsnCode;
    private string formUnitId = string.Empty;
    private string formItemGroupId = string.Empty;
    private bool formIsActive = true;
    private bool formIsSerialized;
    private bool formIsLotControlled;
    // R4 (2026-06-26) — §7.4: nullable so "blank = keep default/unchanged" round-trips correctly.
    private decimal? formOverShipTolerancePct;
    private string formError = string.Empty;
    private string search = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var u = await Api.GetAsync<List<UnitDto>>("api/masters/units?isActive=true");
        units = u?.Data ?? new();
        var g = await Api.GetAsync<List<ItemGroupDto>>("api/masters/item-groups?isActive=true");
        groups = g?.Data ?? new();
        await Load();
    }

    private async Task Load()
    {
        loading = true;
        var resp = await Api.GetAsync<List<ItemDto>>("api/masters/items");
        all = resp?.Data ?? new();
        ApplyFilters();
        loading = false;
    }

    private void ApplyFilters()
    {
        if (all == null) { rows = new(); return; }
        IEnumerable<ItemDto> q = all;
        if (!string.IsNullOrWhiteSpace(search))
        {
            var s = search.Trim();
            q = q.Where(x => x.Code.Contains(s, StringComparison.OrdinalIgnoreCase)
                          || x.Description.Contains(s, StringComparison.OrdinalIgnoreCase));
        }
        rows = q.ToList();
    }

    private void OpenNew()
    {
        editingId = null;
        formCode = string.Empty;
        formDescription = string.Empty;
        formHsnCode = null;
        formUnitId = string.Empty;
        formItemGroupId = string.Empty;
        formIsActive = true;
        formIsSerialized = false;
        formIsLotControlled = false;
        formOverShipTolerancePct = null;
        formError = string.Empty;
        showDialog = true;
    }

    private void OpenEdit(ItemDto r)
    {
        editingId = r.Id;
        formCode = r.Code;
        formDescription = r.Description;
        formHsnCode = r.HsnCode;
        formUnitId = r.UnitId?.ToString() ?? string.Empty;
        formItemGroupId = r.ItemGroupId?.ToString() ?? string.Empty;
        formIsActive = r.IsActive;
        formIsSerialized = r.IsSerialized;
        formIsLotControlled = r.IsLotControlled;
        formOverShipTolerancePct = r.OverShipTolerancePct;
        formError = string.Empty;
        showDialog = true;
    }

    private async Task Save()
    {
        if (!editingId.HasValue && string.IsNullOrWhiteSpace(formCode)) { formError = "Code required."; return; }
        if (string.IsNullOrWhiteSpace(formDescription)) { formError = "Description required."; return; }
        busy = true;
        ApiResult<ItemDto>? resp;
        var hsn = string.IsNullOrWhiteSpace(formHsnCode) ? null : formHsnCode.Trim();
        Guid? unitId = Guid.TryParse(formUnitId, out var ug) ? ug : null;
        Guid? groupId = Guid.TryParse(formItemGroupId, out var gg) ? gg : null;
        // R4 (2026-06-26) — §7.4: 0–999.99 guard mirrors the server validator; blank stays null (keep default/unchanged).
        if (formOverShipTolerancePct is { } tol && (tol < 0m || tol > 999.99m)) { formError = "Over-ship tolerance must be between 0 and 999.99."; busy = false; return; }
        if (editingId.HasValue)
        {
            var req = new UpdateItemRequest(formDescription.Trim(), hsn, groupId, unitId, formIsActive, formOverShipTolerancePct);
            resp = await Api.PutAsync<ItemDto, UpdateItemRequest>($"api/masters/items/{editingId}", req);
        }
        else
        {
            var req = new CreateItemRequest(formCode.Trim(), formDescription.Trim(), hsn, groupId, unitId, formIsActive, formOverShipTolerancePct);
            resp = await Api.PostAsync<ItemDto, CreateItemRequest>("api/masters/items", req);
        }
        if (resp?.Success == true)
        {
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Saved" });
            showDialog = false;
            await Load();
        }
        else { formError = resp?.Errors?.FirstOrDefault() ?? "Failed."; }
        busy = false;
    }

    private async Task Deactivate(Guid id, string label)
    {
        if (!await Dialog.ConfirmDeactivateAsync(label, "ITEM")) return;
        busy = true;
        var resp = await Api.PostAsync<object>($"api/masters/items/{id}/deactivate", new { });
        if (resp?.Success == true)
        {
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Deactivated" });
            await Load();
        }
        else { Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Failed", Detail = resp?.Errors?.FirstOrDefault() ?? "" }); }
        busy = false;
    }
}
