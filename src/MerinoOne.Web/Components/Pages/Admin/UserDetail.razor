@page "/admin/users/{Id:guid}"
@inject ApiClient Api
@inject TokenAccessor Token
@inject NavigationManager Nav
@inject NotificationService Notif
@inject DialogService Dialog

<PageTitle>@detail?.FullName</PageTitle>

@if (loading)
{
    <div class="tl-empty">Loading…</div>
}
else if (detail == null)
{
    <div class="tl-empty">User not found.</div>
}
else
{
    <div class="tl-page">
        <a href="admin/users" class="mer-back-link">
            <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">arrow_back</span>
            Back to list
        </a>
        <header class="tl-header">
            <div>
                <div class="tl-title-row">
                    <h1 class="tl-title">@detail.FullName</h1>
                    <span class="tl-count-chip">@detail.UserCode</span>
                    <span class="tlg-status @(detail.IsActive ? "tlg-status--active" : "tlg-status--danger")">@(detail.IsActive ? "Active" : "Inactive")</span>
                    @if (detail.IsInternal)
                    {
                        <span class="tlg-status tlg-status--info">Internal</span>
                    }
                    @if (detail.IsMfaEnabled)
                    {
                        <span class="tlg-status tlg-status--info">MFA</span>
                    }
                </div>
                <p class="tl-sub">@detail.Email · Seq #@detail.Seq · Created @detail.CreatedOn.ToString("yyyy-MM-dd")</p>
            </div>
            <div class="tl-header__actions">
                @if (Token.HasPermission("User.Write"))
                {
                    if (detail.IsActive)
                    {
                        <button class="rz-button" style="padding:8px 14px;border-radius:6px;border:1px solid var(--mer-red);background:var(--mer-surface);color:var(--mer-red);cursor:pointer;" @onclick="OpenDeactivate">
                            <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">block</span> Deactivate
                        </button>
                    }
                    else
                    {
                        <button class="rz-button rz-secondary" style="padding:8px 14px;border-radius:6px;border:0;color:#fff;cursor:pointer;" @onclick="Reactivate" disabled="@busy">
                            <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">check_circle</span> Reactivate
                        </button>
                    }
                }
            </div>
        </header>

        <div class="mer-tabs" style="display:flex;gap:0;border-bottom:1px solid var(--mer-line);margin-bottom:16px;">
            @foreach (var t in tabs)
            {
                <button class="@(tab==t.Key?"mer-tab mer-tab--active":"mer-tab")" @onclick="@(() => tab = t.Key)" style="padding:10px 16px;background:transparent;border:0;border-bottom:2px solid @(tab==t.Key?"var(--mer-blue)":"transparent");cursor:pointer;font:600 13px/1 'Plus Jakarta Sans',sans-serif;color:@(tab==t.Key?"var(--mer-blue)":"var(--mer-ink-700)");">@t.Value</button>
            }
        </div>

        @if (tab == "overview")
        {
            <div class="rz-card" style="padding:20px;max-width:760px;">
                <h3 style="font-size:14px;font-weight:700;margin-bottom:16px;color:var(--mer-blue-darker);">Profile</h3>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                    <div>
                        <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Full name</label>
                        <input class="rz-textbox" style="width:100%;padding:8px 10px;" @bind="editFullName" />
                    </div>
                    <div>
                        <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Email</label>
                        <input class="rz-textbox" type="email" style="width:100%;padding:8px 10px;" @bind="editEmail" />
                    </div>
                    <div style="display:flex;align-items:center;gap:24px;padding-top:24px;">
                        <label style="display:flex;align-items:center;gap:8px;font-size:13px;cursor:pointer;">
                            <input type="checkbox" @bind="editIsInternal" />
                            Internal user
                        </label>
                        <label style="display:flex;align-items:center;gap:8px;font-size:13px;cursor:pointer;">
                            <input type="checkbox" @bind="editMfaEnabled" />
                            MFA enabled
                        </label>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(overviewError))
                {
                    <div style="background:var(--mer-red-50);color:var(--mer-red);padding:8px 12px;border-radius:6px;font-size:12px;margin-top:12px;">@overviewError</div>
                }
                <div style="display:flex;justify-content:flex-end;gap:8px;margin-top:20px;padding-top:16px;border-top:1px solid var(--mer-line);">
                    <button class="rz-button" style="padding:8px 14px;border-radius:6px;border:1px solid var(--mer-ink-300);background:var(--mer-surface);cursor:pointer;" @onclick="OpenSetPassword">
                        <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">key</span> Set password
                    </button>
                    <button class="rz-button rz-primary" style="padding:8px 14px;border-radius:6px;border:0;color:#fff;cursor:pointer;" @onclick="SaveOverview" disabled="@busy">
                        @(busy ? "Saving…" : "Save")
                    </button>
                </div>
            </div>
        }
        else if (tab == "roles")
        {
            <div class="rz-card" style="padding:20px;">
                <h3 style="font-size:14px;font-weight:700;margin-bottom:16px;color:var(--mer-blue-darker);">Assigned roles</h3>
                @if (detail.Roles.Length == 0)
                {
                    <p style="color:var(--mer-ink-500);font-size:13px;">No roles assigned.</p>
                }
                else
                {
                    <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:20px;">
                        @foreach (var rn in detail.Roles)
                        {
                            var role = availableRoles?.FirstOrDefault(r => r.Name == rn);
                            <span style="display:inline-flex;align-items:center;gap:6px;padding:6px 12px;border-radius:999px;background:var(--mer-blue-50);color:var(--mer-blue-700);font-size:12px;">
                                @rn
                                @if (role != null)
                                {
                                    <button @onclick="() => UnassignRole(role.Id, rn)" style="background:transparent;border:0;color:var(--mer-blue-700);cursor:pointer;line-height:1;padding:0;" title="Remove">
                                        <span class="material-symbols-outlined" style="font-size:14px;">close</span>
                                    </button>
                                }
                            </span>
                        }
                    </div>
                }

                @if (availableRoles != null)
                {
                    var unassigned = availableRoles.Where(ar => !detail.Roles.Contains(ar.Name)).ToList();
                    @if (unassigned.Count > 0)
                    {
                        <div style="display:flex;gap:8px;align-items:center;padding-top:16px;border-top:1px solid var(--mer-line);">
                            <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Assign role:</label>
                            <select class="rz-dropdown" style="padding:6px 10px;border:1px solid var(--mer-ink-300);border-radius:6px;background:var(--mer-surface);min-width:200px;" @bind="roleToAssign">
                                <option value="">— Select role —</option>
                                @foreach (var r in unassigned)
                                {
                                    <option value="@r.Id">@r.Name</option>
                                }
                            </select>
                            <button class="rz-button rz-primary" style="padding:6px 12px;border-radius:6px;border:0;color:#fff;cursor:pointer;" @onclick="AssignRole" disabled="@(roleToAssign == Guid.Empty || busy)">Add</button>
                        </div>
                    }
                }
            </div>
        }
        else if (tab == "suppliers")
        {
            if (detail.IsInternal)
            {
                <div class="tl-empty">
                    <span class="material-symbols-outlined" style="font-size:32px;">info</span>
                    <div>Supplier mappings only apply to non-internal users.</div>
                </div>
            }
            else
            {
                var canProvision = Token.HasPermission("Supplier.Provision");
                // Companies the user does NOT already hold a full-access (AllSuppliers=true) grant on.
                var grantableCompanies = companies
                    .Where(c => !detail.CompanyAccess.Any(a => a.TenantEntityId == c.Id && a.AllSuppliers))
                    .ToList();

                <div class="rz-card" style="padding:20px;margin-bottom:16px;">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
                        <h3 style="font-size:14px;font-weight:700;color:var(--mer-blue-darker);">Company access (@detail.CompanyAccess.Length)</h3>
                    </div>
                    <p style="color:var(--mer-ink-500);font-size:12px;margin-bottom:14px;">
                        <strong>Full access</strong> = a direct grant: the user sees <em>every</em> supplier in that company
                        (including future ones), seccode-bypassed but scoped to that one company.
                        <strong>Supplier-scoped</strong> = the company appears because the user is mapped to one or more of its
                        suppliers; data stays seccode-limited to those suppliers. Mapping a supplier (below) auto-creates a
                        supplier-scoped company access.
                    </p>

                    @if (detail.CompanyAccess.Length == 0)
                    {
                        <p style="color:var(--mer-ink-500);font-size:13px;">No company access yet.</p>
                    }
                    else
                    {
                        <table style="width:100%;font-size:12.5px;border-collapse:collapse;margin-bottom:4px;">
                            <thead>
                                <tr style="border-bottom:1px solid var(--mer-line);">
                                    <th style="text-align:left;padding:8px 4px;color:var(--mer-ink-700);">Company</th>
                                    <th style="text-align:left;padding:8px 4px;color:var(--mer-ink-700);">Access type</th>
                                    <th style="text-align:left;padding:8px 4px;color:var(--mer-ink-700);">Default</th>
                                    <th style="text-align:right;padding:8px 4px;color:var(--mer-ink-700);">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var a in detail.CompanyAccess.OrderBy(x => x.Code))
                            {
                                var accessLabel = $"{a.Code} — {a.Name}";
                                <tr style="border-bottom:1px solid var(--mer-line-soft);">
                                    <td style="padding:8px 4px;">
                                        <span style="font-family:Inter,monospace;background:var(--mer-ink-50);border:1px solid var(--mer-line);border-radius:4px;padding:1px 6px;">@a.Code</span>
                                        <span style="margin-left:6px;">@a.Name</span>
                                    </td>
                                    <td style="padding:8px 4px;">
                                        @if (a.AllSuppliers)
                                        {
                                            <span class="tlg-status tlg-status--active">Full access</span>
                                        }
                                        else
                                        {
                                            <span class="tlg-status tlg-status--info">Supplier-scoped</span>
                                        }
                                    </td>
                                    <td style="padding:8px 4px;color:var(--mer-ink-500);">
                                        @if (a.IsDefault)
                                        {
                                            <span style="display:inline-flex;align-items:center;gap:4px;color:var(--mer-blue-700);">
                                                <span class="material-symbols-outlined" style="font-size:15px;">star</span> Default
                                            </span>
                                        }
                                    </td>
                                    <td style="padding:8px 4px;text-align:right;">
                                        @if (canProvision)
                                        {
                                            <button @onclick="() => RevokeCompany(a.TenantEntityId, accessLabel)" disabled="@busy" style="background:transparent;border:0;color:var(--mer-red);cursor:pointer;" title="Revoke company access">
                                                <span class="material-symbols-outlined" style="font-size:18px;">link_off</span>
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    }

                    @if (canProvision)
                    {
                        <div style="display:flex;gap:8px;align-items:center;padding-top:14px;margin-top:6px;border-top:1px solid var(--mer-line);">
                            <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Add company (full access):</label>
                            <select class="rz-dropdown" style="padding:8px 10px;border:1px solid var(--mer-ink-300);border-radius:6px;background:var(--mer-surface);min-width:260px;" @bind="companyToGrant">
                                <option value="@Guid.Empty">— Select company —</option>
                                @foreach (var c in grantableCompanies)
                                {
                                    <option value="@c.Id">@c.Code — @c.Name</option>
                                }
                            </select>
                            <button class="rz-button rz-primary" style="padding:8px 12px;border-radius:6px;border:0;color:#fff;cursor:pointer;" @onclick="GrantSelectedCompany" disabled="@(companyToGrant == Guid.Empty || busy)">
                                <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">add_link</span> Grant full access
                            </button>
                        </div>
                        <div style="font-size:11px;color:var(--mer-ink-500);margin-top:4px;">Granting a company gives full access to all of its suppliers, including ones added later. A supplier-scoped company is upgraded to full access.</div>
                    }
                </div>

                <div class="rz-card" style="padding:20px;">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
                        <h3 style="font-size:14px;font-weight:700;color:var(--mer-blue-darker);">Mapped suppliers (@detail.SupplierIds.Length)</h3>
                        @if (canProvision)
                        {
                            <button class="rz-button rz-primary" style="padding:6px 12px;border-radius:6px;border:0;color:#fff;cursor:pointer;font-size:12px;" @onclick="OpenBulkMap">
                                <span class="material-symbols-outlined" style="font-size:14px;vertical-align:middle;">checklist</span> Manage supplier maps
                            </button>
                        }
                    </div>
                    @if (detail.SupplierIds.Length == 0)
                    {
                        <p style="color:var(--mer-ink-500);font-size:13px;">No suppliers mapped yet.</p>
                    }
                    else
                    {
                        <table style="width:100%;font-size:12.5px;border-collapse:collapse;">
                            <thead>
                                <tr style="border-bottom:1px solid var(--mer-line);">
                                    <th style="text-align:left;padding:8px 4px;color:var(--mer-ink-700);">Code</th>
                                    <th style="text-align:left;padding:8px 4px;color:var(--mer-ink-700);">Legal name</th>
                                    <th style="text-align:left;padding:8px 4px;color:var(--mer-ink-700);">Company</th>
                                    <th style="text-align:left;padding:8px 4px;color:var(--mer-ink-700);">Access</th>
                                    <th style="text-align:right;padding:8px 4px;color:var(--mer-ink-700);">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                            @* Mapped suppliers come resolved cross-company from the server (detail.MappedSuppliers),
                               so ALL mappings show with their company code regardless of the header's active company. *@
                            @foreach (var m in detail.MappedSuppliers)
                            {
                                <tr style="border-bottom:1px solid var(--mer-line-soft);">
                                    <td style="padding:8px 4px;font-family:Inter,monospace;">@m.SupplierCode</td>
                                    <td style="padding:8px 4px;">@m.LegalName</td>
                                    <td style="padding:8px 4px;">
                                        <span style="font-family:Inter,monospace;background:var(--mer-ink-50);border:1px solid var(--mer-line);border-radius:4px;padding:1px 6px;">@m.CompanyCode</span>
                                    </td>
                                    <td style="padding:8px 4px;color:var(--mer-ink-500);">@(m.CanWrite ? "Read/Write" : "Read")</td>
                                    <td style="padding:8px 4px;text-align:right;">
                                        @if (canProvision)
                                        {
                                            <button @onclick="() => UnmapSupplier(m.SupplierId, m.SupplierCode)" style="background:transparent;border:0;color:var(--mer-red);cursor:pointer;" title="Remove">
                                                <span class="material-symbols-outlined" style="font-size:18px;">delete</span>
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    }
                </div>
            }
        }
        else if (tab == "history")
        {
            <AuditHistoryTab EntityName="AppUser" EntityId="@Id" />
        }
    </div>

    @if (showSetPassword)
    {
        <div style="position:fixed;inset:0;background:var(--mer-modal-backdrop);display:flex;align-items:center;justify-content:center;z-index:1000;">
            <div class="merino-dialog" data-variant="info" style="width:480px;">
                <div class="merino-dialog__accent"></div>
                <header class="merino-dialog__header">
                    <div class="merino-dialog__icon merino-dialog__icon--info"><span class="material-symbols-outlined">key</span></div>
                    <div class="merino-dialog__head-text">
                        <div class="merino-dialog__eyebrow">User</div>
                        <h2 class="merino-dialog__title">Set new password</h2>
                        <p class="merino-dialog__subtitle">For @detail.UserCode</p>
                    </div>
                    <button class="merino-dialog__close" @onclick="() => showSetPassword = false"><span class="material-symbols-outlined">close</span></button>
                </header>
                <div class="merino-dialog__body">
                    <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">New password (min 8 chars)</label>
                    <input type="password" class="rz-textbox" style="width:100%;padding:8px 10px;" @bind="newPassword" />
                    @if (!string.IsNullOrEmpty(passwordError))
                    {
                        <div style="background:var(--mer-red-50);color:var(--mer-red);padding:8px 12px;border-radius:6px;font-size:12px;margin-top:8px;">@passwordError</div>
                    }
                </div>
                <footer class="merino-dialog__footer">
                    <div class="merino-dialog__actions">
                        <button class="merino-dialog__btn" data-intent="ghost" @onclick="() => showSetPassword = false">Cancel</button>
                        <button class="merino-dialog__btn" data-intent="primary" @onclick="DoSetPassword" disabled="@busy">@(busy ? "Saving…" : "Set password")</button>
                    </div>
                </footer>
            </div>
        </div>
    }

    @if (showBulkMap)
    {
        <div style="position:fixed;inset:0;background:var(--mer-modal-backdrop);display:flex;align-items:center;justify-content:center;z-index:1000;">
            <div class="merino-dialog" data-variant="info" data-size="lg" style="width:760px;max-width:94vw;">
                <div class="merino-dialog__accent"></div>
                <header class="merino-dialog__header">
                    <div class="merino-dialog__icon merino-dialog__icon--info"><span class="material-symbols-outlined">checklist</span></div>
                    <div class="merino-dialog__head-text">
                        <div class="merino-dialog__eyebrow">User mapping</div>
                        <h2 class="merino-dialog__title">Manage supplier maps</h2>
                        <p class="merino-dialog__subtitle">Pick a company, then tick the suppliers this user should be mapped to.</p>
                    </div>
                    <button class="merino-dialog__close" @onclick="() => showBulkMap = false"><span class="material-symbols-outlined">close</span></button>
                </header>
                <div class="merino-dialog__body">
                    <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Company *</label>
                    <select class="rz-dropdown" style="width:100%;padding:8px 10px;border:1px solid var(--mer-ink-300);border-radius:6px;background:var(--mer-surface);" @bind="mapCompanyId" @bind:after="OnMapCompanyChanged">
                        <option value="@Guid.Empty">— Select company —</option>
                        @if (companies != null)
                        {
                            @foreach (var c in companies)
                            {
                                <option value="@c.Id">@c.Code — @c.Name</option>
                            }
                        }
                    </select>
                    <div style="font-size:11px;color:var(--mer-ink-500);margin:2px 0 12px;">Diffs against the user's current maps for this company. Saving adds checked rows and removes unchecked ones — other companies are untouched. The user is auto-granted supplier-scoped company access.</div>

                    @if (mapCompanyId != Guid.Empty)
                    {
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
                            <label style="display:flex;align-items:center;gap:8px;font-size:13px;cursor:pointer;white-space:nowrap;">
                                <input type="checkbox" @bind="bulkCanWrite" />
                                Can write (applies to all selected — else read-only)
                            </label>
                            <input type="text" placeholder="Filter code or name…" @bind="supplierFilter" @bind:event="oninput"
                                   style="flex:1;min-width:120px;margin:0 12px;padding:6px 10px;border:1px solid var(--mer-ink-300);border-radius:6px;background:var(--mer-surface);font-size:12.5px;" />
                            <span style="font-size:12px;color:var(--mer-ink-600);white-space:nowrap;">
                                @if (loadingMapSuppliers)
                                {
                                    <span>Loading…</span>
                                }
                                else
                                {
                                    <span style="color:var(--mer-green-dark);">+@AddCount to add</span>
                                    <span style="margin:0 6px;color:var(--mer-ink-300);">·</span>
                                    <span style="color:var(--mer-red);">−@RemoveCount to remove</span>
                                }
                            </span>
                        </div>

                        @if (loadingMapSuppliers)
                        {
                            <div style="color:var(--mer-ink-500);font-size:13px;padding:12px 0;">Loading suppliers…</div>
                        }
                        else if (companySuppliers == null || companySuppliers.Count == 0)
                        {
                            <div style="color:var(--mer-ink-500);font-size:13px;padding:12px 0;">No suppliers in this company.</div>
                        }
                        else
                        {
                            <div style="max-height:46vh;overflow:auto;border:1px solid var(--mer-line);border-radius:8px;">
                                <table style="width:100%;font-size:12.5px;border-collapse:collapse;">
                                    <thead>
                                        <tr style="border-bottom:1px solid var(--mer-line);background:var(--mer-canvas);position:sticky;top:0;">
                                            <th style="width:42px;text-align:center;padding:8px 4px;"></th>
                                            <th style="text-align:left;padding:8px 8px;color:var(--mer-ink-700);">Code</th>
                                            <th style="text-align:left;padding:8px 8px;color:var(--mer-ink-700);">Legal name</th>
                                            <th style="text-align:left;padding:8px 8px;color:var(--mer-ink-700);">Currently</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                    @if (!FilteredSuppliers.Any())
                                    {
                                        <tr><td colspan="4" style="padding:12px 8px;color:var(--mer-ink-500);">No suppliers match "@supplierFilter".</td></tr>
                                    }
                                    @foreach (var s in FilteredSuppliers)
                                    {
                                        var sup = s;
                                        var ck = checkedSuppliers.Contains(sup.Id);
                                        var wasMapped = originalMapped.Contains(sup.Id);
                                        <tr style="border-bottom:1px solid var(--mer-line-soft);">
                                            <td style="text-align:center;padding:8px 4px;">
                                                <input type="checkbox" checked="@ck" @onchange="@((ChangeEventArgs e) => ToggleSupplier(sup.Id, (bool)(e.Value ?? false)))" />
                                            </td>
                                            <td style="padding:8px 8px;font-family:Inter,monospace;">@sup.SupplierCode</td>
                                            <td style="padding:8px 8px;">@sup.LegalName</td>
                                            <td style="padding:8px 8px;color:var(--mer-ink-500);">@(wasMapped ? "Mapped" : "—")</td>
                                        </tr>
                                    }
                                    </tbody>
                                </table>
                            </div>
                        }
                    }
                    @if (!string.IsNullOrEmpty(mapError))
                    {
                        <div style="background:var(--mer-red-50);color:var(--mer-red);padding:8px 12px;border-radius:6px;font-size:12px;margin-top:8px;">@mapError</div>
                    }
                </div>
                <footer class="merino-dialog__footer">
                    <div class="merino-dialog__actions">
                        <button class="merino-dialog__btn" data-intent="ghost" @onclick="() => showBulkMap = false">Cancel</button>
                        <button class="merino-dialog__btn" data-intent="primary" @onclick="DoBulkMap" disabled="@(busy || mapCompanyId == Guid.Empty || loadingMapSuppliers || (AddCount == 0 && RemoveCount == 0))">@(busy ? "Saving…" : "Save changes")</button>
                    </div>
                </footer>
            </div>
        </div>
    }

    @if (showDeactivate)
    {
        <div style="position:fixed;inset:0;background:var(--mer-modal-backdrop);display:flex;align-items:center;justify-content:center;z-index:1000;">
            <div class="merino-dialog" data-variant="danger" style="width:480px;">
                <div class="merino-dialog__accent"></div>
                <header class="merino-dialog__header">
                    <div class="merino-dialog__icon merino-dialog__icon--danger"><span class="material-symbols-outlined">block</span></div>
                    <div class="merino-dialog__head-text">
                        <div class="merino-dialog__eyebrow">User</div>
                        <h2 class="merino-dialog__title">Deactivate @detail.UserCode?</h2>
                        <p class="merino-dialog__subtitle">They will lose access immediately.</p>
                    </div>
                    <button class="merino-dialog__close" @onclick="() => showDeactivate = false"><span class="material-symbols-outlined">close</span></button>
                </header>
                <footer class="merino-dialog__footer">
                    <div class="merino-dialog__actions">
                        <button class="merino-dialog__btn" data-intent="ghost" @onclick="() => showDeactivate = false">Cancel</button>
                        <button class="merino-dialog__btn" data-intent="danger" @onclick="DoDeactivate" disabled="@busy">@(busy ? "Deactivating…" : "Deactivate")</button>
                    </div>
                </footer>
            </div>
        </div>
    }
}

@code {
    [Parameter] public Guid Id { get; set; }
    private UserDetailDto? detail;
    private bool loading = true;
    private bool busy = false;
    private string tab = "overview";
    private readonly Dictionary<string, string> tabs = new()
    {
        ["overview"] = "Overview",
        ["roles"] = "Roles",
        ["suppliers"] = "Supplier Mappings",
        ["history"] = "History"
    };

    private string editFullName = string.Empty;
    private string editEmail = string.Empty;
    private bool editIsInternal;
    private bool editMfaEnabled;
    private string overviewError = string.Empty;

    private bool showSetPassword;
    private string newPassword = string.Empty;
    private string passwordError = string.Empty;

    // Bulk supplier-map (diff grid) state — Feature B.
    private bool showBulkMap;
    private bool bulkCanWrite = false;
    private string mapError = string.Empty;
    private List<SupplierListItemDto>? companySuppliers;     // suppliers filtered to the selected company in the bulk dialog
    private bool loadingMapSuppliers;
    private List<CompanyDto> companies = new();
    private readonly HashSet<Guid> checkedSuppliers = new();  // desired set for the selected company
    private readonly HashSet<Guid> originalMapped = new();    // suppliers already mapped for the selected company (the diff baseline)
    private string supplierFilter = string.Empty;            // client-side search within the picker grid

    private int AddCount => checkedSuppliers.Count(id => !originalMapped.Contains(id));
    private int RemoveCount => originalMapped.Count(id => !checkedSuppliers.Contains(id));

    // Search filters only the displayed rows; checked/baseline sets are unaffected so a filter never loses a selection.
    private IEnumerable<SupplierListItemDto> FilteredSuppliers =>
        companySuppliers == null
            ? Enumerable.Empty<SupplierListItemDto>()
            : string.IsNullOrWhiteSpace(supplierFilter)
                ? companySuppliers
                : companySuppliers.Where(s =>
                    s.SupplierCode.Contains(supplierFilter, StringComparison.OrdinalIgnoreCase)
                    || s.LegalName.Contains(supplierFilter, StringComparison.OrdinalIgnoreCase));

    private bool showDeactivate;

    private List<RoleListItemDto>? availableRoles;
    private Guid roleToAssign = Guid.Empty;

    protected override async Task OnInitializedAsync()
    {
        await Load();
        var rolesResp = await Api.GetAsync<List<RoleListItemDto>>("api/roles");
        availableRoles = rolesResp?.Data ?? new();
        var compResp = await Api.GetAsync<List<CompanyDto>>("api/companies");
        companies = compResp?.Data ?? new();
    }

    private async Task Load()
    {
        loading = true;
        var resp = await Api.GetAsync<UserDetailDto>($"api/users/{Id}");
        detail = resp?.Data;
        if (detail != null)
        {
            editFullName = detail.FullName;
            editEmail = detail.Email;
            editIsInternal = detail.IsInternal;
            editMfaEnabled = detail.IsMfaEnabled;
        }
        loading = false;
    }

    private async Task SaveOverview()
    {
        if (detail == null) return;
        overviewError = string.Empty;
        if (string.IsNullOrWhiteSpace(editFullName)) { overviewError = "Full name required."; return; }
        if (string.IsNullOrWhiteSpace(editEmail) || !editEmail.Contains('@')) { overviewError = "Valid email required."; return; }
        busy = true;
        var req = new UpdateUserRequest(editFullName.Trim(), editEmail.Trim(), editIsInternal, editMfaEnabled);
        var resp = await Api.PutAsync<UpdateUserRequest>($"api/users/{Id}", req);
        if (resp?.Success == true)
        {
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "User updated" });
            await Load();
        }
        else { overviewError = resp?.Errors?.FirstOrDefault() ?? "Update failed."; }
        busy = false;
    }

    private void OpenSetPassword() { newPassword = string.Empty; passwordError = string.Empty; showSetPassword = true; }

    private async Task DoSetPassword()
    {
        if (string.IsNullOrEmpty(newPassword) || newPassword.Length < 8) { passwordError = "Min 8 characters."; return; }
        busy = true;
        var resp = await Api.PostAsync<SetPasswordRequest>($"api/users/{Id}/password", new SetPasswordRequest(newPassword));
        if (resp?.Success == true)
        {
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Password updated" });
            showSetPassword = false;
        }
        else { passwordError = resp?.Errors?.FirstOrDefault() ?? "Failed."; }
        busy = false;
    }

    private async Task AssignRole()
    {
        if (roleToAssign == Guid.Empty) return;
        busy = true;
        var resp = await Api.PostAsync<AssignRoleRequest>($"api/users/{Id}/roles", new AssignRoleRequest(roleToAssign));
        if (resp?.Success == true)
        {
            roleToAssign = Guid.Empty;
            await Load();
        }
        else { Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Failed", Detail = resp?.Errors?.FirstOrDefault() ?? "" }); }
        busy = false;
    }

    private async Task UnassignRole(Guid roleId, string roleName)
    {
        if (!await Dialog.ConfirmDeleteAsync(roleName, category: "ROLE", actionLabel: "Remove",
                subtitle: $"Remove role {roleName} from this user?")) return;
        busy = true;
        var resp = await Api.DeleteAsync($"api/users/{Id}/roles/{roleId}");
        if (resp?.Success == true) await Load();
        else Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Failed", Detail = resp?.Errors?.FirstOrDefault() ?? "" });
        busy = false;
    }

    // Company the bulk-map is made under. Selecting it loads that company's suppliers via
    // GET api/suppliers?tenantEntityId={mapCompanyId} (server requires supplier ∈ this company) and
    // pre-checks any already mapped. Saving auto-creates the user's UserCompanyMap if absent.
    private Guid mapCompanyId = Guid.Empty;

    private void OpenBulkMap()
    {
        bulkCanWrite = false;
        mapCompanyId = Guid.Empty;
        companySuppliers = null;
        checkedSuppliers.Clear();
        originalMapped.Clear();
        supplierFilter = string.Empty;
        mapError = string.Empty;
        showBulkMap = true;
    }

    private async Task OnMapCompanyChanged()
    {
        companySuppliers = null;
        checkedSuppliers.Clear();
        originalMapped.Clear();
        supplierFilter = string.Empty;
        if (mapCompanyId == Guid.Empty) return;
        loadingMapSuppliers = true;
        StateHasChanged();

        // Admin mapping is tenant-wide — use the for-mapping endpoint, which ignores the header's active-company
        // filter (otherwise picking company 2000 while the header is on 3000 returns zero suppliers).
        var resp = await Api.GetAsync<List<SupplierListItemDto>>($"api/suppliers/for-mapping?tenantEntityId={mapCompanyId}");
        companySuppliers = resp?.Data ?? new();

        // Baseline = the user's existing maps whose supplier belongs to this company. detail.MappedSuppliers is
        // cross-company and carries CompanyCode; cross-reference it against this company's supplier list.
        var companyCode = companies.FirstOrDefault(c => c.Id == mapCompanyId)?.Code;
        var companySupplierIds = companySuppliers.Select(s => s.Id).ToHashSet();
        if (detail != null)
        {
            foreach (var m in detail.MappedSuppliers)
            {
                // A mapping is for this company if its CompanyCode matches OR (fallback) its supplier id is in
                // this company's list. The supplier-id check is the authoritative filter.
                if (companySupplierIds.Contains(m.SupplierId) || (companyCode != null && m.CompanyCode == companyCode))
                {
                    originalMapped.Add(m.SupplierId);
                    checkedSuppliers.Add(m.SupplierId);
                }
            }
            // Default the batch Read/Write toggle from the existing rows when uniform (all write → write).
            var existing = detail.MappedSuppliers.Where(m => originalMapped.Contains(m.SupplierId)).ToList();
            bulkCanWrite = existing.Count > 0 && existing.All(m => m.CanWrite);
        }

        loadingMapSuppliers = false;
    }

    private void ToggleSupplier(Guid supplierId, bool on)
    {
        if (on) checkedSuppliers.Add(supplierId);
        else checkedSuppliers.Remove(supplierId);
    }

    private async Task DoBulkMap()
    {
        if (mapCompanyId == Guid.Empty) { mapError = "Select a company."; return; }
        busy = true;
        var req = new SetSupplierMapsRequest(checkedSuppliers.ToArray(), bulkCanWrite);
        var resp = await Api.PutAsync<SetSupplierMapsRequest>($"api/users/{Id}/supplier-maps?tenantEntityId={mapCompanyId}", req);
        if (resp?.Success == true)
        {
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Supplier maps updated" });
            showBulkMap = false;
            await Load();
        }
        else { mapError = resp?.Errors?.FirstOrDefault() ?? "Failed."; }
        busy = false;
    }

    // Feature A — grant a user direct FULL access to a company (every supplier in it). Upgrades a
    // supplier-scoped row to full access server-side.
    private Guid companyToGrant = Guid.Empty;

    private async Task GrantSelectedCompany()
    {
        if (companyToGrant == Guid.Empty) return;
        busy = true;
        var resp = await Api.PostAsync<GrantCompanyRequest>($"api/users/{Id}/company-maps", new GrantCompanyRequest(companyToGrant));
        if (resp?.Success == true)
        {
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Full company access granted" });
            companyToGrant = Guid.Empty;
            await Load();
        }
        else Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Failed", Detail = resp?.Errors?.FirstOrDefault() ?? "" });
        busy = false;
    }

    private async Task RevokeCompany(Guid tenantEntityId, string label)
    {
        if (!await Dialog.ConfirmUnmapAsync(label, "COMPANY ACCESS")) return;
        busy = true;
        var resp = await Api.DeleteAsync($"api/users/{Id}/company-maps/{tenantEntityId}");
        if (resp?.Success == true)
        {
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Company access revoked" });
            await Load();
        }
        else Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Failed", Detail = resp?.Errors?.FirstOrDefault() ?? "" });
        busy = false;
    }

    private async Task UnmapSupplier(Guid supplierId, string label)
    {
        if (!await Dialog.ConfirmUnmapAsync(label, "SUPPLIER MAP")) return;
        busy = true;
        var resp = await Api.DeleteAsync($"api/users/{Id}/supplier-maps/{supplierId}");
        if (resp?.Success == true) await Load();
        else Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Failed", Detail = resp?.Errors?.FirstOrDefault() ?? "" });
        busy = false;
    }

    private void OpenDeactivate() => showDeactivate = true;

    private async Task DoDeactivate()
    {
        busy = true;
        var resp = await Api.PostAsync<object>($"api/users/{Id}/deactivate", new { });
        if (resp?.Success == true)
        {
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "User deactivated" });
            showDeactivate = false;
            await Load();
        }
        else { Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Failed", Detail = resp?.Errors?.FirstOrDefault() ?? "" }); }
        busy = false;
    }

    private async Task Reactivate()
    {
        busy = true;
        var resp = await Api.PostAsync<object>($"api/users/{Id}/reactivate", new { });
        if (resp?.Success == true)
        {
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "User reactivated" });
            await Load();
        }
        else { Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Failed", Detail = resp?.Errors?.FirstOrDefault() ?? "" }); }
        busy = false;
    }

}
