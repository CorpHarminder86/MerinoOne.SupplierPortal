@page "/admin/users"
@inject ApiClient Api
@inject TokenAccessor Token
@inject NavigationManager Nav

<PageTitle>Users</PageTitle>

<div class="tl-page">
    <header class="tl-header">
        <div>
            <div class="tl-title-row">
                <h1 class="tl-title">Users</h1>
                <span class="tl-count-chip">@(paged?.TotalCount ?? 0)</span>
            </div>
            <p class="tl-sub">Portal users — both internal staff and supplier contacts</p>
        </div>
        <div class="tl-header__actions">
            @if (Token.HasPermission("User.Write"))
            {
                <button class="rz-button rz-primary" style="padding:8px 14px;border-radius:6px;border:0;color:#fff;cursor:pointer;" @onclick="GoNew">
                    <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">person_add</span>
                    New user
                </button>
            }
        </div>
    </header>

    <div class="tl-filter-bar" style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
        <input class="rz-textbox" placeholder="Search code / name / email…" style="width:280px;padding:8px 12px;" @bind="search" @bind:event="oninput" @onkeyup="OnSearchKeyup" />
        <select class="rz-dropdown" style="padding:8px 12px;border:1px solid var(--mer-ink-300);border-radius:6px;background:var(--mer-surface);" @bind="internalFilter" @bind:after="ApplyFilters">
            <option value="">Internal: all</option>
            <option value="yes">Internal: Yes</option>
            <option value="no">Internal: No</option>
        </select>
        <select class="rz-dropdown" style="padding:8px 12px;border:1px solid var(--mer-ink-300);border-radius:6px;background:var(--mer-surface);" @bind="activeFilter" @bind:after="ApplyFilters">
            <option value="">Active: all</option>
            <option value="yes">Active: Yes</option>
            <option value="no">Active: No</option>
        </select>
    </div>

    @if (loading)
    {
        <div class="tl-empty">Loading…</div>
    }
    else if (paged == null || paged.Items.Count == 0)
    {
        <div class="tl-empty">
            <span class="material-symbols-outlined" style="font-size:32px;">group</span>
            <div>No users match.</div>
        </div>
    }
    else
    {
        <div class="tl-grid-wrapper" style="--tl-cols: 130px 1.4fr 1.4fr 1.2fr 90px 110px 90px; --tl-min-width: 1100px;">
            <div class="tlg-header">
                <div class="tlg-col">User code</div>
                <div class="tlg-col">Full name</div>
                <div class="tlg-col">Email</div>
                <div class="tlg-col">Roles</div>
                <div class="tlg-col">Internal</div>
                <div class="tlg-col tlg-col--num">Suppliers</div>
                <div class="tlg-col">Active</div>
            </div>
            @foreach (var u in paged.Items)
            {
                <div class="tlg-row" @onclick="() => OpenDetail(u.Id)" style="cursor:pointer">
                    <div class="tlg-col tlg-code">@u.UserCode</div>
                    <div class="tlg-col tlg-name">@u.FullName</div>
                    <div class="tlg-col tlg-desc">@u.Email</div>
                    <div class="tlg-col">@string.Join(", ", u.Roles ?? Array.Empty<string>())</div>
                    <div class="tlg-col">@(u.IsInternal ? "Yes" : "No")</div>
                    <div class="tlg-col tlg-col--num">@u.SupplierMapCount</div>
                    <div class="tlg-col"><span class="tlg-status @(u.IsActive ? "tlg-status--active" : "tlg-status--danger")">@(u.IsActive ? "Active" : "Inactive")</span></div>
                </div>
            }
        </div>

        <Pager Page="page" PageSize="PageSize" TotalCount="paged.TotalCount" PageChanged="OnPageChanged" />
    }
</div>

@code {
    private PagedResult<UserListItemDto>? paged;
    private bool loading = true;
    private string search = string.Empty;
    private string internalFilter = string.Empty;
    private string activeFilter = string.Empty;
    private int page = 1;
    private const int PageSize = 50;

    protected override async Task OnInitializedAsync() => await Reload();

    // Filters are applied server-side (the list is paged) — any filter change resets to page 1.
    private async Task ApplyFilters() { page = 1; await Reload(); }

    private async Task OnSearchKeyup(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await ApplyFilters();
    }

    private async Task Reload()
    {
        loading = true;
        var url = $"api/users?page={page}&pageSize={PageSize}";
        if (!string.IsNullOrWhiteSpace(search)) url += $"&search={Uri.EscapeDataString(search.Trim())}";
        if (internalFilter == "yes") url += "&isInternal=true";
        else if (internalFilter == "no") url += "&isInternal=false";
        if (activeFilter == "yes") url += "&isActive=true";
        else if (activeFilter == "no") url += "&isActive=false";

        var resp = await Api.GetAsync<PagedResult<UserListItemDto>>(url);
        paged = resp?.Data;
        loading = false;
    }

    private async Task OnPageChanged(int newPage) { page = newPage; await Reload(); }

    private void OpenDetail(Guid id) => Nav.NavigateToRoute($"/admin/users/{id}");
    private void GoNew() => Nav.NavigateToRoute("/admin/users/new");
}
