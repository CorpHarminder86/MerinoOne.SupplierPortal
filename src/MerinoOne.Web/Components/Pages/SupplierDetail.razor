    // ---- License actions ----
    private void OpenNewLicense()
    {
        editingLicenseId = null;
        licenseForm = new LicenseFormModel();
        licenseIssue = null;
        licenseExpiry = null;
        licenseError = string.Empty;
        // New license has no id yet — stage attachments under a fresh client-generated draft GUID.
        licenseStagingKey = Guid.NewGuid();
        licenseAttachments.Clear();
        attachError = string.Empty;
        attachUploading = false;
        showLicense = true;
    }

    private void OpenEditLicense(SupplierLicenseDto l)
    {
        editingLicenseId = l.Id;
        licenseForm = new LicenseFormModel { LicenseNumber = l.LicenseNumber, LicenseType = l.LicenseType, Remarks = l.Remarks };
        licenseIssue = l.IssueDate?.ToDateTime(TimeOnly.MinValue);
        licenseExpiry = l.ExpiryDate?.ToDateTime(TimeOnly.MinValue);
        licenseError = string.Empty;
        // Editing an existing license — attach directly against the license id; seed the list from the
        // attachments already loaded by GET /api/suppliers/{id}.
        licenseStagingKey = Guid.Empty;
        licenseAttachments.Clear();
        if (l.Attachments is { Count: > 0 } existing) licenseAttachments.AddRange(existing);
        attachError = string.Empty;
        attachUploading = false;
        showLicense = true;
    }

    // ---- License attachment upload / delete / preview ----
    private async Task OnLicenseFileSelectedAsync(InputFileChangeEventArgs e)
    {
        attachError = string.Empty;
        var file = e.File;
        if (file is null) return;
        if (file.Size > MaxAttachBytes)
        {
            attachError = $"File exceeds 5 MB ({(file.Size / 1024d / 1024d):0.0} MB).";
            return;
        }

        attachUploading = true;
        StateHasChanged();
        try
        {
            using var content = new MultipartFormDataContent();
            var streamContent = new StreamContent(file.OpenReadStream(MaxAttachBytes));
            streamContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(
                string.IsNullOrEmpty(file.ContentType) ? "application/octet-stream" : file.ContentType);
            content.Add(streamContent, "file", file.Name);

            // Existing license → attach onto the license row; new license → stage under the draft GUID.
            var isEdit = editingLicenseId.HasValue;
            content.Add(new StringContent(isEdit ? "SupplierLicense" : "Staging"), "ownerEntityType");
            content.Add(new StringContent((isEdit ? editingLicenseId!.Value : licenseStagingKey).ToString()), "ownerEntityId");
            content.Add(new StringContent(Id.ToString()), "supplierId");

            var resp = await Api.PostMultipartAsync<DocumentAttachmentDto>("api/document-uploads/attach", content);
            if (resp?.Success == true && resp.Data is not null)
            {
                licenseAttachments.Add(resp.Data);
            }
            else
            {
                attachError = resp?.Errors?.FirstOrDefault() ?? "Upload failed.";
            }
        }
        catch (Exception ex)
        {
            attachError = $"Upload failed: {ex.Message}";
        }
        finally
        {
            attachUploading = false;
            StateHasChanged();
        }
    }

    private async Task DeleteAttachment(DocumentAttachmentDto att)
    {
        attachError = string.Empty;
        var resp = await Api.DeleteAsync($"api/document-uploads/{att.Id}");
        if (resp?.Success == true)
        {
            licenseAttachments.Remove(att);
        }
        else
        {
            attachError = resp?.Errors?.FirstOrDefault() ?? "Failed to remove attachment.";
        }
    }

    private void PreviewAttachment(DocumentAttachmentDto att)
    {
        // DocumentAttachmentDto.PreviewUrl == "files/proxy/{id}" (base-href-relative, bearer-injected by the Web proxy).
        _previewDoc = new DocumentPreviewer.DocumentDescriptor(
