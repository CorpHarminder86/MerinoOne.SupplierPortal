    private bool RequireOverride => detail?.Verifications
        .GroupBy(v => v.VerificationType)
        .Select(g => g.OrderByDescending(v => v.AttemptedAt).First())
        .Any(v => v.Result == "Fail") == true;

    protected override async Task OnInitializedAsync()
    {
        await Load();
        // Currency dropdown source for the bank dialog. api/masters/currencies returns Id+Code+Description.
        var cur = await Api.GetAsync<List<CurrencyDto>>("api/masters/currencies?isActive=true");
        currencies = cur?.Data ?? new();
    }

    private async Task Load()
    {
        loading = true;
        var resp = await Api.GetAsync<SupplierDetailDto>($"api/suppliers/{Id}");
        detail = resp?.Data;
        loading = false;
    }

    // ---------------- Bank / License master read-only gating ----------------
    // Internal users with Supplier.Write may CRUD bank/license rows. A supplier's OWN master becomes
    // read-only once Active (§4) — edits then route through a Change Request (later increment). We treat
    // any supplier-role principal as read-once-Active; internal staff with the write permission keep CRUD.
    private bool ReadOnlyMaster => Token.IsSupplier && detail?.RegistrationStatus == "Active";
    private bool CanWriteMaster => !ReadOnlyMaster && Token.HasPermission("Supplier.Write");

    private async Task VerifyAll()
    {
        if (detail == null) return;
        busy = true;
        var types = new List<string>();
        if (!string.IsNullOrEmpty(detail.GstNumber)) types.Add("GST");
        if (!string.IsNullOrEmpty(detail.PanNumber)) types.Add("PAN");
        if (!string.IsNullOrEmpty(detail.MsmeRegNumber)) types.Add("MSME");
        var resp = await Api.PostAsync<List<SupplierVerificationDto>, VerifyNicRequest>(
            $"api/suppliers/{Id}/verify-nic", new VerifyNicRequest(types.ToArray()));
        Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Info, Summary = "Verification", Detail = $"{resp?.Data?.Count ?? 0} verifications recorded." });
        await Load();
        busy = false;
    }

    private void OpenApprove() { overrideComment = string.Empty; approveError = string.Empty; showApprove = true; }

    private async Task DoApprove()
    {
        busy = true; approveError = string.Empty;
        var resp = await Api.PostAsync<ApproveSupplierRequest>($"api/suppliers/{Id}/approve", new ApproveSupplierRequest(string.IsNullOrWhiteSpace(overrideComment) ? null : overrideComment));
        if (resp?.Success == true)
        {
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Approved", Detail = $"{detail!.LegalName} is now Active." });
            showApprove = false;
            await Load();
        }
        else
        {
            approveError = resp?.Errors?.FirstOrDefault() ?? "Approval failed.";
        }
        busy = false;
    }

