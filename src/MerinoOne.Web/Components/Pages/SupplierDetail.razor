    private static string AttachIcon(string contentType) =>
        contentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase) ? "image"
        : string.Equals(contentType, "application/pdf", StringComparison.OrdinalIgnoreCase) ? "picture_as_pdf"
        : "description";

    private async Task SaveLicense()
    {
        licenseError = string.Empty;
        if (string.IsNullOrWhiteSpace(licenseForm.LicenseNumber)) { licenseError = "License number is required."; return; }
        if (string.IsNullOrWhiteSpace(licenseForm.LicenseType)) { licenseError = "License type is required."; return; }
        DateOnly? issue = licenseIssue.HasValue ? DateOnly.FromDateTime(licenseIssue.Value) : null;
        DateOnly? expiry = licenseExpiry.HasValue ? DateOnly.FromDateTime(licenseExpiry.Value) : null;
        if (issue.HasValue && expiry.HasValue && expiry.Value < issue.Value) { licenseError = "Expiry date must be on or after issue date."; return; }
        var remarks = string.IsNullOrWhiteSpace(licenseForm.Remarks) ? null : licenseForm.Remarks!.Trim();

        busy = true;
        ApiResult<SupplierLicenseDto>? resp;
        if (editingLicenseId.HasValue)
        {
            // Edit: attachments were already bound directly to the license id as they were uploaded —
            // no staging rebind needed.
            var req = new UpdateSupplierLicenseRequest(licenseForm.LicenseNumber.Trim(), licenseForm.LicenseType.Trim(), remarks, issue, expiry);
            resp = await Api.PutAsync<SupplierLicenseDto, UpdateSupplierLicenseRequest>($"api/suppliers/{Id}/licenses/{editingLicenseId}", req);
        }
        else
        {
            // Create: pass the staging key so the backend atomically re-points the staged rows onto the new
            // license. (AttachmentIds left null → ALL rows under the key owned by the caller are rebound.)
            var req = new AddSupplierLicenseRequest(licenseForm.LicenseNumber.Trim(), licenseForm.LicenseType.Trim(), remarks, issue, expiry,
                StagingKey: licenseAttachments.Count > 0 ? licenseStagingKey : null);
            resp = await Api.PostAsync<SupplierLicenseDto, AddSupplierLicenseRequest>($"api/suppliers/{Id}/licenses", req);
        }
        if (resp?.Success == true) { Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Saved" }); showLicense = false; await Load(); }
        else { licenseError = resp?.Errors?.FirstOrDefault() ?? "Failed to save license."; }
        busy = false;
    }

