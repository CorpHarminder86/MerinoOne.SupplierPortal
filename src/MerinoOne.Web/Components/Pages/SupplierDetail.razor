                        <div><label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">License type *</label><input class="rz-textbox" style="width:100%;padding:8px 10px;" @bind="licenseForm.LicenseType" placeholder="e.g. GST, ISO 9001, Factory" /></div>
                        <div><label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Issue date</label><input type="date" class="rz-textbox" style="width:100%;padding:8px 10px;" @bind="licenseIssue" /></div>
