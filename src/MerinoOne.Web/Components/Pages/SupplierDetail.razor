@* Reusable preview overlay — rendered once, driven by _previewDoc state. *@
<DocumentPreviewer Doc="_previewDoc" OnClose="() => _previewDoc = null" />

@code {
    [Parameter] public Guid Id { get; set; }
    private SupplierDetailDto? detail;
    private bool loading = true;
    private bool busy = false;
    private bool showApprove = false;
    private string overrideComment = string.Empty;
    private string approveError = string.Empty;
    private string tab = "overview";

    private void TabOverview() => tab = "overview";
    private void TabUsers() => tab = "users";
    private void TabHistory() => tab = "history";

    // ---------------- Bank / License / PO-mode dialog state ----------------
    private List<CurrencyDto> currencies = new();

    private bool showBank;
    private Guid? editingBankId;
    private BankFormModel bankForm = new();
    private string bankError = string.Empty;
    // IFSC is conditionally required (INR only). Resolve the selected currency's code.
    private bool IfscRequired => currencies.FirstOrDefault(c => c.Id == bankForm.CurrencyId)?.Code?.Equals("INR", StringComparison.OrdinalIgnoreCase) == true;

    private bool showLicense;
    private Guid? editingLicenseId;
    private LicenseFormModel licenseForm = new();
    private DateTime? licenseIssue;
    private DateTime? licenseExpiry;
    private string licenseError = string.Empty;

    // License attachment state. For a NEW license we generate a client draft GUID (staging key); files are
    // uploaded immediately under ownerEntityType="Staging" and rebound onto the saved license via StagingKey
    // on create. For an EDIT we attach directly under ownerEntityType="SupplierLicense"/ownerEntityId=licenseId.
    private Guid licenseStagingKey;
    private readonly List<DocumentAttachmentDto> licenseAttachments = new();
    private bool attachUploading;
    private string attachError = string.Empty;
    private const long MaxAttachBytes = 5L * 1024 * 1024;

    private bool showPoMode;
    private string poModeValue = "Manual";
    private string poModeError = string.Empty;

    private static readonly System.Text.RegularExpressions.Regex IfscRegex =
        new("^[A-Z]{4}0[A-Z0-9]{6}$", System.Text.RegularExpressions.RegexOptions.Compiled);

    private sealed class BankFormModel
    {
        public string BankName = string.Empty;
        public string BankAddress = string.Empty;
        public string AccountName = string.Empty;
        public string AccountNumber = string.Empty;
        public Guid? CurrencyId;
        public string IfscCode = string.Empty;
        public string? SwiftCode;
        public bool IsPrimary;
    }

    private sealed class LicenseFormModel
    {
        public string LicenseNumber = string.Empty;
        public string LicenseType = string.Empty;
        public string? Remarks;
    }

    // ---- Bank actions ----
    private void OpenNewBank()
    {
        editingBankId = null;
        bankForm = new BankFormModel { IsPrimary = detail?.BankDetails.Count == 0 };
        bankError = string.Empty;
        showBank = true;
    }

    private void OpenEditBank(SupplierBankDetailDto b)
    {
        editingBankId = b.Id;
        bankForm = new BankFormModel
        {
            BankName = b.BankName,
            BankAddress = b.BankAddress,
            AccountName = b.AccountName,
            AccountNumber = b.AccountNumber,
            CurrencyId = b.CurrencyId,
            IfscCode = b.IfscCode,
            SwiftCode = b.SwiftCode,
            IsPrimary = b.IsPrimary,
        };
        bankError = string.Empty;
        showBank = true;
    }

    private async Task SaveBank()
    {
        bankError = string.Empty;
        if (string.IsNullOrWhiteSpace(bankForm.BankName)) { bankError = "Bank name is required."; return; }
        if (string.IsNullOrWhiteSpace(bankForm.BankAddress)) { bankError = "Bank address is required."; return; }
        if (string.IsNullOrWhiteSpace(bankForm.AccountName)) { bankError = "Account name is required."; return; }
        if (string.IsNullOrWhiteSpace(bankForm.AccountNumber)) { bankError = "Account number is required."; return; }
        if (bankForm.CurrencyId is null || bankForm.CurrencyId == Guid.Empty) { bankError = "Currency is required."; return; }
        var ifsc = (bankForm.IfscCode ?? string.Empty).Trim().ToUpperInvariant();
        if (IfscRequired)
        {
            if (string.IsNullOrWhiteSpace(ifsc)) { bankError = "IFSC code is required for INR accounts."; return; }
            if (!IfscRegex.IsMatch(ifsc)) { bankError = "IFSC must match ^[A-Z]{4}0[A-Z0-9]{6}$."; return; }
        }
        else if (!string.IsNullOrWhiteSpace(ifsc) && !IfscRegex.IsMatch(ifsc))
        {
            bankError = "IFSC must match ^[A-Z]{4}0[A-Z0-9]{6}$.";
            return;
        }

        busy = true;
        var swift = string.IsNullOrWhiteSpace(bankForm.SwiftCode) ? null : bankForm.SwiftCode!.Trim().ToUpperInvariant();
        ApiResult<SupplierBankDetailDto>? resp;
        if (editingBankId.HasValue)
        {
            var req = new UpdateSupplierBankDetailRequest(
                bankForm.BankName.Trim(), bankForm.BankAddress.Trim(), bankForm.AccountName.Trim(),
                bankForm.AccountNumber.Trim(), bankForm.CurrencyId!.Value, ifsc, swift, bankForm.IsPrimary);
            resp = await Api.PutAsync<SupplierBankDetailDto, UpdateSupplierBankDetailRequest>(
                $"api/suppliers/{Id}/bank-details/{editingBankId}", req);
        }
        else
        {
            var req = new AddSupplierBankDetailRequest(
                bankForm.BankName.Trim(), bankForm.BankAddress.Trim(), bankForm.AccountName.Trim(),
                bankForm.AccountNumber.Trim(), bankForm.CurrencyId!.Value, ifsc, swift, bankForm.IsPrimary);
            resp = await Api.PostAsync<SupplierBankDetailDto, AddSupplierBankDetailRequest>(
                $"api/suppliers/{Id}/bank-details", req);
        }
        if (resp?.Success == true) { Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Saved" }); showBank = false; await Load(); }
        else { bankError = resp?.Errors?.FirstOrDefault() ?? "Failed to save bank account."; }
        busy = false;
    }

