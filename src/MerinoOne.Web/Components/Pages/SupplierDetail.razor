@page "/suppliers/{Id:guid}"
@inject ApiClient Api
@inject TokenAccessor Token
@inject NavigationManager Nav
@inject NotificationService Notif
@inject DialogService Dialog

<PageTitle>@detail?.LegalName</PageTitle>

@if (loading)
{
    <div class="tl-empty">Loading…</div>
}
else if (detail == null)
{
    <div class="tl-empty">Supplier not found.</div>
}
else
{
    <div class="tl-page">
        <a href="suppliers" class="mer-back-link">
            <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">arrow_back</span>
            Back to list
        </a>
        <header class="tl-header">
            <div>
                <div class="tl-title-row">
                    <h1 class="tl-title">@detail.LegalName</h1>
                    <span class="tl-count-chip">@detail.SupplierCode</span>
                    <span class="tlg-status @StatusClass(detail.RegistrationStatus)">@detail.RegistrationStatus</span>
                </div>
                <p class="tl-sub">Seq #@detail.Seq · @detail.SupplierType · @detail.TradeName</p>
            </div>
            <div class="tl-header__actions">
                @if (Token.HasPermission("Supplier.VerifyNic"))
                {
                    <button class="rz-button rz-secondary" style="padding:8px 14px;border-radius:6px;border:0;color:#fff;cursor:pointer;" @onclick="VerifyAll" disabled="@busy">
                        <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">verified</span> Verify NIC
                    </button>
                }
                @if (Token.HasPermission("Supplier.Approve") && detail.RegistrationStatus != "Active" && detail.RegistrationStatus != "Approved")
                {
                    <button class="rz-button rz-primary" style="padding:8px 14px;border-radius:6px;border:0;color:#fff;cursor:pointer;" @onclick="OpenApprove">
                        <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">task_alt</span> Approve
                    </button>
                }
            </div>
        </header>

        <div class="mer-tabs" style="display:flex;gap:0;border-bottom:1px solid var(--mer-line);margin-bottom:16px;">
            <button class="mer-tab @(tab=="overview"?"mer-tab--active":"")" @onclick="TabOverview" style="padding:10px 16px;background:transparent;border:0;border-bottom:2px solid @(tab=="overview"?"var(--mer-blue)":"transparent");cursor:pointer;font:600 13px/1 'Plus Jakarta Sans',sans-serif;color:@(tab=="overview"?"var(--mer-blue)":"var(--mer-ink-700)");">Overview</button>
            <button class="mer-tab @(tab=="bank"?"mer-tab--active":"")" @onclick='() => tab = "bank"' style="padding:10px 16px;background:transparent;border:0;border-bottom:2px solid @(tab=="bank"?"var(--mer-blue)":"transparent");cursor:pointer;font:600 13px/1 'Plus Jakarta Sans',sans-serif;color:@(tab=="bank"?"var(--mer-blue)":"var(--mer-ink-700)");">Bank details (@detail.BankDetails.Count)</button>
            <button class="mer-tab @(tab=="licenses"?"mer-tab--active":"")" @onclick='() => tab = "licenses"' style="padding:10px 16px;background:transparent;border:0;border-bottom:2px solid @(tab=="licenses"?"var(--mer-blue)":"transparent");cursor:pointer;font:600 13px/1 'Plus Jakarta Sans',sans-serif;color:@(tab=="licenses"?"var(--mer-blue)":"var(--mer-ink-700)");">Licenses (@detail.Licenses.Count)</button>
            <button class="mer-tab @(tab=="users"?"mer-tab--active":"")" @onclick="TabUsers" style="padding:10px 16px;background:transparent;border:0;border-bottom:2px solid @(tab=="users"?"var(--mer-blue)":"transparent");cursor:pointer;font:600 13px/1 'Plus Jakarta Sans',sans-serif;color:@(tab=="users"?"var(--mer-blue)":"var(--mer-ink-700)");">Supplier users (@detail.LinkedUsers.Count)</button>
            <button class="mer-tab @(tab=="history"?"mer-tab--active":"")" @onclick="TabHistory" style="padding:10px 16px;background:transparent;border:0;border-bottom:2px solid @(tab=="history"?"var(--mer-blue)":"transparent");cursor:pointer;font:600 13px/1 'Plus Jakarta Sans',sans-serif;color:@(tab=="history"?"var(--mer-blue)":"var(--mer-ink-700)");">History</button>
        </div>

        @if (tab == "history")
        {
            <AuditHistoryTab EntityName="Supplier" EntityId="@Id" />
        }
        else if (tab == "bank")
        {
            @* ---------------- Bank details tab ---------------- *@
            <div class="rz-card" style="padding:20px;">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
                    <div>
                        <h3 style="font-size:14px;font-weight:700;margin-bottom:2px;color:var(--mer-blue-darker);">Bank accounts (@detail.BankDetails.Count)</h3>
                        <p style="color:var(--mer-ink-500);font-size:12px;">Settlement accounts. The primary account is starred and used by default for payments.</p>
                    </div>
                    @if (CanWriteMaster)
                    {
                        <button class="rz-button rz-primary" style="padding:8px 14px;border-radius:6px;border:0;color:#fff;cursor:pointer;" @onclick="OpenNewBank">
                            <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">add</span> Add account
                        </button>
                    }
                </div>

                @if (ReadOnlyMaster)
                {
                    <div style="background:var(--mer-amber-50);color:var(--mer-amber-800);padding:10px 14px;border-radius:6px;font-size:12px;margin-bottom:14px;display:flex;gap:8px;align-items:flex-start;">
                        <span class="material-symbols-outlined" style="font-size:16px;">info</span>
                        <span>This supplier is <b>Active</b>. Bank details are read-only here — edits must be submitted through a <b>Change Request</b> (available in a later release).</span>
                    </div>
                }

                @if (detail.BankDetails.Count == 0)
                {
                    <div class="tl-empty"><span class="material-symbols-outlined" style="font-size:32px;">account_balance</span><div>No bank accounts on file.</div></div>
                }
                else
                {
                    <div class="tl-grid-wrapper" style="--tl-cols: 1.4fr 1.2fr 1fr 90px 1fr 80px 110px; --tl-min-width: 980px;">
                        <div class="tlg-header">
                            <div class="tlg-col">Bank</div>
                            <div class="tlg-col">Account name</div>
                            <div class="tlg-col">Account no.</div>
                            <div class="tlg-col">Currency</div>
                            <div class="tlg-col">IFSC / SWIFT</div>
                            <div class="tlg-col">Primary</div>
                            <div class="tlg-col tlg-col--actions">Actions</div>
                        </div>
                        @foreach (var b in detail.BankDetails)
                        {
                            var bank = b;
                            <div class="tlg-row">
                                <div class="tlg-col tlg-desc">@bank.BankName<div style="font-size:11px;color:var(--mer-ink-500);">@bank.BankAddress</div></div>
                                <div class="tlg-col">@bank.AccountName</div>
                                <div class="tlg-col tlg-code">@bank.AccountNumber</div>
                                <div class="tlg-col tlg-code">@(bank.CurrencyCode ?? "—")</div>
                                <div class="tlg-col tlg-code">@bank.IfscCode@(string.IsNullOrEmpty(bank.SwiftCode) ? "" : $" · {bank.SwiftCode}")</div>
                                <div class="tlg-col">@if (bank.IsPrimary) { <span class="tlg-status tlg-status--active">Primary</span> } else { <span style="color:var(--mer-ink-400);">—</span> }</div>
                                <div class="tlg-col tlg-col--actions">
                                    @if (CanWriteMaster)
                                    {
                                        <button @onclick="() => OpenEditBank(bank)" style="background:transparent;border:0;color:var(--mer-blue);cursor:pointer;" title="Edit"><span class="material-symbols-outlined" style="font-size:18px;">edit</span></button>
                                        <button @onclick="() => DeleteBank(bank)" style="background:transparent;border:0;color:var(--mer-red);cursor:pointer;" title="Delete"><span class="material-symbols-outlined" style="font-size:18px;">delete</span></button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        }
        else if (tab == "licenses")
        {
            @* ---------------- Licenses tab ---------------- *@
            <div class="rz-card" style="padding:20px;">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
                    <div>
                        <h3 style="font-size:14px;font-weight:700;margin-bottom:2px;color:var(--mer-blue-darker);">Licenses &amp; certifications (@detail.Licenses.Count)</h3>
                        <p style="color:var(--mer-ink-500);font-size:12px;">Statutory licenses, registrations and certificates with issue / expiry tracking.</p>
                    </div>
                    @if (CanWriteMaster)
                    {
                        <button class="rz-button rz-primary" style="padding:8px 14px;border-radius:6px;border:0;color:#fff;cursor:pointer;" @onclick="OpenNewLicense">
                            <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">add</span> Add license
                        </button>
                    }
                </div>

                @if (ReadOnlyMaster)
                {
                    <div style="background:var(--mer-amber-50);color:var(--mer-amber-800);padding:10px 14px;border-radius:6px;font-size:12px;margin-bottom:14px;display:flex;gap:8px;align-items:flex-start;">
                        <span class="material-symbols-outlined" style="font-size:16px;">info</span>
                        <span>This supplier is <b>Active</b>. Licenses are read-only here — edits must be submitted through a <b>Change Request</b> (available in a later release).</span>
                    </div>
                }

                @if (detail.Licenses.Count == 0)
                {
                    <div class="tl-empty"><span class="material-symbols-outlined" style="font-size:32px;">workspace_premium</span><div>No licenses on file.</div></div>
                }
                else
                {
                    <div class="tl-grid-wrapper" style="--tl-cols: 1.2fr 1fr 1.4fr 110px 110px 1fr 110px; --tl-min-width: 1080px;">
                        <div class="tlg-header">
                            <div class="tlg-col">License no.</div>
                            <div class="tlg-col">Type</div>
                            <div class="tlg-col">Remarks</div>
                            <div class="tlg-col">Issued</div>
                            <div class="tlg-col">Expires</div>
                            <div class="tlg-col">Attachments</div>
                            <div class="tlg-col tlg-col--actions">Actions</div>
                        </div>
                        @foreach (var l in detail.Licenses)
                        {
                            var lic = l;
                            <div class="tlg-row">
                                <div class="tlg-col tlg-code">@lic.LicenseNumber</div>
                                <div class="tlg-col">@lic.LicenseType</div>
                                <div class="tlg-col" style="color:var(--mer-ink-700);">@(string.IsNullOrEmpty(lic.Remarks) ? "—" : lic.Remarks)</div>
                                <div class="tlg-col tlg-code">@(lic.IssueDate?.ToString("yyyy-MM-dd") ?? "—")</div>
                                <div class="tlg-col tlg-code">
                                    @if (lic.ExpiryDate is { } exp)
                                    {
                                        var days = exp.DayNumber - DateOnly.FromDateTime(DateTime.UtcNow).DayNumber;
                                        <span class="tlg-status @(days < 0 ? "tlg-status--danger" : days <= 30 ? "tlg-status--pending" : "tlg-status--active")">@exp.ToString("yyyy-MM-dd")</span>
                                    }
                                    else { <span>—</span> }
                                </div>
                                <div class="tlg-col">
                                    @if (lic.Attachments is { Count: > 0 } atts)
                                    {
                                        <div style="display:flex;flex-direction:column;gap:4px;">
                                            @foreach (var a in atts)
                                            {
                                                var att = a;
                                                <button type="button" @onclick="() => PreviewAttachment(att)" title="@att.FileName"
                                                        style="display:inline-flex;align-items:center;gap:5px;background:transparent;border:0;padding:0;cursor:pointer;color:var(--mer-blue);font-size:11.5px;text-align:left;max-width:100%;">
                                                    <span class="material-symbols-outlined" style="font-size:15px;">@AttachIcon(att.ContentType)</span>
                                                    <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@att.FileName</span>
                                                </button>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span style="color:var(--mer-ink-400);">—</span>
                                    }
                                </div>
                                <div class="tlg-col tlg-col--actions">
                                    @if (CanWriteMaster)
                                    {
                                        <button @onclick="() => OpenEditLicense(lic)" style="background:transparent;border:0;color:var(--mer-blue);cursor:pointer;" title="Edit"><span class="material-symbols-outlined" style="font-size:18px;">edit</span></button>
                                        <button @onclick="() => DeleteLicense(lic)" style="background:transparent;border:0;color:var(--mer-red);cursor:pointer;" title="Delete"><span class="material-symbols-outlined" style="font-size:18px;">delete</span></button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        }
        else if (tab == "users")
        {
            <div class="rz-card" style="padding:20px;">
                <h3 style="font-size:14px;font-weight:700;margin-bottom:4px;color:var(--mer-blue-darker);">Linked supplier users (@detail.LinkedUsers.Count)</h3>
                <p style="color:var(--mer-ink-500);font-size:12px;margin-bottom:14px;">Portal users mapped to this supplier. Manage mappings from the user's detail page (Admin › Users).</p>
                @if (detail.LinkedUsers.Count == 0)
                {
                    <p style="color:var(--mer-ink-500);font-size:13px;">No users are linked to this supplier yet.</p>
                }
                else
                {
                    <table style="width:100%;font-size:12.5px;border-collapse:collapse;">
                        <thead>
                            <tr style="border-bottom:1px solid var(--mer-line);">
                                <th style="text-align:left;padding:8px 4px;color:var(--mer-ink-700);">User code</th>
                                <th style="text-align:left;padding:8px 4px;color:var(--mer-ink-700);">Name</th>
                                <th style="text-align:left;padding:8px 4px;color:var(--mer-ink-700);">Email</th>
                                <th style="text-align:left;padding:8px 4px;color:var(--mer-ink-700);">Type</th>
                                <th style="text-align:left;padding:8px 4px;color:var(--mer-ink-700);">Access</th>
                                <th style="text-align:left;padding:8px 4px;color:var(--mer-ink-700);">Status</th>
                                <th style="text-align:right;padding:8px 4px;color:var(--mer-ink-700);"></th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var u in detail.LinkedUsers)
                        {
                            var usr = u;
                            <tr style="border-bottom:1px solid var(--mer-line-soft);">
                                <td style="padding:8px 4px;font-family:Inter,monospace;">@usr.UserCode</td>
                                <td style="padding:8px 4px;">@usr.FullName</td>
                                <td style="padding:8px 4px;font-family:Inter,monospace;">@usr.Email</td>
                                <td style="padding:8px 4px;">@(usr.IsInternal ? "Internal" : "Supplier")</td>
                                <td style="padding:8px 4px;">
                                    <span class="tlg-status @(usr.CanWrite ? "tlg-status--active" : "tlg-status--info")">@(usr.CanWrite ? "Read/Write" : "Read")</span>
                                </td>
                                <td style="padding:8px 4px;">
                                    <span class="tlg-status @(usr.IsActive ? "tlg-status--active" : "tlg-status--danger")">@(usr.IsActive ? "Active" : "Inactive")</span>
                                </td>
                                <td style="padding:8px 4px;text-align:right;">
                                    <a href="admin/users/@usr.UserId" class="rz-link" style="color:var(--mer-blue);text-decoration:none;font-size:12px;">
                                        <span class="material-symbols-outlined" style="font-size:15px;vertical-align:middle;">open_in_new</span> Manage
                                    </a>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
            </div>
        }
        else
        {
        @if (detail.InviteSummary != null)
        {
            <div class="rz-card" style="padding:20px;margin-bottom:16px;">
                <h3 style="font-size:14px;font-weight:700;margin-bottom:12px;color:var(--mer-blue-darker);">Invite summary</h3>
                <dl style="display:grid;grid-template-columns:160px 1fr 160px 1fr;gap:6px 16px;font-size:13px;">
                    <dt style="color:var(--mer-ink-500);">Legal name</dt><dd>@detail.InviteSummary.LegalName</dd>
                    <dt style="color:var(--mer-ink-500);">Email</dt><dd style="font-family:Inter,monospace;">@detail.InviteSummary.Email</dd>
                    <dt style="color:var(--mer-ink-500);">Mobile</dt><dd style="font-family:Inter,monospace;">@(detail.InviteSummary.MobileNo ?? "—")</dd>
                    <dt style="color:var(--mer-ink-500);">Invited by</dt><dd>@detail.InviteSummary.InvitedBy</dd>
                    <dt style="color:var(--mer-ink-500);">Invited at</dt><dd style="font-family:Inter,monospace;">@detail.InviteSummary.InvitedAt.ToString("yyyy-MM-dd HH:mm")</dd>
                    <dt style="color:var(--mer-ink-500);">Expires at</dt><dd style="font-family:Inter,monospace;">@detail.InviteSummary.ExpiresAt.ToString("yyyy-MM-dd HH:mm")</dd>
                    <dt style="color:var(--mer-ink-500);">Consumed</dt><dd style="font-family:Inter,monospace;">@(detail.InviteSummary.ConsumedAt?.ToString("yyyy-MM-dd HH:mm") ?? "—")</dd>
                    <dt style="color:var(--mer-ink-500);">Cancelled</dt><dd style="font-family:Inter,monospace;">@(detail.InviteSummary.CancelledAt?.ToString("yyyy-MM-dd HH:mm") ?? "—")</dd>
                    <dt style="color:var(--mer-ink-500);">Resends</dt><dd>@detail.InviteSummary.ResendCount @(detail.InviteSummary.LastResentAt != null ? $"(last {detail.InviteSummary.LastResentAt:yyyy-MM-dd HH:mm})" : "")</dd>
                    <dt style="color:var(--mer-ink-500);">Status</dt><dd><span class="tlg-status @StatusClass(detail.InviteSummary.Status)">@detail.InviteSummary.Status</span></dd>
                </dl>
            </div>
        }

        <div style="display:grid;grid-template-columns:1.5fr 1fr;gap:16px;">
            <div class="rz-card" style="padding:20px;">
                <h3 style="font-size:14px;font-weight:700;margin-bottom:12px;color:var(--mer-blue-darker);">Identity</h3>
                <dl style="display:grid;grid-template-columns:160px 1fr;gap:6px 16px;font-size:13px;">
                    <dt style="color:var(--mer-ink-500);">GST number</dt><dd style="font-family:Inter,monospace;">@detail.GstNumber @(detail.GstValidated ? Tick("ok") : "")</dd>
                    <dt style="color:var(--mer-ink-500);">PAN number</dt><dd style="font-family:Inter,monospace;">@detail.PanNumber @(detail.PanValidated ? Tick("ok") : "")</dd>
                    <dt style="color:var(--mer-ink-500);">MSME number</dt><dd style="font-family:Inter,monospace;">@detail.MsmeRegNumber @(detail.MsmeValidated ? Tick("ok") : "")</dd>
                    <dt style="color:var(--mer-ink-500);">Website</dt><dd>@detail.Website</dd>
                    <dt style="color:var(--mer-ink-500);">Invited</dt><dd>@(detail.InvitedAt?.ToString("yyyy-MM-dd"))  by @detail.InvitedBy</dd>
                    <dt style="color:var(--mer-ink-500);">Approved</dt><dd>@(detail.ApprovedAt?.ToString("yyyy-MM-dd"))  @(string.IsNullOrEmpty(detail.ApprovedBy) ? "" : "by " + detail.ApprovedBy)</dd>
                    @if (!string.IsNullOrEmpty(detail.ApprovalOverrideComment))
                    {
                        <dt style="color:var(--mer-ink-500);">Override comment</dt><dd style="background:var(--mer-amber-50);padding:6px 10px;border-radius:4px;">@detail.ApprovalOverrideComment</dd>
                    }
                </dl>
            </div>

            <div class="rz-card" style="padding:20px;">
                <h3 style="font-size:14px;font-weight:700;margin-bottom:12px;color:var(--mer-blue-darker);">NIC verifications</h3>
                @if (detail.Verifications.Count == 0)
                {
                    <p style="color:var(--mer-ink-500);font-size:13px;">No verifications attempted yet.</p>
                }
                else
                {
                    <table style="width:100%;font-size:12.5px;border-collapse:collapse;">
                        <thead>
                            <tr style="border-bottom:1px solid var(--mer-line);">
                                <th style="text-align:left;padding:6px 4px;color:var(--mer-ink-700);">Type</th>
                                <th style="text-align:left;padding:6px 4px;color:var(--mer-ink-700);">When</th>
                                <th style="text-align:left;padding:6px 4px;color:var(--mer-ink-700);">By</th>
                                <th style="text-align:left;padding:6px 4px;color:var(--mer-ink-700);">Result</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var v in detail.Verifications)
                        {
                            <tr style="border-bottom:1px solid var(--mer-line-soft);">
                                <td style="padding:6px 4px;">@v.VerificationType</td>
                                <td style="padding:6px 4px;font-family:Inter,monospace;">@v.AttemptedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                <td style="padding:6px 4px;">@v.AttemptedBy</td>
                                <td style="padding:6px 4px;"><span class="tlg-status @VStatusClass(v.Result)">@v.Result</span></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:16px;">
            <div class="rz-card" style="padding:20px;">
                <h3 style="font-size:14px;font-weight:700;margin-bottom:12px;color:var(--mer-blue-darker);">Commercial terms</h3>
                <dl style="display:grid;grid-template-columns:160px 1fr;gap:6px 16px;font-size:13px;">
                    <dt style="color:var(--mer-ink-500);">Currency</dt><dd style="font-family:Inter,monospace;">@(detail.CurrencyCode ?? "—")</dd>
                    <dt style="color:var(--mer-ink-500);">Payment term</dt><dd>@(detail.PaymentTermCode ?? "—")</dd>
                    <dt style="color:var(--mer-ink-500);">Delivery term</dt><dd>@(detail.DeliveryTermCode ?? "—")</dd>
                    <dt style="color:var(--mer-ink-500);">ERP code</dt><dd style="font-family:Inter,monospace;">@(detail.ErpCode ?? "—")</dd>
                </dl>

                <div style="border-top:1px solid var(--mer-line-soft);margin-top:14px;padding-top:14px;">
                    <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;">
                        <div>
                            <div style="font-size:12.5px;font-weight:600;color:var(--mer-ink-900);">PO response mode</div>
                            <div style="font-size:11.5px;color:var(--mer-ink-500);max-width:340px;">
                                @(detail.PoResponseMode == "Auto"
                                    ? "Auto — incoming POs are acknowledged and accepted automatically at release."
                                    : "Manual — the supplier must acknowledge / accept / reject each PO.")
                            </div>
                        </div>
                        <span class="tlg-status @(detail.PoResponseMode == "Auto" ? "tlg-status--info" : "tlg-status--active")">@detail.PoResponseMode</span>
                    </div>
                    @if (Token.HasPermission("Supplier.Approve"))
                    {
                        <button class="rz-button" style="margin-top:10px;padding:6px 12px;border-radius:6px;border:1px solid var(--mer-ink-300);background:var(--mer-surface);color:var(--mer-ink-700);cursor:pointer;font-size:12px;" @onclick="OpenPoMode" disabled="@busy">
                            <span class="material-symbols-outlined" style="font-size:15px;vertical-align:middle;">swap_horiz</span> Change mode
                        </button>
                    }
                </div>
            </div>

            <div class="rz-card" style="padding:20px;">
                <h3 style="font-size:14px;font-weight:700;margin-bottom:12px;color:var(--mer-blue-darker);">Addresses (@detail.Addresses.Count)</h3>
                @if (detail.Addresses.Count == 0)
                {
                    <p style="color:var(--mer-ink-500);font-size:13px;">No addresses on file.</p>
                }
                else
                {
                    @foreach (var a in detail.Addresses)
                    {
                        <div style="border:1px solid var(--mer-line);border-radius:6px;padding:10px 12px;margin-bottom:8px;background:var(--mer-ink-50);">
                            <div style="font-weight:600;font-size:12px;color:var(--mer-blue-darker);margin-bottom:4px;">@a.AddressType</div>
                            <div style="font-size:12.5px;color:var(--mer-ink-900);">@a.AddressLine1@(string.IsNullOrEmpty(a.AddressLine2) ? "" : $", {a.AddressLine2}")@(string.IsNullOrEmpty(a.Area) ? "" : $", {a.Area}")</div>
                            <div style="font-size:12.5px;color:var(--mer-ink-700);">@a.City, @a.State @a.Pincode · @a.Country</div>
                        </div>
                    }
                }
            </div>

            <div class="rz-card" style="padding:20px;">
                <h3 style="font-size:14px;font-weight:700;margin-bottom:12px;color:var(--mer-blue-darker);">Contacts (@detail.Contacts.Count)</h3>
                @if (detail.Contacts.Count == 0)
                {
                    <p style="color:var(--mer-ink-500);font-size:13px;">No contacts on file.</p>
                }
                else
                {
                    <table style="width:100%;font-size:12.5px;border-collapse:collapse;">
                        <thead>
                            <tr style="border-bottom:1px solid var(--mer-line);">
                                <th style="text-align:left;padding:6px 4px;color:var(--mer-ink-700);">Name</th>
                                <th style="text-align:left;padding:6px 4px;color:var(--mer-ink-700);">Designation</th>
                                <th style="text-align:left;padding:6px 4px;color:var(--mer-ink-700);">Email</th>
                                <th style="text-align:left;padding:6px 4px;color:var(--mer-ink-700);">Phone</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var c in detail.Contacts)
                        {
                            <tr style="border-bottom:1px solid var(--mer-line-soft);">
                                <td style="padding:6px 4px;">@c.ContactName @(c.IsPrimary ? "★" : "")</td>
                                <td style="padding:6px 4px;color:var(--mer-ink-700);">@c.Designation</td>
                                <td style="padding:6px 4px;font-family:Inter,monospace;">@c.Email</td>
                                <td style="padding:6px 4px;font-family:Inter,monospace;">@c.Phone</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        <div class="rz-card" style="padding:20px;margin-top:16px;">
            <h3 style="font-size:14px;font-weight:700;margin-bottom:12px;color:var(--mer-blue-darker);">Uploaded documents (@detail.Documents.Count)</h3>
            @if (detail.Documents.Count == 0)
            {
                <p style="color:var(--mer-ink-500);font-size:13px;">No documents uploaded.</p>
            }
            else
            {
                <div style="display:grid;grid-template-columns:repeat(auto-fill, minmax(220px, 1fr));gap:12px;">
                    @foreach (var d in detail.Documents)
                    {
                        var doc = d; // capture for closure
                        var isImage = doc.MimeType.StartsWith("image/", StringComparison.OrdinalIgnoreCase);
                        var isPdf = string.Equals(doc.MimeType, "application/pdf", StringComparison.OrdinalIgnoreCase);
                        var headIcon = isImage ? "image" : (isPdf ? "picture_as_pdf" : "description");
                        <div style="border:1px solid var(--mer-line);border-radius:8px;padding:12px;background:var(--mer-surface);display:flex;flex-direction:column;gap:8px;">
                            <div style="display:flex;align-items:center;gap:8px;">
                                <span class="material-symbols-outlined" style="font-size:20px;color:var(--mer-blue);">@headIcon</span>
                                <div style="flex:1;min-width:0;">
                                    <div style="font-size:12.5px;font-weight:600;color:var(--mer-ink-900);">@DocLabel(doc.DocumentType)</div>
                                    <div style="font-size:11px;color:var(--mer-ink-500);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@doc.FileName">@doc.FileName · @doc.FileSizeKb KB</div>
                                </div>
                            </div>
                            @* Clickable thumbnail tile — image MimeType renders the actual image,
                               PDF/other render a file-type tile. All open DocumentPreviewer modal. *@
                            <button type="button" @onclick="() => Preview(doc)"
                                    style="display:block;width:100%;height:120px;overflow:hidden;border-radius:6px;background:var(--mer-ink-50);border:0;padding:0;cursor:pointer;">
                                @if (isImage)
                                {
                                    <img src="@doc.FileUrl" alt="@doc.FileName" style="width:100%;height:100%;object-fit:cover;display:block;" />
                                }
                                else
                                {
                                    <div style="width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;color:var(--mer-ink-500);">
                                        <span class="material-symbols-outlined" style="font-size:38px;color:@(isPdf ? "var(--mer-red)" : "var(--mer-ink-400)");">@headIcon</span>
                                        <span style="font-size:11px;font-weight:600;">Click to preview</span>
                                    </div>
                                }
                            </button>
                            <div style="display:flex;align-items:center;gap:6px;font-size:11px;">
                                <span class="tlg-status @AiStatusClass(doc.AiValidationStatus)" title="AI validation">@doc.AiValidationStatus</span>
                                @if (doc.AiValidationConfidence.HasValue)
                                {
                                    <span style="color:var(--mer-ink-500);">@($"{(double)doc.AiValidationConfidence * 100:0}%")</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
        }
    </div>

    @if (showApprove)
    {
