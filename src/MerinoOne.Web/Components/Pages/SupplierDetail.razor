                    @if (!string.IsNullOrEmpty(licenseError)) { <div style="background:var(--mer-red-50);color:var(--mer-red);padding:8px 12px;border-radius:6px;font-size:12px;margin-top:8px;">@licenseError</div> }
                </div>
                <footer class="merino-dialog__footer">
                    <div class="merino-dialog__actions">
                        <button class="merino-dialog__btn" data-intent="ghost" @onclick="() => showLicense = false">Cancel</button>
                        <button class="merino-dialog__btn" data-intent="primary" @onclick="SaveLicense" disabled="@busy">@(busy ? "Saving…" : "Save")</button>
                    </div>
                </footer>
            </div>
        </div>
    }

