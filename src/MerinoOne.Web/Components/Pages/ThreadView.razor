@page "/threads/{ThreadId:guid}"
@inject ApiClient Api
@inject TokenAccessor Token

<PageTitle>Thread</PageTitle>

<div class="tl-page" style="max-width:900px;">
    <header class="tl-header">
        <div>
            <div class="tl-title-row">
                <h1 class="tl-title">Thread</h1>
                <span class="tl-count-chip">@(messages?.Count ?? 0)</span>
            </div>
            <p class="tl-sub">@ThreadId</p>
        </div>
    </header>

    @if (loading)
    {
        <div class="tl-empty">Loading…</div>
    }
    else
    {
        <div class="rz-card" style="padding:16px;display:flex;flex-direction:column;gap:10px;margin-bottom:16px;">
            @foreach (var m in messages!)
            {
                var mine = m.SenderName == Token.FullName;
                <div style="display:flex;@(mine ? "justify-content:flex-end;" : "")">
                    <div style="max-width:70%;background:@(mine ? "var(--mer-blue-50)" : "var(--mer-ink-50)");padding:10px 14px;border-radius:10px;">
                        <div style="font-size:11px;color:var(--mer-ink-500);font-weight:600;margin-bottom:4px;">@m.SenderName · @m.SentAt.ToString("yyyy-MM-dd HH:mm")</div>
                        <div style="font-size:13px;">@m.MessageBody</div>
                    </div>
                </div>
            }
        </div>

        <div class="rz-card" style="padding:14px;">
            <textarea class="rz-textbox" rows="3" placeholder="Reply…" style="width:100%;padding:8px 10px;font-family:inherit;margin-bottom:8px;" @bind="reply"></textarea>
            <div style="display:flex;justify-content:flex-end;">
                <button class="rz-button rz-primary" style="padding:8px 16px;border-radius:6px;border:0;color:#fff;cursor:pointer;" disabled="@busy" @onclick="Send">@(busy ? "Sending…" : "Send")</button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public Guid ThreadId { get; set; }
    private List<MessageDto>? messages;
    private bool loading = true;
    private string reply = string.Empty;
    private bool busy = false;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        loading = true;
        var resp = await Api.GetAsync<List<MessageDto>>($"api/threads/{ThreadId}");
        messages = resp?.Data ?? new();
        loading = false;
    }

    private async Task Send()
    {
        if (string.IsNullOrWhiteSpace(reply)) return;
        busy = true;
        await Api.PostAsync<MessageDto, SendMessageRequest>("api/messages",
            new SendMessageRequest(ThreadId, null, null, reply, null));
        reply = string.Empty;
        await Load();
        busy = false;
    }
}
