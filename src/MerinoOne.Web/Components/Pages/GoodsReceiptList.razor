@page "/goods-receipts"
@inject ApiClient Api

<PageTitle>Goods Receipts</PageTitle>

<div class="tl-page">
    <header class="tl-header">
        <div>
            <div class="tl-title-row">
                <h1 class="tl-title">Goods Receipts</h1>
                <span class="tl-count-chip">@(paged?.TotalCount ?? 0)</span>
            </div>
            <p class="tl-sub">Read-only — receipts confirmed by warehouse via Infor</p>
        </div>
    </header>

    @if (loading)
    {
        <div class="tl-empty">Loading…</div>
    }
    else if (paged == null || paged.Items.Count == 0)
    {
        <div class="tl-empty">
            <span class="material-symbols-outlined" style="font-size:32px;">inventory_2</span>
            <div>No goods receipts.</div>
        </div>
    }
    else
    {
        <div class="tl-grid-wrapper" style="--tl-cols: 150px 120px 130px 1fr 110px 100px 100px 120px; --tl-min-width: 1150px;">
            <div class="tlg-header">
                <div class="tlg-col">GRN #</div>
                <div class="tlg-col tlg-col--num">PO Pos</div>
                <div class="tlg-col">PO #</div>
                <div class="tlg-col">Item</div>
                <div class="tlg-col">ASN</div>
                <div class="tlg-col tlg-col--num">Received</div>
                <div class="tlg-col tlg-col--num">Short</div>
                <div class="tlg-col">Date</div>
            </div>
            @foreach (var g in paged.Items)
            {
                <div class="tlg-row">
                    <div class="tlg-col tlg-code">@g.GrnNumber</div>
                    <div class="tlg-col tlg-col--num">@g.PoPositionNo</div>
                    <div class="tlg-col tlg-code">@g.PoNumber</div>
                    <div class="tlg-col">@g.ItemCode</div>
                    <div class="tlg-col tlg-code">@g.AsnNumber</div>
                    <div class="tlg-col tlg-col--num">@g.ReceivedQty.ToString("0.###")</div>
                    <div class="tlg-col tlg-col--num">@(g.ShortQty > 0 ? g.ShortQty.ToString("0.###") : "—")</div>
                    <div class="tlg-col tlg-code">@g.GrnDate.ToString("yyyy-MM-dd")</div>
                </div>
            }
        </div>

        <Pager Page="page" PageSize="PageSize" TotalCount="paged.TotalCount" PageChanged="OnPageChanged" />
    }
</div>

@code {
    private PagedResult<GoodsReceiptListItemDto>? paged;
    private bool loading = true;
    private int page = 1;
    private const int PageSize = 50;

    protected override async Task OnInitializedAsync() => await Reload();

    private async Task Reload()
    {
        loading = true;
        var resp = await Api.GetAsync<PagedResult<GoodsReceiptListItemDto>>($"api/goods-receipts?page={page}&pageSize={PageSize}");
        paged = resp?.Data;
        loading = false;
    }

    private async Task OnPageChanged(int newPage) { page = newPage; await Reload(); }
}
