@page "/asns/new"
@page "/asns/{Id:guid}"
@inject ApiClient Api
@inject NavigationManager NavMgr
@inject TokenAccessor Token
@inject NotificationService Notif

<PageTitle>@(IsNew ? "New ASN" : detail?.AsnNumber)</PageTitle>

<div class="tl-page">
    <a href="asns" class="mer-back-link">
        <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">arrow_back</span>
        Back to list
    </a>
    <header class="tl-header">
        <div>
            <div class="tl-title-row">
                <h1 class="tl-title">@(IsNew ? "Create ASN" : detail?.AsnNumber)</h1>
                @if (!IsNew && detail != null)
                {
                    <span class="tlg-status @StatusClass(detail.AsnStatus)">@detail.AsnStatus</span>
                    @if (IsLocked)
                    {
                        <span class="tl-count-chip" style="background:var(--mer-ink-100);color:var(--mer-ink-600);">
                            <span class="material-symbols-outlined" style="font-size:14px;vertical-align:middle;">lock</span> Read-only
                        </span>
                    }
                }
                else
                {
                    <span class="tl-count-chip">Step @currentStep of 4</span>
                }
            </div>
            <p class="tl-sub">@HeaderSubtitle</p>
        </div>
        <div class="tl-header__actions">
            @* R7 (§2.2) — document-rail toggle pill with the live fulfilment count. Rendered whenever the rail is
               (both the locked view and the wizard host one); the two-way Open state is shared with the rail. *@
            @if (!loading && (IsNew || detail != null))
            {
                <DocumentRailPill Open="@railOpen" OpenChanged="OnRailOpenChanged"
                                  Satisfied="@(railSummary?.SatisfiedSlots ?? 0)"
                                  Total="@(railSummary?.TotalSlots ?? 0)" />
            }
            @* R5 (§10.2) — buyer decision actions on a PendingApproval ASN. Any mapped PO buyer may decide (Phase 1);
               the server gate (AsnApprovalGate) is authoritative, so we only gate the affordance on Asn.Approve. *@
            @if (!IsNew && detail != null && CanApprove && detail.AsnStatus == "PendingApproval")
            {
                @* §6.2 — a buyer cannot approve OR reject while the ASN's PO is not shippable (e.g. reset to Released
                   by an ERP Modify); both actions are disabled with the reason until the PO is re-confirmed. *@
                <button class="rz-button" style="padding:8px 14px;border-radius:6px;border:1px solid var(--mer-red);background:var(--mer-surface);color:var(--mer-red);cursor:pointer;" @onclick="OpenRejectDialog" disabled="@(busy || detail.ShipBlocked)" title="@(detail.ShipBlocked ? detail.ShipBlockReason : null)">
                    <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">cancel</span> Reject…
                </button>
                <button class="rz-button rz-secondary" style="padding:8px 14px;border-radius:6px;border:0;color:#fff;cursor:pointer;" @onclick="OpenApproveDialog" disabled="@(busy || detail.ShipBlocked)" title="@(detail.ShipBlocked ? detail.ShipBlockReason : null)">
                    <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">task_alt</span> Approve
                </button>
            }
            @* Cancel — supplier-side, available on any of the supplier's active states (Draft / Rejected / PendingApproval).
               A Rejected ASN renders the editable wizard (IsLocked=false); a PendingApproval ASN renders the read-only
               view (IsLocked=true) but the supplier can still withdraw it via Cancel, so this is gated on status, not IsLocked. *@
            @if (!IsNew && detail != null && CanWrite && CanCancel)
            {
                <button class="rz-button" style="padding:8px 14px;border-radius:6px;border:1px solid var(--mer-red);background:var(--mer-surface);color:var(--mer-red);cursor:pointer;" @onclick="OpenCancelDialog" disabled="@busy">
                    <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">block</span> Cancel ASN
                </button>
            }
            <button class="rz-button" style="padding:8px 14px;border-radius:6px;border:1px solid var(--mer-ink-300);background:var(--mer-surface);cursor:pointer;" @onclick="BackToList">Close</button>
        </div>
    </header>

    @* ---------------- R5 (§10.2) approval-session banners (shown in BOTH the editable + read-only branches) ---------------- *@
    @if (!IsNew && detail != null && !loading)
    {
        @* Rejection banner — a Rejected ASN renders the editable wizard; the supplier needs the buyer's reason in view
           while they fix it. Saving an edit returns the ASN to Draft (server flips Rejected→Draft). *@
        @if (detail.AsnStatus == "Rejected")
        {
            <div class="rz-card" style="padding:14px 18px;margin-bottom:16px;display:flex;align-items:flex-start;gap:12px;background:var(--mer-red-50);border:1px solid var(--mer-red);">
                <span class="material-symbols-outlined" style="font-size:22px;color:var(--mer-red);">gpp_bad</span>
                <div style="flex:1;">
                    <div style="font-size:13px;font-weight:700;color:var(--mer-red);">Returned by the buyer</div>
                    <div style="font-size:12.5px;color:var(--mer-ink-700);white-space:pre-wrap;margin-top:2px;">@(string.IsNullOrWhiteSpace(detail.Approval?.Reason) ? "No reason was recorded." : detail.Approval!.Reason)</div>
                    @if (detail.Approval is { } ra)
                    {
                        <div style="font-size:11px;color:var(--mer-ink-500);font-family:Inter,monospace;margin-top:6px;">
                            @(string.IsNullOrEmpty(ra.DecisionBy) ? "" : $"by {ra.DecisionBy} ")@(ra.DecisionOn?.ToString("· yyyy-MM-dd HH:mm"))
                        </div>
                    }
                    <div style="font-size:12px;color:var(--mer-ink-600);margin-top:8px;">Edit the lines / details below and send it for approval again. Saving any change returns the ASN to <b>Draft</b>.</div>
                </div>
            </div>
        }
        @* PendingApproval banner — visible to supplier (status, read-only) and buyer (deciding). Shows the submitted-by/on. *@
        else if (detail.AsnStatus == "PendingApproval" && detail.Approval is { } pa)
        {
            <div class="rz-card" style="padding:14px 18px;margin-bottom:16px;display:flex;align-items:flex-start;gap:12px;background:var(--mer-amber-50);border:1px solid var(--mer-amber-800);">
                <span class="material-symbols-outlined" style="font-size:22px;color:var(--mer-amber-800);">hourglass_top</span>
                <div style="flex:1;">
                    <div style="font-size:13px;font-weight:700;color:var(--mer-amber-800);">Awaiting buyer approval</div>
                    <div style="font-size:12px;color:var(--mer-ink-700);font-family:Inter,monospace;margin-top:2px;">
                        Sent by @(string.IsNullOrEmpty(pa.SubmittedBy) ? "—" : pa.SubmittedBy) · @pa.SubmittedOn.ToString("yyyy-MM-dd HH:mm")
                    </div>
                    @if (CanApprove)
                    {
                        @if (detail.ShipBlocked)
                        {
                            @* §6.2 — the PO is no longer shippable (e.g. re-Released by an ERP Modify): the buyer can
                               neither approve (would ship) nor reject until the PO is re-confirmed. *@
                            <div style="font-size:12px;color:var(--mer-amber-800);font-weight:600;margin-top:8px;">
                                <span class="material-symbols-outlined" style="font-size:15px;vertical-align:middle;">block</span>
                                @detail.ShipBlockReason Approve and Reject are disabled until the PO is re-confirmed.
                            </div>
                        }
                        else
                        {
                            <div style="font-size:12px;color:var(--mer-ink-600);margin-top:8px;">Review the lines, attachments and shipment details below, then <b>Approve</b> (submits the shipment) or <b>Reject</b> with a reason.</div>
                        }
                    }
                    else
                    {
                        <div style="font-size:12px;color:var(--mer-ink-600);margin-top:8px;">The ASN is read-only until the buyer decides. You can cancel it if it was sent in error.</div>
                    }
                </div>
            </div>
        }
        @* Approved/submitted note (the approval session that led to Submitted) — small provenance line on the locked view. *@
        else if (detail.Approval is { Status: "Approved" } ap && (detail.AsnStatus == "Submitted" || detail.AsnStatus == "InTransit" || detail.AsnStatus == "Delivered"))
        {
            <div class="rz-card" style="padding:10px 16px;margin-bottom:16px;display:flex;align-items:center;gap:10px;background:var(--mer-green-50);border:1px solid var(--mer-green);">
                <span class="material-symbols-outlined" style="font-size:18px;color:var(--mer-green-dark);">verified</span>
                <div style="font-size:12px;color:var(--mer-ink-700);font-family:Inter,monospace;">
                    Approved@(string.IsNullOrEmpty(ap.DecisionBy) ? "" : $" by {ap.DecisionBy}")@(ap.DecisionOn?.ToString(" · yyyy-MM-dd HH:mm")) · sent by @(string.IsNullOrEmpty(ap.SubmittedBy) ? "—" : ap.SubmittedBy)
                </div>
            </div>
        }
    }

    @if (loading)
    {
        <div class="tl-empty">Loading…</div>
    }
    else if (!IsNew && detail == null)
    {
        <div class="tl-empty">ASN not found.</div>
    }
    else if (IsLocked && detail != null)
    {
        @* ---------------- Read-only (Submitted/Cancelled) view ---------------- *@
        @* R6 — grouped draft-invoice generation surface. "Blocked" (a PO-line tax has no resolvable rate) shows
           the note + a Retry (POST api/invoices/from-asn — the same idempotent generator); "Generated" lists ALL
           the drafts (one per PO currency/payment-term group). Legacy rows predating InvoiceGenerationStatus fall
           back to the scalar DraftInvoiceId. *@
        var draftInvoiceIds = detail.DraftInvoiceIds is { Count: > 0 } genIds
            ? genIds.ToList()
            : (detail.DraftInvoiceId.HasValue ? new List<Guid> { detail.DraftInvoiceId.Value } : new List<Guid>());

        @* ---- R7 (§2) — document-rail push row: main column (banners + cards) beside the 360px rail. The
              min-width:0 on the main flex child lets it shrink so the rail pushes, never overlays/overflows.
              The read-only host defaults the rail CLOSED (§2.3 — the Mandatory check already passed at
              Send-for-Approval); the header pill still shows the live count. ---- *@
        <div style="display:flex;align-items:stretch;">
        <div style="flex:1;min-width:0;">

        @if (detail.InvoiceGenerationStatus == "Blocked")
        {
            <div class="rz-card" style="padding:14px 18px;margin-bottom:16px;display:flex;align-items:flex-start;gap:12px;background:var(--mer-red-50);border:1px solid var(--mer-red);">
                <span class="material-symbols-outlined" style="font-size:22px;color:var(--mer-red);">report</span>
                <div style="flex:1;">
                    <div style="font-size:13px;font-weight:700;color:var(--mer-red);">Invoice generation blocked</div>
                    <div style="font-size:12.5px;color:var(--mer-ink-700);white-space:pre-wrap;margin-top:2px;">@(string.IsNullOrWhiteSpace(detail.InvoiceGenerationNote) ? "Draft invoice generation could not run for this ASN." : detail.InvoiceGenerationNote)</div>
                    @if (!string.IsNullOrEmpty(invoiceRetryError))
                    {
                        <div style="font-size:12px;color:var(--mer-red);font-weight:600;margin-top:6px;">@invoiceRetryError</div>
                    }
                    <div style="font-size:12px;color:var(--mer-ink-600);margin-top:6px;">Once the named tax code has a rate in the tax master, retry the generation.</div>
                </div>
                @if (Token.IsSupplier || Token.HasPermission("Invoice.Submit"))
                {
                    <button class="rz-button" style="padding:8px 14px;border-radius:6px;border:1px solid var(--mer-red);background:var(--mer-surface);color:var(--mer-red);cursor:pointer;flex:none;" @onclick="RetryInvoiceGeneration" disabled="@invoiceRetryBusy">
                        <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">refresh</span> @(invoiceRetryBusy ? "Retrying…" : "Retry generation")
                    </button>
                }
            </div>
        }
        else if (draftInvoiceIds.Count > 0)
        {
            <div class="rz-card" style="padding:14px 18px;margin-bottom:16px;display:flex;align-items:center;gap:12px;flex-wrap:wrap;background:var(--mer-green-50);border:1px solid var(--mer-green);">
                <span class="material-symbols-outlined" style="font-size:22px;color:var(--mer-green-dark);">receipt_long</span>
                <div style="flex:1;min-width:240px;">
                    <div style="font-size:13px;font-weight:700;color:var(--mer-blue-darker);">@(draftInvoiceIds.Count == 1 ? "Draft invoice created" : $"{draftInvoiceIds.Count} draft invoices created")</div>
                    <div style="font-size:12px;color:var(--mer-ink-600);">@(draftInvoiceIds.Count == 1 ? "A draft invoice spanning this ASN's PO(s) was generated on approval." : "One draft invoice per PO currency / payment-term group was generated on approval.")</div>
                </div>
                @for (var i = 0; i < draftInvoiceIds.Count; i++)
                {
                    var draftId = draftInvoiceIds[i];
                    var draftLabel = draftInvoiceIds.Count == 1 ? "Open draft invoice" : $"Draft invoice #{i + 1}";
                    <a href="invoices/@draftId" class="rz-button rz-primary" style="padding:8px 14px;border-radius:6px;border:0;color:#fff;text-decoration:none;flex:none;">@draftLabel</a>
                }
            </div>
        }

        @* R7 (§2/§3.2) — the old 1.4fr/1fr grid (Shipment beside the always-expanded panel) is gone: the document
           surface moved into the right rail, and the Shipment card spans the full main column. *@
        <div class="rz-card" style="padding:20px;">
                <h3 style="font-size:14px;font-weight:700;margin-bottom:12px;color:var(--mer-blue-darker);">Shipment</h3>
                <dl style="display:grid;grid-template-columns:160px 1fr;gap:6px 16px;font-size:13px;">
                    <dt style="color:var(--mer-ink-500);">Purchase order(s)</dt><dd>@PoSummaryText</dd>
                    <dt style="color:var(--mer-ink-500);">Expected delivery</dt><dd style="font-family:Inter,monospace;">@detail.ExpectedDeliveryDate.ToString("yyyy-MM-dd")</dd>
                    @if (!string.IsNullOrEmpty(detail.TimeWindow)) { <dt style="color:var(--mer-ink-500);">Time window</dt><dd>@detail.TimeWindow</dd> }
                    @if (!string.IsNullOrEmpty(detail.CarrierName)) { <dt style="color:var(--mer-ink-500);">Carrier</dt><dd>@detail.CarrierName</dd> }
                    @if (!string.IsNullOrEmpty(detail.TrackingNumber)) { <dt style="color:var(--mer-ink-500);">Tracking</dt><dd style="font-family:Inter,monospace;">@detail.TrackingNumber</dd> }
                    @if (!string.IsNullOrEmpty(detail.VehicleNumber)) { <dt style="color:var(--mer-ink-500);">Vehicle</dt><dd style="font-family:Inter,monospace;">@detail.VehicleNumber</dd> }
                    @if (!string.IsNullOrEmpty(detail.DriverName)) { <dt style="color:var(--mer-ink-500);">Driver</dt><dd>@detail.DriverName @(string.IsNullOrEmpty(detail.DriverPhone) ? "" : $"· {detail.DriverPhone}")</dd> }
                    @if (detail.SubmittedAt.HasValue) { <dt style="color:var(--mer-ink-500);">Submitted</dt><dd style="font-family:Inter,monospace;">@detail.SubmittedAt.Value.ToString("yyyy-MM-dd HH:mm") @(string.IsNullOrEmpty(detail.SubmittedBy) ? "" : $"by {detail.SubmittedBy}")</dd> }
                    @if (!string.IsNullOrEmpty(detail.ErpSyncId)) { <dt style="color:var(--mer-ink-500);">ERP sync id</dt><dd style="font-family:Inter,monospace;font-size:11px;">@detail.ErpSyncId</dd> }
                    @if (!string.IsNullOrEmpty(detail.ErpCode)) { <dt style="color:var(--mer-ink-500);">ERP code</dt><dd style="font-family:Inter,monospace;">@detail.ErpCode</dd> }
                </dl>
                @if (!string.IsNullOrEmpty(detail.Notes))
                {
                    <h4 style="font-size:12px;font-weight:700;margin:16px 0 6px;color:var(--mer-ink-700);">Notes</h4>
                    <p style="font-size:13px;color:var(--mer-ink-700);white-space:pre-wrap;">@detail.Notes</p>
                }
        </div>

        <div class="rz-card" style="padding:20px;margin-top:16px;">
            <h3 style="font-size:14px;font-weight:700;margin-bottom:12px;color:var(--mer-blue-darker);">Lines (@detail.Lines.Count)</h3>
            <table style="width:100%;font-size:12.5px;border-collapse:collapse;">
                <thead>
                    <tr style="border-bottom:1px solid var(--mer-line);">
                        <th style="text-align:left;padding:6px 4px;color:var(--mer-ink-700);">PO</th>
                        <th style="text-align:right;padding:6px 4px;color:var(--mer-ink-700);">Pos</th>
                        <th style="text-align:right;padding:6px 4px;color:var(--mer-ink-700);">Seq</th>
                        <th style="text-align:left;padding:6px 4px;color:var(--mer-ink-700);">Item</th>
                        <th style="text-align:right;padding:6px 4px;color:var(--mer-ink-700);">Order Qty</th>
                        <th style="text-align:right;padding:6px 4px;color:var(--mer-ink-700);">Ship Qty</th>
                        <th style="text-align:left;padding:6px 4px;color:var(--mer-ink-700);">Balance / allowance</th>
                        <th style="text-align:left;padding:6px 4px;color:var(--mer-ink-700);">Batch</th>
                        <th style="text-align:left;padding:6px 4px;color:var(--mer-ink-700);">Expiry</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var ln in detail.Lines)
                {
                    var line = ln;
                    var hasSerials = line.Serials is { Count: > 0 };
                    var hasLots = line.Lots is { Count: > 0 };
                    <tr style="border-bottom:1px solid var(--mer-line-soft);">
                        <td style="padding:6px 4px;font-family:Inter,monospace;">@line.PoNumber</td>
                        <td style="padding:6px 4px;text-align:right;font-family:Inter,monospace;">@(line.PositionNo ?? line.PoPositionNo)</td>
                        <td style="padding:6px 4px;text-align:right;font-family:Inter,monospace;">@(line.SequenceNo?.ToString() ?? "—")</td>
                        <td style="padding:6px 4px;font-family:Inter,monospace;">@line.ItemCode</td>
                        <td style="padding:6px 4px;text-align:right;font-family:Inter,monospace;">@line.OrderQty.ToString("0.###")</td>
                        <td style="padding:6px 4px;text-align:right;font-family:Inter,monospace;">@line.ShippedQty.ToString("0.###")</td>
                        <td style="padding:6px 4px;">@DetailBalanceCell(line)</td>
                        <td style="padding:6px 4px;">@(string.IsNullOrEmpty(line.BatchNumber) ? "—" : line.BatchNumber)</td>
                        <td style="padding:6px 4px;font-family:Inter,monospace;">@(line.ExpiryDate?.ToString("yyyy-MM-dd") ?? "—")</td>
                    </tr>
                    @if (hasSerials)
                    {
                        <tr style="border-bottom:1px solid var(--mer-line-soft);">
                            <td colspan="9" style="padding:4px 4px 10px 16px;">
                                <div style="font-size:11px;font-weight:700;color:var(--mer-ink-600);margin-bottom:4px;">Serials (@line.Serials!.Count)</div>
                                <div style="display:flex;flex-wrap:wrap;gap:4px;">
                                    @foreach (var s in line.Serials!)
                                    {
                                        <span style="font-family:Inter,monospace;font-size:11px;background:var(--mer-ink-50);border:1px solid var(--mer-line);border-radius:4px;padding:2px 6px;">@s.SerialNumber@(s.ExpiryDate is { } ex ? $" · exp {ex:yyyy-MM-dd}" : "")</span>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                    @if (hasLots)
                    {
                        <tr style="border-bottom:1px solid var(--mer-line-soft);">
                            <td colspan="9" style="padding:4px 4px 10px 16px;">
                                <div style="font-size:11px;font-weight:700;color:var(--mer-ink-600);margin-bottom:4px;">Lots (@line.Lots!.Count)</div>
                                <div style="display:flex;flex-wrap:wrap;gap:6px;">
                                    @foreach (var lot in line.Lots!)
                                    {
                                        <span style="font-family:Inter,monospace;font-size:11px;background:var(--mer-green-soft);border:1px solid var(--mer-green);border-radius:4px;padding:2px 6px;">@lot.LotNo · @lot.Qty.ToString("0.###")@(lot.ExpiryDate.HasValue ? $" · exp {lot.ExpiryDate:yyyy-MM-dd}" : "")@(string.IsNullOrEmpty(lot.ErpCode) ? "" : $" · {lot.ErpCode}")</span>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>

        </div>
        @* R7 (§13.5 semantics unchanged) — the read-only document surface for the locked view (PendingApproval:
           supplier read-only + deciding buyer; Submitted+: view-only for everyone) now lives in the rail. The
           panel inside still renders nothing when no policy rows exist; Editable=false ⇒ no upload/remove. *@
        <DocumentRail EntityCode="Asn"
                      EntityId="@detail.Id"
                      Editable="false"
                      SupplierId="@detail.SupplierId"
                      Open="@railOpen"
                      OpenChanged="OnRailOpenChanged"
                      OnSummaryChanged="OnRailSummary" />
        </div>
    }
    else
    {
        @* ---------------- Draft wizard (editable) ---------------- *@
        @* R7 (§2) — the wizard adopts the document rail too: PERSISTENT across all four steps (the old step-3
           embedded panel is removed). Same push-row plumbing as the locked view; the editable host defaults the
           rail OPEN when any Mandatory slot is empty (§2.3, learned from the panel's first summary). *@
        <div style="display:flex;align-items:stretch;">
        <div style="flex:1;min-width:0;">
        <div class="rz-card" style="padding:20px;">
            <!-- Stepper -->
            <div style="display:flex;gap:0;margin-bottom:24px;border-bottom:1px solid var(--mer-line);">
                @for (int i = 1; i <= 4; i++)
                {
                    var step = i;
                    var active = currentStep == step;
                    var done = currentStep > step;
                    <div style="padding:10px 16px;font-size:13px;font-weight:600;border-bottom:3px solid @(active ? "var(--mer-blue)" : done ? "var(--mer-green)" : "transparent");color:@(active ? "var(--mer-blue)" : done ? "var(--mer-green)" : "var(--mer-ink-500)");cursor:pointer;" @onclick="@(() => GoStep(step))">
                        @step. @StepLabel(step)
                    </div>
                }
            </div>

            @if (currentStep == 1)
            {
                <h3 style="font-size:14px;font-weight:700;margin-bottom:12px;color:var(--mer-blue-darker);">Select purchase order(s)</h3>
                <p style="font-size:12px;color:var(--mer-ink-500);margin-bottom:12px;">@Step1HelperText Lines from every selected PO merge on the next step.</p>

                @* Supplier-first chooser — shown when the signed-in user can act for more than one supplier. *@
                @if (suppliers.Count > 1)
                {
                    <div style="margin-bottom:14px;">
                        <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);display:block;margin-bottom:4px;">Supplier *</label>
                        <select class="rz-dropdown" style="width:100%;max-width:420px;padding:8px 10px;border:1px solid var(--mer-ink-300);border-radius:6px;background:var(--mer-surface);" value="@selectedSupplierId" @onchange="OnSupplierSelect">
                            <option value="">— Select supplier —</option>
                            @foreach (var s in suppliers)
                            {
                                <option value="@s.Id" selected="@(selectedSupplierId == s.Id)">@s.LegalName (@s.SupplierCode)</option>
                            }
                        </select>
                    </div>
                }
                else if (suppliers.Count == 1)
                {
                    <div style="font-size:12.5px;color:var(--mer-ink-700);margin-bottom:12px;">Supplier: <b>@selectedSupplierName</b></div>
                }
                else
                {
                    <div class="tl-empty" style="padding:24px;text-align:left;"><div style="font-size:13px;color:var(--mer-ink-600);">No suppliers available to you.</div></div>
                }

                @if (selectedSupplierId.HasValue)
                {
                    @if (searching)
                    {
                        <p style="color:var(--mer-ink-500);font-size:13px;">Loading open POs…</p>
                    }
                    else if (openPos.Count == 0)
                    {
                        @* 0 open POs for this supplier — no ship-to selector, no PO list. *@
                        <p style="color:var(--mer-ink-500);font-size:13px;margin-bottom:14px;">No matching open POs for this supplier.</p>
                    }
                    else
                    {
                        @* ------ Ship-to gate (§6.2): an ASN never spans two ship-to addresses ------ *@
                        @* Existing-ASN edit locks the ship-to (derived from the covered POs); a new ASN with 2+ ship-tos
                           shows the selector; exactly 1 ship-to auto-selects and shows a small read-only label. *@
                        @if (!IsNew || shipToOptions.Count == 1)
                        {
                            <div style="font-size:12.5px;color:var(--mer-ink-700);margin-bottom:12px;">
                                Ship-to: <b>@SelectedShipToName</b>
                                @if (!IsNew) { <span style="color:var(--mer-ink-500);font-weight:400;"> · locked for this ASN</span> }
                            </div>
                        }
                        else if (shipToOptions.Count > 1)
                        {
                            <div style="margin-bottom:14px;">
                                <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);display:block;margin-bottom:4px;">Ship-to *</label>
                                <select class="rz-dropdown" style="width:100%;max-width:420px;padding:8px 10px;border:1px solid var(--mer-ink-300);border-radius:6px;background:var(--mer-surface);" value="@ShipToSelectValue" @onchange="OnShipToSelect">
                                    <option value="">— Select ship-to —</option>
                                    @foreach (var opt in shipToOptions)
                                    {
                                        var val = opt.Id?.ToString() ?? NoShipToSentinel.ToString();
                                        <option value="@val" selected="@(shipToChosen && ShipToSelectValue == val)">@opt.Name</option>
                                    }
                                </select>
                            </div>
                        }

                        @* The PO search + add list stays HIDDEN until a ship-to is chosen. *@
                        @if (shipToChosen)
                        {
                            <div style="margin-bottom:10px;">
                                <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);display:block;margin-bottom:4px;">Find PO</label>
                                <div style="display:flex;gap:8px;">
                                    <input class="rz-textbox" placeholder="Filter PO number…" style="flex:1;max-width:340px;padding:8px 10px;" @bind="poSearch" @bind:event="oninput" />
                                </div>
                            </div>

                            @if (AddablePos.Count > 0)
                            {
                                <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:14px;max-height:260px;overflow:auto;">
                                    @foreach (var po in AddablePos)
                                    {
                                        var p = po;
                                        <button @onclick="() => AddPo(p)" style="display:flex;align-items:center;gap:10px;border:1px solid var(--mer-line);border-radius:6px;padding:8px 12px;cursor:pointer;background:var(--mer-surface);text-align:left;">
                                            <span style="font-family:Inter,monospace;font-weight:600;font-size:13px;color:var(--mer-blue-darker);">@p.PoNumber</span>
                                            <span style="font-size:12px;color:var(--mer-ink-500);">@p.PoDate.ToString("yyyy-MM-dd")</span>
                                            <span class="tlg-status tlg-status--info">@p.PoStatus</span>
                                            <span style="margin-left:auto;color:var(--mer-blue);font-size:12px;font-weight:600;"><span class="material-symbols-outlined" style="font-size:15px;vertical-align:middle;">add</span> Add</span>
                                        </button>
                                    }
                                </div>
                            }
                            else
                            {
                                <p style="color:var(--mer-ink-500);font-size:13px;margin-bottom:14px;">No matching open POs for this ship-to@(string.IsNullOrWhiteSpace(poSearch) ? "" : $" for \"{poSearch}\"").</p>
                            }

                            <div style="border-top:1px solid var(--mer-line-soft);padding-top:12px;">
                                <div style="font-size:12px;font-weight:700;color:var(--mer-ink-700);margin-bottom:8px;">Selected POs (@selectedPoMap.Count) · <span style="font-weight:400;color:var(--mer-ink-500);">@selectedSupplierName</span></div>
                                @if (selectedPoMap.Count == 0)
                                {
                                    <p style="font-size:12px;color:var(--mer-ink-500);">None yet — add POs above.</p>
                                }
                                else
                                {
                                    <div style="display:flex;flex-wrap:wrap;gap:8px;">
                                        @foreach (var p in selectedPoMap.Values.OrderBy(x => x.PoNumber))
                                        {
                                            var pid = p.Id;
                                            <span style="display:inline-flex;align-items:center;gap:6px;border:1px solid var(--mer-blue);background:var(--mer-blue-50);border-radius:16px;padding:4px 6px 4px 12px;font-size:12.5px;font-family:Inter,monospace;color:var(--mer-blue-darker);">
                                                @p.PoNumber
                                                <button @onclick="() => RemovePo(pid)" title="Remove" style="background:transparent;border:0;color:var(--mer-ink-500);cursor:pointer;line-height:1;display:flex;"><span class="material-symbols-outlined" style="font-size:16px;">close</span></button>
                                            </span>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    }
                }
            }
            else if (currentStep == 2)
            {
                <h3 style="font-size:14px;font-weight:700;margin-bottom:12px;color:var(--mer-blue-darker);">Lines (@lines.Count)</h3>
                @if (linesLoading)
                {
                    <p style="color:var(--mer-ink-500);font-size:13px;">Loading lines…</p>
                }
                else if (lines.Count == 0)
                {
                    <p style="color:var(--mer-ink-500);font-size:13px;">Select at least one PO to load lines.</p>
                }
                else
                {
                    <table style="width:100%;font-size:12.5px;border-collapse:collapse;">
                        <thead>
                            <tr style="border-bottom:1px solid var(--mer-line);">
                                <th style="text-align:left;padding:6px 4px;color:var(--mer-ink-700);">PO</th>
                                <th style="text-align:right;padding:6px 4px;color:var(--mer-ink-700);">Pos</th>
                                <th style="text-align:right;padding:6px 4px;color:var(--mer-ink-700);">Seq</th>
                                <th style="text-align:left;padding:6px 4px;color:var(--mer-ink-700);">Item</th>
                                <th style="text-align:right;padding:6px 4px;color:var(--mer-ink-700);">Order Qty</th>
                                <th style="text-align:left;padding:6px 4px;color:var(--mer-ink-700);">Balance / allowance</th>
                                <th style="text-align:right;padding:6px 4px;color:var(--mer-ink-700);">Ship Qty</th>
                                <th style="text-align:left;padding:6px 4px;color:var(--mer-ink-700);">Batch</th>
                                <th style="text-align:left;padding:6px 4px;color:var(--mer-ink-700);">Expiry</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var ln in lines)
                        {
                            var full = FullyShipped(ln);     // ceiling reached (no over-ship headroom) → row read-only
                            var over = OverAllowance(ln);    // entered qty exceeds the order qty + tolerance ceiling → red border (no inline text; dialog carries the message)
                            <tr style="border-bottom:1px solid var(--mer-line-soft);@(full ? "background:var(--mer-ink-50);" : "")">
                                <td style="padding:6px 4px;font-family:Inter,monospace;">@ln.PoNumber</td>
                                <td style="padding:6px 4px;text-align:right;font-family:Inter,monospace;color:var(--mer-ink-500);">@ln.PositionNo</td>
                                <td style="padding:6px 4px;text-align:right;font-family:Inter,monospace;color:var(--mer-ink-500);">@(ln.SequenceNo?.ToString() ?? "—")</td>
                                <td style="padding:6px 4px;font-family:Inter,monospace;">@ln.ItemCode</td>
                                <td style="padding:6px 4px;text-align:right;font-family:Inter,monospace;">@ln.OrderQty.ToString("0.###")</td>
                                <td style="padding:6px 4px;">@BalanceCell(ln) @if (full) { <span class="tlg-status tlg-status--active" style="margin-left:6px;font-size:10px;">Fully shipped</span> }</td>
                                <td style="padding:6px 4px;text-align:right;">
                                    <input type="number" step="0.001" min="0" max="@ln.OverShipAllowance.ToString("0.###")" class="rz-textbox"
                                           style="width:90px;padding:4px 6px;font-family:Inter,monospace;text-align:right;@(over ? "border:1px solid var(--mer-red);" : "")"
                                           @bind="ln.ShippedQty" @bind:event="oninput" @onblur="() => OnShipQtyBlur(ln)" disabled="@full" title="@(full ? "Line fully shipped — no remaining ship capacity" : null)" />
                                </td>
                                <td style="padding:6px 4px;"><input type="text" class="rz-textbox" style="width:120px;padding:4px 6px;" @bind="ln.BatchNumber" disabled="@full" /></td>
                                <td style="padding:6px 4px;"><input type="date" class="rz-textbox" style="width:130px;padding:4px 6px;" @bind="ln.ExpiryDate" disabled="@full" /></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                    <p style="font-size:11px;color:var(--mer-ink-500);margin-top:8px;">Position &amp; sequence are snapshot from the PO line and cannot be edited.</p>

                    @* ---------------- Serial capture (serialized items) ---------------- *@
                    @if (SerialLines.Count > 0)
                    {
                        <div style="margin-top:22px;border-top:1px solid var(--mer-line);padding-top:16px;">
                            <h3 style="font-size:14px;font-weight:700;margin-bottom:4px;color:var(--mer-blue-darker);">Serial numbers</h3>
                            <p style="font-size:12px;color:var(--mer-ink-500);margin-bottom:14px;">Each serialized item needs exactly one serial per shipped unit. Serials must be unique across the whole ASN.</p>
                            @foreach (var sl in SerialLines)
                            {
                                var line = sl;
                                var need = (int)line.ShippedQty;
                                var filled = line.Serials.Count(s => !string.IsNullOrWhiteSpace(s.Serial));
                                var ok = SerialLineValid(line, out var serMsg);
                                <div style="border:1px solid var(--mer-line);border-radius:8px;padding:14px;margin-bottom:12px;background:var(--mer-surface);">
                                    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;margin-bottom:10px;">
                                        <span style="font-size:13px;font-weight:700;color:var(--mer-blue-darker);font-family:Inter,monospace;">@line.ItemCode <span style="font-weight:400;color:var(--mer-ink-500);">· PO @line.PoNumber · pos @line.PositionNo</span></span>
                                        <span class="tlg-status @(ok ? "tlg-status--active" : "tlg-status--danger")" style="font-family:Inter,monospace;">@filled / @need captured</span>
                                    </div>

                                    @* R4 (2026-06-30) — bulk "expiry for all units": one click fills every serial's expiry (the common shared-expiry case). Per-row expiry below overrides for mixed batches. *@
                                    <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:10px;padding:8px 10px;background:var(--mer-ink-50);border:1px solid var(--mer-line);border-radius:6px;">
                                        <span class="material-symbols-outlined" style="font-size:16px;color:var(--mer-ink-500);">event</span>
                                        <span style="font-size:12px;color:var(--mer-ink-600);">Expiry for all units</span>
                                        <input type="date" class="rz-textbox" style="width:150px;padding:4px 6px;" @bind="line._bulkExpiry" />
                                        <button class="rz-button" style="padding:5px 10px;border-radius:6px;border:1px solid var(--mer-ink-300);background:var(--mer-surface);cursor:pointer;font-size:12px;" @onclick="() => ApplyBulkExpiry(line)">Apply to all</button>
                                        <button class="rz-button" style="padding:5px 10px;border-radius:6px;border:1px solid var(--mer-ink-300);background:var(--mer-surface);cursor:pointer;font-size:12px;" @onclick="() => ClearExpiries(line)">Clear</button>
                                    </div>

                                    @* Paste affordance — split on newline/comma, fill the N boxes, ignore extras (warn). *@
                                    <details style="margin-bottom:10px;">
                                        <summary style="font-size:12px;color:var(--mer-blue);cursor:pointer;">Paste serials</summary>
                                        <div style="margin-top:8px;">
                                            <textarea class="rz-textbox" rows="3" placeholder="Paste serials separated by new lines or commas" style="width:100%;padding:8px 10px;font-family:Inter,monospace;font-size:12px;" @bind="line._pasteBuffer"></textarea>
                                            <button class="rz-button" style="margin-top:6px;padding:6px 12px;border-radius:6px;border:1px solid var(--mer-ink-300);background:var(--mer-surface);cursor:pointer;font-size:12px;" @onclick="() => ApplyPaste(line)">
                                                <span class="material-symbols-outlined" style="font-size:14px;vertical-align:middle;">content_paste</span> Fill @need boxes
                                            </button>
                                            @if (!string.IsNullOrEmpty(line._pasteWarn))
                                            {
                                                <span style="font-size:11px;color:var(--mer-amber-800);margin-left:8px;">@line._pasteWarn</span>
                                            }
                                        </div>
                                    </details>

                                    @if (need > SerialBoxCap)
                                    {
                                        <div style="background:var(--mer-amber-50);color:var(--mer-amber-800);padding:8px 12px;border-radius:6px;font-size:11.5px;margin-bottom:10px;">
                                            Large quantity (@need units). Use <b>Paste serials</b> above. Only the first @SerialBoxCap boxes are rendered for editing; pasted serials beyond that are still captured.
                                        </div>
                                    }
                                    <div style="display:grid;grid-template-columns:26px 1fr 150px;gap:6px 8px;align-items:center;@(need > SerialBoxCap ? "max-height:320px;overflow:auto;" : "")">
                                        @{ var renderCount = Math.Min(need, SerialBoxCap); EnsureSerialSlots(line, need); }
                                        <span></span>
                                        <span style="font-size:10px;color:var(--mer-ink-400);text-transform:uppercase;letter-spacing:.4px;">Serial</span>
                                        <span style="font-size:10px;color:var(--mer-ink-400);text-transform:uppercase;letter-spacing:.4px;">Expiry · optional</span>
                                        @for (int si = 0; si < renderCount; si++)
                                        {
                                            var sIdx = si;
                                            <span style="font-size:10.5px;color:var(--mer-ink-400);font-family:Inter,monospace;text-align:right;">@(sIdx + 1)</span>
                                            <input class="rz-textbox" style="padding:5px 8px;font-family:Inter,monospace;font-size:12px;@(DuplicateSerial(line, sIdx) ? "border:1px solid var(--mer-red);" : "")" placeholder="Serial" @bind="line.Serials[sIdx].Serial" @bind:event="oninput" />
                                            <input type="date" class="rz-textbox" style="padding:5px 6px;font-size:12px;" @bind="line.Serials[sIdx].Expiry" />
                                        }
                                    </div>
                                    @if (!ok)
                                    {
                                        <div style="font-size:11.5px;color:var(--mer-red);margin-top:8px;">@serMsg</div>
                                    }
                                </div>
                            }
                        </div>
                    }

                    @* ---------------- Lot capture (lot-controlled items) ---------------- *@
                    @if (LotLines.Count > 0)
                    {
                        <div style="margin-top:22px;border-top:1px solid var(--mer-line);padding-top:16px;">
                            <h3 style="font-size:14px;font-weight:700;margin-bottom:4px;color:var(--mer-blue-darker);">Lots / batches</h3>
                            <p style="font-size:12px;color:var(--mer-ink-500);margin-bottom:14px;">Split each lot-controlled item into lots whose quantities sum to the shipped quantity. Lot numbers must be unique within the line.</p>
                            @foreach (var ll in LotLines)
                            {
                                var line = ll;
                                var sum = line.Lots.Sum(x => x.Qty ?? 0);
                                var ok = LotLineValid(line, out var lotMsg);
                                <div style="border:1px solid var(--mer-line);border-radius:8px;padding:14px;margin-bottom:12px;background:var(--mer-surface);">
                                    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;margin-bottom:10px;">
                                        <span style="font-size:13px;font-weight:700;color:var(--mer-blue-darker);font-family:Inter,monospace;">@line.ItemCode <span style="font-weight:400;color:var(--mer-ink-500);">· PO @line.PoNumber · pos @line.PositionNo</span></span>
                                        <span class="tlg-status @(ok ? "tlg-status--active" : "tlg-status--danger")" style="font-family:Inter,monospace;">Σ @sum.ToString("0.###") / @line.ShippedQty.ToString("0.###")</span>
                                    </div>
                                    <table style="width:100%;font-size:12.5px;border-collapse:collapse;">
                                        <thead>
                                            <tr style="border-bottom:1px solid var(--mer-line);">
                                                <th style="text-align:left;padding:4px;color:var(--mer-ink-700);">Lot no.</th>
                                                <th style="text-align:right;padding:4px;color:var(--mer-ink-700);width:120px;">Qty</th>
                                                <th style="text-align:left;padding:4px;color:var(--mer-ink-700);width:150px;">Expiry</th>
                                                <th style="width:36px;"></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                        @foreach (var lot in line.Lots)
                                        {
                                            var lr = lot;
                                            var dupLot = DuplicateLot(line, lr);
                                            <tr style="border-bottom:1px solid var(--mer-line-soft);">
                                                <td style="padding:4px;"><input class="rz-textbox" style="width:100%;padding:5px 8px;font-family:Inter,monospace;font-size:12px;@(dupLot ? "border:1px solid var(--mer-red);" : "")" placeholder="Lot / batch" @bind="lr.LotNo" @bind:event="oninput" /></td>
                                                <td style="padding:4px;"><input type="number" step="0.001" class="rz-textbox" style="width:100%;padding:5px 8px;font-family:Inter,monospace;font-size:12px;text-align:right;" @bind="lr.Qty" /></td>
                                                <td style="padding:4px;"><input type="date" class="rz-textbox" style="width:100%;padding:5px 8px;font-size:12px;" @bind="lr.ExpiryDate" /></td>
                                                <td style="padding:4px;text-align:center;"><button type="button" title="Remove lot" @onclick="() => line.Lots.Remove(lr)" style="background:transparent;border:0;color:var(--mer-red);cursor:pointer;"><span class="material-symbols-outlined" style="font-size:16px;">delete</span></button></td>
                                            </tr>
                                        }
                                        </tbody>
                                    </table>
                                    <button class="rz-button" style="margin-top:8px;padding:6px 12px;border-radius:6px;border:1px solid var(--mer-ink-300);background:var(--mer-surface);cursor:pointer;font-size:12px;" @onclick="() => line.Lots.Add(new LotRow())">
                                        <span class="material-symbols-outlined" style="font-size:14px;vertical-align:middle;">add</span> Add lot
                                    </button>
                                    @if (!ok)
                                    {
                                        <div style="font-size:11.5px;color:var(--mer-red);margin-top:8px;">@lotMsg</div>
                                    }
                                </div>
                            }
                        </div>
                    }
                }
            }
            else if (currentStep == 3)
            {
                <h3 style="font-size:14px;font-weight:700;margin-bottom:12px;color:var(--mer-blue-darker);">Shipment details</h3>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                    <div>
                        <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Expected delivery date *</label>
                        <input type="date" class="rz-textbox" style="width:100%;padding:8px 10px;" @bind="expectedDeliveryDate" />
                    </div>
                    <div>
                        <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Time window</label>
                        <input type="text" class="rz-textbox" style="width:100%;padding:8px 10px;" placeholder="e.g., 09:00–11:00" @bind="timeWindow" />
                    </div>
                    <div>
                        <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Carrier name</label>
                        <input type="text" class="rz-textbox" style="width:100%;padding:8px 10px;" @bind="carrierName" />
                    </div>
                    <div>
                        <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Tracking number</label>
                        <input type="text" class="rz-textbox" style="width:100%;padding:8px 10px;font-family:Inter,monospace;" @bind="trackingNumber" />
                    </div>
                    <div>
                        <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Vehicle number</label>
                        <input type="text" class="rz-textbox" style="width:100%;padding:8px 10px;font-family:Inter,monospace;" @bind="vehicleNumber" />
                    </div>
                    <div>
                        <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Driver name</label>
                        <input type="text" class="rz-textbox" style="width:100%;padding:8px 10px;" @bind="driverName" />
                    </div>
                    <div>
                        <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Driver phone</label>
                        <input type="text" class="rz-textbox" style="width:100%;padding:8px 10px;font-family:Inter,monospace;" @bind="driverPhone" />
                    </div>
                </div>
                <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);margin-top:12px;display:block;">Notes</label>
                <textarea class="rz-textbox" rows="3" style="width:100%;padding:8px 10px;font-family:inherit;" @bind="notes"></textarea>

                @* R7 — the R5 §13 Attachment Panel that used to be embedded here (step 3 only) moved into the
                   DocumentRail beside the wizard, where it is reachable from EVERY step. All its semantics
                   (thin client, "save the draft to attach" hint, Draft/Rejected editability) are unchanged. *@
            }
            else if (currentStep == 4)
            {
                <h3 style="font-size:14px;font-weight:700;margin-bottom:12px;color:var(--mer-blue-darker);">Review &amp; submit</h3>
                <dl style="display:grid;grid-template-columns:180px 1fr;gap:6px 16px;font-size:13px;">
                    <dt style="color:var(--mer-ink-500);">Purchase order(s)</dt><dd style="font-family:Inter,monospace;">@string.Join(", ", SelectedPoNumbers)</dd>
                    <dt style="color:var(--mer-ink-500);">Expected delivery</dt><dd style="font-family:Inter,monospace;">@expectedDeliveryDate?.ToString("yyyy-MM-dd")</dd>
                    <dt style="color:var(--mer-ink-500);">Carrier</dt><dd>@(string.IsNullOrEmpty(carrierName) ? "—" : carrierName)</dd>
                    <dt style="color:var(--mer-ink-500);">Tracking</dt><dd style="font-family:Inter,monospace;">@(string.IsNullOrEmpty(trackingNumber) ? "—" : trackingNumber)</dd>
                    <dt style="color:var(--mer-ink-500);">Vehicle</dt><dd style="font-family:Inter,monospace;">@(string.IsNullOrEmpty(vehicleNumber) ? "—" : vehicleNumber)</dd>
                    <dt style="color:var(--mer-ink-500);">Lines</dt><dd>@lines.Count(l => l.ShippedQty > 0) of @lines.Count being shipped</dd>
                    <dt style="color:var(--mer-ink-500);">Attachments</dt><dd>@attachments.Count</dd>
                </dl>

                @if (IsNew)
                {
                    <div style="background:var(--mer-blue-50);color:var(--mer-blue-darker);padding:10px 12px;border-radius:6px;font-size:12px;margin-top:12px;">
                        This saves a <b>Draft</b> ASN. You can add attachments and send it for approval from the draft.
                    </div>
                }
                else
                {
                    @* R5 (§10.1/§10.2) — the supplier no longer submits directly. "Send for approval" moves the ASN to
                       PendingApproval (running the §10.3 attachment check here) for a buyer to Approve (which submits)
                       or Reject. The shipment is locked while it awaits the decision. *@
                    <div style="background:var(--mer-blue-50);color:var(--mer-blue-darker);padding:10px 12px;border-radius:6px;font-size:12px;margin-top:12px;">
                        Sending for approval locks this ASN (header, lines and attachments become read-only) and routes it to the PO buyer(s). On <b>Approve</b> the shipment is submitted and a draft invoice spanning its PO(s) is created.
                    </div>
                }

                @if (!string.IsNullOrEmpty(submitError))
                {
                    <div style="background:var(--mer-red-50);color:var(--mer-red);padding:8px 12px;border-radius:6px;font-size:12px;margin-top:12px;white-space:pre-wrap;">@submitError</div>
                }
            }

            @if (currentStep == 4 && !IsNew && detail?.ShipBlocked == true)
            {
                <div style="background:var(--mer-amber-50, #fff8e6);border:1px solid var(--mer-amber-200,#ffe2a8);color:var(--mer-ink-700);padding:8px 12px;border-radius:6px;font-size:12px;margin-top:12px;">
                    <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">block</span>
                    @detail?.ShipBlockReason
                </div>
            }

            <div style="display:flex;justify-content:space-between;margin-top:24px;padding-top:16px;border-top:1px solid var(--mer-line);">
                <button class="rz-button" style="padding:8px 14px;border-radius:6px;border:1px solid var(--mer-ink-300);background:var(--mer-surface);cursor:pointer;" @onclick="PrevStep" disabled="@(currentStep == 1)">Back</button>
                <div style="display:flex;gap:8px;">
                    @if (currentStep == 4)
                    {
                        <button class="rz-button" style="padding:8px 14px;border-radius:6px;border:1px solid var(--mer-ink-300);background:var(--mer-surface);cursor:pointer;" @onclick="SaveDraft" disabled="@(busy || (!IsNew && detail?.ShipBlocked == true))">@(busy && savingDraft ? "Saving…" : (IsNew ? "Save draft" : "Save changes"))</button>
                        @if (!IsNew)
                        {
                            @* R5 (§10.2) — replaces the old direct Submit. Sends Draft/Rejected → PendingApproval. *@
                            <button class="rz-button rz-secondary" style="padding:8px 14px;border-radius:6px;border:0;color:#fff;cursor:pointer;" @onclick="SendForApproval" disabled="@(busy || detail?.ShipBlocked == true)">
                                <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">send</span> @(busy && !savingDraft ? "Sending…" : "Send for approval")
                            </button>
                        }
                    }
                    else
                    {
                        <button class="rz-button rz-primary" style="padding:8px 14px;border-radius:6px;border:0;color:#fff;cursor:pointer;" @onclick="NextStep" disabled="@(!CanProceed)">Next</button>
                    }
                </div>
            </div>
        </div>

        </div>
        @* R7 — editable-host rail. Wiring is IDENTICAL to the old step-3 embed: EntityId=Guid.Empty for a
           brand-new ASN (policy slots + "save the draft" hint), attachSupplierId stamps the upload seccode,
           OnPanelChanged keeps the step-4 review count fresh. The "Choose a supplier first." pre-condition
           renders inside the rail body via GuardMessage (same condition as before). *@
        <DocumentRail EntityCode="Asn"
                      EntityId="@(Id ?? Guid.Empty)"
                      Editable="@(CanWrite)"
                      SupplierId="@attachSupplierId"
                      OnChanged="OnPanelChanged"
                      GuardMessage="@(IsNew && selectedSupplierId == Guid.Empty ? "Choose a supplier first." : null)"
                      Open="@railOpen"
                      OpenChanged="OnRailOpenChanged"
                      OnSummaryChanged="OnRailSummary" />
        </div>
    }
</div>

