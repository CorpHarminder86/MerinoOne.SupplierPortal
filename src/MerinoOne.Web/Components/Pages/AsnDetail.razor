@code {
    [Parameter] public Guid? Id { get; set; }
    // R4 #6 — "Create ASN from selected POs" on the PO list deep-links here with ?pos=id1,id2 (comma-separated).
    [SupplyParameterFromQuery(Name = "pos")] public string? PreselectPos { get; set; }
    // R5 (§9.2) — the delivery-schedule flow lands on /asns/{id}?step=2 so the supplier opens directly on Lines.
    // Applied ONCE, only for an existing ASN with lines already present; a brand-new ASN always starts at step 1.
    [SupplyParameterFromQuery(Name = "step")] public int? StartStep { get; set; }
    private AsnDetailDto? detail;
    private bool loading = true;
    private bool busy = false;
    private bool savingDraft = false;
    private int currentStep = 1;
    private string submitError = string.Empty;

    // PO selection (multi). R4 #6 — supplier-first + server-side PO autocomplete (no load-all): a single supplier
    // can own thousands of POs, so we pick the supplier first, then SEARCH that supplier's open POs by number.
    private List<SupplierListItemDto> suppliers = new();
    private Guid? selectedSupplierId;
    private string? selectedSupplierName;
    private string poSearch = string.Empty;
    // R5 (§6.2) — `searching` now covers the one-shot open-PO load per supplier (the per-keystroke server search
    // was replaced by a client-side filter over the cached openPos, so the ship-to gate can never be bypassed).
    private bool searching = false;
    private readonly HashSet<Guid> selectedPoIds = new();

    // R5 (§9.2 / §6.2) — ship-to gate. An ASN must not span two ship-to addresses, so the wizard picks the ship-to
    // BEFORE the POs and filters the addable POs to it. openPos caches ALL the supplier's open POs (one load per
    // supplier); shipToOptions is the DISTINCT (ShipToAddressId, Name) over them (a null id collapses to a single
    // "(no ship-to)" option so those POs are still selectable but never mix with a real ship-to). selectedShipToId
    // is nullable-but-set: the "(no ship-to)" group is represented by _noShipToChosen=true with selectedShipToId=null.
    private static readonly Guid NoShipToSentinel = Guid.Empty; // maps the "(no ship-to)" group to a stable <select> value
    private List<PurchaseOrderListItemDto> openPos = new();
    private List<(Guid? Id, string Name)> shipToOptions = new();
    private Guid? selectedShipToId;      // the real ship-to id when a real address is chosen
    private bool shipToChosen;           // true once a ship-to (real or "(no ship-to)") is selected — gates the PO list
    private readonly Dictionary<Guid, PurchaseOrderListItemDto> selectedPoMap = new();

    private List<LineRow> lines = new();
    private bool linesLoading = false;
    private DateTime? expectedDeliveryDate;
    private string? timeWindow;
    private string? carrierName;
    private string? trackingNumber;
    private string? vehicleNumber;
    private string? driverName;
    private string? driverPhone;
    private string? notes;

    // Attachments — R5 (§13): the reusable AttachmentPanel now OWNS upload/list/remove (slots from the policy
    // read-model, files via /api/document-uploads/attach + DELETE). The page keeps only a lightweight count of the
    // ASN's attachments (for the step-4 review summary), refreshed from the by-asn list endpoint on panel changes.
    private readonly List<DocumentAttachmentDto> attachments = new();
    private Guid attachSupplierId;

    // ---- R7 (§2) — document-rail state (shared by the pill in the header and the rail in either branch) ----
    // §2.3 default is host-derived: starts closed; the FIRST panel summary flips it open when this is the
    // editable host AND any Mandatory slot is empty. A manual toggle (pill / Escape / close / backdrop) wins
    // permanently — the auto-default never fights the user.
    private bool railOpen;
    private bool _railUserToggled;
    private AttachmentPanelSummary? railSummary;

    private void OnRailOpenChanged(bool open)
    {
        railOpen = open;
        _railUserToggled = true;
    }

    private void OnRailSummary(AttachmentPanelSummary summary)
    {
        railSummary = summary;
        if (!_railUserToggled && !railOpen && !IsLocked && CanWrite && summary.AnyMandatoryEmpty)
            railOpen = true;
    }
    // R4 (2026-06-23) — deferred-upload staging key for create-mode attachments (rebound onto the ASN by CreateAsn).
    private Guid _stagingKey = Guid.NewGuid();

    private bool showCancel = false;
    private string dialogError = string.Empty;

    // R4 (2026-06-26) — §6.5 / UC-PO-09: PO confirmation-gate block + admin override. When create/submit returns the
    // gate message, surface it; a caller with PurchaseOrder.OverrideGate can supply a reason to re-submit past it.
    private bool showGateOverride = false;
    private string gateBlockMessage = string.Empty;
    private bool showOverShip = false;
    private string gateOverrideReason = string.Empty;
    private string gateOverrideError = string.Empty;

    // R4 (2026-06-26) — §8.3 / UC-ATT-03: missing-Warning-attachment confirm. The first submit returns a 200 with
    // ConfirmationRequired=true; on confirm we re-submit with AcknowledgeMissingAttachments=true.
    private bool showAttachConfirm = false;
    private string attachConfirmMessage = string.Empty;
    private List<string> attachMissing = new();

    // R5 (§10.2) — buyer Approve / Reject dialog state.
    private bool showApprove = false;
    private bool showReject = false;
    private string rejectReason = string.Empty;
    private string approveError = string.Empty;
    private string rejectError = string.Empty;

    // R6 — Retry generation for a Blocked ASN (POST api/invoices/from-asn; idempotent). A still-blocked
    // generator returns 400 with the reason — surfaced inline in the Blocked banner, not a dialog.
    private bool invoiceRetryBusy = false;
    private string invoiceRetryError = string.Empty;

    private async Task RetryInvoiceGeneration()
    {
        if (detail == null) return;
        invoiceRetryBusy = true; invoiceRetryError = string.Empty;
        var resp = await Api.PostAsync<InvoiceDetailDto, CreateInvoiceFromAsnRequest>(
            "api/invoices/from-asn", new CreateInvoiceFromAsnRequest(detail.Id));
        if (resp?.Success == true)
        {
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Draft invoice(s) generated" });
            await Reload();
        }
        else
        {
            invoiceRetryError = resp?.Errors?.FirstOrDefault() ?? "Generation is still blocked.";
        }
        invoiceRetryBusy = false;
    }

    private bool IsNew => !Id.HasValue;
    private bool IsLocked => detail?.IsLocked == true;
    private bool CanWrite => Token.IsSupplier || Token.HasPermission("Asn.Write");
    private bool CanOverrideGate => Token.HasPermission("PurchaseOrder.OverrideGate");
    // R5 (§10.2) — buyer decision permission. Asn.Approve is seeded to SuperAdmin/Admin/Buyer (not Supplier). The
    // server AsnApprovalGate additionally asserts the caller is a MAPPED PO buyer; we only gate the affordance here.
    private bool CanApprove => Token.HasPermission("Asn.Approve");
    // Cancel is supplier-side and valid on any of the supplier's active states (Draft / Rejected / PendingApproval).
    // Submitted/InTransit/Delivered/Cancelled are terminal-for-cancel here (the read-only view hides it via this flag).
    private bool CanCancel => detail?.AsnStatus is "Draft" or "Rejected" or "PendingApproval";

    // The gate block message names the required action; the API stamps it under the "poStatus" error key. Match the
    // stable prefix so we route it to the override dialog rather than the generic error banner.
    private static bool IsGateBlock(string? msg) =>
        !string.IsNullOrEmpty(msg) && msg.Contains("before shipments can be created", StringComparison.OrdinalIgnoreCase);

    private IEnumerable<string> SelectedPoNumbers =>
        selectedPoMap.Values.Select(p => p.PoNumber);

    private string PoSummaryText =>
        detail == null ? "" :
        detail.PurchaseOrders.Count > 0 ? string.Join(", ", detail.PurchaseOrders.Select(p => p.PoNumber))
        : (detail.PoNumber ?? "—");

    private string HeaderSubtitle =>
        IsNew ? "Submit a shipping notice for one or more purchase orders"
        : detail == null ? ""
        : $"ASN for PO {PoSummaryText}";

    // R5 (§6.2) — step-1 helper reflects the supplier → ship-to → POs sequence (each step shown only when it has a
    // choice: the supplier chooser hides at 1 supplier, the ship-to chooser hides at 1 ship-to).
    private string Step1HelperText =>
        suppliers.Count > 1
            ? "Choose the supplier and ship-to address, then add one or more of its open POs for that ship-to."
            : "Choose the ship-to address, then add one or more of the supplier's open POs for that ship-to.";

    // The value the ship-to <select> binds to: the real id, or the "(no ship-to)" sentinel when that group is chosen.
    private string ShipToSelectValue => !shipToChosen ? "" : (selectedShipToId?.ToString() ?? NoShipToSentinel.ToString());

    // Display name for the currently chosen ship-to (used by the read-only/locked labels).
    private string SelectedShipToName =>
        shipToOptions.FirstOrDefault(o => o.Id == selectedShipToId).Name ?? "(no ship-to)";

    // The POs offered to add: cached open POs for the chosen ship-to, minus already-selected ones, filtered by the
    // (client-side) PO-number contains text. A PO from another ship-to can never appear here → never be added.
    private List<PurchaseOrderListItemDto> AddablePos =>
        !shipToChosen ? new()
        : openPos
            .Where(p => p.ShipToAddressId == selectedShipToId)
            .Where(p => !selectedPoIds.Contains(p.Id))
            // R4 §6.2 — offer ONLY POs whose confirmation gate is open (not shippable → hidden from the picker).
            .Where(p => p.IsShippable)
            .Where(p => string.IsNullOrWhiteSpace(poSearch) || p.PoNumber.Contains(poSearch.Trim(), StringComparison.OrdinalIgnoreCase))
            .OrderBy(p => p.PoNumber)
            .ToList();

    private bool CanProceed => currentStep switch
    {
        // Step 1 (§6.2) — a ship-to must be chosen AND ≥1 PO added. The "(no ship-to)" group counts as chosen
        // (shipToChosen), so Next unblocks for those POs too. Existing-ASN edit derives the ship-to as locked.
        1 => shipToChosen && selectedPoIds.Count > 0,
        // Step 2 also gates on serial/lot capture: every serialized line must have N serials and every lot line
        // must have Σqty == ShippedQty (no dupes). The backend SubmitAsnCommand re-enforces; this blocks early.
        2 => lines.Any(l => l.ShippedQty > 0) && SerialLotCaptureValid,
        3 => expectedDeliveryDate.HasValue,
        _ => true
    };

    // R4 (2026-06-27) — client-side over-ship UX: restrict the supplier as soon as the entered ship qty exceeds the
    // order qty + over-ship tolerance ceiling (OverShipAllowance), instead of only failing at submit; and lock a row
    // that has no remaining ship capacity. The server atomic guard (behind Fulfilment.EnforceOverShipGuard) remains
    // the authoritative check.
    private static bool OverAllowance(LineRow l) => l.ShippedQty > l.OverShipAllowance;
    private static bool FullyShipped(LineRow l) => l.OverShipAllowance <= 0;

    // Surface the over-ship dialog the moment the Ship Qty field loses focus (not only on Next).
    private void OnShipQtyBlur(LineRow l) { if (OverAllowance(l)) showOverShip = true; }

    // Reload whenever the route id changes — Blazor REUSES this component across /asns/new -> /asns/{id}
    // (the save-draft navigation), so OnInitializedAsync (once-only) would leave detail=null => "ASN not found".
    private Guid? _loadedId;
    private bool _loadedNew;
    // R5 (§9.2) — one-shot guard so ?step= is honored on the FIRST existing-ASN load only (not on the save-draft
    // re-navigation or later re-renders). Once applied it stays true for the component's lifetime.
    private bool _startStepApplied;
    protected override async Task OnParametersSetAsync()
    {
        if (_loadedId != Id || (IsNew && !_loadedNew))
        {
            _loadedId = Id;
            _loadedNew = IsNew;
            currentStep = 1;
            await Reload();
        }
    }

    // R5 (§13) — the AttachmentPanel raises this after every upload/remove. Refresh the lightweight count the
    // step-4 review summary shows from the by-asn list endpoint (the panel owns the actual files + their display).
    private async Task OnPanelChanged()
    {
        if (!Id.HasValue) return;
        var resp = await Api.GetAsync<List<DocumentAttachmentDto>>($"api/document-uploads/by-asn/{Id.Value}");
        attachments.Clear();
        if (resp?.Data is { } docs) attachments.AddRange(docs);
        StateHasChanged();
    }

    private async Task Reload()
    {
        loading = true;
        if (IsNew)
        {
            // Suppliers the signed-in user can act for (seccode-scoped). Supplier-first picker when >1.
            var sup = await Api.GetAsync<List<SupplierListItemDto>>("api/suppliers");
            suppliers = sup?.Data ?? new();
            if (!string.IsNullOrWhiteSpace(PreselectPos))
                await ApplyPreselectAsync();
            else if (suppliers.Count == 1)
                await ChooseSupplierAsync(suppliers[0].Id);
            loading = false;
        }
        else
        {
            var resp = await Api.GetAsync<AsnDetailDto>($"api/asns/{Id}");
            detail = resp?.Data;
            if (detail != null)
            {
                attachSupplierId = detail.SupplierId;
                expectedDeliveryDate = detail.ExpectedDeliveryDate;
                timeWindow = detail.TimeWindow;
                carrierName = detail.CarrierName;
                trackingNumber = detail.TrackingNumber;
                vehicleNumber = detail.VehicleNumber;
                driverName = detail.DriverName;
                driverPhone = detail.DriverPhone;
                notes = detail.Notes;

                attachments.Clear();
                attachments.AddRange(detail.Attachments);

                // Selected PO set from the covered-PO list (falls back to the scalar header for single-PO).
                selectedPoIds.Clear();
                selectedPoMap.Clear();
                selectedSupplierId = detail.SupplierId;
                selectedSupplierName = detail.SupplierName;
                // The picker on an edited Draft is fixed to the ASN's supplier (single-entry list → no chooser).
                suppliers = new List<SupplierListItemDto> { new(detail.SupplierId, 0, "", detail.SupplierName, null, null, null, "", false, DateTime.UtcNow) };
                foreach (var po in detail.PurchaseOrders)
                {
                    selectedPoIds.Add(po.PurchaseOrderId);
                    selectedPoMap[po.PurchaseOrderId] = new PurchaseOrderListItemDto(po.PurchaseOrderId, 0, po.PoNumber, detail.SupplierId, detail.SupplierName, "", "", DateTime.UtcNow, "", 0, DateTime.UtcNow);
                }
                if (selectedPoIds.Count == 0 && detail.PurchaseOrderId is { } pid) selectedPoIds.Add(pid);

                lines = detail.Lines.Select(l => new LineRow
                {
                    PurchaseOrderLineId = l.PurchaseOrderLineId,
                    PurchaseOrderId = l.PurchaseOrderId,
                    PoNumber = l.PoNumber,
                    PositionNo = l.PositionNo ?? l.PoPositionNo,
                    SequenceNo = l.SequenceNo,
                    ItemCode = l.ItemCode,
                    OrderQty = l.OrderQty,
                    ShippedQty = l.ShippedQty,
                    BatchNumber = l.BatchNumber,
                    ExpiryDate = l.ExpiryDate,
                    // AsnLineDto carries no Item flag — infer the line type from which capture collection is
                    // populated (serialized XOR lot-controlled). Re-merged with PO flags below for empty lines.
                    IsSerialized = l.Serials is { Count: > 0 },
                    IsLotControlled = l.Lots is { Count: > 0 },
                    Serials = l.Serials?.Select(s => new SerialRow { Serial = s.SerialNumber, Expiry = s.ExpiryDate }).ToList() ?? new(),
                    Lots = l.Lots?.Select(x => new LotRow { LotNo = x.LotNo, Qty = x.Qty, ExpiryDate = x.ExpiryDate }).ToList() ?? new(),
                    // R4 (2026-06-26) — §7.3 / DI-04: ship-tracking from the ASN line (ReloadLines re-merges the PO
                    // line's authoritative figures for editable drafts; the locked read-only view uses these).
                    ShippedQtyToDate = l.ShippedQtyToDate,
                    Balance = l.Balance,
                    OverShipAllowance = l.OverShipAllowance
                }).ToList();

                // For an editable (Draft/Rejected) ASN cache the supplier's open POs so the picker can add/remove POs
                // (same supplier), and DERIVE + LOCK the ship-to from the covered POs (§6.2 — an ASN never spans two
                // ship-to addresses). ReloadLines re-fetches the PO lines and merges authoritative Item flags onto
                // these rows (so a serialized/lot line with NOTHING captured yet still gets its capture section),
                // preserving the serials/lots just read back from the ASN.
                if (!IsLocked)
                {
                    await LoadOpenPos();
                    LockShipToFromCoveredPos();
                    await ReloadLines();
                }

                // R5 (§9.2) — honor ?step= ONCE: the delivery-schedule flow lands on /asns/{id}?step=2 to open
                // directly on Lines. Only for an EXISTING ASN that already has lines, and only on the first load
                // (guarded so the save-draft re-navigation / later re-renders never re-jump the wizard). An
                // IsLocked ASN renders the read-only view (no wizard) so the clamp is harmless there.
                if (!_startStepApplied && StartStep.HasValue && lines.Count > 0)
                {
                    currentStep = Math.Clamp(StartStep.Value, 1, 4);
                }
                _startStepApplied = true;
            }
            loading = false;
        }
    }

    private async Task OnSupplierSelect(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out var id)) { await ChooseSupplierAsync(id); }
        else
        {
            selectedSupplierId = null; selectedSupplierName = null;
            // Clearing the supplier also clears the ship-to gate + PO cache/selection.
            selectedPoIds.Clear(); selectedPoMap.Clear(); lines.Clear();
            openPos = new(); shipToOptions = new(); selectedShipToId = null; shipToChosen = false;
        }
    }

    private async Task ChooseSupplierAsync(Guid supplierId)
    {
        selectedSupplierId = supplierId;
        attachSupplierId = supplierId;   // create-mode staging uploads stamp this supplier's seccode
        selectedSupplierName = suppliers.FirstOrDefault(s => s.Id == supplierId)?.LegalName;
        // Switching supplier resets the PO picker AND the ship-to gate (an ASN ships from a single supplier).
        selectedPoIds.Clear(); selectedPoMap.Clear(); lines.Clear();
        poSearch = string.Empty;
        selectedShipToId = null; shipToChosen = false;
        await LoadOpenPos();
    }

    // R5 (§6.2) — user picked a ship-to (or the "(no ship-to)" group). Changing it CLEARS the current PO selection
    // (mirrors changing supplier) so the two never mix; the ship-to itself stays so the user can add another PO.
    private async Task OnShipToSelect(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString();
        if (string.IsNullOrEmpty(raw))
        {
            selectedShipToId = null; shipToChosen = false;
        }
        else if (Guid.TryParse(raw, out var g))
        {
            // The sentinel (Guid.Empty) is the "(no ship-to)" group → selectedShipToId stays null but chosen=true.
            selectedShipToId = g == NoShipToSentinel ? (Guid?)null : g;
            shipToChosen = true;
        }
        // Clear any PO selection carried over from a previously chosen ship-to.
        selectedPoIds.Clear(); selectedPoMap.Clear(); lines.Clear();
        poSearch = string.Empty;
        await ReloadLines();
    }

    // R5 (§6.2) — load ALL the supplier's open POs ONCE (pageSize 200) and derive the DISTINCT ship-to options. The
    // list-item DTO carries ShipToAddressId/Name; a null id collapses into a single "(no ship-to)" option. When only
    // one ship-to exists, auto-select it (no selector). The PO list then filters this cache client-side.
    private async Task LoadOpenPos()
    {
        if (!selectedSupplierId.HasValue) { openPos = new(); shipToOptions = new(); return; }
        searching = true; StateHasChanged();
        var url = $"api/purchase-orders?page=1&pageSize=200&supplierId={selectedSupplierId}&status=Released,Acknowledged,Accepted,PartiallyDelivered";
        var resp = await Api.GetAsync<PagedResult<PurchaseOrderListItemDto>>(url);
        openPos = resp?.Data?.Items ?? new();
        RebuildShipToOptions();
        // Exactly one ship-to → auto-select (skip the selector). Zero POs leaves options empty (no selector shown).
        if (shipToOptions.Count == 1)
        {
            selectedShipToId = shipToOptions[0].Id;
            shipToChosen = true;
        }
        searching = false;
    }

    // DISTINCT (ShipToAddressId, Name) over the cached open POs. Real addresses first (by name); the null-id group,
    // if any PO has no ship-to, appended once as "(no ship-to)".
    private void RebuildShipToOptions()
    {
        var real = openPos
            .Where(p => p.ShipToAddressId.HasValue)
            .GroupBy(p => p.ShipToAddressId!.Value)
            .Select(g => ((Guid?)g.Key, g.First().ShipToAddressName ?? g.Key.ToString()))
            .OrderBy(x => x.Item2, StringComparer.OrdinalIgnoreCase)
            .ToList();
        shipToOptions = real;
        if (openPos.Any(p => !p.ShipToAddressId.HasValue))
            shipToOptions.Add(((Guid?)null, "(no ship-to)"));
    }

    // Existing-ASN edit (§6.2) — the ship-to is fixed by the ASN's covered POs, so lock it rather than re-select.
    // Derive it from the first covered PO that appears in the loaded open-PO cache (the list DTO carries ShipTo*);
    // if none of the covered POs are still in the open set, fall back to whatever LoadOpenPos auto-selected (or
    // leave chosen so the locked label renders). Also upgrade the synthetic selectedPoMap entries (built from the
    // ASN header, ship-to null) to the richer open-PO list items where available so filters stay consistent.
    private void LockShipToFromCoveredPos()
    {
        var covered = openPos.Where(p => selectedPoIds.Contains(p.Id)).ToList();
        foreach (var p in covered) selectedPoMap[p.Id] = p;   // richer list item (with ship-to) over the header stub
        if (covered.Count > 0)
        {
            selectedShipToId = covered[0].ShipToAddressId;
            shipToChosen = true;
        }
        else
        {
            // No covered PO is in the open set (they moved out of the open statuses). Keep the gate satisfied so the
            // editor is not blocked — the user can still edit the existing lines; adding a new PO needs an open one.
            shipToChosen = true;
        }
    }

    private async Task AddPo(PurchaseOrderListItemDto po)
    {
        // Defence-in-depth: never add a PO from a ship-to other than the chosen one (the AddablePos filter already
        // excludes them, but a stale reference must not slip a cross-ship-to PO onto the ASN).
        if (po.ShipToAddressId != selectedShipToId) return;
        if (selectedPoIds.Add(po.Id))
        {
            selectedPoMap[po.Id] = po;
            await ReloadLines();
        }
    }

    // Removing the LAST selected PO keeps the ship-to (so the user can add another PO under it) — only supplier/
    // ship-to changes reset the gate.
    private async Task RemovePo(Guid poId)
    {
        if (selectedPoIds.Remove(poId))
        {
            selectedPoMap.Remove(poId);
            await ReloadLines();
        }
    }

    // ?pos=id1,id2 from the PO list "Create ASN from selected". Resolve the supplier from the first PO, then add
    // every preselected PO that belongs to that supplier (cross-supplier ids are skipped — one ASN, one supplier).
    // NOTE: the checkbox that produced ?pos= was removed (PreselectPos is effectively dead), but the path is kept
    // coherent — after loading the supplier's open POs it derives + locks the ship-to from the added POs so the
    // §6.2 gate holds even on a deep link.
    private async Task ApplyPreselectAsync()
    {
        var ids = (PreselectPos ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(s => Guid.TryParse(s, out var g) ? g : Guid.Empty).Where(g => g != Guid.Empty).Distinct().ToList();
        if (ids.Count == 0) return;
        foreach (var id in ids)
        {
            var po = (await Api.GetAsync<PurchaseOrderDetailDto>($"api/purchase-orders/{id}"))?.Data;
            if (po == null) continue;
            if (!selectedSupplierId.HasValue)
            {
                selectedSupplierId = po.SupplierId; selectedSupplierName = po.SupplierName; attachSupplierId = po.SupplierId;
                await LoadOpenPos();   // cache the supplier's open POs (with ship-to) so the gate can lock a ship-to
            }
            if (po.SupplierId != selectedSupplierId) continue;
            // Only add a preselected PO that is in the open set AND (once a ship-to is locked) matches it.
            var listItem = openPos.FirstOrDefault(x => x.Id == po.Id);
            if (listItem == null) continue;
            if (shipToChosen && listItem.ShipToAddressId != selectedShipToId) continue;
            if (!shipToChosen) { selectedShipToId = listItem.ShipToAddressId; shipToChosen = true; }
            selectedPoIds.Add(listItem.Id);
            selectedPoMap[listItem.Id] = listItem;
        }
        if (selectedPoIds.Count > 0) await ReloadLines();
    }

    // Merge PO lines for every selected PO; preserve already-entered ship qty/batch/expiry by line id.
    private async Task ReloadLines()
    {
        linesLoading = true;
        StateHasChanged();
        var existing = lines.ToDictionary(l => l.PurchaseOrderLineId);
        var merged = new List<LineRow>();
        foreach (var poId in selectedPoIds)
        {
            var resp = await Api.GetAsync<PurchaseOrderDetailDto>($"api/purchase-orders/{poId}");
            if (resp?.Data == null) continue;
            var poNo = resp.Data.PoNumber;
            foreach (var l in resp.Data.Lines.OrderBy(x => x.PositionNo).ThenBy(x => x.SequenceNo))
            {
                var prev = existing.GetValueOrDefault(l.Id);
                merged.Add(new LineRow
                {
                    PurchaseOrderLineId = l.Id,
                    PurchaseOrderId = poId,
                    PoNumber = poNo,
                    PositionNo = l.PositionNo,
                    SequenceNo = l.SequenceNo,
                    ItemCode = l.ItemCode,
                    OrderQty = l.OrderQty,
                    ShippedQty = prev?.ShippedQty ?? 0,
                    BatchNumber = prev?.BatchNumber,
                    ExpiryDate = prev?.ExpiryDate,
                    // Serial/lot capture flags snapshot from the PO line's Item (serialized XOR lot-controlled).
                    IsSerialized = l.IsSerialized,
                    IsLotControlled = l.IsLotControlled,
                    // Preserve already-captured serials/lots across a PO add/remove re-merge.
                    Serials = prev?.Serials ?? new(),
                    Lots = prev?.Lots ?? new(),
                    // R4 (2026-06-26) — §7.3 / DI-04: live ship-tracking from the PO line.
                    ShippedQtyToDate = l.ShippedQtyToDate,
                    Balance = l.Balance,
                    OverShipAllowance = l.OverShipAllowance,
                    IsOverShippedQtyReduced = l.IsOverShippedQtyReduced
                });
            }
        }
        lines = merged;
        linesLoading = false;
        StateHasChanged();
    }

    private void GoStep(int s) { if (s <= currentStep) currentStep = s; }
    private void PrevStep() { if (currentStep > 1) currentStep--; }
    private void NextStep()
    {
        // Over-ship: surface a dialog naming the offending lines rather than silently disabling Next (§7 guard).
        if (currentStep == 2 && lines.Any(OverAllowance)) { showOverShip = true; return; }
        if (currentStep < 4 && CanProceed) currentStep++;
    }
    private string StepLabel(int s) => s switch { 1 => "PO(s)", 2 => "Lines", 3 => "Shipment", 4 => "Review", _ => "" };

    // ---- Save draft (create or update) ----
    private async Task SaveDraft()
    {
        if (selectedPoIds.Count == 0 || !expectedDeliveryDate.HasValue) { submitError = "Select at least one PO and an expected delivery date."; currentStep = 1; return; }
        busy = true; savingDraft = true; submitError = string.Empty;

        var lineReqs = BuildLineRequests();
        if (lineReqs.Count == 0) { submitError = "Enter a ship quantity on at least one line."; busy = false; savingDraft = false; currentStep = 2; return; }

        if (IsNew)
        {
            await CreateDraftAsync(lineReqs, overrideReason: null);
        }
        else
        {
            var req = new UpdateAsnRequest(expectedDeliveryDate.Value, timeWindow, carrierName, trackingNumber, vehicleNumber, driverName, driverPhone, notes, lineReqs);
            var resp = await Api.PutAsync<AsnDetailDto, UpdateAsnRequest>($"api/asns/{Id}", req);
            if (resp?.Success == true) { Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Draft saved" }); await Reload(); }
            else { submitError = resp?.Errors?.FirstOrDefault() ?? "Failed to save (the ASN may no longer be Draft)."; }
        }
        busy = false; savingDraft = false;
    }

    // ---- R5 (§10.2) Send for approval (Draft/Rejected -> PendingApproval) ----
    // Replaces the old direct Submit. The supplier persists pending edits (an edit on a Rejected ASN flips it back to
    // Draft server-side), then POSTs /send-for-approval. The §10.3 attachment-requirement check runs server-side here:
    // a missing Mandatory blocks (400), a missing Warning returns ConfirmationRequired (two-step, same UX as R4 submit).
    private async Task SendForApproval()
    {
        if (IsNew) { await SaveDraft(); return; }
        busy = true; savingDraft = false; submitError = string.Empty;

        // Block the obvious serial/lot failures before the round-trip (the backend re-enforces at Approve/Submit).
        if (!SerialLotCaptureValid)
        {
            submitError = "Fix the serial/lot capture before sending: every serialized line needs one serial per unit, and every lot line's quantities must sum to the shipped quantity (no duplicates).";
            busy = false; currentStep = 2; return;
        }

        // Persist any pending header/line edits first (send-for-approval validates the stored ASN; a save on a Rejected
        // ASN returns it to Draft).
        var lineReqs = BuildLineRequests();
        var upd = new UpdateAsnRequest(expectedDeliveryDate!.Value, timeWindow, carrierName, trackingNumber, vehicleNumber, driverName, driverPhone, notes, lineReqs);
        var saveResp = await Api.PutAsync<AsnDetailDto, UpdateAsnRequest>($"api/asns/{Id}", upd);
        if (saveResp?.Success != true)
        {
            submitError = saveResp?.Errors?.FirstOrDefault() ?? "Could not save before sending for approval.";
            busy = false;
            return;
        }

        await SendForApprovalAsync(acknowledgeMissingAttachments: false);
        busy = false;
    }

    // ---- Create draft (with optional gate override). On a gate block, route to the override dialog. ----
    private async Task CreateDraftAsync(List<CreateAsnLineRequest> lineReqs, string? overrideReason)
    {
        var poList = selectedPoIds.ToList();
        var req = new CreateAsnRequest(
            poList.Count == 1 ? poList[0] : (Guid?)null,
            poList.Count > 1 ? poList : null,
            expectedDeliveryDate!.Value, timeWindow, carrierName, trackingNumber, vehicleNumber, driverName, driverPhone, notes, lineReqs,
            StagingKey: _stagingKey,
            OverrideReason: string.IsNullOrWhiteSpace(overrideReason) ? null : overrideReason.Trim());
        var resp = await Api.PostAsync<AsnDetailDto, CreateAsnRequest>("api/asns", req);
        if (resp?.Success == true && resp.Data != null)
        {
            showGateOverride = false;
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Draft ASN created" });
            // Navigate to the saved draft so attachments (ownerEntityType='Asn') become available + submit is enabled.
            NavMgr.NavigateToRoute($"/asns/{resp.Data.Id}");
            return;
        }
        var err = resp?.Errors?.FirstOrDefault();
        if (IsGateBlock(err)) { OpenGateOverride(err!); }
        else { submitError = err ?? "Failed to create ASN."; }
    }

    // ---- R5 (§10.2/§10.3) Send-for-approval — handles the §13.6 Warning-attachment confirm two-step. ----
    // Note: the PO confirmation gate + over-ship guard NO LONGER fire here (§10.4) — they moved to the buyer's
    // Approve (the final Submit). So the only two-step on this path is the Warning-attachment confirm.
    private async Task SendForApprovalAsync(bool acknowledgeMissingAttachments)
    {
        var body = new SendForApprovalRequest(acknowledgeMissingAttachments);
        var resp = await Api.PostAsync<AsnDetailDto, SendForApprovalRequest>($"api/asns/{Id}/send-for-approval", body);

        // (1) Success — now PendingApproval.
        if (resp?.Success == true && resp.Data != null)
        {
            showAttachConfirm = false;
            detail = resp.Data;
            attachments.Clear();
            attachments.AddRange(resp.Data.Attachments);
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Sent for approval", Detail = "The PO buyer(s) will review and approve or reject this ASN." });
            await Reload();   // re-render in the locked/read-only PendingApproval view
            return;
        }

        // (2) Warning attachments missing — 200 ConfirmationRequired, nothing committed. Show the confirm dialog.
        if (resp?.ConfirmationRequired == true)
        {
            attachConfirmMessage = string.IsNullOrEmpty(resp.ConfirmationMessage)
                ? "One or more required attachments were not uploaded, do you wish to proceed?"
                : resp.ConfirmationMessage!;
            attachMissing = resp.MissingAttachments ?? new();
            showAttachConfirm = true;
            return;
        }

        // (3) Blocking error — missing Mandatory attachment, not-Draft, etc.
        submitError = resp?.Errors?.FirstOrDefault()
            ?? "Could not send for approval (a mandatory attachment may be missing, or the ASN is no longer Draft/Rejected).";
    }

    // The PO confirmation-gate override dialog only fires on CREATE now (§6.5 / UC-PO-09) — §10.4 moved the submit-time
    // gate to the buyer's Approve, so send-for-approval never hits it.
    private void OpenGateOverride(string message)
    {
        gateBlockMessage = message;
        gateOverrideReason = string.Empty;
        gateOverrideError = string.Empty;
        showAttachConfirm = false;
        showGateOverride = true;
    }

    private async Task ConfirmGateOverride()
    {
        if (string.IsNullOrWhiteSpace(gateOverrideReason)) { gateOverrideError = "A reason is required to override the gate."; return; }
        busy = true; gateOverrideError = string.Empty; submitError = string.Empty;
        // Only the create path can reach the gate now (§10.4 moved the submit-time gate to the buyer's Approve).
        var lineReqs = BuildLineRequests();
        await CreateDraftAsync(lineReqs, gateOverrideReason);
        busy = false;
    }

    // Re-send acknowledging the missing Warning attachments (§13.6 / §10.3 two-step).
    private async Task ConfirmSubmitWithMissingAttachments()
    {
        busy = true; submitError = string.Empty;
        await SendForApprovalAsync(acknowledgeMissingAttachments: true);
        busy = false;
    }

    // ============================ R5 (§10.2) buyer Approve / Reject ============================
    private void OpenApproveDialog() { approveError = string.Empty; showApprove = true; }
    private void OpenRejectDialog() { rejectReason = string.Empty; rejectError = string.Empty; showReject = true; }

    // Approve runs the SUBMIT path server-side: the over-ship atomic guard consumes balance, the ASN flips to
    // Submitted and a draft invoice is created. If the balance was lost after approval (UC-AP-05) Submit fails and the
    // ASN stays PendingApproval — we surface that message in the dialog.
    private async Task DoApprove()
    {
        busy = true; approveError = string.Empty;
        var resp = await Api.PostAsync<AsnDetailDto, ApproveAsnRequest>($"api/asns/{Id}/approve", new ApproveAsnRequest());
        if (resp?.Success == true && resp.Data != null)
        {
            showApprove = false;
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "ASN approved", Detail = resp.Data.DraftInvoiceId.HasValue ? "The shipment was submitted and a draft invoice created." : "The shipment was submitted." });
            await Reload();
        }
        else
        {
            approveError = resp?.Errors?.FirstOrDefault() ?? "Could not approve (the shipment balance may have changed, or you are not a mapped buyer for this ASN).";
        }
        busy = false;
    }

    // Reject needs a mandatory reason; no balance was consumed so there is no reversal. The ASN returns to Rejected and
    // the supplier is notified (best-effort, server-side).
    private async Task DoReject()
    {
        if (string.IsNullOrWhiteSpace(rejectReason)) { rejectError = "A reason is required to reject."; return; }
        busy = true; rejectError = string.Empty;
        var resp = await Api.PostAsync<AsnDetailDto, RejectAsnRequest>($"api/asns/{Id}/reject", new RejectAsnRequest(rejectReason.Trim()));
        if (resp?.Success == true)
        {
            showReject = false;
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Warning, Summary = "ASN rejected", Detail = "The supplier can edit and re-send it for approval." });
            await Reload();
        }
        else
        {
            rejectError = resp?.Errors?.FirstOrDefault() ?? "Could not reject (it may no longer be PendingApproval, or you are not a mapped buyer).";
        }
        busy = false;
    }

    // ---- Cancel ----
    private void OpenCancelDialog() { dialogError = string.Empty; showCancel = true; }

    private async Task DoCancel()
    {
        busy = true; dialogError = string.Empty;
        var resp = await Api.PostAsync<object>($"api/asns/{Id}/cancel", new { });
        if (resp?.Success == true) { Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Warning, Summary = "ASN cancelled" }); showCancel = false; await Reload(); }
        else { dialogError = resp?.Errors?.FirstOrDefault() ?? "Could not cancel (it may already be Cancelled)."; }
        busy = false;
    }

    // R5 (§13) — attachment upload/list/remove moved into the reusable AttachmentPanel (Components/Shared).
    // OnPanelChanged (above) keeps the page's review-summary count in sync; the panel handles the rest.

    // R4 (2026-06-26) — §7.3 / §5.3 / DI-04: render the nominal balance + the over-ship allowance SEPARATELY, plus
    // the "qty reduced below shipped" exception flag. Shared shape for the wizard (LineRow) and the locked view
    // (AsnLineDto) via the two thin wrappers below.
    private static RenderFragment RenderBalance(decimal balance, decimal overShipAllowance, bool overShippedReduced) => builder =>
    {
        var seq = 0;
        builder.OpenElement(seq++, "div");
        builder.AddAttribute(seq++, "style", "display:flex;flex-direction:column;gap:2px;font-family:Inter,monospace;");

        builder.OpenElement(seq++, "span");
        builder.AddContent(seq++, $"Balance {balance.ToString("0.###")}");
        builder.CloseElement();

        if (overShipAllowance - balance > 0)
        {
            builder.OpenElement(seq++, "span");
            builder.AddAttribute(seq++, "style", "font-size:10.5px;color:var(--mer-ink-500);");
            builder.AddContent(seq++, $"over-ship allowance up to {overShipAllowance.ToString("0.###")}");
            builder.CloseElement();
        }

        if (overShippedReduced)
        {
            builder.OpenElement(seq++, "span");
            builder.AddAttribute(seq++, "class", "tlg-status tlg-status--danger");
            builder.AddAttribute(seq++, "title", "Order qty was revised below the quantity already shipped");
            builder.AddAttribute(seq++, "style", "font-family:'Plus Jakarta Sans',sans-serif;width:fit-content;margin-top:2px;");
            builder.AddContent(seq++, "qty reduced below shipped");
            builder.CloseElement();
        }
        builder.CloseElement();
    };

    private RenderFragment BalanceCell(LineRow l) => RenderBalance(l.Balance, l.OverShipAllowance, l.IsOverShippedQtyReduced);
    // AsnLineDto carries no IsOverShippedQtyReduced (it's a PO-line concept) — pass false in the locked view.
    private RenderFragment DetailBalanceCell(AsnLineDto l) => RenderBalance(l.Balance, l.OverShipAllowance, false);

    private void BackToList() => NavMgr.NavigateToRoute("/asns");

    private string StatusClass(string status) => status switch
    {
        "Delivered" => "tlg-status--active",
        // R5 (§10.1) — PendingApproval sits between Draft and Submitted; treated like the other in-flight states.
        "Submitted" or "InTransit" or "PendingApproval" => "tlg-status--pending",
        "Cancelled" or "Rejected" => "tlg-status--danger",
        _ => "tlg-status--info"
    };

    // Build the line request set from the grid, mapping captured serials/lots onto each line. Only the
    // collection matching the line's type is populated (serialized XOR lot-controlled); the other stays null.
    private List<CreateAsnLineRequest> BuildLineRequests() =>
        lines.Where(l => l.ShippedQty > 0).Select(l =>
        {
            List<AsnLineSerialInput>? serials = null;
            List<AsnLineLotInput>? lots = null;
            if (l.IsSerialized)
                serials = l.Serials.Where(s => !string.IsNullOrWhiteSpace(s.Serial))
                    .Select(s => new AsnLineSerialInput(s.Serial.Trim(), s.Expiry)).ToList();
            else if (l.IsLotControlled)
                lots = l.Lots.Where(x => !string.IsNullOrWhiteSpace(x.LotNo) && (x.Qty ?? 0) > 0)
                    .Select(x => new AsnLineLotInput(x.LotNo.Trim(), x.Qty ?? 0, x.ExpiryDate)).ToList();
            return new CreateAsnLineRequest(l.PurchaseOrderLineId, l.ShippedQty, l.BatchNumber, l.ExpiryDate, serials, lots);
        }).ToList();

    // ---- Serial / lot capture helpers (R4 2026-06-23) ----
    // Don't render thousands of textboxes for huge qty: render up to this many; the paste box still fills the rest.
    private const int SerialBoxCap = 200;

    // The step-2 capture sections render only for VALID shipped lines — qty within the over-ship allowance. An
    // over-shipped line generates NO serial/lot boxes (capturing N serials against an invalid qty makes no sense);
    // it shows the red border + over-ship dialog, and NextStep blocks advancing until the qty is corrected.
    private List<LineRow> SerialLines => lines.Where(l => l.IsSerialized && l.ShippedQty > 0 && !OverAllowance(l)).ToList();
    private List<LineRow> LotLines => lines.Where(l => l.IsLotControlled && l.ShippedQty > 0 && !OverAllowance(l)).ToList();

    // Grow the per-line serial slot list to N so the indexed @bind targets exist. New rows inherit the line's bulk
    // expiry (so "set expiry for all" then grow, or grow then "apply to all", both land the shared date).
    private static void EnsureSerialSlots(LineRow line, int need)
    {
        while (line.Serials.Count < need) line.Serials.Add(new SerialRow { Expiry = line._bulkExpiry });
        // Trim trailing extras only if the user reduced ShippedQty (keep what fits N).
        if (line.Serials.Count > need) line.Serials.RemoveRange(need, line.Serials.Count - need);
    }

    // R4 (2026-06-30) — bulk expiry: copy the line's _bulkExpiry onto every serial row (overwrites per-row edits —
    // the common case is one shared expiry). "Clear" nulls them all.
    private static void ApplyBulkExpiry(LineRow line)
    {
        EnsureSerialSlots(line, (int)line.ShippedQty);
        foreach (var s in line.Serials) s.Expiry = line._bulkExpiry;
    }

    private static void ClearExpiries(LineRow line)
    {
        line._bulkExpiry = null;
        foreach (var s in line.Serials) s.Expiry = null;
    }

    private static bool DuplicateSerial(LineRow line, int idx)
    {
        var v = line.Serials[idx].Serial?.Trim();
        if (string.IsNullOrEmpty(v)) return false;
        for (int j = 0; j < line.Serials.Count; j++)
            if (j != idx && string.Equals(line.Serials[j].Serial?.Trim(), v, StringComparison.OrdinalIgnoreCase)) return true;
        return false;
    }

    private static bool DuplicateLot(LineRow line, LotRow lot)
    {
        var v = lot.LotNo?.Trim();
        if (string.IsNullOrEmpty(v)) return false;
        return line.Lots.Count(x => string.Equals(x.LotNo?.Trim(), v, StringComparison.OrdinalIgnoreCase)) > 1;
    }

    // Paste → split on newline/comma → fill exactly N boxes; extras are ignored (warned). Cleaned non-empty.
    private static void ApplyPaste(LineRow line)
    {
        var need = (int)line.ShippedQty;
        var tokens = (line._pasteBuffer ?? string.Empty)
            .Split(new[] { '\n', '\r', ',' }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToList();
        EnsureSerialSlots(line, need);
        var take = Math.Min(tokens.Count, need);
        for (int i = 0; i < take; i++) line.Serials[i].Serial = tokens[i];
        line._pasteWarn = tokens.Count > need ? $"{tokens.Count - need} extra serial(s) ignored (need {need})." : null;
        line._pasteBuffer = string.Empty;
    }

    // A serialized line is valid when exactly N non-empty serials are captured with no case-insensitive dupes.
    private static bool SerialLineValid(LineRow line, out string message)
    {
        var need = (int)line.ShippedQty;
        var vals = line.Serials.Select(s => s.Serial?.Trim()).Where(s => !string.IsNullOrEmpty(s)).ToList();
        if (vals.Count != need) { message = $"Captured {vals.Count} of {need} required serial(s)."; return false; }
        var distinct = vals.Select(s => s!.ToLowerInvariant()).Distinct().Count();
        if (distinct != vals.Count) { message = "Duplicate serial numbers on this line."; return false; }
        message = string.Empty; return true;
    }

    // A lot line is valid when Σqty == ShippedQty, every lot has a non-empty unique lotNo and a qty > 0.
    private static bool LotLineValid(LineRow line, out string message)
    {
        if (line.Lots.Count == 0) { message = "Add at least one lot."; return false; }
        if (line.Lots.Any(l => string.IsNullOrWhiteSpace(l.LotNo))) { message = "Every lot needs a lot number."; return false; }
        if (line.Lots.Any(l => (l.Qty ?? 0) <= 0)) { message = "Every lot needs a quantity greater than zero."; return false; }
        var dupes = line.Lots.GroupBy(l => l.LotNo!.Trim().ToLowerInvariant()).Any(g => g.Count() > 1);
        if (dupes) { message = "Duplicate lot numbers on this line."; return false; }
        if (line.Lots.Sum(l => l.Qty ?? 0) != line.ShippedQty) { message = $"Lot quantities must sum to {line.ShippedQty:0.###}."; return false; }
        message = string.Empty; return true;
    }

    // True only if EVERY serialized/lot line currently passes — gates Next on step 2 and the final submit.
    private bool SerialLotCaptureValid =>
        SerialLines.All(l => SerialLineValid(l, out _))
        && LotLines.All(l => LotLineValid(l, out _));

    private class LineRow
    {
        public Guid PurchaseOrderLineId { get; set; }
        public Guid PurchaseOrderId { get; set; }
        public string PoNumber { get; set; } = string.Empty;
        public int PositionNo { get; set; }
        public int? SequenceNo { get; set; }
        public string ItemCode { get; set; } = string.Empty;
        public decimal OrderQty { get; set; }
        public decimal ShippedQty { get; set; }
        public string? BatchNumber { get; set; }
        public DateTime? ExpiryDate { get; set; }

        // R4 (2026-06-23) — Serial/Lot capture. Item flags (serialized XOR lot-controlled) drive which capture
        // section the line gets; Serials/Lots hold the captured values. ShippedQty is the required count/Σ.
        public bool IsSerialized { get; set; }
        public bool IsLotControlled { get; set; }
        public List<SerialRow> Serials { get; set; } = new();
        public List<LotRow> Lots { get; set; } = new();
        // R4 (2026-06-30) — bulk "expiry for all units" picker value (transient; copied onto each SerialRow.Expiry).
        public DateOnly? _bulkExpiry { get; set; }

        // R4 (2026-06-26) — §7.3 / §5.3 / DI-04: the PO-line ship-tracking figures shown on the ASN wizard. Balance
        // is nominal (MAX(0, orderQty − shippedQtyToDate)); OverShipAllowance is the tolerance-adjusted ceiling
        // headroom — shown SEPARATELY. IsOverShippedQtyReduced flags a line whose orderQty was revised below the
        // already-shipped cumulative (UC-ASN-10).
        public decimal ShippedQtyToDate { get; set; }
        public decimal Balance { get; set; }
        public decimal OverShipAllowance { get; set; }
        public bool IsOverShippedQtyReduced { get; set; }

        // Transient UI state (not persisted): the paste textarea buffer + the last paste warning for this line.
        public string? _pasteBuffer { get; set; }
        public string? _pasteWarn { get; set; }
    }

    // One captured serial row (serialized line): one physical unit = one serial + optional expiry. (R4 2026-06-30)
    private class SerialRow
    {
        public string Serial { get; set; } = string.Empty;
        public DateOnly? Expiry { get; set; }
    }

    // One captured lot row (lot-controlled line): lotNo + qty + optional expiry.
    private class LotRow
    {
        public string LotNo { get; set; } = string.Empty;
        public decimal? Qty { get; set; }
        public DateOnly? ExpiryDate { get; set; }
    }
}
