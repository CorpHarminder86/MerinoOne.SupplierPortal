@page "/invoices/{Id:guid}"
@inject ApiClient Api
@inject TokenAccessor Token
@inject NavigationManager Nav
@inject NotificationService Notif

<PageTitle>@detail?.InvoiceNumber</PageTitle>

@if (loading)
{
    <div class="tl-empty">Loading…</div>
}
else if (detail == null)
{
    <div class="tl-empty">Invoice not found.</div>
}
else
{
    <div class="tl-page">
        <a href="invoices" class="mer-back-link">
            <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">arrow_back</span>
            Back to list
        </a>
        <header class="tl-header">
            <div>
                <div class="tl-title-row">
                    <h1 class="tl-title">@detail.InvoiceNumber</h1>
                    <span class="tlg-status @StatusClass(detail.InvoiceStatus)">@detail.InvoiceStatus</span>
                </div>
                <p class="tl-sub">@detail.SupplierName · @PoHeaderText · @detail.InvoiceDate.ToString("yyyy-MM-dd")</p>
            </div>
            <div class="tl-header__actions">
                @* R6 — frozen-snapshot PDF, any status. Same-origin proxy (/files/invoice-pdf/{id} in Program.cs)
                   attaches the cookie-JWT as bearer; page access already implies Invoice.Read. *@
                <a class="rz-button" style="padding:8px 14px;border-radius:6px;border:1px solid var(--mer-ink-300);background:var(--mer-surface);color:var(--mer-ink-700);text-decoration:none;" href="files/invoice-pdf/@Id" download>
                    <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">download</span> Download PDF
                </a>
                @if (Token.HasPermission("Invoice.Submit") && detail.InvoiceStatus == "Draft")
                {
                    <button class="rz-button" style="padding:8px 14px;border-radius:6px;border:1px solid var(--mer-ink-300);background:var(--mer-surface);cursor:pointer;color:var(--mer-ink-700);" @onclick="OpenEdit" disabled="@busy">
                        <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">edit</span> Edit
                    </button>
                    @* R6 — the DRAFT-{asn}-{n} (and legacy INV-DRAFT-) placeholder is rejected server-side; block
                       the affordance client-side too until the supplier keys the real number via Edit. *@
                    <button class="rz-button rz-secondary" style="padding:8px 14px;border-radius:6px;border:0;color:#fff;cursor:pointer;" @onclick="OpenSubmit"
                            disabled="@(busy || HasPlaceholderNumber)"
                            title="@(HasPlaceholderNumber ? "Replace the draft placeholder with the real invoice number (Edit) before submitting." : null)">
                        <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">send</span> Submit
                    </button>
                }
                @if (Token.HasPermission("Invoice.Revoke") && detail.InvoiceStatus == "Submitted" && !detail.ErpPostedAt.HasValue)
                {
                    <button class="rz-button" style="padding:8px 14px;border-radius:6px;border:1px solid var(--mer-warning);background:var(--mer-surface);color:var(--mer-warning);cursor:pointer;" @onclick="OpenRevoke" disabled="@busy">
                        <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">undo</span> Revoke to Draft
                    </button>
                }
                @if (Token.HasPermission("Invoice.Review") && detail.InvoiceStatus == "Submitted")
                {
                    <button class="rz-button" style="padding:8px 14px;border-radius:6px;border:1px solid var(--mer-ink-300);background:var(--mer-surface);cursor:pointer;color:var(--mer-ink-700);" @onclick="OpenReview" disabled="@busy">
                        <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">fact_check</span> Mark Under Review
                    </button>
                }
                @if (Token.HasPermission("Invoice.Approve") && (detail.InvoiceStatus == "UnderReview" || detail.InvoiceStatus == "Matched"))
                {
                    <button class="rz-button rz-secondary" style="padding:8px 14px;border-radius:6px;border:0;color:#fff;cursor:pointer;" @onclick="OpenApprove" disabled="@busy">
                        <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">task_alt</span> Approve
                    </button>
                    <button class="rz-button" style="padding:8px 14px;border-radius:6px;border:1px solid var(--mer-red);background:var(--mer-surface);color:var(--mer-red);cursor:pointer;" @onclick="OpenReject" disabled="@busy">
                        <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">cancel</span> Reject
                    </button>
                }
                @if (Token.HasPermission("CreditDebitNote.Write"))
                {
                    <button class="rz-button" style="padding:8px 14px;border-radius:6px;border:1px solid var(--mer-ink-300);background:var(--mer-surface);cursor:pointer;color:var(--mer-ink-700);" @onclick="OpenCreateNote" disabled="@busy">
                        <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">request_quote</span> Create Credit/Debit Note
                    </button>
                }
            </div>
        </header>

        <div class="mer-tabs" style="display:flex;gap:0;border-bottom:1px solid var(--mer-line);margin-bottom:16px;">
            <button class="mer-tab @(tab=="overview"?"mer-tab--active":"")" @onclick="TabOverview" style="padding:10px 16px;background:transparent;border:0;border-bottom:2px solid @(tab=="overview"?"var(--mer-blue)":"transparent");cursor:pointer;font:600 13px/1 'Plus Jakarta Sans',sans-serif;color:@(tab=="overview"?"var(--mer-blue)":"var(--mer-ink-700)");">Overview</button>
            <button class="mer-tab @(tab=="history"?"mer-tab--active":"")" @onclick="TabHistory" style="padding:10px 16px;background:transparent;border:0;border-bottom:2px solid @(tab=="history"?"var(--mer-blue)":"transparent");cursor:pointer;font:600 13px/1 'Plus Jakarta Sans',sans-serif;color:@(tab=="history"?"var(--mer-blue)":"var(--mer-ink-700)");">History</button>
        </div>

        @if (tab == "history")
        {
            <AuditHistoryTab EntityName="Invoice" EntityId="@Id" />
        }
        else
        {
        <div style="display:grid;grid-template-columns:1.5fr 1fr;gap:16px;">
            <div class="rz-card" style="padding:20px;">
                <h3 style="font-size:14px;font-weight:700;margin-bottom:12px;color:var(--mer-blue-darker);">Invoice details</h3>
                <dl style="display:grid;grid-template-columns:160px 1fr;gap:6px 16px;font-size:13px;">
                    <dt style="color:var(--mer-ink-500);">Supplier</dt><dd>@detail.SupplierName (@detail.SupplierCode)</dd>
                    <dt style="color:var(--mer-ink-500);">Purchase order(s)</dt>
                    <dd style="font-family:Inter,monospace;">
                        @if (detail.PurchaseOrders.Count > 0)
                        {
                            @foreach (var po in detail.PurchaseOrders)
                            {
                                <a href="purchase-orders/@po.PurchaseOrderId" style="color:var(--mer-blue);margin-right:8px;">@po.PoNumber</a>
                            }
                        }
                        else if (detail.PurchaseOrderId.HasValue)
                        {
                            <a href="purchase-orders/@detail.PurchaseOrderId" style="color:var(--mer-blue);">@detail.PoNumber</a>
                        }
                        else { <span>—</span> }
                    </dd>
                    @if (!string.IsNullOrEmpty(detail.AsnNumber))
                    {
                        <dt style="color:var(--mer-ink-500);">ASN</dt>
                        <dd>
                            @if (detail.AsnId.HasValue)
                            {
                                <a href="asns/@detail.AsnId" style="color:var(--mer-blue);font-family:Inter,monospace;">@detail.AsnNumber</a>
                            }
                            else { <span style="font-family:Inter,monospace;">@detail.AsnNumber</span> }
                        </dd>
                    }
                    <dt style="color:var(--mer-ink-500);">Origin</dt>
                    <dd>
                        @if (detail.InvoiceOrigin == "AsnGenerated")
                        {
                            <span class="tlg-status tlg-status--info" title="Auto-generated from the ASN at approval">ASN-generated</span>
                        }
                        else
                        {
                            <span class="tlg-status tlg-status--off">Manual entry</span>
                        }
                    </dd>
                    <dt style="color:var(--mer-ink-500);">Invoice date</dt><dd style="font-family:Inter,monospace;">@detail.InvoiceDate.ToString("yyyy-MM-dd")</dd>
                    <dt style="color:var(--mer-ink-500);">Matching</dt><dd>@detail.MatchingType</dd>
                    @if (!string.IsNullOrEmpty(detail.GrnReference))
                    {
                        <dt style="color:var(--mer-ink-500);">GRN reference</dt><dd style="font-family:Inter,monospace;">@detail.GrnReference</dd>
                    }
                    @if (!string.IsNullOrEmpty(detail.EInvoiceIrn))
                    {
                        <dt style="color:var(--mer-ink-500);">e-Invoice IRN</dt><dd style="font-family:Inter,monospace;font-size:11px;">@detail.EInvoiceIrn</dd>
                    }
                    @if (!string.IsNullOrEmpty(detail.EInvoiceAckNo))
                    {
                        <dt style="color:var(--mer-ink-500);">Ack #</dt><dd style="font-family:Inter,monospace;">@detail.EInvoiceAckNo</dd>
                    }
                    @if (!string.IsNullOrEmpty(detail.EWayBillNumber))
                    {
                        <dt style="color:var(--mer-ink-500);">e-Way Bill</dt><dd style="font-family:Inter,monospace;">@detail.EWayBillNumber</dd>
                    }
                    @if (detail.SubmittedAt.HasValue)
                    {
                        <dt style="color:var(--mer-ink-500);">Submitted</dt><dd style="font-family:Inter,monospace;">@detail.SubmittedAt.Value.ToString("yyyy-MM-dd HH:mm") @(string.IsNullOrEmpty(detail.SubmittedBy) ? "" : $"by {detail.SubmittedBy}")</dd>
                    }
                    @if (detail.ApprovedAt.HasValue)
                    {
                        <dt style="color:var(--mer-ink-500);">Approved</dt><dd style="font-family:Inter,monospace;">@detail.ApprovedAt.Value.ToString("yyyy-MM-dd HH:mm") by @detail.ApprovedBy</dd>
                    }
                    @if (detail.RevokedAt.HasValue)
                    {
                        <dt style="color:var(--mer-ink-500);">Revoked</dt><dd style="font-family:Inter,monospace;">@detail.RevokedAt.Value.ToString("yyyy-MM-dd HH:mm") @(string.IsNullOrEmpty(detail.RevokedBy) ? "" : $"by {detail.RevokedBy}")</dd>
                    }
                    @if (!string.IsNullOrEmpty(detail.RevokeReason))
                    {
                        <dt style="color:var(--mer-ink-500);">Revoke reason</dt><dd style="white-space:pre-wrap;">@detail.RevokeReason</dd>
                    }
                    @if (detail.ErpPostedAt.HasValue)
                    {
                        <dt style="color:var(--mer-ink-500);">ERP posted</dt><dd style="font-family:Inter,monospace;">@detail.ErpPostedAt.Value.ToString("yyyy-MM-dd HH:mm")</dd>
                    }
                    @if (!string.IsNullOrEmpty(detail.ErpCode))
                    {
                        <dt style="color:var(--mer-ink-500);">ERP code</dt><dd style="font-family:Inter,monospace;">@detail.ErpCode</dd>
                    }
                    @if (!string.IsNullOrEmpty(detail.RejectionReason))
                    {
                        <dt style="color:var(--mer-ink-500);">Rejection reason</dt><dd style="background:var(--mer-red-50);color:var(--mer-red);padding:6px 10px;border-radius:4px;">@detail.RejectionReason</dd>
                    }
                </dl>
            </div>

            <div class="rz-card" style="padding:20px;">
                <h3 style="font-size:14px;font-weight:700;margin-bottom:12px;color:var(--mer-blue-darker);">Totals</h3>
                <dl style="display:grid;grid-template-columns:140px 1fr;gap:6px 16px;font-size:13px;">
                    <dt style="color:var(--mer-ink-500);">Currency</dt><dd>@detail.CurrencyCode</dd>
                    <dt style="color:var(--mer-ink-500);">Invoice amount</dt><dd style="font-family:Inter,monospace;text-align:right;">@detail.InvoiceAmount.ToString("N2")</dd>
                    <dt style="color:var(--mer-ink-500);">Tax</dt><dd style="font-family:Inter,monospace;text-align:right;">@detail.TaxAmount.ToString("N2")</dd>
                    <dt style="color:var(--mer-ink-500);font-weight:700;">Net</dt><dd style="font-family:Inter,monospace;text-align:right;font-weight:700;color:var(--mer-blue-darker);">@detail.NetAmount.ToString("N2")</dd>
                </dl>
                @if (!string.IsNullOrEmpty(detail.Notes))
                {
                    <h4 style="font-size:12px;font-weight:700;margin:16px 0 6px;color:var(--mer-ink-700);">Notes</h4>
                    <p style="font-size:13px;color:var(--mer-ink-700);white-space:pre-wrap;">@detail.Notes</p>
                }
            </div>
        </div>

        @* R6 (D14) — ASN-seeded Draft editing lives HERE (not a separate page): when the invoice is Draft and the
           caller holds Invoice.Submit, Billed Qty (capped at the LIVE RemainingQty) and Tax (reselect from the
           governed active list — the rate is display-only, NEVER typed) become editable per line. Amounts shown
           are a client-side preview (round(qty×price,2); tax = round(lineAmount×rate/100,2)) — the server
           recompute on save is authoritative. *@
        <div class="rz-card" style="padding:20px;margin-top:16px;">
            <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:12px;">
                <div>
                    <h3 style="font-size:14px;font-weight:700;margin-bottom:2px;color:var(--mer-blue-darker);">Lines (@detail.Lines.Count)</h3>
                    @if (CanEditLines && detail.Lines.Count > 0)
                    {
                        <p style="font-size:12px;color:var(--mer-ink-500);margin:0;">Billed quantity is capped at each PO line's remaining invoiceable balance. Tax is reselected from the governed list — the rate follows the selection.</p>
                    }
                </div>
                @if (CanEditLines && detail.Lines.Count > 0)
                {
                    <button class="rz-button rz-secondary" style="padding:8px 14px;border-radius:6px;border:0;color:#fff;cursor:pointer;flex:none;" @onclick="SaveLines"
                            disabled="@(busy || AnyLineErrors)" title="@(AnyLineErrors ? "Fix the highlighted line errors first." : null)">
                        <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">save</span> @(busy ? "Saving…" : "Save lines")
                    </button>
                }
            </div>
            @if (detail.Lines.Count == 0)
            {
                <p style="font-size:13px;color:var(--mer-ink-500);">No lines on this invoice.</p>
            }
            else
            {
                <table style="width:100%;font-size:12.5px;border-collapse:collapse;">
                    <thead>
                        <tr style="border-bottom:1px solid var(--mer-line);">
                            <th style="text-align:left;padding:6px 4px;color:var(--mer-ink-700);">Item</th>
                            <th style="text-align:left;padding:6px 4px;color:var(--mer-ink-700);">Description</th>
                            <th style="text-align:left;padding:6px 4px;color:var(--mer-ink-700);">PO</th>
                            <th style="text-align:right;padding:6px 4px;color:var(--mer-ink-700);">Billed Qty</th>
                            <th style="text-align:right;padding:6px 4px;color:var(--mer-ink-700);">Unit Price</th>
                            <th style="text-align:left;padding:6px 4px;color:var(--mer-ink-700);">Tax</th>
                            <th style="text-align:right;padding:6px 4px;color:var(--mer-ink-700);">Rate %</th>
                            <th style="text-align:right;padding:6px 4px;color:var(--mer-ink-700);">Tax Amt</th>
                            <th style="text-align:right;padding:6px 4px;color:var(--mer-ink-700);">Line Amt</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var ln in detail.Lines.OrderBy(l => l.ItemCode))
                    {
                        var ed = CanEditLines && lineEdits.TryGetValue(ln.Id, out var st) ? st : null;
                        <tr style="border-bottom:1px solid var(--mer-line-soft);">
                            <td style="padding:6px 4px;font-family:Inter,monospace;">@ln.ItemCode</td>
                            <td style="padding:6px 4px;">@ln.ItemDescription</td>
                            <td style="padding:6px 4px;font-family:Inter,monospace;">
                                @if (ln.PurchaseOrderId.HasValue && !string.IsNullOrEmpty(ln.PoNumber))
                                {
                                    <a href="purchase-orders/@ln.PurchaseOrderId" style="color:var(--mer-blue);">@ln.PoNumber</a>
                                }
                                else { <span>—</span> }
                            </td>
                            @if (ed != null)
                            {
                                <td style="padding:6px 4px;text-align:right;">
                                    <input type="number" min="0" max="@ed.RemainingQty.ToString("0.####", System.Globalization.CultureInfo.InvariantCulture)" step="0.0001"
                                           class="rz-textbox" style="width:110px;padding:6px 8px;font-family:Inter,monospace;text-align:right;@(ed.Error != null ? "border-color:var(--mer-red);" : "")"
                                           @bind="ed.BilledQty" @bind:after="() => OnQtyChanged(ed)" />
                                    <div style="font-size:10.5px;color:var(--mer-ink-500);font-family:Inter,monospace;margin-top:2px;">of @ed.RemainingQty.ToString("0.####") remaining</div>
                                    @if (ed.Error != null)
                                    {
                                        <div style="font-size:10.5px;color:var(--mer-red);font-weight:600;margin-top:2px;white-space:normal;">@ed.Error</div>
                                    }
                                </td>
                                <td style="padding:6px 4px;text-align:right;font-family:Inter,monospace;">@ln.UnitPrice.ToString("0.00")</td>
                                <td style="padding:6px 4px;">
                                    <select class="rz-dropdown" style="max-width:230px;padding:6px 8px;border:1px solid var(--mer-ink-300);border-radius:6px;background:var(--mer-surface);font-size:12px;"
                                            @bind="ed.TaxIdStr" @bind:after="() => OnTaxChanged(ed)">
                                        <option value="">(no tax)</option>
                                        @* The line's current tax stays selectable even when it is missing from the
                                           active list (inactive / rate-less) so "keep current" always round-trips. *@
                                        @if (ed.SnapshotTaxIdStr.Length > 0 && taxes.All(t => t.Id.ToString() != ed.SnapshotTaxIdStr))
                                        {
                                            <option value="@ed.SnapshotTaxIdStr">@ed.SnapshotLabel</option>
                                        }
                                        @foreach (var t in taxes)
                                        {
                                            <option value="@t.Id">@($"{t.Code} — {t.Description} ({t.TaxRate!.Value:0.####}%)")</option>
                                        }
                                    </select>
                                </td>
                                <td style="padding:6px 4px;text-align:right;font-family:Inter,monospace;">@(ed.Rate?.ToString("0.####") ?? "—")</td>
                                <td style="padding:6px 4px;text-align:right;font-family:Inter,monospace;">@EditTaxAmount(ed).ToString("N2")</td>
                                <td style="padding:6px 4px;text-align:right;font-family:Inter,monospace;font-weight:600;">@EditLineAmount(ed).ToString("N2")</td>
                            }
                            else
                            {
                                <td style="padding:6px 4px;text-align:right;font-family:Inter,monospace;">@ln.BilledQty.ToString("0.###")</td>
                                <td style="padding:6px 4px;text-align:right;font-family:Inter,monospace;">@ln.UnitPrice.ToString("0.00")</td>
                                <td style="padding:6px 4px;font-family:Inter,monospace;" title="@ln.TaxDescription">@(ln.TaxCode ?? "—")</td>
                                <td style="padding:6px 4px;text-align:right;font-family:Inter,monospace;">@(ln.TaxRatePct?.ToString("0.####") ?? "—")</td>
                                <td style="padding:6px 4px;text-align:right;font-family:Inter,monospace;">@ln.TaxAmount.ToString("0.00")</td>
                                <td style="padding:6px 4px;text-align:right;font-family:Inter,monospace;font-weight:600;">@ln.LineAmount.ToString("0.00")</td>
                            }
                        </tr>
                    }
                    </tbody>
                    <tfoot>
                        <tr style="border-top:2px solid var(--mer-line);">
                            <td colspan="6" style="padding:8px 4px;text-align:right;font-weight:700;color:var(--mer-ink-700);">Totals</td>
                            <td></td>
                            <td style="padding:8px 4px;text-align:right;font-family:Inter,monospace;font-weight:600;">@DisplayTaxTotal.ToString("N2")</td>
                            <td style="padding:8px 4px;text-align:right;font-family:Inter,monospace;font-weight:700;color:var(--mer-blue-darker);">@DisplayLineTotal.ToString("N2")</td>
                        </tr>
                        <tr>
                            <td colspan="8" style="padding:2px 4px 6px;text-align:right;font-size:11.5px;color:var(--mer-ink-500);">Net (amount + tax)</td>
                            <td style="padding:2px 4px 6px;text-align:right;font-family:Inter,monospace;font-weight:700;color:var(--mer-blue-darker);">@((DisplayLineTotal + DisplayTaxTotal).ToString("N2"))</td>
                        </tr>
                    </tfoot>
                </table>
            }
        </div>

        @* R5 (§13 / §13.7) — the reusable policy-driven Attachment Panel on the Invoice entity. Same component as the
           ASN screen, keyed by EntityCode="Invoice". Renders nothing when no AttachmentRequirementPolicy rows exist for
           the Invoice entity. R6 (D16) — /api/document-uploads/attach + DELETE now accept ownerEntityType=Invoice for
           DRAFT invoices, so the panel is editable exactly while the invoice is Draft and the caller can submit it
           (mirrors the ASN Draft-only rule). Enforcement of any attachment policy stays at the invoice-submit site
           (§13.7), not in the panel. *@
        <div style="margin-top:16px;">
            <AttachmentPanel EntityCode="Invoice"
                             EntityId="@detail.Id"
                             Editable="@(detail.InvoiceStatus == "Draft" && Token.HasPermission("Invoice.Submit"))"
                             SupplierId="@detail.SupplierId" />
        </div>
        }
    </div>

    @if (showReview)
    {
        <div style="position:fixed;inset:0;background:var(--mer-modal-backdrop);display:flex;align-items:center;justify-content:center;z-index:1000;">
            <div class="merino-dialog" data-variant="info" data-size="md" style="width:540px;">
                <div class="merino-dialog__accent"></div>
                <header class="merino-dialog__header">
                    <div class="merino-dialog__icon merino-dialog__icon--info"><span class="material-symbols-outlined">fact_check</span></div>
                    <div class="merino-dialog__head-text">
                        <div class="merino-dialog__eyebrow">Invoice</div>
                        <h2 class="merino-dialog__title">Mark @detail.InvoiceNumber under review?</h2>
                        <p class="merino-dialog__subtitle">Move invoice into the matching workflow.</p>
                    </div>
                    <button class="merino-dialog__close" @onclick="() => showReview = false"><span class="material-symbols-outlined">close</span></button>
                </header>
                <div class="merino-dialog__body">
                    <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Notes (optional)</label>
                    <textarea class="rz-textbox" rows="3" style="width:100%;padding:8px 10px;font-family:inherit;" @bind="dialogNotes"></textarea>
                    @if (!string.IsNullOrEmpty(dialogError)) { <div style="background:var(--mer-red-50);color:var(--mer-red);padding:8px 12px;border-radius:6px;font-size:12px;margin-top:8px;">@dialogError</div> }
                </div>
                <footer class="merino-dialog__footer">
                    <div class="merino-dialog__actions">
                        <button class="merino-dialog__btn" data-intent="ghost" @onclick="() => showReview = false">Cancel</button>
                        <button class="merino-dialog__btn" data-intent="primary" @onclick="DoReview" disabled="@busy">@(busy ? "Working…" : "Mark Under Review")</button>
                    </div>
                </footer>
            </div>
        </div>
    }

    @if (showApprove)
    {
        <div style="position:fixed;inset:0;background:var(--mer-modal-backdrop);display:flex;align-items:center;justify-content:center;z-index:1000;">
            <div class="merino-dialog" data-variant="success" data-size="md" style="width:540px;">
                <div class="merino-dialog__accent"></div>
                <header class="merino-dialog__header">
                    <div class="merino-dialog__icon merino-dialog__icon--success"><span class="material-symbols-outlined">task_alt</span></div>
                    <div class="merino-dialog__head-text">
                        <div class="merino-dialog__eyebrow">Invoice</div>
                        <h2 class="merino-dialog__title">Approve @detail.InvoiceNumber</h2>
                        <p class="merino-dialog__subtitle">Approves invoice for payment.</p>
                    </div>
                    <button class="merino-dialog__close" @onclick="() => showApprove = false"><span class="material-symbols-outlined">close</span></button>
                </header>
