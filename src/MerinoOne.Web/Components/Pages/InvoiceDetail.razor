    @if (showRevoke)
    {
        <div style="position:fixed;inset:0;background:var(--mer-modal-backdrop);display:flex;align-items:center;justify-content:center;z-index:1000;">
            <div class="merino-dialog" data-variant="danger" data-size="md" style="width:540px;">
                <div class="merino-dialog__accent"></div>
                <header class="merino-dialog__header">
                    <div class="merino-dialog__icon merino-dialog__icon--danger"><span class="material-symbols-outlined">undo</span></div>
                    <div class="merino-dialog__head-text">
                        <div class="merino-dialog__eyebrow">Invoice · Admin</div>
                        <h2 class="merino-dialog__title">Revoke @detail.InvoiceNumber to Draft</h2>
                        <p class="merino-dialog__subtitle">Pre-post revoke (Submitted → Draft). Returns the invoice to the supplier for amendment.</p>
                    </div>
                    <button class="merino-dialog__close" @onclick="() => showRevoke = false"><span class="material-symbols-outlined">close</span></button>
                </header>
                <div class="merino-dialog__body">
                    <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Reason (optional)</label>
                    <textarea class="rz-textbox" rows="3" style="width:100%;padding:8px 10px;font-family:inherit;" @bind="revokeReason"></textarea>
                    @if (!string.IsNullOrEmpty(dialogError)) { <div style="background:var(--mer-red-50);color:var(--mer-red);padding:8px 12px;border-radius:6px;font-size:12px;margin-top:8px;">@dialogError</div> }
                </div>
                <footer class="merino-dialog__footer">
                    <div class="merino-dialog__actions">
                        <button class="merino-dialog__btn" data-intent="ghost" @onclick="() => showRevoke = false">Cancel</button>
                        <button class="merino-dialog__btn" data-intent="danger" @onclick="DoRevoke" disabled="@busy">@(busy ? "Revoking…" : "Revoke to Draft")</button>
                    </div>
                </footer>
            </div>
        </div>
    }

    @* R6 — submit 409: another invoice consumed the PO line's remaining quantity between draft and submit
       (the atomic per-line reservation rolled back). Closing reloads so the lines show the fresh RemainingQty. *@
    @if (showConflict)
    {
        <div style="position:fixed;inset:0;background:var(--mer-modal-backdrop);display:flex;align-items:center;justify-content:center;z-index:1000;">
            <div class="merino-dialog" data-variant="danger" data-size="md" style="width:540px;">
                <div class="merino-dialog__accent"></div>
                <header class="merino-dialog__header">
                    <div class="merino-dialog__icon merino-dialog__icon--danger"><span class="material-symbols-outlined">sync_problem</span></div>
                    <div class="merino-dialog__head-text">
                        <div class="merino-dialog__eyebrow">Invoice · Submit</div>
                        <h2 class="merino-dialog__title">Quantity no longer available</h2>
                        <p class="merino-dialog__subtitle">The submit was rolled back — nothing was reserved.</p>
                    </div>
                    <button class="merino-dialog__close" @onclick="CloseConflict"><span class="material-symbols-outlined">close</span></button>
                </header>
                <div class="merino-dialog__body">
                    <p style="font-size:13px;color:var(--mer-ink-700);white-space:pre-wrap;">@conflictMessage</p>
                    <p style="font-size:12px;color:var(--mer-ink-500);margin-top:8px;">Review the refreshed remaining balances on the lines, adjust the billed quantities and submit again.</p>
                </div>
                <footer class="merino-dialog__footer">
                    <div class="merino-dialog__actions">
                        <button class="merino-dialog__btn" data-intent="primary" @onclick="CloseConflict">Refresh &amp; review</button>
                    </div>
                </footer>
            </div>
        </div>
    }
}

@code {
    [Parameter] public Guid Id { get; set; }
    private InvoiceDetailDto? detail;
    private bool loading = true;
    private bool busy = false;
    private string tab = "overview";

    private void TabOverview() => tab = "overview";
    private void TabHistory() => tab = "history";

    private bool showReview = false;
    private bool showApprove = false;
    private bool showReject = false;
    private bool showCreateNote = false;
    private bool showEdit = false;
    private bool showSubmit = false;
    private bool showRevoke = false;
    private string dialogNotes = string.Empty;
    private string rejectionReason = string.Empty;
    private string dialogError = string.Empty;
    private string noteType = "CN";
    private string noteNumber = string.Empty;
    private decimal noteAmount = 0;
    private string noteReason = string.Empty;

    // Draft edit fields
    private string editInvoiceNumber = string.Empty;
    private DateTime? editInvoiceDate;
    private string editEInvoiceIrn = string.Empty;
    private string editEInvoiceAckNo = string.Empty;
    private string editEWayBillNumber = string.Empty;
    private string editNotes = string.Empty;

    // Admin revoke
    private string revokeReason = string.Empty;

    // ---- R6 (D14) — Draft line editing state ----
    // One edit row per invoice line, seeded from the DTO snapshot on every Load. BilledQty is FE-capped at the
    // line's LIVE RemainingQty; Rate is display-only (snapshot until the tax is reselected, then the governed
    // list's rate). The server recompute on PUT is authoritative — everything here is preview.
    private readonly Dictionary<Guid, LineEditState> lineEdits = new();
    private List<TaxDto> taxes = new();
    private bool taxesLoaded;

    // R6 — submit 409 reservation-conflict dialog.
    private bool showConflict;
    private string conflictMessage = string.Empty;

    private bool CanEditLines => detail?.InvoiceStatus == "Draft" && Token.HasPermission("Invoice.Submit");
    private bool AnyLineErrors => lineEdits.Values.Any(e => e.Error != null);

    // R6 (D5) — both provisional prefixes are rejected server-side on submit; mirror the block client-side.
    private bool HasPlaceholderNumber =>
        detail != null &&
        (detail.InvoiceNumber.StartsWith("DRAFT-", StringComparison.OrdinalIgnoreCase) ||
         detail.InvoiceNumber.StartsWith("INV-DRAFT-", StringComparison.OrdinalIgnoreCase));

    private sealed class LineEditState
    {
        public Guid LineId { get; init; }
        public decimal RemainingQty { get; init; }
        public decimal UnitPrice { get; init; }
        public decimal BilledQty { get; set; }
        public string TaxIdStr { get; set; } = string.Empty;   // "" = (no tax) → TaxId null CLEARS the tax
        public decimal? Rate { get; set; }                      // display-only; never typed
        public string? Error { get; set; }
        public string SnapshotTaxIdStr { get; init; } = string.Empty;
        public string SnapshotLabel { get; init; } = string.Empty;
        public decimal? SnapshotRate { get; init; }
    }

    private void BuildLineEdits()
    {
        lineEdits.Clear();
        if (detail == null || !CanEditLines) return;
        foreach (var ln in detail.Lines)
        {
            var st = new LineEditState
            {
                LineId = ln.Id,
                RemainingQty = ln.RemainingQty,
                UnitPrice = ln.UnitPrice,
                BilledQty = ln.BilledQty,
                TaxIdStr = ln.TaxId?.ToString() ?? string.Empty,
                Rate = ln.TaxRatePct,
                SnapshotTaxIdStr = ln.TaxId?.ToString() ?? string.Empty,
                SnapshotLabel = $"{ln.TaxCode ?? "?"} — {ln.TaxDescription} ({ln.TaxRatePct?.ToString("0.####") ?? "?"}%)",
                SnapshotRate = ln.TaxRatePct,
            };
            // A sibling submit may have shrunk the live balance below this draft's billed qty — flag immediately.
            ValidateQty(st);
            lineEdits[ln.Id] = st;
        }
    }

    private static void ValidateQty(LineEditState e)
    {
        if (e.BilledQty < 0) e.BilledQty = 0;
        e.Error = e.BilledQty > e.RemainingQty
            ? $"Exceeds the remaining invoiceable balance ({e.RemainingQty:0.####})."
            : null;
    }

    private void OnQtyChanged(LineEditState e) => ValidateQty(e);

    private void OnTaxChanged(LineEditState e)
    {
        if (!Guid.TryParse(e.TaxIdStr, out var tid)) { e.Rate = null; return; }
        var t = taxes.FirstOrDefault(x => x.Id == tid);
        // Reselecting the (inactive) snapshot tax falls back to the frozen snapshot rate.
        e.Rate = t?.TaxRate ?? (e.TaxIdStr == e.SnapshotTaxIdStr ? e.SnapshotRate : null);
    }

    private static decimal EditLineAmount(LineEditState e) => decimal.Round(e.BilledQty * e.UnitPrice, 2);
    private static decimal EditTaxAmount(LineEditState e)
        => e.Rate is { } r ? decimal.Round(EditLineAmount(e) * r / 100m, 2) : 0m;

    private decimal DisplayLineTotal =>
        CanEditLines && lineEdits.Count > 0 ? lineEdits.Values.Sum(EditLineAmount) : detail?.Lines.Sum(l => l.LineAmount) ?? 0m;
    private decimal DisplayTaxTotal =>
        CanEditLines && lineEdits.Count > 0 ? lineEdits.Values.Sum(EditTaxAmount) : detail?.Lines.Sum(l => l.TaxAmount) ?? 0m;

    // Always sends EVERY line's current (billedQty, taxId) — TaxId null clears the tax server-side, so the
    // line's current selection must round-trip even when the user never touched it.
    private List<UpdateInvoiceLineRequest>? BuildLineRequests() =>
        !CanEditLines || lineEdits.Count == 0
            ? null
            : lineEdits.Values
                .Select(e => new UpdateInvoiceLineRequest(
                    e.LineId,
                    e.BilledQty,
                    Guid.TryParse(e.TaxIdStr, out var tid) ? tid : null))
                .ToList();

    // Line-only save from the Lines card — same PUT as the Edit modal, header metadata unchanged.
    private async Task SaveLines()
    {
        if (detail == null || !CanEditLines) return;
        if (AnyLineErrors)
        {
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Fix line errors", Detail = "One or more billed quantities exceed the remaining invoiceable balance." });
            return;
        }
        busy = true;
        var req = new UpdateInvoiceRequest(
            detail.InvoiceNumber, detail.InvoiceDate,
            detail.EInvoiceIrn, detail.EInvoiceAckNo, detail.EWayBillNumber, detail.Notes,
            BuildLineRequests());
        var resp = await Api.PutAsync<InvoiceDetailDto, UpdateInvoiceRequest>($"api/invoices/{Id}", req);
        if (resp?.Success == true)
        {
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Lines saved" });
            await Load();
        }
        else
        {
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Save failed", Detail = resp?.Errors?.FirstOrDefault() ?? "The lines could not be saved (the invoice may no longer be Draft, or a quantity exceeds the live remaining balance)." });
        }
        busy = false;
    }

    private async Task CloseConflict()
    {
        showConflict = false;
        await Load(); // refresh the lines' RemainingQty after the losing race
    }

    // PO header label tolerant of the nullable single-PO header (multi-PO uses PoSummary on the list DTO).
    private string PoHeaderText =>
        detail == null ? "" :
        detail.PurchaseOrders.Count > 1 ? $"{detail.PurchaseOrders.Count} POs"
        : detail.PurchaseOrders.Count == 1 ? $"PO {detail.PurchaseOrders[0].PoNumber}"
        : !string.IsNullOrEmpty(detail.PoNumber) ? $"PO {detail.PoNumber}"
        : "No PO";

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        loading = true;
        var resp = await Api.GetAsync<InvoiceDetailDto>($"api/invoices/{Id}");
        detail = resp?.Data;
        // R6 — rebuild the Draft edit rows from the fresh snapshot; load the governed active tax list once.
        BuildLineEdits();
        if (CanEditLines && !taxesLoaded)
        {
            taxesLoaded = true;
            var t = await Api.GetAsync<List<TaxDto>>("api/masters/taxes?isActive=true");
            // Rate-less rows are excluded — the server 400s a reselect onto a tax with no rate anyway.
            taxes = (t?.Data ?? new List<TaxDto>()).Where(x => x.TaxRate.HasValue).OrderBy(x => x.Code).ToList();
        }
        loading = false;
    }

    private void OpenReview() { dialogNotes = string.Empty; dialogError = string.Empty; showReview = true; }
    private void OpenApprove() { dialogNotes = string.Empty; dialogError = string.Empty; showApprove = true; }
    private void OpenReject() { rejectionReason = string.Empty; dialogError = string.Empty; showReject = true; }
    private void OpenCreateNote() { noteType = "CN"; noteNumber = string.Empty; noteAmount = 0; noteReason = string.Empty; dialogError = string.Empty; showCreateNote = true; }

    private void SetNoteTypeCN() => noteType = "CN";
    private void SetNoteTypeDN() => noteType = "DN";

    // ---- Draft edit ----
    private void OpenEdit()
    {
        if (detail == null) return;
        editInvoiceNumber = detail.InvoiceNumber;
        editInvoiceDate = detail.InvoiceDate;
        editEInvoiceIrn = detail.EInvoiceIrn ?? string.Empty;
        editEInvoiceAckNo = detail.EInvoiceAckNo ?? string.Empty;
        editEWayBillNumber = detail.EWayBillNumber ?? string.Empty;
        editNotes = detail.Notes ?? string.Empty;
        dialogError = string.Empty;
        showEdit = true;
    }

    private async Task DoEdit()
    {
        if (string.IsNullOrWhiteSpace(editInvoiceNumber)) { dialogError = "Invoice number is required."; return; }
        if (!editInvoiceDate.HasValue) { dialogError = "Invoice date is required."; return; }
        if (AnyLineErrors) { dialogError = "Fix the highlighted line errors on the Lines table before saving."; return; }
        busy = true; dialogError = string.Empty;
        // R6 (D14) — the PUT always carries the CURRENT line state (billedQty + taxId per line) in Draft, so a
        // metadata save can never silently discard pending inline line edits (Load() after save rebuilds them).
        var req = new UpdateInvoiceRequest(
            editInvoiceNumber.Trim(),
            editInvoiceDate.Value,
            string.IsNullOrWhiteSpace(editEInvoiceIrn) ? null : editEInvoiceIrn.Trim(),
            string.IsNullOrWhiteSpace(editEInvoiceAckNo) ? null : editEInvoiceAckNo.Trim(),
            string.IsNullOrWhiteSpace(editEWayBillNumber) ? null : editEWayBillNumber.Trim(),
            string.IsNullOrWhiteSpace(editNotes) ? null : editNotes.Trim(),
            BuildLineRequests());
        var resp = await Api.PutAsync<InvoiceDetailDto, UpdateInvoiceRequest>($"api/invoices/{Id}", req);
        if (resp?.Success == true) { Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Invoice saved" }); showEdit = false; await Load(); }
        else { dialogError = resp?.Errors?.FirstOrDefault() ?? "Save failed (the invoice may no longer be Draft, or the number is a duplicate)."; }
        busy = false;
    }

    // ---- Submit (Draft -> Submitted) ----
    // R4 (2026-06-26) — §8.3 / UC-ATT-03: missing-Warning-attachment confirm two-step.
    private bool showAttachConfirm = false;
    private string attachConfirmMessage = string.Empty;
    private List<string> attachMissing = new();

    private void OpenSubmit() { dialogError = string.Empty; showSubmit = true; }

    private Task DoSubmit() => DoSubmitInternal(acknowledgeMissingAttachments: false);

    private async Task DoSubmitInternal(bool acknowledgeMissingAttachments)
    {
        busy = true; dialogError = string.Empty;
        // R6 — the notices-aware envelope: advisory rate-drift lines ride a SUCCESSFUL submit; a folded non-2xx
        // keeps its HTTP status so the 409 reservation conflict gets its own dialog.
        var resp = await Api.PostWithNoticesAsync<InvoiceDetailDto, SubmitInvoiceRequest>(
            $"api/invoices/{Id}/submit", new SubmitInvoiceRequest(acknowledgeMissingAttachments));

        // (1) Success — status lands on Matched or MatchExceptions; drift notices toast as warnings.
        if (resp?.Success == true)
        {
            showAttachConfirm = false; showSubmit = false;
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Invoice submitted" });
            foreach (var n in resp.Notices)
            {
                Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Warning, Summary = "Tax rate re-resolved", Detail = n, Duration = 8000 });
            }
            await Load();
        }
        // (2) Warning attachments missing — 200 ConfirmationRequired, nothing committed. Confirm to proceed.
        else if (resp?.ConfirmationRequired == true)
        {
            attachConfirmMessage = string.IsNullOrEmpty(resp.ConfirmationMessage)
                ? "One or more required attachments were not uploaded, do you wish to proceed?"
                : resp.ConfirmationMessage!;
            attachMissing = resp.MissingAttachments ?? new();
            showSubmit = false;
            showAttachConfirm = true;
        }
        // (3) R6 — 409: another invoice consumed the remaining PO-line quantity; the whole submit rolled back.
        else if (resp?.StatusCode == 409)
        {
            showSubmit = false; showAttachConfirm = false;
            conflictMessage = resp.Errors?.FirstOrDefault()
                ?? "Another invoice already reserved the remaining quantity on one or more PO lines.";
            showConflict = true;
        }
        // (4) Blocking error (incl. mandatory-missing 400) — show on whichever dialog is open.
        else
        {
            dialogError = resp?.Errors?.FirstOrDefault() ?? "Submit failed (mandatory invoice number + date, a missing mandatory attachment, or the invoice is no longer Draft).";
            if (showAttachConfirm) { Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Submit failed", Detail = dialogError }); }
        }
        busy = false;
    }

    // ---- Admin revoke (Submitted -> Draft) — round-trips RowVersion for the optimistic-concurrency guard. ----
    private void OpenRevoke() { revokeReason = string.Empty; dialogError = string.Empty; showRevoke = true; }

    private async Task DoRevoke()
    {
        if (detail == null) return;
        busy = true; dialogError = string.Empty;
        var req = new RevokeInvoiceRequest(string.IsNullOrWhiteSpace(revokeReason) ? null : revokeReason.Trim(), detail.RowVersion);
        var resp = await Api.PostAsync<InvoiceDetailDto, RevokeInvoiceRequest>($"api/invoices/{Id}/revoke", req);
        if (resp?.Success == true)
        {
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Warning, Summary = "Invoice revoked to Draft" });
            showRevoke = false;
            await Load();
        }
        else
        {
            // 409 (stale RowVersion / already posted / no longer Submitted) is folded into Errors by ApiClient.
            // Surface it and reload so the user sees the current state + a fresh RowVersion before retrying.
            dialogError = (resp?.Errors?.FirstOrDefault() ?? "Revoke failed.")
                + " The invoice state was refreshed — review it and try again if still applicable.";
            await Load();
        }
        busy = false;
    }

    private async Task DoReview()
    {
        busy = true; dialogError = string.Empty;
        var resp = await Api.PostAsync<InvoiceDetailDto, ReviewInvoiceRequest>($"api/invoices/{Id}/review", new ReviewInvoiceRequest());
        if (resp?.Success == true) { Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Marked under review" }); showReview = false; await Load(); }
        else { dialogError = resp?.Errors?.FirstOrDefault() ?? "Failed."; }
        busy = false;
    }

    private async Task DoApprove()
    {
        busy = true; dialogError = string.Empty;
        var resp = await Api.PostAsync<InvoiceDetailDto, ApproveInvoiceRequest>($"api/invoices/{Id}/approve", new ApproveInvoiceRequest(string.IsNullOrWhiteSpace(dialogNotes) ? null : dialogNotes));
        if (resp?.Success == true) { Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Approved" }); showApprove = false; await Load(); }
        else { dialogError = resp?.Errors?.FirstOrDefault() ?? "Failed."; }
        busy = false;
    }

    private async Task DoReject()
    {
        if (string.IsNullOrWhiteSpace(rejectionReason)) { dialogError = "Reason is required."; return; }
        busy = true; dialogError = string.Empty;
        var resp = await Api.PostAsync<InvoiceDetailDto, RejectInvoiceRequest>($"api/invoices/{Id}/reject", new RejectInvoiceRequest(rejectionReason));
        if (resp?.Success == true) { Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Warning, Summary = "Rejected" }); showReject = false; await Load(); }
        else { dialogError = resp?.Errors?.FirstOrDefault() ?? "Failed."; }
        busy = false;
    }

    private async Task DoCreateNote()
    {
        if (string.IsNullOrWhiteSpace(noteNumber)) { dialogError = "Note number is required."; return; }
        if (noteAmount <= 0) { dialogError = "Amount must be greater than 0."; return; }
        busy = true; dialogError = string.Empty;
        var req = new CreateCreditDebitNoteRequest(detail!.Id, noteType, noteNumber, noteAmount, string.IsNullOrWhiteSpace(noteReason) ? null : noteReason);
        var resp = await Api.PostAsync<CreditDebitNoteDetailDto, CreateCreditDebitNoteRequest>("api/credit-debit-notes", req);
        if (resp?.Success == true)
        {
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = $"{noteType} created" });
            showCreateNote = false;
            if (resp.Data != null) Nav.NavigateToRoute($"/credit-debit-notes/{resp.Data.Id}");
        }
        else { dialogError = resp?.Errors?.FirstOrDefault() ?? "Failed."; }
        busy = false;
    }

    // R6 — Draft is the muted/off chip (SupplierChangeStatus convention, mirrored in InvoiceList); "Matched"
    // stays in the pending/positive arm (submit now lands on Matched or MatchExceptions, never "Submitted").
    private string StatusClass(string status) => status switch
    {
        "Draft" => "tlg-status--off",
        "Approved" or "Paid" => "tlg-status--active",
        "Submitted" or "UnderReview" or "Matched" or "PartiallyPaid" => "tlg-status--pending",
        "Rejected" or "Cancelled" or "MatchExceptions" => "tlg-status--danger",
        _ => "tlg-status--info"
    };
}
