@page "/settings/inbound-sync-log"
@inject ApiClient Api
@inject TokenAccessor Token

@* R5 (TSD R5 Addendum §12 / §12.3 — Component 8). The admin inbound Sync Log over proc.SyncLog: one row per
   inbound ERP call attempt with its status and (for Failed rows) the error message inline. This is where the
   unresolvable-ship-to (§6.2) and unmapped-status (§11.3) failures land, so Failed rows are the focus — the
   default filter lands on them. Distinct from the legacy /integrations/sync-log (integration.InforSyncLog).
   The raw payload is fetched on a by-id drill-in (the list never ships it — Failed rows can carry a large
   nvarchar(max) payload). Admin-gated to match the other Settings/Integration admin views. *@

<PageTitle>Inbound Sync Log</PageTitle>

@if (!Token.IsAdmin && !Token.HasPermission("Integration.Read"))
{
    <div class="tl-empty">
        <span class="material-symbols-outlined" style="font-size:32px;">lock</span>
        <div>Access denied — admin only.</div>
    </div>
}
else
{
    <div class="tl-page">
        <header class="tl-header">
            <div>
                <div class="tl-title-row">
                    <h1 class="tl-title">Inbound Sync Log</h1>
                    <span class="tl-count-chip">@(paged?.TotalCount ?? 0)</span>
                </div>
                <p class="tl-sub">Inbound ERP call attempts · ship-to and PO-status failures land here · Settings → Integration</p>
            </div>
        </header>

        <div class="tl-filter-bar" style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
            <select class="rz-dropdown" style="padding:8px 12px;border:1px solid var(--mer-ink-300);border-radius:6px;background:var(--mer-surface);" @bind="statusFilter" @bind:after="OnFilterChanged">
                <option value="">All statuses</option>
                <option value="Failed">Failed</option>
                <option value="Success">Success</option>
            </select>
            <select class="rz-dropdown" style="padding:8px 12px;border:1px solid var(--mer-ink-300);border-radius:6px;background:var(--mer-surface);" @bind="entityFilter" @bind:after="OnFilterChanged">
                <option value="">All entities</option>
                <option value="PurchaseOrder">Purchase order</option>
                <option value="DeliverySchedule">Delivery schedule</option>
                <option value="GoodsReceipt">Goods receipt</option>
                <option value="Invoice">Invoice</option>
                <option value="Payment">Payment</option>
                <option value="Supplier">Supplier</option>
                <option value="Tax">Tax</option>
                <option value="Item">Item</option>
            </select>
            <label style="font-size:12px;color:var(--mer-ink-600);display:inline-flex;align-items:center;gap:4px;">External ref
                <input type="text" class="rz-textbox" style="padding:7px 8px;border:1px solid var(--mer-ink-300);border-radius:6px;font-family:Inter,monospace;width:160px;" placeholder="e.g. PO number" @bind="externalRefFilter" @bind:after="OnFilterChanged" />
            </label>
            <label style="font-size:12px;color:var(--mer-ink-600);display:inline-flex;align-items:center;gap:4px;">From
                <input type="date" class="rz-textbox" style="padding:7px 8px;border:1px solid var(--mer-ink-300);border-radius:6px;" @bind="fromDate" @bind:after="OnFilterChanged" />
            </label>
            <label style="font-size:12px;color:var(--mer-ink-600);display:inline-flex;align-items:center;gap:4px;">To
                <input type="date" class="rz-textbox" style="padding:7px 8px;border:1px solid var(--mer-ink-300);border-radius:6px;" @bind="toDate" @bind:after="OnFilterChanged" />
            </label>
            <button class="rz-button" style="padding:7px 12px;border-radius:6px;border:1px solid var(--mer-ink-300);background:var(--mer-surface);cursor:pointer;font-size:12px;" @onclick="ClearFilters">Clear</button>
        </div>

        @if (loading)
        {
            <div class="tl-empty">Loading…</div>
        }
        else if (notFound)
        {
            <div class="tl-empty">
                <span class="material-symbols-outlined" style="font-size:32px;">construction</span>
                <div>Inbound sync log endpoint not available.</div>
            </div>
        }
        else if (paged == null || paged.Items.Count == 0)
        {
            <div class="tl-empty">
                <span class="material-symbols-outlined" style="font-size:32px;">sync</span>
                <div>No inbound sync events for this filter.</div>
            </div>
        }
        else
        {
            <div class="tl-grid-wrapper" style="--tl-cols: 150px 150px 160px 110px 1.6fr 160px 70px; --tl-min-width: 1180px;">
                <div class="tlg-header">
                    <div class="tlg-col">API</div>
                    <div class="tlg-col">Entity type</div>
                    <div class="tlg-col">External ref</div>
                    <div class="tlg-col">Status</div>
                    <div class="tlg-col">Error</div>
                    <div class="tlg-col">Received on</div>
                    <div class="tlg-col tlg-col--actions">Payload</div>
                </div>
                @foreach (var s in paged.Items)
                {
                    var row = s;
                    var isFailed = string.Equals(row.Status, "Failed", StringComparison.OrdinalIgnoreCase);
                    <div class="tlg-row" style="@(isFailed ? "background:var(--mer-red-50);" : "")">
                        <div class="tlg-col tlg-code" title="@row.Api">@row.Api</div>
                        <div class="tlg-col">@(string.IsNullOrEmpty(row.EntityType) ? "—" : row.EntityType)</div>
                        <div class="tlg-col tlg-code" title="@row.ExternalRef">@(string.IsNullOrEmpty(row.ExternalRef) ? "—" : row.ExternalRef)</div>
                        <div class="tlg-col"><span class="tlg-status @StatusClass(row.Status)">@row.Status</span></div>
                        <div class="tlg-col" style="font-size:12px;@(isFailed ? "color:var(--mer-red);" : "color:var(--mer-ink-500);")" title="@row.ErrorMessage">
                            @(string.IsNullOrEmpty(row.ErrorMessage) ? "—" : row.ErrorMessage)
                        </div>
                        <div class="tlg-col tlg-code">@row.ReceivedOn.ToString("yyyy-MM-dd HH:mm:ss")</div>
                        <div class="tlg-col tlg-col--actions">
                            @if (row.HasPayload)
                            {
                                <button @onclick="() => ViewPayload(row)" disabled="@busy" style="background:transparent;border:0;color:var(--mer-blue);cursor:pointer;" title="View the stored request payload">
                                    <span class="material-symbols-outlined" style="font-size:18px;">data_object</span>
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>

            <div style="display:flex;justify-content:space-between;align-items:center;margin-top:12px;font-size:13px;color:var(--mer-ink-600);">
                <div>Page @paged.Page of @paged.TotalPages — @paged.TotalCount rows</div>
                <div style="display:flex;gap:6px;">
                    <button class="rz-button" style="padding:6px 12px;border-radius:6px;border:1px solid var(--mer-ink-300);background:var(--mer-surface);cursor:pointer;" @onclick="Prev" disabled="@(paged.Page <= 1)">Prev</button>
                    <button class="rz-button" style="padding:6px 12px;border-radius:6px;border:1px solid var(--mer-ink-300);background:var(--mer-surface);cursor:pointer;" @onclick="Next" disabled="@(paged.Page >= paged.TotalPages)">Next</button>
                </div>
            </div>
        }
    </div>

    @* Payload viewer — fetched on demand (only Failed rows carry a payload; success rows store none). *@
    @if (showPayload)
    {
        <div style="position:fixed;inset:0;background:var(--mer-modal-backdrop);display:flex;align-items:center;justify-content:center;z-index:1000;">
            <div class="merino-dialog" data-variant="info" data-size="lg" style="width:880px;max-width:92vw;">
                <div class="merino-dialog__accent"></div>
                <header class="merino-dialog__header">
                    <div class="merino-dialog__icon merino-dialog__icon--info"><span class="material-symbols-outlined">data_object</span></div>
                    <div class="merino-dialog__head-text">
                        <div class="merino-dialog__eyebrow">Inbound sync log</div>
                        <h2 class="merino-dialog__title">Stored request payload</h2>
                        <p class="merino-dialog__subtitle">@payloadSubtitle</p>
                    </div>
                    <button class="merino-dialog__close" @onclick="ClosePayload"><span class="material-symbols-outlined">close</span></button>
                </header>
                <div class="merino-dialog__body">
                    @if (!string.IsNullOrEmpty(payloadError))
                    {
                        <div style="background:var(--mer-red-50);color:var(--mer-red);padding:8px 12px;border-radius:6px;font-size:12px;margin-bottom:10px;">@payloadError</div>
                    }
                    @if (payloadLoading)
                    {
                        <div style="color:var(--mer-ink-500);font-size:13px;">Loading payload…</div>
                    }
                    else if (string.IsNullOrWhiteSpace(payloadText))
                    {
                        <div style="color:var(--mer-ink-500);font-size:13px;">No payload stored for this row.</div>
                    }
                    else
                    {
                        <pre style="margin:0;max-height:60vh;overflow:auto;background:var(--mer-canvas);border:1px solid var(--mer-line);border-radius:8px;padding:14px 16px;font-family:Inter,monospace;font-size:12.5px;line-height:1.5;color:var(--mer-ink-900);white-space:pre;">@payloadText</pre>
                    }
                </div>
                <footer class="merino-dialog__footer">
                    <div class="merino-dialog__actions">
                        <button class="merino-dialog__btn" data-intent="primary" @onclick="ClosePayload">Close</button>
                    </div>
                </footer>
            </div>
        </div>
    }
}

@code {
    private PagedResult<SyncLogDto>? paged;
    private bool loading = true;
    private bool busy;
    private bool notFound;

    // Failed rows are the focus — land on them by default.
    private string statusFilter = "Failed";
    private string entityFilter = string.Empty;
    private string externalRefFilter = string.Empty;
    private DateTime? fromDate;
    private DateTime? toDate;
    private int page = 1;
    private const int PageSize = 50;

    private async Task OnFilterChanged() { page = 1; await Reload(); }
    private async Task ClearFilters()
    {
        statusFilter = string.Empty; entityFilter = string.Empty; externalRefFilter = string.Empty;
        fromDate = null; toDate = null; page = 1;
        await Reload();
    }

    protected override async Task OnInitializedAsync()
    {
        if (!Token.IsAdmin && !Token.HasPermission("Integration.Read")) { loading = false; return; }
        await Reload();
    }

    private async Task Reload()
    {
        loading = true; notFound = false;
        var url = $"api/integration/inbound-sync-log?page={page}&pageSize={PageSize}";
        if (!string.IsNullOrWhiteSpace(statusFilter)) url += $"&status={Uri.EscapeDataString(statusFilter)}";
        if (!string.IsNullOrWhiteSpace(entityFilter)) url += $"&entityType={Uri.EscapeDataString(entityFilter)}";
        if (!string.IsNullOrWhiteSpace(externalRefFilter)) url += $"&externalRef={Uri.EscapeDataString(externalRefFilter.Trim())}";
        if (fromDate.HasValue) url += $"&fromDate={fromDate.Value:yyyy-MM-dd}";
        if (toDate.HasValue) url += $"&toDate={toDate.Value:yyyy-MM-dd}";
        try
        {
            var resp = await Api.GetAsync<PagedResult<SyncLogDto>>(url);
            if (resp == null || (!resp.Success && resp.Data == null)) { notFound = true; }
            else paged = resp.Data;
        }
        catch { notFound = true; }
        loading = false;
    }

    private async Task Prev() { if (page > 1) { page--; await Reload(); } }
    private async Task Next() { if (paged != null && page < paged.TotalPages) { page++; await Reload(); } }

    // ===== Payload drill-in =====
    private bool showPayload;
    private bool payloadLoading;
    private string? payloadText;
    private string payloadSubtitle = string.Empty;
    private string payloadError = string.Empty;

    private async Task ViewPayload(SyncLogDto s)
    {
        if (!s.HasPayload) return;
        showPayload = true;
        payloadLoading = true;
        payloadText = null;
        payloadError = string.Empty;
        payloadSubtitle = $"{(string.IsNullOrEmpty(s.EntityType) ? s.Api : s.EntityType)} · {(string.IsNullOrEmpty(s.ExternalRef) ? "—" : s.ExternalRef)} · {s.ReceivedOn:yyyy-MM-dd HH:mm:ss}";
        busy = true;
        StateHasChanged();

        var resp = await Api.GetAsync<string>($"api/integration/inbound-sync-log/{s.Id}/payload");
        if (resp?.Success != true) { payloadError = resp?.Errors?.FirstOrDefault() ?? "Failed to load payload."; }
        payloadText = FormatJson(resp?.Data);
        payloadLoading = false;
        busy = false;
    }

    private void ClosePayload() { showPayload = false; payloadText = null; payloadError = string.Empty; }

    // Pretty-print the stored JSON; fall back to the raw text if it isn't valid JSON.
    private static string? FormatJson(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return null;
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(raw);
            return System.Text.Json.JsonSerializer.Serialize(doc.RootElement,
                new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        }
        catch { return raw; }
    }

    private static string StatusClass(string status) => status switch
    {
        "Success" => "tlg-status--active",
        "Failed" => "tlg-status--danger",
        _ => "tlg-status--info"
    };
}
