@page "/settings/idm-entity-types"
@page "/settings/idm-attachment-types"
@inject ApiClient Api
@inject TokenAccessor Token
@inject NotificationService Notif

@* R8 (2026-07-04, renamed 2026-07-05) — TSD R8 §7. Settings › IDM Entity Type: maps a PORTAL entity's attachment
   type to an Infor IDM entity type; this mapping drives DocumentUpload.idmEntityType classification (worker
   stamping + manual Backfill). Old route kept as an alias. Pattern cloned from AttachmentRequirements.razor.
   The generic per-tenant knobs (poll/batch/backoff) live on Admin › System settings › Infor IDM. *@

<PageTitle>IDM Entity Type</PageTitle>

<div class="tl-page">
    <header class="tl-header">
        <div>
            <div class="tl-title-row">
                <h1 class="tl-title">IDM Entity Type</h1>
                <span class="tl-count-chip">@configs.Count</span>
            </div>
            <p class="tl-sub">Maps portal entities (ASN / Invoice) to Infor IDM entity types — drives document classification &amp; backfill · Settings → Infor IDM</p>
        </div>
        @if (CanWrite)
        {
            <div class="tl-header__actions">
                <button class="mbtn mbtn--primary" @onclick="OpenNew" disabled="@busy" title="Map another attachment type to Infor IDM">
                    <span class="material-symbols-outlined">add</span> New
                </button>
                @if (Token.HasPermission("Integration.IdmSync.Manage"))
                {
                    <button class="mbtn mbtn--outline" @onclick="() => showBackfill = true" disabled="@busy" title="Stamp idmEntityType on existing documents">
                        <span class="material-symbols-outlined">database</span> Backfill
                    </button>
                }
            </div>
        }
    </header>

    @if (!CanRead)
    {
        <div class="tl-empty">
            <span class="material-symbols-outlined" style="font-size:32px;">lock</span>
            <div>You do not have permission to view IDM settings.</div>
        </div>
    }
    else if (loading)
    {
        <div class="tl-empty">Loading…</div>
    }
    else if (configs.Count == 0)
    {
        <div class="tl-empty">
            <span class="material-symbols-outlined" style="font-size:32px;">rule</span>
            <div>No IDM entity-type mappings.</div>
        </div>
    }
    else
    {
        <div class="tl-grid-wrapper" style="--tl-cols: 200px 160px 200px 1fr 90px 120px 240px; --tl-min-width: 1270px;">
            <div class="tlg-header">
                <div class="tlg-col">Portal entity</div>
                <div class="tlg-col">Attachment type</div>
                <div class="tlg-col">IDM entity type</div>
                <div class="tlg-col">Eligibility gate (JSONata)</div>
                <div class="tlg-col">Enabled</div>
                <div class="tlg-col">Drift</div>
                <div class="tlg-col tlg-col--actions">Actions</div>
            </div>
            @foreach (var c in configs)
            {
                var cfg = c;
                <div class="tlg-row">
                    <div class="tlg-col tlg-name">@PortalLabel(cfg.OwnerEntityType)</div>
                    <div class="tlg-col">
                        @if (string.IsNullOrEmpty(cfg.AttachmentType))
                        {
                            <span style="color:var(--mer-ink-500);font-style:italic;">All types</span>
                        }
                        else
                        {
                            @cfg.AttachmentType
                        }
                    </div>
                    <div class="tlg-col tlg-code" title="@cfg.IdmEntityType">@cfg.IdmEntityType</div>
                    <div class="tlg-col">
                        @if (string.IsNullOrWhiteSpace(cfg.EligibilityGateExpr))
                        {
                            <span style="color:var(--mer-ink-400);" title="blank gate — never satisfied (fail closed)">— none —</span>
                        }
                        else
                        {
                            <span class="tlg-code" style="font-size:11.5px;" title="@cfg.EligibilityGateExpr">@Truncate(cfg.EligibilityGateExpr, 70)</span>
                        }
                    </div>
                    <div class="tlg-col"><span class="tlg-status @(cfg.IsEnabled ? "tlg-status--active" : "tlg-status--danger")">@(cfg.IsEnabled ? "On" : "Off")</span></div>
                    <div class="tlg-col">
                        @if (cfg.IsDrifted)
                        {
                            <span class="tlg-status tlg-status--pending" title="differs from repo default">Modified</span>
                        }
                        else
                        {
                            <span class="tlg-status tlg-status--active" title="matches repo default">Default</span>
                        }
                    </div>
                    <div class="tlg-col tlg-col--actions" style="display:flex;gap:6px;flex-wrap:wrap;justify-content:flex-end;">
                        @if (CanWrite)
                        {
                            <button class="mbtn mbtn--row mbtn--accent" @onclick="() => OpenEdit(cfg)" disabled="@busy" title="Edit mapping / gate">
                                <span class="material-symbols-outlined">edit</span> Edit
                            </button>
                            @if (cfg.HasRepoDefault && cfg.IsDrifted)
                            {
                                <button class="mbtn mbtn--row mbtn--outline" @onclick="() => ConfirmRestore(cfg)" disabled="@busy" title="Restore repo default">
                                    <span class="material-symbols-outlined">settings_backup_restore</span> Restore
                                </button>
                            }
                            <button class="mbtn mbtn--row mbtn--danger" @onclick="() => ConfirmDelete(cfg)" disabled="@busy" title="Delete mapping (un-classifies unpushed documents)">
                                <span class="material-symbols-outlined">delete</span> Delete
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@* ---------------- Edit dialog ---------------- *@
@if (editing is not null)
{
    <div style="position:fixed;inset:0;background:var(--mer-modal-backdrop);display:flex;align-items:center;justify-content:center;z-index:1000;">
        <div class="merino-dialog" data-variant="info" data-size="lg" style="width:880px;max-width:92vw;">
            <div class="merino-dialog__accent"></div>
            <header class="merino-dialog__header">
                <div class="merino-dialog__icon merino-dialog__icon--info"><span class="material-symbols-outlined">rule</span></div>
                <div class="merino-dialog__head-text">
                    <div class="merino-dialog__eyebrow">@(isNew ? "New mapping" : $"{PortalLabel(editing.OwnerEntityType)} · {(string.IsNullOrEmpty(editing.AttachmentType) ? "All types" : editing.AttachmentType)} → {editing.IdmEntityType}")</div>
                    <h2 class="merino-dialog__title">@(isNew ? "New IDM mapping" : "Edit IDM mapping")</h2>
                </div>
                <button class="merino-dialog__close" @onclick="() => editing = null"><span class="material-symbols-outlined">close</span></button>
            </header>
            <div class="merino-dialog__body">
                <div style="display:flex;flex-direction:column;gap:14px;">
                    @* Identity fields — editable in BOTH new and edit. *@
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
                        <div>
                            <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Portal entity *</label>
                            <select class="rz-dropdown" style="width:100%;padding:8px 10px;border:1px solid var(--mer-ink-300);border-radius:6px;background:var(--mer-surface);" @bind="formOwnerEntityType">
                                <option value="">— select —</option>
                                @foreach (var (val, label) in PortalEntities)
                                {
                                    <option value="@val">@label</option>
                                }
                            </select>
                        </div>
                        <div>
                            <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Attachment type</label>
                            <select class="rz-dropdown" style="width:100%;padding:8px 10px;border:1px solid var(--mer-ink-300);border-radius:6px;background:var(--mer-surface);" @bind="formAttachmentType">
                                <option value="">— All types (push every document of this entity) —</option>
                                @foreach (var t in attachmentTypeOptions)
                                {
                                    <option value="@t.Code">@t.Name (@t.Code)</option>
                                }
                            </select>
                            <div style="font-size:11px;color:var(--mer-ink-500);margin-top:2px;">Optional. Leave as <em>All types</em> to classify every document of the portal entity.</div>
                        </div>
                    </div>
                    <div>
                        <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">IDM entity type *</label>
                        <input class="rz-textbox" list="idm-entity-type-hints" style="width:100%;padding:8px 10px;font-family:Inter,monospace;font-size:12.5px;" @bind="formIdmEntityType" placeholder="e.g. InforInvoice" />
                        <datalist id="idm-entity-type-hints">
                            @foreach (var t in entityTypeOptions)
                            {
                                <option value="@t.IdmEntityType">@PortalLabel(t.OwnerEntityType)</option>
                            }
                        </datalist>
                        <div style="font-size:11px;color:var(--mer-ink-500);margin-top:2px;">The MDS_EntityType value / config selector. Free text — an entity type with no registered snapshot provider stays dormant (nothing dispatches) until a provider is added.</div>
                    </div>
                    <div>
                        <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Eligibility gate (JSONata boolean)</label>
                        <textarea class="rz-textbox" style="width:100%;min-height:90px;padding:8px 10px;font-family:Inter,monospace;font-size:12.5px;" @bind="formGateExpr" placeholder="(invoice.erpCompany != null and $trim($string(invoice.erpCompany)) != &quot;&quot;) and …"></textarea>
                        <div style="font-size:11px;color:var(--mer-ink-500);margin-top:2px;">Must evaluate to <span style="font-family:Inter,monospace;">true</span> on the snapshot for the document to be pushed (strict — anything else fails closed). One gate language across IDM and LN (TSD R9 §2.11).</div>
                    </div>
                    <div>
                        <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Create mapping expression *</label>
                        <textarea class="rz-textbox" style="width:100%;min-height:120px;padding:8px 10px;font-family:Inter,monospace;font-size:12.5px;" @bind="formCreate" placeholder="{ ... JSONata create envelope mapping ... }"></textarea>
                    </div>
                    <div>
                        <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Mutate (update) mapping expression</label>
                        <textarea class="rz-textbox" style="width:100%;min-height:120px;padding:8px 10px;font-family:Inter,monospace;font-size:12.5px;" @bind="formMutate" placeholder="Leave blank to reuse the create mapping on update."></textarea>
                    </div>
                    <label style="display:flex;align-items:center;gap:8px;font-size:13px;cursor:pointer;">
                        <input type="checkbox" @bind="formEnabled" /> Enabled
                    </label>
                </div>
                @if (!string.IsNullOrEmpty(formError))
                {
                    <div style="background:var(--mer-red-50);color:var(--mer-red);padding:8px 12px;border-radius:6px;font-size:12px;margin-top:8px;white-space:pre-wrap;">@formError</div>
                }
            </div>
            <footer class="merino-dialog__footer">
                <div class="merino-dialog__actions">
                    <button class="merino-dialog__btn" data-intent="ghost" @onclick="() => editing = null">Cancel</button>
                    <button class="merino-dialog__btn" data-intent="primary" @onclick="Save" disabled="@busy">@(busy ? "Saving…" : "Save")</button>
                </div>
            </footer>
        </div>
    </div>
}

@* ---------------- Restore-default confirm ---------------- *@
@if (restoreRow is not null)
{
    <div style="position:fixed;inset:0;background:var(--mer-modal-backdrop);display:flex;align-items:center;justify-content:center;z-index:1001;">
        <div class="merino-dialog" data-variant="warning" data-size="sm" style="width:480px;">
            <div class="merino-dialog__accent"></div>
            <header class="merino-dialog__header">
                <div class="merino-dialog__icon merino-dialog__icon--warning"><span class="material-symbols-outlined">settings_backup_restore</span></div>
                <div class="merino-dialog__head-text">
                    <div class="merino-dialog__eyebrow">Infor IDM</div>
                    <h2 class="merino-dialog__title">Restore default?</h2>
                </div>
                <button class="merino-dialog__close" @onclick="() => restoreRow = null"><span class="material-symbols-outlined">close</span></button>
            </header>
            <div class="merino-dialog__body">
                <p style="font-size:13px;color:var(--mer-ink-700);margin:0;">This overwrites the create + mutate mapping expressions for <strong>@restoreRow.AttachmentType</strong> with the source-controlled repo default. Your customisations are lost.</p>
            </div>
            <footer class="merino-dialog__footer">
                <div class="merino-dialog__actions">
                    <button class="merino-dialog__btn" data-intent="ghost" @onclick="() => restoreRow = null">Cancel</button>
                    <button class="merino-dialog__btn" data-intent="primary" @onclick="Restore" disabled="@busy">@(busy ? "Restoring…" : "Restore default")</button>
                </div>
            </footer>
        </div>
    </div>
}

@* ---------------- Delete-mapping confirm ---------------- *@
@if (deleteRow is not null)
{
    <div style="position:fixed;inset:0;background:var(--mer-modal-backdrop);display:flex;align-items:center;justify-content:center;z-index:1001;">
        <div class="merino-dialog" data-variant="warning" data-size="sm" style="width:520px;">
            <div class="merino-dialog__accent"></div>
            <header class="merino-dialog__header">
                <div class="merino-dialog__icon merino-dialog__icon--warning"><span class="material-symbols-outlined">delete</span></div>
                <div class="merino-dialog__head-text">
                    <div class="merino-dialog__eyebrow">Infor IDM</div>
                    <h2 class="merino-dialog__title">Delete this mapping?</h2>
                </div>
                <button class="merino-dialog__close" @onclick="() => deleteRow = null"><span class="material-symbols-outlined">close</span></button>
            </header>
            <div class="merino-dialog__body">
                <p style="font-size:13px;color:var(--mer-ink-700);margin:0 0 8px;">Removes the <strong>@PortalLabel(deleteRow.OwnerEntityType) · @(string.IsNullOrEmpty(deleteRow.AttachmentType) ? "All types" : deleteRow.AttachmentType)</strong> → <span style="font-family:Inter,monospace;">@deleteRow.IdmEntityType</span> mapping.</p>
                <p style="font-size:12.5px;color:var(--mer-ink-600);margin:0;">Documents of this type not yet pushed to IDM are un-classified (their <span style="font-family:Inter,monospace;">idmEntityType</span> is cleared); already-pushed documents keep their classification so a later IDM delete can still resolve. Queued sync rows become <em>Unresolvable</em>.</p>
            </div>
            <footer class="merino-dialog__footer">
                <div class="merino-dialog__actions">
                    <button class="merino-dialog__btn" data-intent="ghost" @onclick="() => deleteRow = null">Cancel</button>
                    <button class="merino-dialog__btn" data-intent="danger" @onclick="Delete" disabled="@busy">@(busy ? "Deleting…" : "Delete mapping")</button>
                </div>
            </footer>
        </div>
    </div>
}

@* ---------------- Backfill confirm ---------------- *@
@if (showBackfill)
{
    <div style="position:fixed;inset:0;background:var(--mer-modal-backdrop);display:flex;align-items:center;justify-content:center;z-index:1001;">
        <div class="merino-dialog" data-variant="info" data-size="sm" style="width:480px;">
            <div class="merino-dialog__accent"></div>
            <header class="merino-dialog__header">
                <div class="merino-dialog__icon merino-dialog__icon--info"><span class="material-symbols-outlined">database</span></div>
                <div class="merino-dialog__head-text">
                    <div class="merino-dialog__eyebrow">Infor IDM</div>
                    <h2 class="merino-dialog__title">Backfill entity types?</h2>
                </div>
                <button class="merino-dialog__close" @onclick="() => showBackfill = false"><span class="material-symbols-outlined">close</span></button>
            </header>
            <div class="merino-dialog__body">
                <p style="font-size:13px;color:var(--mer-ink-700);margin:0;">Stamps <span style="font-family:Inter,monospace;">idmEntityType</span> on existing documents whose type maps to an enabled config and are not yet classified. Safe to re-run.</p>
            </div>
            <footer class="merino-dialog__footer">
                <div class="merino-dialog__actions">
                    <button class="merino-dialog__btn" data-intent="ghost" @onclick="() => showBackfill = false">Cancel</button>
                    <button class="merino-dialog__btn" data-intent="primary" @onclick="Backfill" disabled="@busy">@(busy ? "Stamping…" : "Backfill")</button>
                </div>
            </footer>
        </div>
    </div>
}

@code {
    private bool CanRead => Token.HasPermission("Settings.Read");
    private bool CanWrite => Token.HasPermission("Settings.Write");

    private List<IdmAttachmentTypeConfigDto> configs = new();
    private bool loading = true;
    private bool busy;

    private IdmAttachmentTypeConfigDto? editing;
    private bool isNew;
    private string formOwnerEntityType = string.Empty;
    private string formAttachmentType = string.Empty;
    private string formIdmEntityType = string.Empty;
    private string formGateExpr = string.Empty;
    private string formCreate = string.Empty;
    private string formMutate = string.Empty;
    private bool formEnabled = true;
    private string formError = string.Empty;

    private List<AttachmentTypeDto> attachmentTypeOptions = new();
    private List<IdmEntityTypeOptionDto> entityTypeOptions = new();

    /// <summary>Portal entities that can own IDM-syncable documents (doc.DocumentUpload.OwnerEntityType values).</summary>
    private static readonly (string Value, string Label)[] PortalEntities =
    {
        ("Asn", "Advance Shipping Notice"),
        ("Invoice", "Invoice"),
        ("Supplier", "Supplier"),
    };

    private IdmAttachmentTypeConfigDto? restoreRow;
    private IdmAttachmentTypeConfigDto? deleteRow;
    private bool showBackfill;

    private static string Truncate(string s, int max) => s.Length <= max ? s : s[..max] + "…";

    /// <summary>Portal-entity display name (mirrors AttachmentRequirements' Entity picker labels).</summary>
    private static string PortalLabel(string? ownerEntityType) => ownerEntityType switch
    {
        "Asn" => "Advance Shipping Notice",
        "Invoice" => "Invoice",
        "Supplier" => "Supplier",
        null or "" => "—",
        _ => ownerEntityType
    };

    protected override async Task OnInitializedAsync()
    {
        if (!CanRead) { loading = false; return; }
        await Load();
    }

    private async Task Load()
    {
        loading = true;
        var resp = await Api.GetAsync<List<IdmAttachmentTypeConfigDto>>("api/integration/idm/attachment-type-configs");
        configs = resp?.Data ?? new();
        loading = false;
    }

    /// <summary>Lazily load the attachment-type + IDM-entity-type option lists (shared by the New + Edit dialogs).</summary>
    private async Task EnsureOptionsLoadedAsync()
    {
        if (attachmentTypeOptions.Count == 0)
        {
            var t = await Api.GetAsync<List<AttachmentTypeDto>>("api/settings/attachment-types");
            attachmentTypeOptions = (t?.Data ?? new()).Where(x => x.IsActive).ToList();
        }
        if (entityTypeOptions.Count == 0)
        {
            var e = await Api.GetAsync<List<IdmEntityTypeOptionDto>>("api/integration/idm/entity-types");
            entityTypeOptions = e?.Data ?? new();
        }
    }

    private async Task OpenEdit(IdmAttachmentTypeConfigDto c)
    {
        await EnsureOptionsLoadedAsync();
        editing = c;
        isNew = false;
        formOwnerEntityType = c.OwnerEntityType ?? string.Empty;
        formAttachmentType = c.AttachmentType ?? string.Empty;
        formIdmEntityType = c.IdmEntityType;
        formGateExpr = c.EligibilityGateExpr;
        formCreate = c.CreateMappingExpression;
        formMutate = c.MutateMappingExpression ?? string.Empty;
        formEnabled = c.IsEnabled;
        formError = string.Empty;
    }

    private async Task OpenNew()
    {
        await EnsureOptionsLoadedAsync();
        editing = new IdmAttachmentTypeConfigDto(Guid.Empty, null, string.Empty, null, string.Empty, string.Empty, null, true, false, false);
        isNew = true;
        formOwnerEntityType = string.Empty;
        formAttachmentType = string.Empty;
        formIdmEntityType = string.Empty;
        formGateExpr = string.Empty;
        formCreate = string.Empty;
        formMutate = string.Empty;
        formEnabled = true;
        formError = string.Empty;
    }

    private async Task Save()
    {
        if (editing is null) return;
        formError = string.Empty;
        if (string.IsNullOrWhiteSpace(formOwnerEntityType)) { formError = "Portal entity is required."; return; }
        if (string.IsNullOrWhiteSpace(formIdmEntityType)) { formError = "IDM entity type is required."; return; }
        if (string.IsNullOrWhiteSpace(formCreate)) { formError = "Create mapping expression is required."; return; }
        busy = true;
        var req = new SaveIdmAttachmentTypeConfigRequest(
            isNew ? null : editing.Id,
            formOwnerEntityType,
            string.IsNullOrWhiteSpace(formAttachmentType) ? null : formAttachmentType,
            formIdmEntityType.Trim(),
            formGateExpr.Trim(),
            formCreate.Trim(),
            string.IsNullOrWhiteSpace(formMutate) ? null : formMutate.Trim(),
            formEnabled);
        var resp = await Api.PostAsync<Guid, SaveIdmAttachmentTypeConfigRequest>("api/integration/idm/attachment-type-configs", req);
        if (resp?.Success == true)
        {
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Saved" });
            editing = null;
            await Load();
        }
        else
        {
            // 400 surfaces the JSONata compile error inline.
            formError = resp?.Errors?.FirstOrDefault() ?? "Failed to save.";
        }
        busy = false;
    }

    private void ConfirmRestore(IdmAttachmentTypeConfigDto c) => restoreRow = c;

    private async Task Restore()
    {
        if (restoreRow is null) return;
        busy = true;
        var resp = await Api.PostAsync<bool, object>($"api/integration/idm/attachment-type-configs/{restoreRow.Id}/restore-default", new { });
        if (resp?.Success == true)
        {
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Restored to default" });
            restoreRow = null;
            await Load();
        }
        else
        {
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Restore failed", Detail = resp?.Errors?.FirstOrDefault() ?? string.Empty });
        }
        busy = false;
    }

    private void ConfirmDelete(IdmAttachmentTypeConfigDto c) => deleteRow = c;

    private async Task Delete()
    {
        if (deleteRow is null) return;
        busy = true;
        var resp = await Api.DeleteAsync<IdmConfigDeleteResultDto>($"api/integration/idm/attachment-type-configs/{deleteRow.Id}");
        if (resp?.Success == true && resp.Data?.Deleted == true)
        {
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Mapping deleted", Detail = $"{resp.Data.ClearedDocuments} unpushed document(s) un-classified." });
            deleteRow = null;
            await Load();
        }
        else
        {
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Delete failed", Detail = resp?.Errors?.FirstOrDefault() ?? string.Empty });
        }
        busy = false;
    }

    private async Task Backfill()
    {
        busy = true;
        var resp = await Api.PostAsync<int, object>("api/integration/idm/attachment-type-configs/backfill", new { });
        if (resp?.Success == true)
        {
            var n = resp.Data;
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Backfill complete", Detail = $"Stamped {n} documents." });
            showBackfill = false;
            await Load();
        }
        else
        {
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Backfill failed", Detail = resp?.Errors?.FirstOrDefault() ?? string.Empty });
        }
        busy = false;
    }
}
