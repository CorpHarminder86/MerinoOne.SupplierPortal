@page "/settings/companies"
@inject ApiClient Api
@inject TokenAccessor Token
@inject NotificationService Notif
@inject DialogService Dialog

@* R5 (TSD R5 Addendum §5 / §5.2 — Component 1, Company Master; [[r5-consolidation]]). After the backend
   consolidation the duplicate admin.Company entity was DROPPED — the "company" is now the pre-existing
   admin.TenantEntity, served READ-ONLY by Contracts.Companies.CompanyDto over api/companies/accessible.
   Companies are ERP-synced TenantEntities, so this screen no longer creates / edits / deactivates them; it
   only LISTS them (Settings.Read) and manages each company's named, ERP-mappable ship-to addresses
   (admin.CompanyAddress, which now hangs directly off the TenantEntity). The address CompanyId field carries
   a TenantEntity id. The address dialog uses the shared GeoAutocomplete (mirroring supplier onboarding):
   Country / PIN / State / City are typeaheads; picking a PIN reverse-fills City/State/Country. Only STRING
   names/code are persisted — the geo ids are transient cascade drivers. Settings.Write to manage addresses. *@

<PageTitle>Companies</PageTitle>

<div class="tl-page">
    <header class="tl-header">
        <div>
            <div class="tl-title-row">
                <h1 class="tl-title">Companies</h1>
                <span class="tl-count-chip">@(companies?.Count ?? 0)</span>
            </div>
            <p class="tl-sub">Companies (buying entities) synced from the ERP · pick one to manage its named ship-to addresses</p>
        </div>
    </header>

    @* ---------------- Companies list (read-only — ERP-synced TenantEntities) ---------------- *@
    @if (companiesLoading)
    {
        <div class="tl-empty">Loading…</div>
    }
    else if (companies == null || companies.Count == 0)
    {
        <div class="tl-empty">
            <span class="material-symbols-outlined" style="font-size:32px;">domain</span>
            <div>No companies available.</div>
        </div>
    }
    else
    {
        <div class="tl-grid-wrapper" style="--tl-cols: 130px 1.6fr 90px; --tl-min-width: 560px;">
            <div class="tlg-header">
                <div class="tlg-col">Code</div>
                <div class="tlg-col">Name</div>
                <div class="tlg-col">Active</div>
            </div>
            @foreach (var c in companies)
            {
                var company = c;
                <div class="tlg-row @(selectedCompany?.Id == company.Id ? "tlg-row--selected" : "")"
                     style="cursor:pointer;@(selectedCompany?.Id == company.Id ? "background:rgba(46,91,183,.08);" : "")"
                     @onclick="() => SelectCompany(company)">
                    <div class="tlg-col tlg-code">@company.Code</div>
                    <div class="tlg-col tlg-desc" style="font-weight:600;color:var(--mer-blue-darker);">@company.Name</div>
                    <div class="tlg-col"><span class="tlg-status @(company.IsActive ? "tlg-status--active" : "tlg-status--danger")">@(company.IsActive ? "Yes" : "No")</span></div>
                </div>
            }
        </div>

        @* ---------------- Addresses for the selected company ---------------- *@
        @if (selectedCompany != null)
        {
            <div class="rz-card" style="padding:20px;margin-top:18px;">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
                    <div>
                        <h3 style="font-size:14px;font-weight:700;margin-bottom:2px;color:var(--mer-blue-darker);">
                            Ship-to addresses · @selectedCompany.Name (@(addresses?.Count ?? 0))
                        </h3>
                        <p style="color:var(--mer-ink-500);font-size:12px;">Each address has a mandatory name (the ship-to label) and an optional ERP ship-to code, unique within the company.</p>
                    </div>
                    @if (CanWrite)
                    {
                        <button class="rz-button rz-primary" style="padding:8px 14px;border-radius:6px;border:0;color:#fff;cursor:pointer;" @onclick="OpenNewAddress">
                            <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">add_location_alt</span> Add address
                        </button>
                    }
                </div>

                @if (addressesLoading)
                {
                    <div class="tl-empty">Loading…</div>
                }
                else if (addresses == null || addresses.Count == 0)
                {
                    <div class="tl-empty">
                        <span class="material-symbols-outlined" style="font-size:32px;">location_off</span>
                        <div>No addresses for this company yet.</div>
                    </div>
                }
                else
                {
                    <div class="tl-grid-wrapper" style="--tl-cols: 1.4fr 150px 110px 1.6fr 90px 150px; --tl-min-width: 960px;">
                        <div class="tlg-header">
                            <div class="tlg-col">Address name</div>
                            <div class="tlg-col">ERP code</div>
                            <div class="tlg-col">Type</div>
                            <div class="tlg-col">Address</div>
                            <div class="tlg-col">Active</div>
                            <div class="tlg-col tlg-col--actions">Actions</div>
                        </div>
                        @foreach (var a in addresses)
                        {
                            var addr = a;
                            <div class="tlg-row">
                                <div class="tlg-col tlg-desc" style="font-weight:600;color:var(--mer-blue-darker);">@addr.AddressName</div>
                                <div class="tlg-col tlg-code">@(string.IsNullOrEmpty(addr.ErpCode) ? "—" : addr.ErpCode)</div>
                                <div class="tlg-col">@addr.AddressType</div>
                                <div class="tlg-col" style="font-size:12px;color:var(--mer-ink-700);">@FormatLine(addr)</div>
                                <div class="tlg-col"><span class="tlg-status @(addr.IsActive ? "tlg-status--active" : "tlg-status--danger")">@(addr.IsActive ? "Yes" : "No")</span></div>
                                <div class="tlg-col tlg-col--actions">
                                    @if (CanWrite)
                                    {
                                        <button class="mbtn mbtn--row mbtn--accent" @onclick="() => OpenEditAddress(addr)" title="Edit">
                                            <span class="material-symbols-outlined">edit</span> Edit
                                        </button>
                                        @if (addr.IsActive)
                                        {
                                            <button class="mbtn mbtn--row mbtn--danger" @onclick="() => DeactivateAddress(addr)" title="Deactivate">
                                                <span class="material-symbols-outlined">block</span> Off
                                            </button>
                                        }
                                    }
                                    else
                                    {
                                        <span style="color:var(--mer-ink-300);">—</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    }
</div>

@* ---------------- Address add/edit dialog (supplier address field set + addressName / erpCode + geo autocomplete) ---------------- *@
@if (showAddressDialog)
{
    <div style="position:fixed;inset:0;background:var(--mer-modal-backdrop);display:flex;align-items:center;justify-content:center;z-index:1000;">
        <div class="merino-dialog" data-variant="info" data-size="md" style="width:640px;">
            <div class="merino-dialog__accent"></div>
            <header class="merino-dialog__header">
                <div class="merino-dialog__icon merino-dialog__icon--info"><span class="material-symbols-outlined">location_on</span></div>
                <div class="merino-dialog__head-text">
                    <div class="merino-dialog__eyebrow">Ship-to address · @selectedCompany?.Name</div>
                    <h2 class="merino-dialog__title">@(editingAddressId.HasValue ? "Edit address" : "New address")</h2>
                </div>
                <button class="merino-dialog__close" @onclick="() => showAddressDialog = false"><span class="material-symbols-outlined">close</span></button>
            </header>
            <div class="merino-dialog__body">
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                    <div>
                        <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Address name / ship-to label *</label>
                        <input class="rz-textbox" style="width:100%;padding:8px 10px;" @bind="af.AddressName" placeholder="e.g. Bhiwandi DC" />
                    </div>
                    <div>
                        <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">ERP ship-to code</label>
                        <input class="rz-textbox" style="width:100%;padding:8px 10px;font-family:Inter,monospace;" @bind="af.ErpCode" placeholder="e.g. DC-BHIWANDI-01" />
                    </div>
                    <div>
                        <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Address type *</label>
                        <select class="rz-dropdown" style="width:100%;padding:8px 10px;border:1px solid var(--mer-ink-300);border-radius:6px;background:var(--mer-surface);" @bind="af.AddressType">
                            @foreach (var t in AddressTypes)
                            {
                                <option value="@t">@t</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Country *</label>
                        <GeoAutocomplete Placeholder="Country" Value="@af.Country"
                            Style="width:100%;padding:8px 10px;"
                            Search="@((q, sk) => SearchCountries(q, sk))"
                            ValueChanged="@(v => { af.Country = v; af.CountryId = null; af.StateId = null; af.CityId = null; af.PostalCodeId = null; af.State = string.Empty; af.City = string.Empty; af.Pincode = string.Empty; })"
                            OnSelected="@(g => { af.Country = g.Name; af.CountryId = g.Id; af.StateId = null; af.CityId = null; af.PostalCodeId = null; af.State = string.Empty; af.City = string.Empty; af.Pincode = string.Empty; })" />
                    </div>
                    <div style="grid-column:1 / span 2;">
                        <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Address line 1 *</label>
                        <input class="rz-textbox" style="width:100%;padding:8px 10px;" @bind="af.AddressLine1" />
                    </div>
                    <div style="grid-column:1 / span 2;">
                        <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Address line 2</label>
                        <input class="rz-textbox" style="width:100%;padding:8px 10px;" @bind="af.AddressLine2" />
                    </div>
                    <div style="grid-column:1 / span 2;">
                        <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">Pincode — pick to auto-fill city / state / country</label>
                        <GeoAutocomplete Placeholder="PIN — pick to auto-fill city / state / country" Value="@af.Pincode" UseCode="true" Disabled="@(af.CountryId is null)"
                            Style="width:100%;padding:8px 10px;font-family:Inter,monospace;"
                            Search="@((q, sk) => SearchPostals(q, sk))"
                            ValueChanged="@(v => { af.Pincode = v; af.PostalCodeId = null; af.StateId = null; af.CityId = null; af.State = string.Empty; af.City = string.Empty; })"
                            OnSelected="@(g => OnPostalSelected(g))" />
                    </div>
                    <div>
                        <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">State *</label>
                        <GeoAutocomplete Placeholder="State" Value="@af.State" Disabled="@(af.CountryId is null || af.PostalCodeId is not null)"
                            Style="width:100%;padding:8px 10px;"
                            Search="@((q, sk) => SearchStates(q, sk))"
                            ValueChanged="@(v => { af.State = v; af.StateId = null; })"
                            OnSelected="@(g => { af.State = g.Name; af.StateId = g.Id; af.CityId = null; })" />
                    </div>
                    <div>
                        <label style="font-size:12px;font-weight:600;color:var(--mer-ink-700);">City *</label>
                        <GeoAutocomplete Placeholder="City" Value="@af.City" Disabled="@(af.CountryId is null || af.PostalCodeId is not null)"
                            Style="width:100%;padding:8px 10px;"
                            Search="@((q, sk) => SearchCities(q, sk))"
                            ValueChanged="@(v => { af.City = v; af.CityId = null; })"
                            OnSelected="@(g => { af.City = g.Name; af.CityId = g.Id; })" />
                    </div>
                    @if (editingAddressId.HasValue)
                    {
                        <label style="display:flex;align-items:center;gap:8px;font-size:13px;cursor:pointer;align-self:end;padding-bottom:8px;">
                            <input type="checkbox" @bind="af.IsActive" /> Active
                        </label>
                    }
                </div>
                <p style="font-size:11px;color:var(--mer-ink-500);margin-top:8px;">To change Country/State/City, re-pick Country to enable the lookups. State/City are disabled once a PIN is chosen (the PIN drives them).</p>
                @if (!string.IsNullOrEmpty(addressError)) { <div style="background:var(--mer-red-50);color:var(--mer-red);padding:8px 12px;border-radius:6px;font-size:12px;margin-top:12px;">@addressError</div> }
            </div>
            <footer class="merino-dialog__footer">
                <div class="merino-dialog__actions">
                    <button class="merino-dialog__btn" data-intent="ghost" @onclick="() => showAddressDialog = false">Cancel</button>
                    <button class="merino-dialog__btn" data-intent="primary" @onclick="SaveAddress" disabled="@busy">@(busy ? "Saving…" : "Save")</button>
                </div>
            </footer>
        </div>
    </div>
}

@code {
    private bool CanWrite => Token.HasPermission("Settings.Write");
    private bool CanRead => Token.HasPermission("Settings.Read");
    private bool busy;

    // Address types mirror the supplier address control (Register.razor) + the §4.2 "Plant" option.
    private static readonly string[] AddressTypes = { "Registered", "Billing", "Shipping", "Plant", "Other" };

    // ---- Companies (read-only TenantEntities from api/companies/accessible) ----
    private List<CompanyDto>? companies;
    private bool companiesLoading = true;
    private CompanyDto? selectedCompany;

    // ---- Addresses (for the selected company) ----
    private List<CompanyAddressDto>? addresses;
    private bool addressesLoading;

    private bool showAddressDialog;
    private Guid? editingAddressId;
    private readonly AddressForm af = new();
    private string addressError = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (!CanRead) { companiesLoading = false; return; }
        await LoadCompanies();
    }

    private async Task LoadCompanies()
    {
        companiesLoading = true;
        // Companies are the pre-existing TenantEntities; the accessible-companies endpoint is Settings.Read-safe
        // for every authenticated user and returns only the companies the caller may act under.
        var resp = await Api.GetAsync<List<CompanyDto>>("api/companies/accessible");
        companies = resp?.Data ?? new();
        // Keep the current selection if it still exists; otherwise drop it.
        if (selectedCompany != null)
            selectedCompany = companies.FirstOrDefault(c => c.Id == selectedCompany.Id);
        companiesLoading = false;
    }

    private async Task SelectCompany(CompanyDto c)
    {
        selectedCompany = c;
        await LoadAddresses();
    }

    private async Task LoadAddresses()
    {
        if (selectedCompany == null) { addresses = null; return; }
        addressesLoading = true;
        addresses = null;
        StateHasChanged();
        var resp = await Api.GetAsync<List<CompanyAddressDto>>($"api/settings/companies/{selectedCompany.Id}/addresses");
        addresses = resp?.Data ?? new();
        addressesLoading = false;
    }

    // ---- Address CRUD ----
    private void OpenNewAddress()
    {
        editingAddressId = null;
        af.Reset();
        addressError = string.Empty;
        showAddressDialog = true;
    }

    private void OpenEditAddress(CompanyAddressDto a)
    {
        editingAddressId = a.Id;
        af.AddressName = a.AddressName;
        af.ErpCode = a.ErpCode ?? string.Empty;
        af.AddressType = a.AddressType;
        af.AddressLine1 = a.AddressLine1;
        af.AddressLine2 = a.AddressLine2 ?? string.Empty;
        af.City = a.City;
        af.State = a.State;
        af.Pincode = a.Pincode ?? string.Empty;
        af.Country = a.Country;
        af.IsActive = a.IsActive;
        // Existing rows have no resolved geo ids — the lookups start disabled; the note tells the user to
        // re-pick Country to enable them (mirrors supplier onboarding's existing-row behaviour).
        af.CountryId = null; af.StateId = null; af.CityId = null; af.PostalCodeId = null;
        addressError = string.Empty;
        showAddressDialog = true;
    }

    private async Task SaveAddress()
    {
        addressError = string.Empty;
        if (selectedCompany == null) { addressError = "Select a company first."; return; }
        if (string.IsNullOrWhiteSpace(af.AddressName)) { addressError = "Address name is required."; return; }
        if (string.IsNullOrWhiteSpace(af.AddressType)) { addressError = "Address type is required."; return; }
        if (string.IsNullOrWhiteSpace(af.AddressLine1)) { addressError = "Address line 1 is required."; return; }
        if (string.IsNullOrWhiteSpace(af.City)) { addressError = "City is required."; return; }
        if (string.IsNullOrWhiteSpace(af.State)) { addressError = "State is required."; return; }

        var erp = string.IsNullOrWhiteSpace(af.ErpCode) ? null : af.ErpCode.Trim();
        var line2 = string.IsNullOrWhiteSpace(af.AddressLine2) ? null : af.AddressLine2.Trim();
        var pincode = string.IsNullOrWhiteSpace(af.Pincode) ? null : af.Pincode.Trim();
        var country = string.IsNullOrWhiteSpace(af.Country) ? null : af.Country.Trim();

        busy = true;
        // Persist STRINGS only — the transient geo ids (CountryId/StateId/CityId/PostalCodeId) drive the
        // cascade but are never sent; the request DTOs carry names/code, exactly like supplier onboarding.
        ApiResult<CompanyAddressDto>? resp;
        if (editingAddressId.HasValue)
        {
            var req = new UpdateCompanyAddressRequest(af.AddressName.Trim(), erp, af.AddressType, af.AddressLine1.Trim(), line2, af.City.Trim(), af.State.Trim(), pincode, country, af.IsActive);
            resp = await Api.PutAsync<CompanyAddressDto, UpdateCompanyAddressRequest>($"api/settings/company-addresses/{editingAddressId}", req);
        }
        else
        {
            var req = new CreateCompanyAddressRequest(selectedCompany.Id, af.AddressName.Trim(), erp, af.AddressType, af.AddressLine1.Trim(), line2, af.City.Trim(), af.State.Trim(), pincode, country);
            resp = await Api.PostAsync<CompanyAddressDto, CreateCompanyAddressRequest>("api/settings/company-addresses", req);
        }

        if (resp?.Success == true)
        {
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Saved" });
            showAddressDialog = false;
            await LoadAddresses();
        }
        else
        {
            // Surface the server's validation message cleanly — including the duplicate-erpCode-per-company error
            // backstopped by UQ_CompanyAddress_company_erp (§4.2 / UC-CM-03).
            addressError = resp?.Errors?.FirstOrDefault() ?? "Failed to save address.";
        }
        busy = false;
    }

    private async Task DeactivateAddress(CompanyAddressDto a)
    {
        if (!await Dialog.ConfirmDeactivateAsync(a.AddressName, "ADDRESS")) return;
        busy = true;
        var req = new UpdateCompanyAddressRequest(a.AddressName, a.ErpCode, a.AddressType, a.AddressLine1, a.AddressLine2, a.City, a.State, a.Pincode, a.Country, false);
        var resp = await Api.PutAsync<CompanyAddressDto, UpdateCompanyAddressRequest>($"api/settings/company-addresses/{a.Id}", req);
        if (resp?.Success == true)
        {
            Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Deactivated" });
            await LoadAddresses();
        }
        else { Notif.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Failed", Detail = resp?.Errors?.FirstOrDefault() ?? "" }); }
        busy = false;
    }

    // ---------------- Geo autocomplete (authenticated /api/geo) — mirrors supplier onboarding ----------------
    private Task<List<GeoLookupDto>> SearchCountries(string q, int skip) => Geo("countries", q, null, skip);
    private Task<List<GeoLookupDto>> SearchStates(string q, int skip) => Geo("states", q, $"countryId={af.CountryId}", skip);
    private Task<List<GeoLookupDto>> SearchCities(string q, int skip) =>
        Geo("cities", q, $"countryId={af.CountryId}" + (af.StateId is Guid s ? $"&stateId={s}" : ""), skip);
    private Task<List<GeoLookupDto>> SearchPostals(string q, int skip) =>
        Geo("postal-codes", q, $"countryId={af.CountryId}", skip);

    private async Task<List<GeoLookupDto>> Geo(string seg, string q, string? extra, int skip)
    {
        var url = $"api/geo/{seg}?";
        if (!string.IsNullOrEmpty(extra)) url += extra + "&";
        if (!string.IsNullOrWhiteSpace(q)) url += "search=" + Uri.EscapeDataString(q.Trim()) + "&";
        if (skip > 0) url += "skip=" + skip;
        var resp = await Api.GetAsync<List<GeoLookupDto>>(url);
        return resp?.Data ?? new();
    }

    // Reverse-cascade: picking a PIN fills city/state/country from the postal-code master. CompanyAddress has
    // no Area field, so the returned area is intentionally dropped (do NOT invent a CompanyAddress.Area).
    private async Task OnPostalSelected(GeoLookupDto g)
    {
        af.Pincode = g.Code;
        af.PostalCodeId = g.Id;
        var detail = (await Api.GetAsync<PostalCodeDetailDto>($"api/geo/postal-codes/{g.Id}/detail"))?.Data;
        if (detail is null) return;
        if (detail.CountryId is Guid cid) { af.CountryId = cid; if (!string.IsNullOrWhiteSpace(detail.CountryName)) af.Country = detail.CountryName!; }
        if (detail.StateId is Guid sid) { af.StateId = sid; if (!string.IsNullOrWhiteSpace(detail.StateName)) af.State = detail.StateName!; }
        if (detail.CityId is Guid ctid) { af.CityId = ctid; if (!string.IsNullOrWhiteSpace(detail.CityName)) af.City = detail.CityName!; }
        StateHasChanged();
    }

    private static string FormatLine(CompanyAddressDto a)
    {
        var parts = new List<string> { a.AddressLine1 };
        if (!string.IsNullOrWhiteSpace(a.AddressLine2)) parts.Add(a.AddressLine2!);
        parts.Add($"{a.City}, {a.State}{(string.IsNullOrWhiteSpace(a.Pincode) ? "" : " " + a.Pincode)}");
        parts.Add(a.Country);
        return string.Join(" · ", parts);
    }

    private sealed class AddressForm
    {
        public string AddressName { get; set; } = string.Empty;
        public string ErpCode { get; set; } = string.Empty;
        public string AddressType { get; set; } = "Shipping";
        public string AddressLine1 { get; set; } = string.Empty;
        public string AddressLine2 { get; set; } = string.Empty;
        public string City { get; set; } = string.Empty;
        public string State { get; set; } = string.Empty;
        public string Pincode { get; set; } = string.Empty;
        public string Country { get; set; } = "India";
        public bool IsActive { get; set; } = true;

        // Transient geo-cascade ids — drive the autocompletes ONLY; never persisted (the request DTOs carry
        // the string names/code). Mirrors supplier onboarding's AddressRow transient ids.
        public Guid? CountryId { get; set; }
        public Guid? StateId { get; set; }
        public Guid? CityId { get; set; }
        public Guid? PostalCodeId { get; set; }

        public void Reset()
        {
            AddressName = string.Empty;
            ErpCode = string.Empty;
            AddressType = "Shipping";
            AddressLine1 = string.Empty;
            AddressLine2 = string.Empty;
            City = string.Empty;
            State = string.Empty;
            Pincode = string.Empty;
            Country = "India";
            IsActive = true;
            CountryId = null;
            StateId = null;
            CityId = null;
            PostalCodeId = null;
        }
    }
}
