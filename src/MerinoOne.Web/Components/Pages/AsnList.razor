@page "/asns"
@inject ApiClient Api
@inject NavigationManager Nav
@inject TokenAccessor Token

<PageTitle>ASNs</PageTitle>

<div class="tl-page">
    <header class="tl-header">
        <div>
            <div class="tl-title-row">
                <h1 class="tl-title">Advance Shipping Notices</h1>
                <span class="tl-count-chip">@(paged?.TotalCount ?? 0)</span>
            </div>
            <p class="tl-sub">In-transit and delivered shipments</p>
        </div>
        <div class="tl-header__actions">
            @if (Token.IsSupplier || Token.HasPermission("Asn.Create"))
            {
                <button class="rz-button rz-primary" style="padding:8px 14px;border-radius:6px;border:0;color:#fff;cursor:pointer;" @onclick="NewAsn">
                    <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">add</span> New ASN
                </button>
            }
        </div>
    </header>

    <div class="tl-filter-bar" style="display:flex;gap:8px;align-items:center;">
        <select class="rz-dropdown" style="padding:8px 12px;border:1px solid var(--mer-ink-300);border-radius:6px;background:var(--mer-surface);" @bind="statusFilter" @bind:after="Reload">
            <option value="">All statuses</option>
            <option value="Draft">Draft</option>
            <option value="Submitted">Submitted</option>
            <option value="InTransit">In Transit</option>
            <option value="Delivered">Delivered</option>
            <option value="Cancelled">Cancelled</option>
        </select>
    </div>

    @if (loading)
    {
        <div class="tl-empty">Loading…</div>
    }
    else if (paged == null || paged.Items.Count == 0)
    {
        <div class="tl-empty">
            <span class="material-symbols-outlined" style="font-size:32px;">local_shipping</span>
            <div>No ASNs.</div>
        </div>
    }
    else
    {
        <div class="tl-grid-wrapper" style="--tl-cols: 150px 150px 140px 1fr 130px 130px; --tl-min-width: 1050px;">
            <div class="tlg-header">
                <div class="tlg-col">ASN #</div>
                <div class="tlg-col">PO #</div>
                <div class="tlg-col">Expected</div>
                <div class="tlg-col">Carrier</div>
                <div class="tlg-col">Tracking</div>
                <div class="tlg-col">Status</div>
            </div>
            @foreach (var a in paged.Items)
            {
                <div class="tlg-row" @onclick="() => OpenDetail(a.Id)" style="cursor:pointer">
                    <div class="tlg-col tlg-code">@a.AsnNumber</div>
                    <div class="tlg-col tlg-code">@a.PoNumber</div>
                    <div class="tlg-col tlg-code">@a.ExpectedDeliveryDate.ToString("yyyy-MM-dd")</div>
                    <div class="tlg-col">@a.CarrierName</div>
                    <div class="tlg-col tlg-code">@a.TrackingNumber</div>
                    <div class="tlg-col"><span class="tlg-status @StatusClass(a.AsnStatus)">@a.AsnStatus</span></div>
                </div>
            }
        </div>

        <Pager Page="page" PageSize="PageSize" TotalCount="paged.TotalCount" PageChanged="OnPageChanged" />
    }
</div>

@code {
    private PagedResult<AsnListItemDto>? paged;
    private bool loading = true;
    private string statusFilter = string.Empty;
    private int page = 1;
    private const int PageSize = 50;

    protected override async Task OnInitializedAsync() => await Reload();

    private async Task Reload()
    {
        loading = true;
        var url = $"api/asns?page={page}&pageSize={PageSize}";
        if (!string.IsNullOrWhiteSpace(statusFilter)) url += $"&status={Uri.EscapeDataString(statusFilter)}";
        var resp = await Api.GetAsync<PagedResult<AsnListItemDto>>(url);
        paged = resp?.Data;
        loading = false;
    }

    private async Task OnPageChanged(int newPage) { page = newPage; await Reload(); }

    private void OpenDetail(Guid id) => Nav.NavigateTo($"/asns/{id}");
    private void NewAsn() => Nav.NavigateTo("/asns/new");

    private string StatusClass(string status) => status switch
    {
        "Delivered" => "tlg-status--active",
        "Submitted" or "InTransit" => "tlg-status--pending",
        "Cancelled" => "tlg-status--danger",
        _ => "tlg-status--info"
    };
}
