@page "/payments/{Id:guid}"
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>@detail?.PaymentReference</PageTitle>

@if (loading)
{
    <div class="tl-empty">Loading…</div>
}
else if (detail == null)
{
    <div class="tl-empty">Payment not found.</div>
}
else
{
    <div class="tl-page">
        <a href="/payments" class="mer-back-link">
            <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">arrow_back</span>
            Back to list
        </a>
        <header class="tl-header">
            <div>
                <div class="tl-title-row">
                    <h1 class="tl-title">@detail.PaymentReference</h1>
                    <span class="tlg-status tlg-status--active">Paid</span>
                </div>
                <p class="tl-sub">@detail.SupplierName · Invoice <a href="/invoices/@detail.InvoiceId" style="color:var(--mer-blue);">@detail.InvoiceNumber</a> · @detail.PaymentDate.ToString("yyyy-MM-dd")</p>
            </div>
        </header>

        <div style="display:grid;grid-template-columns:1.4fr 1fr;gap:16px;">
            <div class="rz-card" style="padding:20px;">
                <h3 style="font-size:14px;font-weight:700;margin-bottom:12px;color:var(--mer-blue-darker);">Payment details</h3>
                <dl style="display:grid;grid-template-columns:180px 1fr;gap:6px 16px;font-size:13px;">
                    <dt style="color:var(--mer-ink-500);">Payment reference</dt><dd style="font-family:Inter,monospace;">@detail.PaymentReference</dd>
                    <dt style="color:var(--mer-ink-500);">Invoice</dt><dd><a href="/invoices/@detail.InvoiceId" style="color:var(--mer-blue);font-family:Inter,monospace;">@detail.InvoiceNumber</a></dd>
                    <dt style="color:var(--mer-ink-500);">Supplier</dt><dd>@detail.SupplierName</dd>
                    <dt style="color:var(--mer-ink-500);">Payment date</dt><dd style="font-family:Inter,monospace;">@detail.PaymentDate.ToString("yyyy-MM-dd")</dd>
                    <dt style="color:var(--mer-ink-500);">Mode</dt><dd>@(detail.PaymentMode ?? "—")</dd>
                    <dt style="color:var(--mer-ink-500);">Bank</dt><dd>@(detail.BankName ?? "—")</dd>
                    @if (!string.IsNullOrEmpty(detail.BankAccountRef))
                    {
                        <dt style="color:var(--mer-ink-500);">Account ref</dt><dd style="font-family:Inter,monospace;">@detail.BankAccountRef</dd>
                    }
                    @if (!string.IsNullOrEmpty(detail.ErpSyncId))
                    {
                        <dt style="color:var(--mer-ink-500);">ERP sync id</dt><dd style="font-family:Inter,monospace;font-size:11px;color:var(--mer-ink-500);">@detail.ErpSyncId</dd>
                    }
                    @if (!string.IsNullOrEmpty(detail.Remarks))
                    {
                        <dt style="color:var(--mer-ink-500);">Remarks</dt><dd style="white-space:pre-wrap;">@detail.Remarks</dd>
                    }
                </dl>
            </div>

            <div class="rz-card" style="padding:20px;">
                <h3 style="font-size:14px;font-weight:700;margin-bottom:12px;color:var(--mer-blue-darker);">Amounts</h3>
                <dl style="display:grid;grid-template-columns:140px 1fr;gap:6px 16px;font-size:13px;">
                    <dt style="color:var(--mer-ink-500);">Gross paid</dt><dd style="font-family:Inter,monospace;text-align:right;">@detail.PaymentAmount.ToString("N2")</dd>
                    <dt style="color:var(--mer-ink-500);">TDS deducted</dt><dd style="font-family:Inter,monospace;text-align:right;color:var(--mer-amber-800);">@detail.TdsDeducted.ToString("N2")</dd>
                    @if (!string.IsNullOrEmpty(detail.TdsSection))
                    {
                        <dt style="color:var(--mer-ink-500);">TDS section</dt><dd>@detail.TdsSection</dd>
                    }
                    <dt style="color:var(--mer-ink-500);font-weight:700;">Net paid</dt><dd style="font-family:Inter,monospace;text-align:right;font-weight:700;color:var(--mer-blue-darker);">@detail.NetPaid.ToString("N2")</dd>
                </dl>
            </div>
        </div>

        <div class="rz-card" style="padding:20px;margin-top:16px;">
            <h3 style="font-size:14px;font-weight:700;margin-bottom:12px;color:var(--mer-blue-darker);">Remittance advice</h3>
            @if (remittanceLoading)
            {
                <p style="font-size:13px;color:var(--mer-ink-500);">Loading remittance…</p>
            }
            else if (remittance == null)
            {
                <p style="font-size:13px;color:var(--mer-ink-500);">Remittance advice not available.</p>
            }
            else
            {
                <dl style="display:grid;grid-template-columns:180px 1fr;gap:6px 16px;font-size:13px;margin-bottom:12px;">
                    <dt style="color:var(--mer-ink-500);">Payment reference</dt><dd style="font-family:Inter,monospace;">@remittance.PaymentReference</dd>
                    <dt style="color:var(--mer-ink-500);">Payment date</dt><dd style="font-family:Inter,monospace;">@remittance.PaymentDate.ToString("yyyy-MM-dd")</dd>
                    <dt style="color:var(--mer-ink-500);font-weight:700;">Net paid</dt><dd style="font-family:Inter,monospace;font-weight:700;color:var(--mer-blue-darker);">@remittance.NetPaid.ToString("N2")</dd>
                </dl>
                @if (!string.IsNullOrEmpty(remittance.RemittancePdfUrl))
                {
                    <a href="@remittance.RemittancePdfUrl" target="_blank" rel="noopener" class="rz-button rz-primary" style="display:inline-flex;align-items:center;gap:6px;padding:8px 14px;border-radius:6px;border:0;color:#fff;text-decoration:none;">
                        <span class="material-symbols-outlined" style="font-size:16px;">picture_as_pdf</span>
                        View remittance PDF
                    </a>
                }
                else
                {
                    <p style="font-size:13px;color:var(--mer-ink-500);">Remittance advice not available.</p>
                }
            }
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }
    private PaymentDetailDto? detail;
    private RemittanceDto? remittance;
    private bool loading = true;
    private bool remittanceLoading = true;

    protected override async Task OnInitializedAsync()
    {
        var resp = await Api.GetAsync<PaymentDetailDto>($"api/payments/{Id}");
        detail = resp?.Data;
        loading = false;

        var remResp = await Api.GetAsync<RemittanceDto>($"api/payments/{Id}/remittance");
        remittance = remResp?.Data;
        remittanceLoading = false;
    }
}
