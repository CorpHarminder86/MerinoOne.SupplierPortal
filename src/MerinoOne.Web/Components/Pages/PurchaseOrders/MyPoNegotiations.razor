@page "/po-negotiations"
@inject ApiClient Api
@inject TokenAccessor Token
@inject NavigationManager Nav

@* ------------------------------------------------------------------------------------------------
   Supplier-facing list of the caller's OWN PO negotiations ("PO Change Requests"). The list endpoint
   is seccode-scoped, so a supplier principal already only sees its own negotiations — no supplierId
   filter needed here. Every row opens the source PO detail (the negotiation diff lives there + on the
   buyer review screen). Status filter mirrors MyChangeRequests.
------------------------------------------------------------------------------------------------ *@

<PageTitle>My PO change requests</PageTitle>

<div class="tl-page">
    <header class="tl-header">
        <div>
            <div class="tl-title-row">
                <h1 class="tl-title">My PO change requests</h1>
                <span class="tl-count-chip">@(rows?.Count ?? 0)</span>
            </div>
            <p class="tl-sub">Negotiations you raised on released purchase orders. Approved changes are pushed to ERP; rejected ones revert the PO.</p>
        </div>
    </header>

    <div class="tl-filter-bar">
        <select class="rz-textbox" style="width:200px;padding:8px 12px;" @bind="statusFilter" @bind:after="Load">
            <option value="">All statuses</option>
            @foreach (var s in StatusFilterOptions)
            {
                <option value="@s">@PoNegotiationStatus.Label(s)</option>
            }
        </select>
    </div>

    @if (loading)
    {
        <div class="tl-empty">Loading…</div>
    }
    else if (rows == null || rows.Count == 0)
    {
        <div class="tl-empty">
            <span class="material-symbols-outlined" style="font-size:32px;">handshake</span>
            <div>No PO change requests yet.</div>
            <p style="color:var(--mer-ink-500);font-size:12px;margin-top:6px;">Open a released purchase order and choose <b>Negotiation</b> to propose revised quantities or delivery dates.</p>
        </div>
    }
    else
    {
        <div class="tl-grid-wrapper" style="--tl-cols: 1fr 1fr 120px 90px 160px; --tl-min-width: 880px;">
            <div class="tlg-header">
                <div class="tlg-col">PO Number</div>
                <div class="tlg-col">Supplier</div>
                <div class="tlg-col">Status</div>
                <div class="tlg-col">Lines</div>
                <div class="tlg-col">Submitted</div>
            </div>
            @foreach (var r in rows)
            {
                var row = r;
                <div class="tlg-row" @onclick="() => Open(row)" style="cursor:pointer">
                    <div class="tlg-col tlg-code">@row.PoNumber</div>
                    <div class="tlg-col tlg-name">@row.SupplierName</div>
                    <div class="tlg-col"><span class="tlg-status @PoNegotiationStatus.CssClass(row.NegotiationStatus)">@PoNegotiationStatus.Label(row.NegotiationStatus)</span></div>
                    <div class="tlg-col">@row.LineCount</div>
                    <div class="tlg-col tlg-code">@row.SubmittedAt.ToString("yyyy-MM-dd")</div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<PoNegotiationListItemDto>? rows;
    private bool loading = true;
    private string statusFilter = string.Empty;

    private static readonly string[] StatusFilterOptions =
        { "Submitted", "Approved", "Rejected", "Cancelled" };

    protected override Task OnInitializedAsync() => Load();

    private async Task Load()
    {
        loading = true;
        var url = "api/purchase-orders/negotiations";
        if (!string.IsNullOrEmpty(statusFilter)) url += $"?status={Uri.EscapeDataString(statusFilter)}";
        var resp = await Api.GetAsync<List<PoNegotiationListItemDto>>(url);
        rows = resp?.Data ?? new();
        loading = false;
    }

    // Supplier rows open the source PO (the negotiation status + Cancel affordance live on that detail).
    private async Task Open(PoNegotiationListItemDto r)
    {
        var detail = await Api.GetAsync<PoNegotiationDto>($"api/purchase-orders/negotiations/{r.Id}");
        var poId = detail?.Data?.PurchaseOrderId;
        if (poId is { } id) Nav.NavigateToRoute($"/purchase-orders/{id}");
    }
}
