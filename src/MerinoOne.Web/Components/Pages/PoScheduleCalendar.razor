@page "/po-schedule-calendar"
@inject ApiClient Api
@inject TokenAccessor Token
@inject NavigationManager Nav

@* R4 Module 9 — PO Schedule Calendar (Q11 = RadzenScheduler). Each PoCalendarEventDto becomes an
   all-day appointment on its delivery date; the title is PoNumber + supplier and the body lists items+qty.
   Clicking an event navigates to /purchase-orders/{id}. The visible month/week window drives the from/to
   fetch (LoadData) — we clamp to the ≤366-day API limit and refetch on every navigation. Read-only. *@

<PageTitle>PO Schedule Calendar</PageTitle>

<div class="tl-page">
    <header class="tl-header">
        <div>
            <div class="tl-title-row">
                <h1 class="tl-title">PO Schedule Calendar</h1>
                <span class="tl-count-chip">@appointments.Count</span>
            </div>
            <p class="tl-sub">Read-only — purchase-order deliveries by date. Click an event to open the PO.</p>
        </div>
    </header>

    <div class="tl-filter-bar">
        @if (!Token.IsSupplier)
        {
            <select class="rz-dropdown" style="padding:8px 12px;border:1px solid var(--mer-ink-300);border-radius:6px;background:var(--mer-surface);min-width:220px;" @bind="supplierFilter" @bind:after="OnSupplierChanged">
                <option value="">All suppliers</option>
                @if (suppliers != null)
                {
                    @foreach (var s in suppliers)
                    {
                        <option value="@s.Id">@s.SupplierCode — @s.LegalName</option>
                    }
                }
            </select>
        }
        @if (loadError is not null)
        {
            <span class="poc-err"><span class="material-symbols-outlined" style="font-size:15px;">error</span> @loadError</span>
        }
    </div>

    <div class="poc-wrap">
        <RadzenScheduler @ref="scheduler" TItem="PoAppointment" Data="appointments"
                         StartProperty="Start" EndProperty="End" TextProperty="Title"
                         Style="height:720px;"
                         LoadData="OnLoadData"
                         AppointmentSelect="OnAppointmentSelect"
                         AppointmentRender="OnAppointmentRender">
            <ChildContent>
                <RadzenMonthView />
                <RadzenWeekView />
                <RadzenDayView />
            </ChildContent>
            <Template Context="appt">
                <div class="poc-appt">
                    <div class="poc-appt__title">@appt.PoNumber</div>
                    <div class="poc-appt__sub">@appt.SupplierName</div>
                </div>
            </Template>
        </RadzenScheduler>
    </div>
</div>

<style>
    .poc-wrap { background:var(--mer-surface); border:1px solid var(--mer-line); border-radius:var(--mer-radius-lg); padding:8px; }
    .poc-err { display:inline-flex; align-items:center; gap:4px; color:var(--mer-red); font-size:12px; }
    .poc-appt { line-height:1.25; }
    .poc-appt__title { font:600 11.5px/1.3 'Plus Jakarta Sans',sans-serif; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .poc-appt__sub { font-size:10px; opacity:0.85; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }

    /* Merino-fit the scheduler chrome — Radzen Material defaults use its own accent; rebind to Merino tokens. */
    .poc-wrap .rz-event { background:var(--mer-blue) !important; color:#fff !important; border:0 !important; border-radius:6px !important; }
    .poc-wrap .rz-event:hover { background:var(--mer-blue-hover) !important; }
    .poc-wrap .rz-view-button.rz-state-active,
    .poc-wrap .rz-scheduler-toolbar .rz-button.rz-state-active { background:var(--mer-blue) !important; color:#fff !important; }
    .poc-wrap .rz-today { color:var(--mer-blue-darker); }
</style>

@code {
    private RadzenScheduler<PoAppointment>? scheduler;
    private List<PoAppointment> appointments = new();
    private List<SupplierListItemDto>? suppliers;
    private string supplierFilter = string.Empty;
    private string? loadError;

    // Typed appointment wrapper the scheduler binds to (Start/End/Title) — carries the PO id for click-through
    // and the item list for the appointment tooltip.
    public class PoAppointment
    {
        public DateTime Start { get; set; }
        public DateTime End { get; set; }
        public string Title { get; set; } = string.Empty;
        public string PoNumber { get; set; } = string.Empty;
        public string SupplierName { get; set; } = string.Empty;
        public Guid PurchaseOrderId { get; set; }
        public string ItemsSummary { get; set; } = string.Empty;
    }

    protected override async Task OnInitializedAsync()
    {
        if (!Token.IsSupplier)
        {
            var sup = await Api.GetAsync<List<SupplierListItemDto>>("api/suppliers");
            suppliers = sup?.Data?.OrderBy(s => s.LegalName).ToList();
        }
        // The scheduler raises LoadData for its initial window on first render, which performs the first fetch.
    }

    // Fired by the scheduler whenever the visible window changes (initial render + every month/week navigation).
    private async Task OnLoadData(SchedulerLoadDataEventArgs args)
    {
        loadError = null;

        // The API rejects ranges > 366 days. Month/week views never exceed ~42 days, but guard anyway so a future
        // wide view (or a year view) can't 400 the endpoint.
        var from = args.Start.Date;
        var to = args.End.Date;
        if ((to - from).TotalDays > 366)
        {
            to = from.AddDays(366);
        }

        var url = $"api/purchase-orders/schedule-calendar?from={from:yyyy-MM-dd}&to={to:yyyy-MM-dd}";
        if (!string.IsNullOrWhiteSpace(supplierFilter)) url += $"&supplierId={Uri.EscapeDataString(supplierFilter)}";

        var resp = await Api.GetAsync<List<PoCalendarEventDto>>(url);
        if (resp?.Success != true)
        {
            loadError = resp?.Errors?.FirstOrDefault() ?? "Could not load the schedule.";
            appointments = new();
            return;
        }

        appointments = (resp.Data ?? new()).Select(e => new PoAppointment
        {
            Start = e.Date.Date,
            End = e.Date.Date.AddDays(1),   // render as an all-day chip on its delivery date
            Title = $"{e.PoNumber} · {e.SupplierName}",
            PoNumber = e.PoNumber,
            SupplierName = e.SupplierName,
            PurchaseOrderId = e.PurchaseOrderId,
            ItemsSummary = string.Join(", ", e.Items.Select(i => $"{i.ItemCode} ({i.Qty:0.###})"))
        }).ToList();
    }

    private void OnAppointmentSelect(SchedulerAppointmentSelectEventArgs<PoAppointment> args)
    {
        if (args.Data is { } appt)
            Nav.NavigateToRoute($"/purchase-orders/{appt.PurchaseOrderId}");
    }

    // Give every chip a Merino-tokened look + an items tooltip (the title attr surfaces item codes + qty).
    private void OnAppointmentRender(SchedulerAppointmentRenderEventArgs<PoAppointment> args)
    {
        args.Attributes["style"] = "background:var(--mer-blue);color:#fff;border:0;cursor:pointer;";
        if (args.Data is { } d && !string.IsNullOrWhiteSpace(d.ItemsSummary))
            args.Attributes["title"] = $"{d.PoNumber} — {d.SupplierName}\n{d.ItemsSummary}";
    }

    private async Task OnSupplierChanged()
    {
        // Re-run the load for the currently visible window under the new supplier filter.
        if (scheduler is not null)
            await scheduler.Reload();
    }
}
