@inject ApiClient Api
@inject NavigationManager Nav
@implements IDisposable

<div class="mer-search" @onfocusout="OnBlur">
    <span class="material-symbols-outlined" style="font-size:18px;color:var(--mer-ink-500);">search</span>
    <input class="mer-search__input"
           placeholder="Search suppliers, POs, invoices…"
           @bind="query"
           @bind:event="oninput"
           @onkeyup="OnKey"
           @onfocus="OnFocus" />

    @if (showDropdown)
    {
        <div class="mer-search__dropdown" @onmousedown:preventDefault>
            @if (searching)
            {
                <div class="mer-search__empty">Searching…</div>
            }
            else if (results == null || results.Count == 0)
            {
                <div class="mer-search__empty">No results for "@query"</div>
            }
            else
            {
                @foreach (var r in results)
                {
                    <div class="mer-search__row" @onclick="@(() => OpenResult(r))">
                        <span class="mer-search__row-icon material-symbols-outlined">@IconFor(r.Module)</span>
                        <div class="mer-search__row-meta">
                            <span class="mer-search__row-code">@r.Module · @r.Code</span>
                            <span class="mer-search__row-title">@r.Title@(string.IsNullOrEmpty(r.Subtitle) ? "" : " · " + r.Subtitle)</span>
                        </div>
                        @if (!string.IsNullOrEmpty(r.Status))
                        {
                            <span class="tlg-status @StatusClass(r.Status)" style="font-size:10.5px;">@r.Status</span>
                        }
                    </div>
                }
                <div class="mer-search__see-all" @onclick="SeeAll">See all results for "@query"</div>
            }
        </div>
    }
</div>

<style>
    .mer-search { position: relative; display: flex; align-items: center; gap: 8px; background: var(--mer-ink-50); border: 1px solid var(--mer-line); border-radius: 999px; padding: 6px 14px; min-width: 320px; }
    .mer-search:focus-within { background: var(--mer-surface); border-color: var(--mer-blue); box-shadow: var(--mer-focus-ring, 0 0 0 3px rgba(46, 91, 183, .18)); }
    .mer-search__input { background: transparent; border: 0; outline: 0; font: 500 13px/1 'Plus Jakarta Sans', sans-serif; color: var(--mer-ink-900); flex: 1; }
    .mer-search__dropdown { position: absolute; top: calc(100% + 6px); left: 0; right: 0; background: var(--mer-surface); border: 1px solid var(--mer-line); border-radius: var(--mer-radius-lg); box-shadow: var(--mer-shadow-lg); padding: 4px; max-height: 420px; overflow-y: auto; z-index: 1000; }
    .mer-search__row { display: flex; align-items: center; gap: 10px; padding: 8px 10px; border-radius: var(--mer-radius); cursor: pointer; }
    .mer-search__row:hover { background: var(--mer-ink-50); }
    .mer-search__row-icon { color: var(--mer-blue); }
    .mer-search__row-meta { display: flex; flex-direction: column; flex: 1; min-width: 0; }
    .mer-search__row-code { font: 500 11px/1 'Inter', monospace; color: var(--mer-ink-500); }
    .mer-search__row-title { font: 600 13px/1.3 'Plus Jakarta Sans', sans-serif; color: var(--mer-ink-900); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .mer-search__see-all { padding: 8px 10px; font: 500 12px/1 'Plus Jakarta Sans', sans-serif; color: var(--mer-blue); cursor: pointer; border-top: 1px solid var(--mer-line-soft); margin-top: 4px; }
    .mer-search__empty { padding: 16px; text-align: center; color: var(--mer-ink-500); font-size: 12.5px; }
</style>

@code {
    private string query = string.Empty;
    private List<SearchResultDto>? results;
    private bool searching = false;
    private bool showDropdown = false;
    private CancellationTokenSource? cts;
    private System.Threading.Timer? debounceTimer;

    private void OnFocus()
    {
        if (!string.IsNullOrEmpty(query) && query.Length >= 2)
        {
            showDropdown = true;
        }
    }

    private void OnBlur()
    {
        // Delay close so click on row registers
        Task.Delay(150).ContinueWith(_ => InvokeAsync(() => { showDropdown = false; StateHasChanged(); }));
    }

    private void OnKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            SeeAll();
            return;
        }
        if (e.Key == "Escape")
        {
            showDropdown = false;
            return;
        }
        ScheduleSearch();
    }

    private void ScheduleSearch()
    {
        debounceTimer?.Dispose();
        if (string.IsNullOrEmpty(query) || query.Length < 2)
        {
            results = null;
            showDropdown = false;
            StateHasChanged();
            return;
        }
        debounceTimer = new System.Threading.Timer(async _ => await InvokeAsync(RunSearch), null, 250, System.Threading.Timeout.Infinite);
    }

    private async Task RunSearch()
    {
        cts?.Cancel();
        cts = new CancellationTokenSource();
        searching = true;
        showDropdown = true;
        StateHasChanged();
        try
        {
            var resp = await Api.GetAsync<List<SearchResultDto>>($"api/search?q={Uri.EscapeDataString(query)}&limit=10");
            results = resp?.Data ?? new List<SearchResultDto>();
        }
        catch
        {
            results = new List<SearchResultDto>();
        }
        finally
        {
            searching = false;
            StateHasChanged();
        }
    }

    private void OpenResult(SearchResultDto r)
    {
        showDropdown = false;
        query = string.Empty;
        var url = r.Module switch
        {
            "Supplier" => $"/suppliers/{r.Id}",
            "PurchaseOrder" => $"/purchase-orders/{r.Id}",
            "Invoice" => $"/invoices/{r.Id}",
            "Asn" => $"/asns/{r.Id}",
            "GoodsReceipt" => $"/goods-receipts/{r.Id}",
            "Payment" => $"/payments/{r.Id}",
            "CommunicationMessage" => $"/threads/{r.Id}",
            _ => "/"
        };
        Nav.NavigateToRoute(url);
    }

    private void SeeAll()
    {
        if (string.IsNullOrWhiteSpace(query)) return;
        showDropdown = false;
        Nav.NavigateToRoute($"/search?q={Uri.EscapeDataString(query)}");
    }

    private string IconFor(string module) => module switch
    {
        "Supplier" => "groups",
        "PurchaseOrder" => "description",
        "Invoice" => "receipt_long",
        "Asn" => "local_shipping",
        "Payment" => "payments",
        "CommunicationMessage" => "mail",
        _ => "circle"
    };

    private string StatusClass(string status) => status switch
    {
        "Active" or "Approved" or "Accepted" or "Delivered" or "Closed" or "Paid" => "tlg-status--active",
        "Submitted" or "UnderReview" or "Pending" or "Released" or "Acknowledged" or "PartiallyDelivered" or "Registering" or "Invited" => "tlg-status--pending",
        "Rejected" or "Cancelled" or "Suspended" or "Failed" => "tlg-status--danger",
        _ => "tlg-status--info"
    };

    public void Dispose()
    {
        debounceTimer?.Dispose();
        cts?.Cancel();
        cts?.Dispose();
    }
}
